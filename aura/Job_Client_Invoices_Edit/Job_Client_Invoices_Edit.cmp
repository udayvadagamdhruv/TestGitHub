<aura:component controller="Job_Billing_Tab" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,lightning:actionOverride,force:hasRecordId,force:lightningQuickActionWithoutHeader,force:hasSObjectName" access="global" >
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="record" type="Object" />
    <aura:attribute name="recordError" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="fieldSet" type="List"  />
    <aura:attribute name="Labelname" type="string"  />
    <aura:attribute name="CLIRecordid" type="String"/>
    <aura:attribute name="ClientRecords" type="Object"/>
    <aura:attribute name="ObjectType" type="Object"/>
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/> 
    <lightning:recordEditForm aura:id="CLIEditform"  objectApiName="{!v.sObjectName}" density="comfy"  recordId="{!v.recordId}" onsubmit="{!c.RecordSubmit}" onload="{!c.onloadrecord}"  onsuccess="{!c.onRecordSuccess}" >
        <lightning:messages /> 
        <div aura:id="editDialog" role="dialog" tabindex="-1" aria-labelledby="header43" class="slds-modal slds-fade-in-open">
            <div aura:id="errorMsgs"></div>
            <div class="slds-modal__container">
                <div class="slds-modal__header">
                    <h2 class="slds-text-heading--medium"> 
                        Edit {!v.simpleRecord.Name}
                    </h2>
                </div>
                <div class="slds-modal__content slds-p-around--medium slds-grid slds-wrap ">
                  <lightning:layout multipleRows="true"> 
                      <aura:iteration items="{!v.fieldSet}" var="field">
                        <aura:if isTrue="{!(field=='Job__c') || (field=='Client_Name__c')|| (field=='Name')}">        
                            <aura:set attribute="else">   
                                 <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                <lightning:inputField fieldName="{!field}" aura:id="JobCLIField"  class="{!'slds-form-element  slds-p-horizontal_x-small' + ' ' +((field=='Name') || (field=='Quantity__c') || (field=='Amount__c') ? 'frequired' :' ')}" /> 
                                </lightning:layoutItem>
                                </aura:set>
                        </aura:if>
                       
                        <aura:if isTrue="{!field=='Name'}"> 
                             <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                            <div class="slds-form-element  slds-p-horizontal_x-small">
                                <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Client_Invoice__c.Name.label}</label>
                                <div class="slds-form-element__control">
                                    <ui:outputText value="{!v.simpleRecord.Name}"  />
                                </div>
                            </div>
                            </lightning:layoutItem>
                        </aura:if>
                        
                        <aura:if isTrue="{!field=='Job__c'}"> 
                             <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                            <div class="slds-form-element  slds-p-horizontal_x-small">
                                <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Client_Invoice__c.Job__c.label}</label>
                                <div class="slds-form-element__control">
                                    <ui:outputText value="{!v.simpleRecord.Job__r.Name}"  />
                                </div>
                            </div>
                            </lightning:layoutItem>
                        </aura:if>
                        
                                               
                        <aura:if isTrue="{!field=='Client_Name__c'}">
                             <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                            <div class=" slds-p-horizontal_x-small"> 
                                <lightning:select  name="Client Name" aura:id="ClientId" label="{!v.ObjectType.Client_Invoice__c.Client_Name__c.label}">
                                    <aura:iteration items="{!v.ClientRecords}" var="Cli">
                                        <option text="{!Cli.value}" value="{!Cli.key}" />
                                    </aura:iteration>
                                </lightning:select>
                            </div>
                            </lightning:layoutItem>
                        </aura:if>
                    </aura:iteration>
                    </lightning:layout>
                    <br></br>
                </div>
                <div class="slds-modal__footer">                
                    <lightning:button variant="neutral" label="Cancel" onclick="{!c.doCancel}" />
                    <lightning:button  variant="brand"  label="Save" type="submit" />
                </div>              
            </div>
        </div>
    </lightning:recordEditForm> 
    <div aura:id="overlay" class="slds-backdrop slds-backdrop--open"></div>
    <aura:if isTrue="{!not(empty(v.recordError))}">
        <div class="recordError">
            {!v.recordError}</div>
    </aura:if>   
    
</aura:component>