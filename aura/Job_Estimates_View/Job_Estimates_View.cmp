<aura:component controller="job_Cost_Tab_cmp" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="Estrecord" type="Object" />
    <aura:attribute name="EstsimpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="isAccess" type="list" /><!-- to check Quote permissions(creatable,editable)-->

    <aura:attribute name="proTempList" type="Map" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isEstSpecOpen" type="boolean" default="false" />
    <aura:attribute name="estSpecRecId" type="String"/>
    <aura:attribute name="ObjectType" type="Object"/>
    
    
    <aura:attribute name="EstSpecRecords" type="Object" />
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="DESC" />
    
    <aura:attribute name="EstimateSpecSection" type="String" default="Estimate Spec Items" required="true" access="global"/>
    
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="DynamicLabels" type="list"/>  
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.Estrecord}"
                      targetFields ="{!v.EstsimpleRecord}"
                      mode="EDIT"/>    
       <aura:if isTrue="{!v.isAccess[3]}">
    <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="EstSpecs">
        <lightning:accordionSection name="EstSpecs" label="{!v.EstimateSpecSection}" class="slds-card"> 
            <div class="c-container">
                <aura:if isTrue="{!!v.isMobile}">
                    <lightning:layout >
                        
                        <lightning:layoutItem padding="around-small" size="2">
                            <lightning:select aura:id="ProTemplateId" name="ProTemplate" label="Production Spec Template">
                                <aura:iteration items="{!v.proTempList}" var="pTrec">
                                    <option text="{!pTrec.value}" value="{!pTrec.key}"></option>
                                </aura:iteration>
                            </lightning:select>
                        </lightning:layoutItem>
                        <lightning:layoutItem padding="around-small" size="4" >   
                            <div style="padding-top: 24px;">
                                <lightning:button label="Import Spec Items" title="Base action" onclick="{! c.ImportProductionTemp}"/>
                                <lightning:button  label="Add Spec Item" title="Base action" onclick="{! c.NewEstimateSpec}"/> 
                            </div>
                        </lightning:layoutItem>
                        
                    </lightning:layout>
                    
                    <aura:if isTrue="{!empty(v.EstSpecRecords)}">
                        <b>No records to display</b>
                        <aura:set attribute="else" >
                            <lightning:card>
                                
                                <div>
                                    <lightning:datatable class="tablecss"
                                                         aura:id="EstSpecDataTable"
                                                         columns="{!v.columns}"
                                                         data="{!v.EstSpecRecords}"
                                                         keyField="Id"
                                                         hideCheckboxColumn="true"
                                                         showRowNumberColumn="true"
                                                         errors="{!v.errors}"
                                                         onsort="{!c.updateColumnSorting}"
                                                         sortedBy="{!v.sortedBy}"
                                                         sortedDirection="{!v.sortedDirection}" 
                                                         onrowaction="{! c.handleRowAction }" />
                                </div>
                                
                                <aura:if isTrue="{!v.isLoading}">
                                    <lightning:spinner alternativeText="Loading"/>
                                </aura:if>
                            </lightning:card>
                        </aura:set>
                    </aura:if>
                </aura:if>
                <aura:if isTrue="{!v.isMobile}">
                    <div>
                       <center> <lightning:button  label="Add Spec Item" title="Base action" onclick="{! c.NewEstimateSpec}"/> </center>
                    </div>
                    <aura:iteration items="{!v.EstSpecRecords}" var="EstSpec">
                        <table>
                            <tr>
                                <td colspan="2">
                                     <b> <ui:outputText value="{!EstSpec.Name}"/></b>
                                </td>
                                <td width="20%" style="text-align:right;" class="MobileMoreActions" >
                                    <lightning:buttonMenu name="{!EstSpec.Id}" aura:id="EstSpecItem" onselect="{!c.handleEstSpecQuickAction}">
                                        <lightning:menuItem value="Edit_EstSpec" label="Edit" iconName="utility:edit"/>
                                        <lightning:menuItem value="Delete_EstSpec" label="Delete" iconName="utility:delete"/>
                                    </lightning:buttonMenu>
                                </td>
                            </tr>
                            <tr>
                                <td width="40%" style="vertical-align:top;">                                   
                                    <ui:outputText value="{!v.DynamicLabels[0].Desc}"/>:                                   
                                </td>
                                <td width="60%">
                                    <ui:outputDate value="{!EstSpec.Description__c}"/>	
                                </td>
                            </tr>
                        </table>
                        <hr style="margin: 0.4rem 0;"/>
                    </aura:iteration>
                </aura:if>
            </div>
        </lightning:accordionSection>
    </lightning:accordion>  
    </aura:if>
    <aura:if isTrue="{!v.isEstSpecOpen}">
        <lightning:recordEditForm aura:id="EstSpecEditform" density="comfy" objectApiName="Estimate_Spec_Item__c" recordId="{!v.estSpecRecId}"  onsubmit="{!c.EstSpecOnsubmit}" onsuccess="{!c.onEstSpecRecordSuccess}"  >
            <lightning:messages /> 
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.estSpecRecId==null?'New':'Edit'} Estimate Spec Item</h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                        <aura:iteration items="{!v.fieldset}" var="field">
                            <aura:if isTrue="{!field=='Estimates__c'}">
                                <div class="slds-form-element  slds-p-horizontal_x-small">
                                    <label class="slds-form-element__label" for="text-input-id-1">  {!v.ObjectType.Estimate_Spec_Item__c.Estimates__c.label}</label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.EstsimpleRecord.Name}"  />
                                    </div>
                                </div> 
                                
                                <aura:set attribute="else" >
                                    <lightning:inputField fieldName="{!field}" aura:id="EstimateSpecField"  class="{!'slds-form-element slds-p-horizontal_x-small' + ' ' +((field=='Name') ? 'frequired' :' ')}"/>      
                                </aura:set>
                            </aura:if>
                        </aura:iteration>
                        <br></br>
                    </div>
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
    
    
</aura:component>