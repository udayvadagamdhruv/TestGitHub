<aura:component controller="job_Cost_Tab_cmp" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    <aura:attribute name="jobrecordId" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="record" type="Object"/>
    <aura:attribute name="isAccess" type="list" /><!-- to check Quote permissions(creatable,editable)-->
    <aura:attribute name="InvPOrecordId" type="String" />
    <aura:attribute name="POsimpleRecord" type="Object" />
    <aura:attribute name="POrecordError" type="Object" />
    <aura:attribute name="POrecord" type="Object"/>
    
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="desc" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isPOOpen" type="boolean" default="false"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="PORecordid" type="String" />
    <aura:attribute name="PORecordDetails" type="Sobject"/>
    <aura:attribute name="VendorRecords" type="Object"/>
    <aura:attribute name="VendorConRecords" type="Object"/>
    <aura:attribute name="StaffRecords" type="Object"/>
    <aura:attribute name="VendorIdApp" type="String" default=""/>
    <aura:attribute name="OrgBasedCon" type="boolean" default="false"/>
    <aura:attribute name="showProductionEstimate" type="boolean" default="false"/>
    <aura:attribute name="TotalAmount" type="double" />
    
    <aura:attribute name="PoLineItems" type="List" />
    
    <aura:attribute name="DynamicLabels" type="list"/>
    <aura:attribute name="isMobile" type="boolean" />
    
    <aura:attribute name="PoLidata" type="Object"/>
    <aura:attribute name="PoLicolumns" type="List"/>
    <aura:attribute name="PoLiselectedRowsCount" type="Integer" />
    
    <aura:attribute name="Selected_POLI" type="Object[]" default=""/>
    
    <!-- <aura:attribute name="isPOContentClose" type="boolean" default="false"/> -->
    
    <aura:attribute name="Invfieldset" type="List"/>
    <aura:attribute name="isLogInvOpen" type="boolean" default="false"/>
    
    <aura:attribute name="Selected_ESTLI" type="Sobject[]" default=""/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <aura:handler name="ChangdVendorApproveList" event="c:Approved_Estimate_LI" action="{!c.handleselectedRecord}" />
    
    <!--  <aura:handler event="c.UpdateRecordsforChanges" action="{!c.handleselectedRecord}" /> -->
    <aura:attribute name="ObjectType" type="Object"/> 
    <aura:attribute name="Labelname" type="string"/>
    
  
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.jobrecordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="VIEW"/>  
    
    <!-- This attribute will hold the update records from data table-->
    <aura:attribute name="updatedRecord" type="Object[]" />
    <!--  <aura:if isTrue="{!!v.isPOContentClose}">-->
    <aura:if isTrue="{!!v.isMobile}">
       
        <div align="center">
            <lightning:button variant="neutral" label="New" title="New" onclick="{!c.POCreate}"/>
            
        </div>
        <br/>
        <aura:if isTrue="{!empty(v.data)}">
            <b>No records to display</b>
            <aura:set attribute="else">
                <lightning:card>
                    <div>
                        <lightning:datatable class="POtablecss"
                                             aura:id="PODataTable"
                                             columns="{!v.columns}"
                                             data="{!v.data}"
                                             keyField="Id"
                                             onsave ="{!c.onSave}"
                                             hideCheckboxColumn="true"
                                             showRowNumberColumn="true"
                                             errors="{!v.errors}"
                                             onsort="{!c.updateColumnSorting}"
                                             sortedBy="{!v.sortedBy}"
                                             sortedDirection="{!v.sortedDirection}" 
                                             onrowaction="{!c.handleRowAction}" />
                    </div>
                    <br/>
                    
                    <div style="float:right;padding-right:20px;font-size:1.10em;font-style:normal;font-family: 'Calibri';font-weight:bold">
                        <span style="font-style:italic;" > PO Total</span>
                        &nbsp;:&nbsp;&nbsp; <ui:outputCurrency value="{!v.TotalAmount}"/>   
                    </div>
                    
                </lightning:card>
                <aura:if isTrue="{!v.isLoading}">
                    <lightning:spinner alternativeText="Loading"/>
                </aura:if>
            </aura:set>
        </aura:if>
    </aura:if>
    <aura:if isTrue="{!v.isMobile}">
        <aura:if isTrue="{!empty(v.data)}">
            <b>No records to display</b>
            <aura:set attribute="else">
                <aura:iteration items="{!v.data}" var="po">
                    <table>
                        <tr>
                            <td colspan="2">
                                <a href="{!'/'+po.Id}"> <b> <ui:outputText value="{!po.Name}"/></b></a> 
                            </td>
                            <!--td width="20%" style="text-align:right;" class="MobileMoreActions" >
                                <lightning:buttonMenu name="{!po.Id}" aura:id="qtItem" onselect="{! c.handleQtQuickAction }">
                                    <lightning:menuItem value="Edit" label="Edit" iconName="utility:edit"/>
                                    <lightning:menuItem value="Delete" label="Delete" iconName="utility:delete"/>                                   
                                </lightning:buttonMenu>
                            </td-->
                        </tr>                           
                        <tr>
                            <td width="40%" >
                                <ui:outputText value="{!v.DynamicLabels[0].InvoiceCreated}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputText value="{!po.Invoice_Created__c}"/>
                            </td>
                        </tr>
                        <tr>
                            <td width="40%" >
                                <ui:outputText value="{!v.DynamicLabels[0].Vendor}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputDate value="{!po.Vendor__c}"/>	
                            </td>
                        </tr>
                        <tr>
                            <td width="40%" >
                                <ui:outputText value="{!v.DynamicLabels[0].IssueDate}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputDate value="{!po.Issue_Date__c}"/>	
                            </td>
                        </tr>
                         <tr>
                            <td width="40%" >
                                <ui:outputText value="{!v.DynamicLabels[0].DueDate}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputDate value="{!po.Due_Date__c}"/>	
                            </td>
                        </tr>
                        <tr>
                            <td width="40%">
                                <ui:outputText value="{!v.DynamicLabels[0].Status}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputText value="{!po.Status__c}"/>                               
                            </td>
                        </tr>
                         <tr>
                            <td width="40%" >
                                <ui:outputText value="{!v.DynamicLabels[0].Amount}"/>:
                            </td>
                            <td width="60%">
                                <p><lightning:formattedNumber value="{!po.Total_Amount__c}" style="currency" currencyCode="USD"/></p>
                            </td>
                        </tr>
                    </table>
                    <hr style="margin: 0.4rem 0;"/>
                </aura:iteration>
            </aura:set>
        </aura:if>
    </aura:if>
    <!-- </aura:if>-->
    
    <aura:if isTrue="{!v.isPOOpen}">
        <lightning:recordEditForm aura:id="JobPOEditform" density="comfy" objectApiName="Purchase_Order__c" recordId="{!v.PORecordid}" onload="{!c.jobPOload}"  onsubmit="{!c.jobPOOnsubmit}" onsuccess="{!c.onPORecordSuccess}"  >
            <lightning:messages />
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.PORecordid==null?'New ':'Edit '} {!v.Labelname}</h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                          <lightning:layout multipleRows="true">  
                        <aura:iteration items="{!v.fieldset}" var="field">
                            <aura:if isTrue="{!(field=='Name') || (field=='Invoice_Created__c') || (field=='Job__c') || (field=='Vendor__c') || (field=='Vendor_Contact__c') || (field=='Approved_By_Staff__c')}">    
                                <aura:set attribute="else">  
                                    <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                    <lightning:inputField fieldName="{!field}" aura:id="JobPOField"  class="{! ' slds-p-horizontal_x-small'+' '+ ((field=='Due_Date__c' || field=='Issue_Date__c')?'frequired':' ')}"    /> 
                                    </lightning:layoutItem>
                                    </aura:set>
                            </aura:if>
                            <aura:if isTrue="{!(field=='Name') &amp;&amp; (v.PORecordid!=null)}"> 
                              <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                  <div class="slds-form-element  slds-p-horizontal_x-small">
                                    <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Purchase_Order__c.Name.label}</label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.PORecordDetails.Name.value}"  />
                                    </div>
                                </div>
                                </lightning:layoutItem>
                            </aura:if>
                            
                            <aura:if isTrue="{!field=='Job__c'}"> 
                                <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                    <div class="slds-form-element  slds-p-horizontal_x-small" >
                                    <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Purchase_Order__c.Job__c.label}</label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.simpleRecord.Name}"  />
                                    </div>
                                </div>
                                </lightning:layoutItem>
                            </aura:if>
                            
                            <aura:if isTrue="{!field=='Vendor__c'}">
                                <aura:if isTrue="{!v.PORecordid==null}">
                                   <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                       <div class=" slds-p-horizontal_x-small"> 
                                        <lightning:select  name="Vendor" aura:id="VendorId" label="{!v.ObjectType.Purchase_Order__c.Vendor__c.label}" class="frequired"  onchange="{!c.VendorChange}">
                                            <aura:iteration items="{!v.VendorRecords}" var="Ven">
                                                <option text="{!Ven.value}" value="{!Ven.key}" />
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                    </lightning:layoutItem>
                                    
                                    <aura:set attribute="else">   
                                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-form-element  slds-p-horizontal_x-small">
                                            <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Purchase_Order__c.Vendor__c.label}</label>
                                            <div class="slds-form-element__control">
                                                <!-- <ui:outputText aura:id="VendorId" value="{!v.PORecordDetails.Vendor__c}"  />-->
                                                <ui:outputText value="{!v.PORecordDetails.Vendor__r.value.fields.Name.value}"  />
                                            </div>
                                        </div>
                                        </lightning:layoutItem>
                                    </aura:set>
                                </aura:if> 
                            </aura:if>
                            
                            <aura:if isTrue="{!(field=='Invoice_Created__c') &amp;&amp; (v.PORecordid!=null)}"> 
                               <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                   <div class="slds-form-element  slds-p-horizontal_x-small">
                                    <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Purchase_Order__c.Invoice_Created__c.label} </label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.PORecordDetails.Invoice_Created__c.value}"  />
                                    </div>
                                </div>
                                </lightning:layoutItem>
                            </aura:if> 
                            
                            <aura:if isTrue="{!field=='Vendor_Contact__c'}">
                                <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                <div class="slds-p-horizontal_x-small"> 
                                    <lightning:select  name="Vendor Contact" aura:id="VenConId" label="{!v.ObjectType.Purchase_Order__c.Vendor_Contact__c.label}"  >
                                        <option text="--None--" value="" />
                                        <aura:iteration items="{!v.VendorConRecords}" var="VenCon">
                                            <option text="{!VenCon.Name}" value="{!VenCon.Id}" />
                                        </aura:iteration>
                                    </lightning:select>
                                </div>
                                </lightning:layoutItem>
                            </aura:if> 
                            
                            <aura:if isTrue="{!field=='Approved_By_Staff__c'}">
                              <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                  <div class=" slds-p-horizontal_x-small"> 
                                    <lightning:select  name="Approved By" aura:id="StaffID" label="{!v.ObjectType.Purchase_Order__c.Approved_By_Staff__c.label}"  >
                                        <option text="--None--" value="" />
                                        <aura:iteration items="{!v.StaffRecords}" var="Staff">
                                            <option text="{!Staff.Name}" value="{!Staff.Id}" />
                                        </aura:iteration>
                                    </lightning:select>
                                </div>
                                </lightning:layoutItem>
                            </aura:if> 
                            
                        </aura:iteration>
                        
                        <aura:if isTrue="{!v.PORecordid==null}">
                            
                            <br></br>
                            <div style="width:100% !important;">  
                                <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="LineItems">
                                    <lightning:accordionSection name="LineItems" label="Add Line Items"  > 
                                        <c:Approved_Vendor_Estimate_LI_PO_INV aura:id="AVELID" JobId="{!v.jobrecordId}" VendorId="{!v.VendorIdApp}" />
                                    </lightning:accordionSection>
                                </lightning:accordion>  
                            </div>
                        </aura:if>
                        </lightning:layout>
                    </div>
                    
                    
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
    
    
    <aura:if isTrue="{!v.isLogInvOpen}">
        
        <force:recordData aura:id="porecord"
                          layoutType="FULL"
                          recordId="{!v.InvPOrecordId}"
                          targetError="{!v.POrecordError}"
                          targetRecord="{!v.POrecord}"
                          targetFields ="{!v.POsimpleRecord}"
                          mode="VIEW"/>  
        
        
        <lightning:recordEditForm aura:id="LogInvFromPoForm" objectApiName="Invoice__c" onsubmit="{!c.InvFromPOOnsubmit}" onsuccess="{!c.InvFromPOOnsucess}" density="comfy">
            <lightning:messages />
            <!--************************************************  MODAL BOX Start Log Invoice From Po *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModelForLogInvoice}"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">New Invoice</h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                      <lightning:layout multipleRows="true">
                          <aura:iteration items="{!v.Invfieldset}" var="Invfield">
                            <aura:if isTrue="{!(Invfield=='Job__c') || (Invfield=='Vendor__c') || (Invfield=='Purchase_Order__c')}">    
                                <aura:set attribute="else">   
                                     <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                    <lightning:inputField fieldName="{!Invfield}" aura:id="InvPOField"  class="{! ' slds-p-horizontal_x-small'+' '+ ((Invfield=='Name' || Invfield=='Date_Received__c')?'frequired':' ')}"    /> 
                                    </lightning:layoutItem>
                                    </aura:set>
                            </aura:if>
                            
                            <aura:if isTrue="{!Invfield=='Job__c'}"> 
                               <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                   <div class="slds-form-element slds-p-horizontal_x-small">
                                    <label class="slds-form-element__label" for="text-input-id-1"> Job</label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.simpleRecord.Name}"  />
                                    </div>
                                </div>
                                </lightning:layoutItem>
                            </aura:if>
                            
                            
                            <aura:if isTrue="{!Invfield=='Vendor__c'}"> 
                              <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                  <div class="slds-form-element  slds-p-horizontal_x-small">
                                    <label class="slds-form-element__label" for="text-input-id-1"> Vendor</label>
                                    <div class="slds-form-element__control">
                                        <ui:outputText value="{!v.POsimpleRecord.Vendor__r.Name}"  /> 
                                    </div>
                                </div>
                                </lightning:layoutItem>
                            </aura:if>
                            
                        </aura:iteration>
                       
                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                        <div class="slds-form-element  slds-p-horizontal_x-small">
                            <label class="slds-form-element__label" for="text-input-id-1"> PO# </label>
                            <div class="slds-form-element__control">
                                <ui:outputText value="{!v.POsimpleRecord.Name}"  />  
                            </div>
                        </div>
                          </lightning:layoutItem>
                        </lightning:layout>
                        
                        <aura:if isTrue="{!empty(v.PoLidata)}">
                            <aura:set attribute="else"> 
                                <br></br>
                                
                                <div>
                                    <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="POLineItemsForInvoice">
                                        <lightning:accordionSection name="POLineItemsForInvoice" label="Add Line Items"   > 
                                            
                                            <h1>Selected Rows: {! v.PoLiselectedRowsCount }</h1>
                                            <lightning:datatable class="AppEstimatetablecss"
                                                                 columns="{!v.PoLicolumns}"
                                                                 data="{!v.PoLidata }"
                                                                 keyField="id"
                                                                 onrowselection="{! c.updateSelectedTextPOLI }"/>
                                        </lightning:accordionSection>
                                    </lightning:accordion>
                                </div>
                            </aura:set>
                        </aura:if>
                    </div>
                    
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModelForLogInvoice}"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
    
</aura:component>