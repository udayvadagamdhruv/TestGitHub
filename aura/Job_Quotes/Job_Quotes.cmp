<aura:component controller="job_Cost_Tab_cmp"  implements="flexipage:availableForAllPageTypes,force:hasSObjectName,flexipage:availableForRecordHome,force:hasRecordId" access="global" >
    
    <!-- <ltng:require  scripts="{!$Resorce.JobPage}" afterScriptsLoaded="{!c.scriptsLoaded}" />  -->
    <aura:attribute name="jobrecordId" type="String" />
    <aura:attribute name="isAccess" type="list" /><!-- to check Quote permissions(creatable,editable)-->
    <aura:attribute name="record" type="Object" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="rawData" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="desc" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isOpen" type="boolean" default="false"/>
    <aura:attribute name="quoteRecordid" type="String"/>
    <aura:attribute name="GL_DepartmentRecords" type="Object"/>
    <aura:attribute name="GL_CodeRecords" type="Object"/>
    
    <aura:attribute name="DynamicLabels" type="list"/>
    
    <aura:attribute name="isMobile" type="boolean" />
    
    <aura:attribute name="selectedLookUpRecord_GLD" type="sObject" default="{}"/>
    <aura:attribute name="selectedLookUpRecord_GLC" type="sObject" default="{}"/>
    <aura:attribute name="GLDRecord" type="String" default=""/>
    
    <aura:attribute name="erorrMsg" type="Object" default="" />
    <aura:attribute name="isErrorOcuur" type="boolean" default="false" />
    <aura:attribute name="Labelname" type="string"/>
    <aura:attribute name="ObjectType" type="Object"/>
    
   
    
    <!-- <aura:html tag="style">
        .QuoteNonEditable button{
        display:none;
        } 
    </aura:html> -->
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    <!-- <aura:handler event="c.UpdateRecordsforChanges" action="{!c.recordsUpdateforchanges}" />  -->
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.jobrecordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>    
    
    <!-- This attribute will hold the update records from data table-->
    <aura:attribute name="updatedRecord" type="Object[]" />
    
    <aura:if isTrue="{!!v.isMobile}">
      
        <div id="newbutid" align="center" draggable="false" >
            <lightning:button variant="neutral" label="New" title="New" onclick="{!c.QuoteCreate }"/>
            <!--lightning:button variant="neutral" label="Quote View" title="Quote View" onclick="{!c.NagivatetoQuoteSection}"/-->
        </div>
        <br/>
        <aura:if isTrue="{!empty(v.data)}">
            <b>No records to display</b>
            <aura:set attribute="else" >
                
                <div aura:id="QuoteTble">
                    <lightning:datatable class="Quotetablecss"
                                         aura:id="QuoteDataTable"
                                         columns="{! v.columns }"
                                         data="{! v.data }"
                                         keyField="Id"
                                         onsave ="{!c.onSave}"
                                         hideCheckboxColumn="true"
                                         errors="{!v.errors}"
                                         onsort="{!c.updateColumnSorting}"
                                         sortedBy="{!v.sortedBy}"
                                         sortedDirection="{!v.sortedDirection}" 
                                         onrowaction="{!c.handleRowAction}" />
                </div>
                <aura:if isTrue="{! v.isLoading }">
                    <lightning:spinner alternativeText="Loading"/>
                </aura:if>
                
            </aura:set>
        </aura:if>
    </aura:if>
    <aura:if isTrue="{!v.isMobile}">
        <center>
            
            <lightning:button variant="neutral" label="New" title="New" onclick="{!c.QuoteCreate}" />    
            
        </center>
        <br/>
        <aura:iteration items="{!v.data}" var="qt">
            <table>
                <tr>
                    <td colspan="2">
                        <a href="{!'/'+qt.Id}"> <b> <ui:outputText value="{!qt.Name}"/></b></a> 
                    </td>
                    <td width="20%" style="text-align:right;" class="MobileMoreActions" >
                        <lightning:buttonMenu name="{!qt.Id}" aura:id="qtItem" onselect="{! c.handleQtQuickAction }">
                            <lightning:menuItem value="Edit" label="Edit" iconName="utility:edit"/>
                            <lightning:menuItem value="Delete" label="Delete" iconName="utility:delete"/>
                            <lightning:menuItem value="Unapprove" label="Unapprove" disabled="{!!qt.Approved__c}" iconName="utility:close"/>
                        </lightning:buttonMenu>
                    </td>
                </tr>                           
                <tr>
                    
                    <td width="40%" >
                        <ui:outputText value="{!v.DynamicLabels[0].Amount}"/>:
                    </td>
                    <td width="60%">
                        <p><lightning:formattedNumber value="{!qt.Amount__c}" style="currency" currencyCode="USD"/></p>
                    </td>
                </tr>
                <tr>
                    <td width="40%" >
                        <ui:outputText value="{!v.DynamicLabels[0].DueDate}"/>:
                    </td>
                    <td width="60%">
                        <ui:outputDate value="{!qt.Due_Date__c}"/>	
                    </td>
                </tr>
                <tr>
                    <td width="40%">
                        <ui:outputText value="{!v.DynamicLabels[0].Status}"/>:
                    </td>
                    <td width="60%">
                        <aura:if isTrue="{!qt.Approved__c}">
                            <ui:outputText value="Approved" />             
                            <aura:set attribute="else">
                                <ui:outputText value="Unapproved" />  
                            </aura:set>
                        </aura:if>
                    </td>
                </tr>
            </table>
            <hr style="margin: 0.4rem 0;"/>
        </aura:iteration>
    </aura:if>
    
    
    
    <aura:if isTrue="{!v.isOpen}">
        <lightning:recordEditForm aura:id="JobQuoteEditform" density="comfy" objectApiName="Quote__c" recordId="{!v.quoteRecordid}" onload="{!c.jobQuoteload}"  onsubmit="{!c.jobQuoteOnsubmit}" onsuccess="{!c.onQuoteRecordSuccess}"  >
            
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.quoteRecordid==null?'New ':'Edit '} {!v.Labelname}</h2>
                  
                    </header>
                    
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                        
                        <!-- *********************Error Section ************************** -->
                        <aura:if isTrue="{!v.isErrorOcuur}">
                            <div class="slds-size--1-of-1 slds-p-horizontal_x-small">
                                <ui:message title="Error" severity="error" closable="false">
                                    <span>{!v.erorrMsg}</span>
                                </ui:message>  
                            </div>
                        </aura:if>
                        <br/>
                        
                        <!-- *********************Error Section ************************** -->
                        <lightning:layout multipleRows="true">  
                            <aura:iteration items="{!v.fieldset}" var="field">
                                
                                <aura:if isTrue="{!(field=='Job__c') || (field=='GL_Department__c') || (field=='GL_Code__c')}">    
                                    <aura:set attribute="else">  
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <lightning:inputField fieldName="{!field}" aura:id="JobQuoteField"  class="{!'slds-form-element  slds-p-horizontal_x-small' + ' ' +((field=='Name') || (field=='Quantity__c') ? 'frequired' :' ')}"  /> 
                                        </lightning:layoutItem>
                                        
                                    </aura:set>
                                </aura:if>
                                <aura:if isTrue="{!field=='Job__c'}"> 
                                    
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-form-element slds-p-horizontal_x-small">
                                            <label class="slds-form-element__label" for="text-input-id-1">{!v.ObjectType.Quote__c.Job__c.label} </label>
                                            <div class="slds-form-element__control">
                                                <ui:outputText value="{!v.simpleRecord.Name}" />
                                            </div>
                                        </div>
                                    </lightning:layoutItem>
                                    
                                </aura:if>
                                <aura:if isTrue="{!field=='GL_Department__c'}">
                                    <div class="slds-size--1-of-1 slds-p-horizontal_x-small">
                                        <c:customLookup aura:id="GLD_GLC_AuraId" objectAPIName="GL_Department__c" DepobjectAPIName="GL_Code__c" IconName="custom:custom94" DepIconName="custom:custom24" selectedRecord="{!v.selectedLookUpRecord_GLD}" 
                                                        DepenselectedRecord="{!v.selectedLookUpRecord_GLC}" label="{!V.ObjectType.Quote__c.GL_Department__c.label}" Depelabel="{!V.ObjectType.Quote__c.GL_Code__c.label}" RelationShipName="GL_Department__c" ParentFilter=""  ChildFilter=""
                                                        ParentRecId="{!v.GLDRecord}" ParentSortBy="Order By Name" ChildSortBy="Order By Name" IsDependent="true" IsParentReq="true" IsChildReq="true"/>
                                        
                                    </div>   
                                    
                                </aura:if> 
                            </aura:iteration>
                        </lightning:layout>
                        
                        <br></br>
                    </div>
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
</aura:component>