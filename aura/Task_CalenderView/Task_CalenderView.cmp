<aura:component controller="job_Cost_Tab_cmp" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    <ltng:require styles="{!join(',',
                          $Resource.FullCalendar380 + '/fullcalendar-3.8.0/fullcalendar.css'
                          )}"
                  scripts="{!join(',',
                           $Resource.FullCalendar380 + '/fullcalendar-3.8.0/moment.min.js',
                           $Resource.FullCalendar380  + '/fullcalendar-3.8.0/jquery.min.js',
                           $Resource.FullCalendar380  + '/fullcalendar-3.8.0/jquery-ui.min.js',
                           $Resource.FullCalendar380  + '/fullcalendar-3.8.0/fullcalendar.min.js'
                           )}"
                  afterScriptsLoaded="{!c.afterScriptsLoaded}" />
    
     <ltng:require styles="/resource/FullCalendar380/fullcalendar-3.8.0/fullcalendar.css"/>
    
    
    
    <aura:attribute name='recordId' type='String' default="a0Y3600000AiJCAEA3"/>
     <aura:attribute name='statusList' type="List[]"/>
    <aura:attribute name='Objectlist' type='Object[]'/>
    
    
    <lightning:select aura:id="task_status_change" name="select" label="Task Status">
        <aura:iteration items="{!v.statusList}" var="ss">
         <option value="{!ss}">{!ss}</option>
        </aura:iteration>
    </lightning:select>
    <br/><br/>
    
    <div id="calendar" class="slds-card">
   </div>
</aura:component>