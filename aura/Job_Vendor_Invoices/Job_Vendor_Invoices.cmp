<aura:component controller="job_Cost_Tab_cmp" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    <aura:attribute name="jobrecordId" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="record" type="Object"/>
    <aura:attribute name="isAccess" type="list" /><!-- to check Quote permissions(creatable,editable)-->
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="DESC" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isInvOpen" type="boolean" default="false"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="VendorInvRecordid" type="String"/>
    <aura:attribute name="VendorRecords" type="Object"/>
    <aura:attribute name="TotalAmount" type="double" />
    <aura:attribute name="ObjectType" type="Object"/> 
    <aura:handler event="c.UpdateRecordsforChanges" action="{!c.recordsUpdateforchanges}" />
    <aura:attribute name="Labelname" type="string"/>
    
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="DynamicLabels" type="list"/>
    
   
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.jobrecordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>  
    
    <!-- This attribute will hold the update records from data table-->
    <aura:attribute name="updatedRecord" type="Object[]" />
    <aura:if isTrue="{!!v.isMobile}">
     
        <div align="center" draggable="false" >
            <lightning:button variant="neutral" label="New" title="New" onclick="{!c.InvCreate}"/>
        </div>
        <br/>
        <aura:if isTrue="{!empty(v.data)}">
            <b>No records to display</b>
            <aura:set attribute="else">
                <lightning:card>
                    <div>
                        <lightning:datatable class="tablecss"
                                             aura:id="InvDataTable"
                                             columns="{!v.columns}"
                                             data="{!v.data}"
                                             keyField="Id"
                                             onsave ="{!c.onSave}"
                                             hideCheckboxColumn="true"
                                             showRowNumberColumn="true"
                                             errors="{!v.errors}"
                                             onsort="{!c.updateColumnSorting}"
                                             sortedBy="{!v.sortedBy}"
                                             sortedDirection="{!v.sortedDirection}" 
                                             onrowaction="{!c.handleRowAction}" />
                    </div>
                    <br/>
                    <div style="float:right;padding-right:3%;font-size:1.10em;font-style:normal;font-family: 'Calibri';font-weight:bold">
                        <span style="font-style:italic;" > Actual Amount Total  </span>
                        &nbsp;:&nbsp;&nbsp; <ui:outputCurrency value="{!v.TotalAmount}"/>   
                    </div>   
                    
                </lightning:card>
                <aura:if isTrue="{!v.isLoading}">
                    <lightning:spinner alternativeText="Loading"/>
                </aura:if>
            </aura:set>
        </aura:if>
    </aura:if>
    <aura:if isTrue="{!v.isMobile}">
        <!--div align="center" draggable="false" >
            <lightning:button variant="neutral" label="New" title="New" onclick="{!c.InvCreate}"/>
        </div>
        <br/-->
        <aura:if isTrue="{!empty(v.data)}">
            <b>No records to display</b>
            <aura:set attribute="else">
                <aura:iteration items="{!v.data}" var="VdInv">
                    <table>
                        <tr>
                            <td colspan="2">
                                <b> <a href="{!'/'+VdInv.Id}"><ui:outputText value="{!VdInv.Name}"/></a></b>
                            </td>
                            <!--td width="20%" style="text-align:right;" class="MobileMoreActions" >
                                <lightning:buttonMenu name="{!VdInv.Id}" aura:id="SpecItem" onselect="{! c.handleVdInvcQuickAction }">
                                    <lightning:menuItem value="Edit" label="Edit"  iconName="action:edit"/>
                                    <lightning:menuItem value="Delete" label="Delete" disabled="{!VdInv.isInvLI}" iconName="utility:delete"/>
                                </lightning:buttonMenu>
                            </td-->
                        </tr>                          
                        <tr>
                            <td width="40%" style="vertical-align:top;">
                                <ui:outputText value="{!v.DynamicLabels[0].Vendor}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputText value="{!VdInv.Vendor__c}"/>
                            </td>
                        </tr>
                        <tr>
                            <td width="40%" style="vertical-align:top;">
                                <ui:outputText value="{!v.DynamicLabels[0].PO}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputText value="{!VdInv.Purchase_Order__c}"/>
                            </td>
                        </tr>
                        <tr>
                            <td width="40%" style="vertical-align:top;">
                                <ui:outputText value="{!v.DynamicLabels[0].DateReceived}"/>:
                            </td>
                            <td width="60%">
                                <ui:outputDate value="{!VdInv.Date_Received__c}"/>
                            </td>
                        </tr>
                        <tr>
                            <td width="40%" style="vertical-align:top;">
                                <ui:outputText value="{!v.DynamicLabels[0].Amount}"/>:
                            </td>
                            <td width="60%">
                                <p><lightning:formattedNumber  value="{!VdInv.Total_Amount__c}" style="currency" currencyCode="USD"/></p>
                            </td>
                        </tr>
                    </table>
                    <hr style="margin: 0.4rem 0;"/>
                </aura:iteration>
            </aura:set>
        </aura:if>
    </aura:if>
    <aura:if isTrue="{!v.isInvOpen}">
        <lightning:recordEditForm aura:id="JobInvEditform" density="comfy" objectApiName="Invoice__c" recordId="{!v.VendorInvRecordid}" onload="{!c.jobInvload}"  onsubmit="{!c.jobInvOnsubmit}" onsuccess="{!c.onInvRecordSuccess}"  >
            <lightning:messages /> 
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.VendorInvRecordid==null?'New ':'Edit '} {!v.Labelname}</h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                        <lightning:layout multipleRows="true">  
                            <aura:iteration items="{!v.fieldset}" var="field">
                                <aura:if isTrue="{!(field=='Job__c') || (field=='Vendor__c')}">    
                                    <aura:set attribute="else">
                                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <lightning:inputField fieldName="{!field}" aura:id="JobInvField"  class="{!'slds-form-element  slds-p-horizontal_x-small' + ' ' +((field=='Name') || (field=='Date_Received__c') ? 'frequired' :' ')}" /> 
                                        </lightning:layoutItem>
                                    </aura:set>
                                </aura:if>
                                <aura:if isTrue="{!field=='Job__c'}"> 
                                    <aura:if isTrue="{!v.VendorInvRecordid!=null}">
                                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <lightning:outputField fieldName="Job__c" class="slds-form-element  slds-p-horizontal_x-small" />
                                        </lightning:layoutItem>
                                        <aura:set attribute="else"> 
                                            <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                                <div class="slds-form-element  slds-p-horizontal_x-small">
                                                    <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Invoice__c.Job__c.label}</label>
                                                    <div class="slds-form-element__control">
                                                        <ui:outputText value="{!v.simpleRecord.Name}"  />
                                                    </div>
                                                </div>
                                            </lightning:layoutItem>
                                        </aura:set>
                                    </aura:if>
                                </aura:if>
                                
                                
                                
                                <aura:if isTrue="{!field=='Vendor__c'}">
                                    
                                    <aura:if isTrue="{!v.VendorInvRecordid!=null}">
                                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <lightning:outputField fieldName="Vendor__c" class="slds-form-element  slds-p-horizontal_x-small" />
                                        </lightning:layoutItem>
                                        <aura:set attribute="else">   
                                            <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                                <div class=" slds-p-horizontal_x-small"> 
                                                    <lightning:select  name="Vendor" aura:id="VendorId" label="{!v.ObjectType.Invoice__c.Vendor__c.label}" class="frequired" >
                                                        <aura:iteration items="{!v.VendorRecords}" var="Ven">
                                                            <option text="{!Ven.value}" value="{!Ven.key}" />
                                                        </aura:iteration>
                                                    </lightning:select>
                                                </div>
                                            </lightning:layoutItem>
                                        </aura:set>
                                    </aura:if>  
                                    
                                </aura:if> 
                                
                            </aura:iteration>
                        </lightning:layout>
                        <br></br><br></br><br></br><br></br>
                    </div>
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
</aura:component>