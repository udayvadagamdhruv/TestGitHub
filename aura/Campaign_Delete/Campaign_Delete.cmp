<aura:component controller="Job_Task_View_Controller" implements="flexipage:availableForAllPageTypes,force:lightningQuickActionWithoutHeader,flexipage:availableForRecordHome,force:hasSObjectName,force:hasRecordId" access="global">
    <aura:attribute name="recordId" type="string" default="" />
    <aura:attribute name="sObjectName" type="string" default="" />
     <lightning:navigation aura:id="navService"/>
    <aura:attribute name="error" type="boolean" default="false" />
    <aura:attribute name="errorMsg" type="string" default="" />
 
     <!-- Custom Styles for Modal Header and Footer --> 
    <ltng:require  styles="{!$Resource.LtngStyles + '/LCmpModalandChart/Styles/ModalHederFooterStyles.css'}"/>
   
     
    <!--Modal Header-->  
    <div class="modal-header slds-modal__header slds-size_1-of-1">
        <h4 class="title slds-text-heading--medium">Campaign Delete</h4>
    </div>
    <!--End Modal Header-->  
     
    <!--Modal Body-->   
    <div class="slds-modal__content slds-p-around--x-small slds-align_absolute-center slds-size_1-of-1 slds-is-relative">
  
        <aura:if isTrue="{!v.error}">
            <div class="slds-size--1-of-1 slds-p-horizontal_x-small">
                 <center>Jobs Under this Campaign can't be deleted.</center>
                <ui:message title="Error" severity="error" closable="false">
                    <div>{!v.errorMsg}</div>
                </ui:message>  
            </div>
            
            <aura:set attribute="else">
                <form class="slds-form--stacked">
                    <b>  Do you want to Delete the Campaign?</b> 
                </form> 
            </aura:set>  
        </aura:if>
        <br/>
    </div>
    <!--End of Modal Body--> 
     
    <!--Modal Footer-->  
    <div class="modal-footer slds-modal__footer slds-size_1-of-1"> 
        <aura:if isTrue="{!v.error}">   
               <!-- <lightning:button variant="brand"  label="Go to Campaing Detail page" title="Go to Detail Page" onclick="{! c.handleClose}"/>  -->
              <lightning:button variant="brand"  label="Go to Campaign List View" title="Go to Campaign List View" onclick="{! c.gotoCampaignView}"/>
            <aura:set attribute="else">
                <lightning:button variant="brand" label="Delete" title="Delete" onclick="{! c.dodeleteCampaign}"/>
            </aura:set>
        </aura:if>
     
        <lightning:button variant="Neutral" class="slds-button" label="Cancel" onclick="{!c.handleClose}"/>
    </div>
   
</aura:component>