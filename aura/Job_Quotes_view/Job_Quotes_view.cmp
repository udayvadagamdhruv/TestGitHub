<aura:component controller="job_Cost_Tab_cmp" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global"  >
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="record" type="Object" />
    <aura:attribute name="isAccess" type="list" /><!-- to check PE permissions(creatable,editable)-->
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="QuotespecRecords" type="Object" />
    <aura:attribute name="QuoteSpecColumns" type="Object"/>
    <aura:attribute name="specerrors" type="Object"/>
    <aura:attribute name="activeSections" type="List" default="['Spec_Items','Vendors']" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="fieldset1" type="List"/>
    <aura:attribute name="isOpen" type="boolean" default="false"/>
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="Object"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="DESC" />
    <aura:attribute name="ObjectApiName" type="String"/>
    <aura:attribute name="quoteRecordid" type="String"/>
    <aura:attribute name="VendorRecords" type="Object"/>
    <aura:attribute name="proTempList" type="Map" />
    <aura:attribute name="ObjectType" type="Object"/>
    
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="VendorNewBtnMobile" type="boolean" default="true"/>
    <aura:attribute name="DynamicLabelsQuote" type="list"/>
    <aura:attribute name="DynamicLabelsSpec" type="list"/>
    
    <aura:attribute name="QuoteSpecSection" type="String" default="Spec Items" required="true" access="global"/>
    <aura:attribute name="VendorQuoteSection" type="String" default="Vendor Quotes" required="true" access="global"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>    
    <aura:if isTrue="{!!v.isMobile}">
        <aura:if isTrue="{!v.isAccess[2]}">
            <lightning:card iconName="standard:record"  title="{!v.QuoteSpecSection}">
                
                <aura:set attribute="actions">
                    <aura:if isTrue="{!v.simpleRecord.Approved__c}" >
                        <aura:set attribute="else" >
                            <lightning:button label="New" title="New Spec" onclick="{!c.NewQuoteSpec}" />
                        </aura:set>
                    </aura:if>
                </aura:set>
                
                <div class="c-container">
                    <lightning:layout >
                        <lightning:layoutItem padding="around-small" size="2">
                            <lightning:select aura:id="ProTemplateId" name="ProTemplate" label="Production Spec Template">
                                <aura:iteration items="{!v.proTempList}" var="pTrec">
                                    <option text="{!pTrec.value}" value="{!pTrec.key}"></option>
                                </aura:iteration>
                            </lightning:select>
                        </lightning:layoutItem>
                        <lightning:layoutItem padding="around-small" size="4" >   
                            <div style="padding-top: 24px;">
                                <lightning:button label="Import Spec Items" title="Base action" onclick="{! c.ImportProductionTemp}"/>
                            </div>
                        </lightning:layoutItem>
                        
                    </lightning:layout>
                </div>
                <br/>
                
                <lightning:layout multipleRows="true"> 
                    
                    <aura:if isTrue="{!empty(v.QuotespecRecords)}">
                        <b>No records to display</b>
                        <aura:set attribute="else" >
                            <div>
                                <lightning:datatable class="tablecss"
                                                     aura:Id="QuoteSpecsTableId"
                                                     data="{!v.QuotespecRecords}"
                                                     columns="{!v.QuoteSpecColumns}"
                                                     keyField="Id"
                                                     errors="{!v.specerrors}"
                                                     onsave="{!c.onQuotesSpecsSave}"
                                                     hideCheckboxColumn="true"
                                                     onsort="{!c.updateColumnSortingforSpecs}"
                                                     sortedBy="{!v.sortedBy}"
                                                     sortedDirection="{!v.sortedDirection}"
                                                     onrowaction="{!c.handleRowSpecActions}"
                                                     />
                                
                            </div>
                            <!--   <aura:iteration items="{!v.QuotespecRecords}" var="QSpecList">
                <lightning:layoutItem padding="around-small" size="6">  
                    <div class="slds-grid slds-wrap" >
                        <div class="slds-size_5-of-6">
                            <ul>
                                <li class="slds-item">
                                    <lightning:tile  label="{!QSpecList.Name}" >
                                        <aura:set attribute="media">                
                                            <lightning:icon iconName="standard:record" size="small" alternativeText="Event" />
                                        </aura:set>
                                        <ul class="slds-list_horizontal slds-has-dividers_right">
                                            <li class="slds-item" style="white-space:pre-line;word-break:keep-all;" >{!QSpecList.Description__c}</li>
                                        </ul>
                                    </lightning:tile>
                                </li>
                                
                            </ul> 
                        </div>
                        <div class="slds-size_1-of-6">
                            <aura:if isTrue="{!v.simpleRecord.Approved__c}" >
                                <aura:set attribute="else" >
                                    <lightning:buttonMenu aura:id="menu" alternativeText="Show menu" value="{!QSpecList.Id}" onselect="{!c.handleSelect}" >
                                        <lightning:menuItem aura:id="menuItems" label="Edit" value="EditSpec"  iconName="utility:edit"/>
                                        <lightning:menuItem aura:id="menuItems" label="Delete" value="DeleteSpec" iconName="utility:delete"/>
                                    </lightning:buttonMenu>
                                </aura:set>
                            </aura:if>
                        </div>
                    </div>
                </lightning:layoutItem>
                
            </aura:iteration> -->
                        </aura:set>
                    </aura:if>
                </lightning:layout>
                
            </lightning:card>
        </aura:if>
    </aura:if>
    <aura:if isTrue="{!v.isMobile}">
        <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="VendorQuotes">
            <lightning:accordionSection name="VendorQuotes" label="{!v.QuoteSpecSection}"  class="slds-card" >
                <center>
                    <aura:if isTrue="{!v.VendorNewBtnMobile}" >
                        <lightning:button label="New" title="New Spec" onclick="{!c.NewQuoteSpec}" />
                    </aura:if>
                </center>
                <aura:if isTrue="{!empty(v.QuotespecRecords)}">
                    <b>No recods to display</b>
                    <aura:set attribute="else" >
                        <aura:iteration items="{!v.QuotespecRecords}" var="QtSpec">
                            <table>
                                <tr>
                                    <td colspan="2">
                                        <b><ui:outputText value="{!QtSpec.Name}"/></b>
                                    </td>
                                    <td width="20%" style="text-align:right;" class="MobileMoreActions" >
                                        <lightning:buttonMenu name="{!QtSpec.Id}" aura:id="SpecItem" onselect="{! c.handleSpecQuickAction }">
                                            <lightning:menuItem value="Edit" label="Edit" disabled="{!!v.VendorNewBtnMobile}" iconName="action:edit"/>
                                            <lightning:menuItem value="Delete" label="Delete" disabled="{!!v.VendorNewBtnMobile}"  iconName="utility:delete"/>
                                        </lightning:buttonMenu>
                                    </td>
                                </tr>                          
                                <tr>
                                    <td width="40%" style="vertical-align:top;">
                                        <ui:outputText value="{!v.DynamicLabelsSpec[0].Description}"/>:
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!QtSpec.Description__c}"/>
                                    </td>
                                </tr>
                            </table>
                            <hr style="margin: 0.4rem 0;"/>
                        </aura:iteration>
                    </aura:set>
                </aura:if>
            </lightning:accordionSection>
        </lightning:accordion>
    </aura:if>
    
    <aura:if isTrue="{!!v.isMobile}">
        <aura:if isTrue="{!v.isAccess[5]}">
            <lightning:card iconName="standard:quotes"  title="{!v.VendorQuoteSection}">
                <aura:set attribute="actions">
                    <aura:if isTrue="{!v.simpleRecord.Approved__c}" >
                        <aura:set attribute="else" >
                            <lightning:button label="New" title="New Vendor" onclick="{!c.NewVendorQuote}" />
                        </aura:set>
                    </aura:if>
                </aura:set>
                <aura:if isTrue="{!empty(v.data)}">
                    <b>No recods to display</b>
                    <aura:set attribute="else" >
                        
                        <div>
                            <lightning:datatable class="tablecss"
                                                 aura:id="VendorQuoteDataTable"
                                                 columns="{! v.columns }"
                                                 data="{! v.data }"
                                                 keyField="Id"
                                                 onsave ="{!c.onSave}"
                                                 hideCheckboxColumn="true"
                                                 errors="{!v.errors}"
                                                 onsort="{!c.updateColumnSorting}"
                                                 sortedBy="{!v.sortedBy}"
                                                 sortedDirection="{!v.sortedDirection}" 
                                                 onrowaction="{!c.handleRowAction}" />
                        </div>
                        <aura:if isTrue="{! v.isLoading }">
                            <lightning:spinner alternativeText="Loading"/>
                        </aura:if>
                        
                    </aura:set>
                </aura:if>
            </lightning:card>
        </aura:if>
    </aura:if>
    <aura:if isTrue="{!v.isMobile}">
        
        <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="VendorQuotes">
            <lightning:accordionSection name="VendorQuotes" label="{!v.VendorQuoteSection}"  class="slds-card" >
                <center>
                    <aura:if isTrue="{!v.VendorNewBtnMobile}" >
                        <lightning:button label="New" title="New Vendor" onclick="{!c.NewVendorQuote}" />
                    </aura:if>
                </center>
                <aura:if isTrue="{!empty(v.data)}">
                    <b>No recods to display</b>
                    <aura:set attribute="else" >
                        <aura:iteration items="{!v.data}" var="Vendor">
                            <table>
                                <tr>
                                    <td colspan="2">
                                        <!--a href="{!'/one/one.app#/sObject/'+Vendor.Vendor__c}"--> <b> <ui:outputText value="{!Vendor.Vendor__r.Name}"/></b><!--/a--> 
                                    </td>
                                    <td width="20%" style="text-align:right;" class="MobileMoreActions" >
                                        <lightning:buttonMenu name="{!Vendor.Id}" aura:id="EstItem" onselect="{! c.handleVdQuickAction }">
                                            <lightning:menuItem value="Approve" label="Approve" disabled="{!Vendor.Restrict__c}" iconName="action:approval"/>
                                            <lightning:menuItem value="Delete" label="Delete" disabled="{!Vendor.Restrict__c}" iconName="utility:delete"/>
                                        </lightning:buttonMenu>
                                    </td>
                                </tr>                           
                                <tr>
                                    <td width="40%" >
                                        <ui:outputText value="{!v.DynamicLabelsQuote[0].Name}"/>:
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!Vendor.Name}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40%" >
                                        <ui:outputText value="{!v.DynamicLabelsQuote[0].Date}"/>:
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!Vendor.Date__c}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40%" >
                                        <ui:outputText value="{!v.DynamicLabelsQuote[0].Amount}"/>:
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!Vendor.Amount__c}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40%" >
                                        <ui:outputText value="{!v.DynamicLabelsQuote[0].Restrict}"/>:
                                    </td>
                                    <td width="60%">
                                        <aura:if isTrue="{!Vendor.Restrict__c}">
                                            <ui:outputText value="Approved" />             
                                            <aura:set attribute="else">
                                                <ui:outputText value="Unapproved" />  
                                            </aura:set>
                                        </aura:if>
                                    </td>
                                </tr>
                            </table>
                            <hr style="margin: 0.4rem 0;"/>
                        </aura:iteration>
                    </aura:set>
                </aura:if>
                
            </lightning:accordionSection>
        </lightning:accordion>
    </aura:if>
    
    <aura:if isTrue="{!v.isOpen}">
        <lightning:recordEditForm aura:id="QuoteSpecEditform" density="comfy" objectApiName="{!v.ObjectApiName}" recordId="{!v.quoteRecordid}"   onsubmit="{!c.QuoteSpecOnsubmit}" onsuccess="{!c.onQuoteSpecRecordSuccess}"  >
            <lightning:messages /> 
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.quoteRecordid==null?'New':'Edit'} {!v.ObjectApiName=='Quote_Spec_Item__c'?' Quote Spec':' Vendor Quote'}</h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                        
                        <aura:iteration items="{!v.fieldset}" var="field">
                            <aura:if isTrue="{!(field=='Quote__c') || (field=='Vendor__c') }">    
                                <aura:set attribute="else">  
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                        <lightning:inputField fieldName="{!field}" aura:id="QuoteSpecField"  class="{!'slds-form-element  slds-p-horizontal_x-small' + ' ' +((field=='Name') || (field=='Date__c') ? 'frequired' :' ')}" /> 
                                    </lightning:layoutItem>
                                </aura:set>
                            </aura:if>
                            <aura:if isTrue="{!field=='Quote__c'}"> 
                                <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                    <div class="slds-form-element slds-p-horizontal_x-small">
                                        <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Quote_Spec_Item__c.Quote__c.label} </label>
                                        <div class="slds-form-element__control">
                                            <ui:outputText value="{!v.simpleRecord.Name}"  />
                                        </div>
                                    </div>
                                </lightning:layoutItem>
                            </aura:if>
                            <aura:if isTrue="{!field=='Vendor__c'}">
                                <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                    <div class=" slds-p-horizontal_x-small frequired" > 
                                        <lightning:select  name="Vendor" aura:id="VendorId" label="{!v.ObjectType.Vendor_Quote__c.Vendor__c.label}" >
                                            <aura:iteration items="{!v.VendorRecords}" var="Ven">
                                                <option text="{!Ven.value}" value="{!Ven.key}" />
                                            </aura:iteration>
                                        </lightning:select>
                                    </div>
                                </lightning:layoutItem>
                            </aura:if> 
                        </aura:iteration>
                        <br></br>
                    </div>
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
</aura:component>