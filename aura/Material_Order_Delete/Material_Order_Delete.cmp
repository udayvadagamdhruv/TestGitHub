<aura:component controller="Vendor_MO_Controller" implements="flexipage:availableForAllPageTypes,force:lightningQuickActionWithoutHeader,flexipage:availableForRecordHome,force:hasSObjectName,force:hasRecordId" access="global">
    <aura:attribute name="recordId" type="string" default="" />
    <aura:attribute name="sObjectName" type="string" default="" />
     <lightning:navigation aura:id="navService"/>
    <aura:attribute name="error" type="boolean" default="false" />
    <aura:attribute name="errorMsg" type="string" default="" />
 
    
     
    <!--Modal Header-->  
    <div class="modal-header slds-modal__header slds-size_1-of-1">
        <h4 class="title slds-text-heading--medium">Material Order Delete</h4>
    </div>
    <!--End Modal Header-->  
     
    <!--Modal Body-->   
    <div class="slds-modal__content slds-p-around--x-small slds-align_absolute-center slds-size_1-of-1 slds-is-relative">
  
        <aura:if isTrue="{!v.error}">
            <div class="custom-color">
                 <b><center>Error: Material order cannot be deleted. It has material purchase line items.</center></b>
            </div>
            
            <aura:set attribute="else">
                <form class="slds-form--stacked">
                    <b>  Do you want to Delete the Material Order?</b> 
                </form> 
            </aura:set>  
        </aura:if>
        <br/>
    </div>
    <!--End of Modal Body--> 
     
    <!--Modal Footer-->  
    <div class="modal-footer slds-modal__footer slds-size_1-of-1"> 
        <aura:if isTrue="{!v.error}">   
             <lightning:button variant="Neutral" class="slds-button" label="Cancel" onclick="{!c.handleClose}"/>
            <aura:set attribute="else">
                 <lightning:button variant="Neutral" class="slds-button" label="Cancel" onclick="{!c.handleClose}"/>
                <lightning:button variant="brand" label="Delete" title="Delete" onclick="{! c.dodeleteMO}"/>
            </aura:set>
        </aura:if>
     
       
    </div>
   
</aura:component>