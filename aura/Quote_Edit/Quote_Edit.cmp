<aura:component controller="job_Cost_Tab_cmp"  implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,lightning:actionOverride,force:hasRecordId,force:lightningQuickActionWithoutHeader,force:hasSObjectName" access="global" >
    <aura:attribute name="record" type="Object" />
    <aura:attribute name="recordError" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="fieldSet" type="List"  />
    <aura:attribute name="Labelname" type="string"  />
    <aura:attribute name="GL_CodeRecords" type="List" />
    <aura:attribute name="GL_DepartmentRecords" type="List" />
    <aura:attribute name="GLDSelectId" type="String" />
    <aura:attribute name="GLCodeSelectId" type="String" />
    
    <aura:attribute name="selectedLookUpRecord_GLD" type="sObject" default="{}"/>
    <aura:attribute name="selectedLookUpRecord_GLC" type="sObject" default="{}"/>
    <aura:attribute name="GLDRecord" type="String" default=""/>
    
    <aura:attribute name="isMobile" type="boolean" />
    
    <aura:attribute name="allObjectLabels" type="Object"  />
    <aura:attribute name="ObjectType" type="Object"/>
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/> 
    
    <lightning:recordEditForm aura:id="QuoteEditform" density="comfy" objectApiName="{!v.sObjectName}"  recordId="{!v.recordId}" onsubmit="{!c.RecordSubmit}" onload="{!c.onloadrecord}"  onsuccess="{!c.onRecordSuccess}" >
        <lightning:messages /> 
        <div aura:id="editDialog" role="dialog" tabindex="-1" aria-labelledby="header43" class="slds-modal slds-fade-in-open">
            <div aura:id="errorMsgs"></div>
            <div class="slds-modal__container">
                <div class="slds-modal__header">
                    <h2 class="slds-text-heading--medium"> 
                        Edit {!v.simpleRecord.Name}
                    </h2>
                </div>
                <div class="slds-modal__content slds-p-around--medium slds-grid slds-wrap ">
                    <div class="{!v.isMobile?'showScroll':''}">
                        <ui:scrollerWrapper class="{!v.isMobile?'scrollerSizecart':''}">
                            <lightning:layout multipleRows="true">  
                                <aura:iteration items="{!v.fieldSet}" var="field">
                                    <aura:if isTrue="{!(field=='Job__c') || (field=='GL_Department__c') || (field=='GL_Code__c')}">    
                                        <aura:set attribute="else"> 
                                            <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                                <lightning:inputField fieldName="{!field}" aura:id="JobQuoteField"  class="{!'slds-form-element  slds-p-horizontal_x-small' + ' ' +((field=='Name') || (field=='Quantity__c') ? 'frequired' :' ')}"/> 
                                            </lightning:layoutItem>
                                        </aura:set>
                                    </aura:if>
                                    <aura:if isTrue="{!field=='Job__c'}"> 
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <div class="slds-form-element  slds-p-horizontal_x-small">
                                                <label class="slds-form-element__label" for="text-input-id-1">  Job </label>
                                                <div class="slds-form-element__control">
                                                    <ui:outputText value="{!v.simpleRecord.Job__r.Name}"  />
                                                </div>
                                            </div>
                                        </lightning:layoutItem>
                                    </aura:if>
                                    
                                    <aura:if isTrue="{!field=='GL_Department__c'}">
                                        <div class="slds-size--1-of-1 slds-p-horizontal_x-small">
                                            <c:customLookup aura:id="GLD_GLC_AuraId" objectAPIName="GL_Department__c" DepobjectAPIName="GL_Code__c" IconName="custom:custom94" DepIconName="custom:custom24" selectedRecord="{!v.selectedLookUpRecord_GLD}" 
                                                            DepenselectedRecord="{!v.selectedLookUpRecord_GLC}" label="Dep" Depelabel="Code" RelationShipName="GL_Department__c" ParentFilter=""  ChildFilter=""
                                                            ParentRecId="{!v.GLDRecord}" ParentSortBy="Order By Name" ChildSortBy="Order By Name" IsDependent="true" IsParentReq="true" IsChildReq="true"/>
                                            
                                        </div>   
                                        
                                    </aura:if> 
                                </aura:iteration>
                            </lightning:layout>
                        </ui:scrollerWrapper>
                    </div>
                    <br></br>
                </div>
                <div class="slds-modal__footer">                
                    <lightning:button variant="neutral" label="Cancel" onclick="{!c.doCancel}" />
                    <lightning:button  variant="brand"  label="Save" type="submit" />
                </div>              
            </div>
        </div>
    </lightning:recordEditForm> 
    <div aura:id="overlay" class="slds-backdrop slds-backdrop--open"></div>
    <aura:if isTrue="{!not(empty(v.recordError))}">
        <div class="recordError">
            {!v.recordError}</div>
    </aura:if>   
    
</aura:component>