<aura:component controller="ClientController"  implements="flexipage:availableForAllPageTypes,force:hasSObjectName,flexipage:availableForRecordHome,force:hasRecordId" access="global" >
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="desc" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isCCOpen" type="boolean" default="false"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="CConRecordid" type="String"/>
    <aura:attribute name="record" type="Object"/>
    <aura:attribute name="roles" type="Object"/>
    <!-- This attribute will hold the update records from data table-->
    <aura:attribute name="updatedRecord" type="Object[]" />
    <aura:attribute name="Labelname" type="string"  />
    <aura:attribute name="CConactiveSections" type="List" default="['Details','Address','Others']" />
    <aura:attribute name="ClientContactSec" type="String" default="Client Contact" required="true" access="global"/>
    <aura:attribute name="ObjectType" type="Object"/>
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>    
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="ClientContacts">
        <lightning:accordionSection name="ClientContacts" label="{!v.ClientContactSec}"  class="slds-card" >  
            <div align="center" >
               <lightning:button variant="neutral" label="New" title="New" onclick="{!c.CConCreate}"/>
            </div>
            <br/>
            <aura:if isTrue="{!empty(v.data)}">
                <b>No records to display</b>
                <aura:set attribute="else" >
                    
                    <lightning:card>
                        <div>
                            <lightning:datatable class="CContablecss"
                                                 aura:id="CConDataTable"
                                                 columns="{!v.columns}"
                                                 data="{!v.data}"
                                                 keyField="Id"
                                                 onsave ="{!c.onSave}"
                                                 hideCheckboxColumn="true"
                                                 showRowNumberColumn="true"
                                                 errors="{!v.errors}"
                                                 onsort="{!c.updateColumnSorting}"
                                                 sortedBy="{!v.sortedBy}"
                                                 sortedDirection="{!v.sortedDirection}" 
                                                 onrowaction="{! c.handleRowAction }" />
                        </div>
                        
                    </lightning:card>
                    <aura:if isTrue="{! v.isLoading }">
                        <lightning:spinner alternativeText="Loading"/>
                    </aura:if>
                </aura:set>
            </aura:if>
        </lightning:accordionSection>
    </lightning:accordion>
    
    <aura:if isTrue="{!v.isCCOpen}">
        <lightning:recordEditForm aura:id="CConEditform" density="comfy" objectApiName="Client_Contact__c" recordId="{!v.CConRecordid}" onload="{!c.CConload}"  onsubmit="{!c.CConOnsubmit}" onsuccess="{!c.CCononRecordSuccess}"  >
            <lightning:messages />  
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 class="slds-text-heading--medium"> 
                            <aura:if isTrue="{!v.CConRecordid!=null}">
                                Edit {!v.Labelname}
                                <aura:set attribute="else">
                                    New {!v.Labelname} 
                                </aura:set>
                            </aura:if> 
                        </h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium " id="modal-content-id-1">
                        <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="{!v.CConactiveSections}"> 
                           
                            <lightning:accordionSection name="Details" label="Details"  class="slds-card" >
                                <lightning:layout multipleRows="true">
                                    <aura:iteration items="{!v.fieldset}" var="field">
                                        <aura:if isTrue="{!(field=='First_Name__c')||(field=='Last_Name__c')||(field=='Active__c')||(field=='Salesforce_User__c') || (field=='Email__c')||(field=='Mobile_Phone__c')||(field=='Business_Phone__c')||(field=='UserName__c')||(field=='Fax__c')||(field=='Department__c')}">    
                                            <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                                <lightning:inputField fieldName="{!field}" aura:id="CConField" class="{!((field=='Email__c') || (field=='UserName__c') || (field=='First_Name__c') || (field=='Last_Name__c')? 'frequired' :' ')}" /> 
                                            </lightning:layoutItem>
                                        </aura:if>
                                        <aura:if isTrue="{!(field=='Client__c') &amp;&amp; (v.CConRecordid==null)}"> 
                                            <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                                <label class="slds-form-element__label" for="text-input-id-1"> {!V.ObjectType.Client_Contact__c.Client__c.label} </label>
                                                <div class="slds-form-element__control">
                                                    <ui:outputText value="{!v.simpleRecord.Name}"  />
                                                </div>
                                            </lightning:layoutItem>
                                        </aura:if>
                                        <aura:if isTrue="{!(field=='Client__c') &amp;&amp; (v.CConRecordid!=null)}"> 
                                            <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                                <lightning:inputField fieldName="{!field}" aura:id="CConField"/> 
                                            </lightning:layoutItem>
                                        </aura:if>
                                        <aura:if isTrue="{!field=='Client_Contact_Role__c'}"> 
                                            <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" >
                                                <lightning:select  name="Role" aura:id="RoleId" label="{!V.ObjectType.Client_Contact__c.Client_Contact_Role__c.label}" class="frequired">
                                                    <option text="--None--" value="" />
                                                    <aura:iteration items="{!v.roles}" var="Rol">
                                                        <option text="{!Rol.value}" value="{!Rol.value}" />
                                                    </aura:iteration>
                                                </lightning:select>
                                            </lightning:layoutItem>
                                        </aura:if>
                                    </aura:iteration>
                                </lightning:layout>
                            </lightning:accordionSection> 
                                
                            <lightning:accordionSection name="Address" label="Address" class="slds-card">
                                <lightning:layout multipleRows="true"> 
                                    <aura:iteration items="{!v.fieldset}" var="field">
                                        <aura:if isTrue="{!(field=='Shipping_Address__c')||(field=='Shipping_Address_2__c')||(field=='State__c')||(field=='Zip__c')||(field=='City__c')}">    
                                            <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                                <lightning:inputField fieldName="{!field}" aura:id="CConField"  /> 
                                            </lightning:layoutItem>
                                        </aura:if>
                                    </aura:iteration>
                                </lightning:layout>
                            </lightning:accordionSection>
                            
                            <lightning:accordionSection name="Others" label="Others"  class="slds-card" > 
                               
                                 <lightning:layout multipleRows="true"> 
                                <aura:iteration items="{!v.fieldset}" var="field">
                                   
                                    <aura:if isTrue="{!(field=='First_Name__c')||(field=='Last_Name__c')||(field=='Email__c')||(field=='Business_Phone__c')||(field=='Mobile_Phone__c')||(field=='Fax__c')||(field=='UserName__c')||(field=='Client__c')||(field=='Client_Contact_Role__c')||(field=='Client__c')||(field=='Department__c')||(field=='Active__c')||(field=='Salesforce_User__c')||(field=='Shipping_Address__c')||(field=='Shipping_Address_2__c')||(field=='State__c')||(field=='Zip__c')||(field=='City__c')}">    
                                        <aura:set attribute="else">    
                                                <lightning:inputField fieldName="{!field}" aura:id="CConField"  class="slds-form-element slds-size--1-of-2 slds-p-horizontal_x-small" /> 
                                        </aura:set>
                                    </aura:if>
                                </aura:iteration>
                                     </lightning:layout>
                            </lightning:accordionSection> 
                            <br></br>
                            
                         
                           
                        </lightning:accordion> 
                    </div>
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
    
</aura:component>