<aura:component controller="VendorsController" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,lightning:actionOverride,force:hasRecordId,force:lightningQuickActionWithoutHeader,force:hasSObjectName" access="global" >
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="record" type="Object" />
    <aura:attribute name="recordError" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="fieldset" type="List"  />
    <aura:attribute name="Labelname" type="string"  />
    <aura:attribute name="CLIRecordid" type="String"/>
    <aura:attribute name="sObjectName" type="String"/>
    <aura:attribute name="roles" type="Object"/>
    <aura:attribute name="VenConactiveSections" type="List" default="['Details','Contact','Others']" />
    <aura:attribute name="ObjectType" type="Object"/>
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/> 
    <lightning:recordEditForm aura:id="VenConEditform"  density="comfy" objectApiName="{!v.sObjectName}"  recordId="{!v.recordId}" onsubmit="{!c.RecordSubmit}" onload="{!c.onloadrecord}"  onsuccess="{!c.onRecordSuccess}" >
        <lightning:messages /> 
        <div aura:id="editDialog" role="dialog" tabindex="-1" aria-labelledby="header43" class="slds-modal slds-fade-in-open">
            <div aura:id="errorMsgs"></div>
            <div class="slds-modal__container">
                <div class="slds-modal__header">
                    <h2 class="slds-text-heading--medium"> 
                        Edit {!v.simpleRecord.Name}
                    </h2>
                </div>
                <div class="slds-modal__content slds-p-around--medium slds-grid slds-wrap ">{!v.fieldset}
                    <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="{!v.VenConactiveSections}"> 
                        
                        <lightning:accordionSection name="Details" label="Details"  class="slds-card" >
                            <lightning:layout multipleRows="true">
                                <aura:iteration items="{!v.fieldset}" var="field">
                                    <aura:if isTrue="{!(field=='First_Name__c')||(field=='Last_Name__c')}">    
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                            <lightning:inputField fieldName="{!field}" aura:id="VenConField"/> 
                                        </lightning:layoutItem>
                                    </aura:if>
                                </aura:iteration>
                            </lightning:layout>
                        </lightning:accordionSection> 
                        
                        <lightning:accordionSection name="Contact" label="Contact"  class="slds-card">
                            <lightning:layout multipleRows="true"> 
                                <aura:iteration items="{!v.fieldset}" var="field">
                                    <aura:if isTrue="{!(field=='Email__c')||(field=='Phone_2__c')||(field=='Phone_1__c')||(field=='User_Name__c')}">    
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                            <lightning:inputField fieldName="{!field}" aura:id="VenConField"  class="{!((field=='Email__c') || (field=='User_Name__c') ? 'frequired' :' ')}" /> 
                                        </lightning:layoutItem>
                                    </aura:if>
                                </aura:iteration>
                            </lightning:layout>
                        </lightning:accordionSection>
                        
                        <lightning:accordionSection name="Others" label="Others"  class="slds-card" > 
                            <lightning:layout multipleRows="true"> 
                                <aura:iteration items="{!v.fieldset}" var="field">
                                    <aura:if isTrue="{!field=='Vendor__c'}"> 
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" > 
                                            <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Vendor_Contact__c.Vendor__c.label}</label>
                                            <div class="slds-form-element__control">
                                                <ui:outputText value="{!v.simpleRecord.Vendor__r.Name}"  />
                                            </div>
                                        </lightning:layoutItem>
                                    </aura:if>
                                    <aura:if isTrue="{!field=='Role__c'}"> 
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small" >
                                            <lightning:select  name="Role" aura:id="RoleId" label="{!v.ObjectType.Vendor_Contact__c.Role__c.label}" class="frequired">
                                                <option text="--None--" value="" />
                                                <aura:iteration items="{!v.roles}" var="Rol">
                                                    <option text="{!Rol.value}" value="{!Rol.value}" />
                                                </aura:iteration>
                                            </lightning:select>
                                        </lightning:layoutItem>
                                    </aura:if>
                                    
                                    <aura:if isTrue="{!(field=='First_Name__c')||(field=='Last_Name__c')||(field=='Email__c')||(field=='Phone_2__c')||(field=='Phone_1__c')||(field=='User_Name__c')||(field=='Vendor__c')||(field=='Role__c')}">    
                                        <aura:set attribute="else">    
                                            <lightning:inputField fieldName="{!field}" aura:id="VenConField"  class="slds-form-element slds-size--1-of-2 slds-p-horizontal_x-small" /> 
                                        </aura:set>
                                    </aura:if>
                                </aura:iteration>
                            </lightning:layout>
                        </lightning:accordionSection> 
                        <br></br>
                    </lightning:accordion> 
                </div>
                <div class="slds-modal__footer">                
                    <lightning:button variant="neutral" label="Cancel" onclick="{!c.doCancel}" />
                    <lightning:button  variant="brand"  label="Save" type="submit" />
                </div>              
            </div>
        </div>
    </lightning:recordEditForm> 
    <div aura:id="overlay" class="slds-backdrop slds-backdrop--open"></div>
    <aura:if isTrue="{!not(empty(v.recordError))}">
        <div class="recordError">
            {!v.recordError}</div>
    </aura:if>   
    
</aura:component>