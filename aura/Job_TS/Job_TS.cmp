<aura:component controller="Job_TS_GD_Tags"  implements="flexipage:availableForAllPageTypes,force:hasSObjectName,flexipage:availableForRecordHome,force:hasRecordId" access="global" >
    <aura:attribute name="helpText" type="List"/>
    
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="DESC" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isTSOpen" type="boolean" default="false"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="TSRecordid" type="String"/>
    <aura:attribute name="record" type="Object"/>
    <aura:attribute name="JobName" type="Object"/>
    <aura:attribute name="TaskName" type="Object"/> 
    <aura:attribute name="GLCodeofTask" type="Object"/>
    <aura:attribute name="TotalHours" type="Decimal"/>
    <aura:attribute name="RemainHours" type="Decimal"/>
    <aura:attribute name="GLCodeofTaskid" type="Object"/>
    <aura:attribute name="isStartEnd" type="Boolean" default="false"/>
    <aura:attribute name="TSactiveSections" type="List" default="['EntrySection']" />
    <aura:attribute name="TotalHoursWorked" type="Decimal"/>
    <aura:attribute name="today" type="Date" default=""/>
    <aura:attribute name="loginUserId" type="list" default=""/>
    <aura:attribute name="TSAccessable" type="Object[]"/>
    <aura:attribute name="DynamicLabels" type="list"/>    
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="selectedLookUpRecord_User" type="sObject" default="{}"/>  
    
    <aura:attribute name="enableInfiniteLoading" type="Boolean" default="true"/>
    <aura:attribute name="initialRows" type="Integer" default="10"/>
    <aura:attribute name="rowsToLoad" type="Integer" default="10"/>
    <aura:attribute name="totalNumberOfRows" type="Integer" default="10"/>
    <aura:attribute name="loadMoreStatus" type="String" default="Please scroll down to load more data"/>
    <aura:attribute name="showRowNumberColumn" type="Boolean" default="false"/>
    <aura:attribute name="rowNumberOffset" type="Integer" default="0"/>
    <aura:attribute name="rowsToAdd" type="Integer" default="10"/>
    <aura:attribute name="currentCount" type="Integer" default="10"/>
    <aura:attribute name="TotalTimesheetHours" type="Decimal" default="0" />
    
    <!-- This attribute will hold the update records from data table-->
    <aura:attribute name="updatedRecord" type="Object[]" />
    
    <aura:attribute name="TimesheetSection" type="String" default="Timesheet" required="true" access="global"/>
    
    <aura:attribute name="ObjectType" type="Object"/>
    <aura:attribute name="Labelname" type="string"/>
    <aura:handler event="c:UpdateRecordsforChanges" action="{!c.refreshTS}" />
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>    
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:if isTrue="{!v.TSAccessable[0]}">   
        <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="TS">
            <lightning:accordionSection name="TS" label="{!v.TimesheetSection}"  class="slds-card" >  
                <aura:if isTrue="{!!v.isMobile}">
                    <c:customHelpText text="{!v.helpText[0].Job_Time__c}" />
                    <div align="center">
                        <lightning:button variant="neutral" label="New" title="New" onclick="{!c.TSCreate}"/>
                    </div>
                    <br/>
                    <aura:if isTrue="{!empty(v.data)}">
                        <br/> <b>No records to display</b>
                        <aura:set attribute="else" >
                            <div  style="height: 420px">
                                <lightning:datatable class="tablecss"
                                                     aura:id="TSDataTable"
                                                     columns="{!v.columns}"
                                                     data="{!v.data}"
                                                     keyField="Id"
                                                     enableInfiniteLoading="true"
                                                     loadMoreOffset="{!v.loadMoreOffset}"
                                                     onloadmore="{!c.handleLoadMoreRec}"
                                                     rowNumberOffset="0"  
                                                     onsave ="{!c.onSave}"
                                                     hideCheckboxColumn="true"
                                                     showRowNumberColumn="true"
                                                     errors="{!v.errors}"
                                                     onsort="{!c.updateColumnSorting}"
                                                     sortedBy="{!v.sortedBy}"
                                                     sortedDirection="{!v.sortedDirection}" 
                                                     onrowaction="{! c.handleRowAction }" 
                                                     />
                            </div>
                            <br/>
                            <div class="slds-grid slds-wrap">
                                <div class="slds-col slds-size_4-of-12">
                                    <strong>Total Rows : {!v.totalNumberOfRows}</strong>
                                </div>
                                <div class="slds-col slds-size_4-of-12">
                                    <center>
                                        <strong>Total Hours Worked : {!v.TotalTimesheetHours}</strong>
                                    </center>
                                </div> 
                                <div class="slds-col slds-size_4-of-12 ">
                                    <strong class="slds-float_right">{!v.loadMoreStatus}</strong>
                                </div>
                            </div>
                            <aura:if isTrue="{!v.isLoading}">
                                <lightning:spinner alternativeText="Loading"/>
                            </aura:if>
                            
                        </aura:set>
                    </aura:if>
                </aura:if>
                <aura:if isTrue="{!v.isMobile}">
                    <center>
                        <lightning:button variant="neutral" label="New" title="New" onclick="{!c.TSCreate}" />    
                    </center>
                    <br/>
                    <aura:if isTrue="{!empty(v.data)}">
                        <br/> <b>No records to display</b>
                        <aura:set attribute="else" >
                            <aura:iteration items="{!v.data}" var="ts">
                                <table>
                                    <tr>
                                        
                                        <td colspan="2">
                                            <a href="{!'/'+ts.Id}"> <b> <ui:outputText value="{!ts.Task_Name__c}"/></b></a> 
                                        </td>
                                        <td width="20%" style="text-align:right;" class="MobileMoreActions" >
                                            <lightning:buttonMenu name="{!ts.Id}" aura:id="tsItem" onselect="{!c.handleTsQuickAction}">
                                                <lightning:menuItem value="Edit" label="Edit" iconName="utility:edit"/>
                                                <lightning:menuItem value="Delete" label="Delete" iconName="utility:delete"/>
                                            </lightning:buttonMenu>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td width="40%" style="vertical-align:top;">                                   
                                            <ui:outputText value="{!v.DynamicLabels[0].Date}"/>:                                   
                                        </td>
                                        <td width="60%">
                                            <ui:outputDate value="{!ts.Date__c}"/>	
                                        </td>
                                    </tr>
                                    <tr>
                                        <td width="40%" >
                                            <ui:outputText value="{!v.DynamicLabels[0].Hours}"/>:
                                        </td>
                                        <td width="60%">
                                            <ui:outputText value="{!ts.Hours_Worked__c}"/>	
                                        </td>
                                    </tr>
                                    <tr>
                                        <td width="40%" style="vertical-align:top;">                                   
                                            <ui:outputText value="{!v.DynamicLabels[0].Staff}"/>:                                   
                                        </td>
                                        <td width="60%">
                                            <ui:outputText value="{!ts.User__c}"/>	
                                        </td>
                                    </tr>
                                </table>
                                <hr style="margin: 0.4rem 0;"/>
                            </aura:iteration>
                            <table>
                                <tr>
                                    <td width="50%">
                                        <b><ui:outputText value="Total Hours Worked"/>:</b>
                                    </td>
                                    <td width="50%" >
                                        <b>{!v.TotalTimesheetHours}</b>	
                                    </td>
                                </tr>
                            </table>
                        </aura:set>
                    </aura:if>
                </aura:if>
                
            </lightning:accordionSection>
        </lightning:accordion>
        
        
        <aura:if isTrue="{!v.isTSOpen}">
            <lightning:recordEditForm aura:id="TSEditform" density="comfy" objectApiName="Timesheet_Entries__c" recordId="{!v.TSRecordid}" onload="{!c.jobTSload}"  onsubmit="{!c.jobTSOnsubmit}" onsuccess="{!c.onTSRecordSuccess}"  >
                <lightning:messages />    
                <!--************************************************  MODAL BOX Start *************************************************--> 
                
                <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                    
                    <div class="slds-modal__container">
                        <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                        <header class="slds-modal__header">
                            <lightning:buttonIcon iconName="utility:close"
                                                  onclick="{! c.closeModel }"
                                                  alternativeText="close"
                                                  variant="bare-inverse"
                                                  class="slds-modal__close"/>
                            <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.TSRecordid==null?'New ':'Edit '} {!v.Labelname}</h2>
                        </header>
                        <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                        <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                            
                            <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="{!v.TSactiveSections}"> 
                                <lightning:accordionSection name="WatchSection" label="Watch Section"  class="slds-card" >    
                                    <lightning:layout multipleRows="true">  
                                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <div class="slds-form-element__control">
                                                <lightning:inputField fieldName="Start_Watch__c" aura:id="STWatch" class="slds-form-element slds-p-horizontal_x-small" onchange="{!c.TotalHrs}"/> 
                                            </div>
                                        </lightning:layoutItem>
                                        <lightning:layoutItem size="12" smallDeviceSize="6" mediumDeviceSize="12" largeDeviceSize="6" padding="around-small">
                                            <div class="slds-form-element__control">
                                                <lightning:inputField fieldName="End_Watch__c" aura:id="ETWatch" class="slds-form-element  slds-p-horizontal_x-small" onchange="{!c.TotalHrs}"/> 
                                            </div>
                                        </lightning:layoutItem>
                                    </lightning:layout>   
                                </lightning:accordionSection>  
                                
                                <lightning:accordionSection name="EntrySection" label="Entry Section"  class="slds-card" >    
                                    <lightning:layout multipleRows="true">  
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <label class="slds-form-element__label" for="text-input-id-1">{!v.ObjectType.Timesheet_Entries__c.Job__c.label} </label>
                                            <div class="slds-form-element__control slds-form-element">
                                                <ui:outputText value="{!v.JobName}" />
                                            </div>
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <div class="slds-form-element__control slds-form-element slds-size--2-of-2 slds-p-horizontal_x-small">
                                                <lightning:select name="TaskSelect" aura:id="TaskNameId" label="{!V.ObjectType.Timesheet_Entries__c.Task_Name__c.label}" onchange="{!c.GLCode}" class="frequired">
                                                    <option text="-None-" value="" />
                                                    <aura:iteration items="{!v.TaskName}" var="Tsk">
                                                        <option text="{!Tsk.Name}" value="{!Tsk.Name}" />
                                                    </aura:iteration>
                                                </lightning:select> 
                                            </div>
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <label class="slds-form-element__label" for="text-input-id-1"> {!V.ObjectType.Timesheet_Entries__c.GL_Code__c.label} </label>
                                            <div class="slds-form-element__control slds-form-element">
                                                <ui:outputText value="{!v.GLCodeofTask}" aura:id="GLC" />
                                            </div>
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <label class="slds-form-element__label" for="text-input-id-1"> Total Hours Estimated </label>
                                            <div class="slds-form-element__control slds-form-element">
                                                <ui:outputText value="{!v.TotalHours}" />
                                            </div>
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <lightning:inputField fieldName="Date__c" aura:id="DTValueauraId" class="slds-form-element frequired"/> 
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <label class="slds-form-element__label" for="text-input-id-1"> Total Hours Remaining </label>
                                            <div class="slds-form-element__control slds-form-element">
                                                <ui:outputText value="{!v.RemainHours}" />
                                            </div>
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">   
                                            <lightning:inputField fieldName="Notes__c" aura:id="Note" class="slds-form-element"/> 
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12"  smallDeviceSize="12"  mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">    
                                            <aura:if isTrue="{!!v.isStartEnd}" >    
                                                <lightning:inputField fieldName="Hours_Worked__c" aura:id="THW" class="slds-form-element" />
                                                <aura:set attribute="else">   
                                                    <label class="slds-form-element__label" for="text-input-id-1"> Total Hours Worked </label>
                                                    <div class="slds-form-element__control slds-form-element">
                                                        <ui:outputText  value="{!v.TotalHoursWorked}" aura:id="oTHW"/>
                                                    </div>
                                                </aura:set>
                                            </aura:if>
                                        </lightning:layoutItem>
                                        
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">   
                                            <c:customLookup aura:id="uCstLookup" objectAPIName="User" selectedRecord='{!v.selectedLookUpRecord_User}'  IconName="standard:user" label="User" IsDependent='false'/>
                                            
                                            
                                            <!--lightning:inputField fieldName="User__c" aura:id="auraUserId" class="slds-form-element"/--> 
                                        </lightning:layoutItem>
                                        
                                    </lightning:layout>
                                </lightning:accordionSection> 
                            </lightning:accordion>      
                            
                            
                        </div>
                        <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                        <footer class="slds-modal__footer">
                            <lightning:button variant="neutral" 
                                              label="Cancel"
                                              title="Cancel"
                                              onclick="{! c.closeModel }"/>
                            <lightning:button variant="brand" 
                                              label="Save"
                                              title="Save"
                                              type="submit" />
                        </footer>
                    </div>
                    
                </section>
            </lightning:recordEditForm> 
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
            
        </aura:if>
    </aura:if>
</aura:component>