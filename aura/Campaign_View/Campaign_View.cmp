<aura:component controller="DetailPageComponentController" implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId"  access="global" >
    
    <!--  <ltng:require styles="{!$Resource.SLDS + '/assets/styles/salesforce-lightning-design-system-vf.min.css'}"/> -->
    <!-- <ltng:require styles="/resource/SLDS/assets/styles/salesforce-lightning-design-system-vf.min.css"/> -->
    <aura:attribute name="recordId" type="Id" />
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate"/>
    <aura:attribute name="sortedDirection" type="String" default="desc" />
    
    <aura:attribute name="jobRecords" type="Object" />
    <aura:attribute name="jobNotes" type="Object" />
    <aura:attribute name="jobAttachs" type="Object" />
    <aura:attribute name="jobChatterFiles" type="Object" />
    <aura:attribute name="statusPicklist" type="String[]" default="Active"/>
    <aura:attribute name="CampTempList" type="Object" />
    <aura:attribute name="activeSections" type="List" default="['Jobs','JobNotes','JobAttachments','JobChatterFiles']" />
    
    <aura:attribute name="JobsSection" type="String" default="Jobs" required="true" access="global"/>
    <aura:attribute name="JobNotesSection" type="String" default="Job Notes" required="true" access="global" />
    <aura:attribute name="JobFilesSection" type="String" default="Job Files" required="true" access="global"/>
    
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="DynamicLabels" type="list"/>  
    
    <aura:attribute name="recordError" type="String"/>
    <aura:attribute name="recordInfo" type="Object" />
    <aura:attribute name="simpleRecord" type="Object"/>
    <force:recordData aura:id="recordLoaderId"
                      layoutType="FULL"
                      recordId="{!v.recordId}"
                      targetRecord="{!v.recordInfo}"                           
                      targetError="{!v.recordError}"
                      targetFields="{!v.simpleRecord}"
                      mode="VIEW"
                      />
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    
    <!-- <c:svgIcon svgPath="/resource/SLDS/assets/icons/standard-sprite/svg/symbols.svg#user" category="standard" size="small" name="user" /> -->
    <lightning:accordion allowMultipleSectionsOpen="true"  activeSectionName="{!v.activeSections}">
        <lightning:accordionSection name="Jobs" label="{!v.JobsSection}"  class="slds-card" >
            <aura:if isTrue="{!v.isMobile}">
            <lightning:card>
                
                <div class="demo-only demo-only--sizing slds-grid slds-wrap">
                    <div class="slds-size_3-of-10">
                        <div class="slds-m-around_x-small">
                            <lightning:select name="select1" aura:id="pickJob" label="Job Status" onchange="{!c.StatusChange}"   >
                                <aura:iteration items="{!v.statusPicklist}" var="option">
                                    <option text="{!option}" value="{!option}" />
                                </aura:iteration>
                            </lightning:select>  
                        </div>
                    </div>
                    <div class="slds-size_3-of-10">
                        <div class="slds-m-around_x-small">
                            <lightning:select name="campSelect" aura:id="campSelectId" label="Campaign Template"  >
                                <option text="--None--" value=""/>
                                <aura:iteration items="{!v.CampTempList}" var="Temp">
                                    <option text="{!Temp.Name}" value="{!Temp.Id}" />
                                </aura:iteration>
                            </lightning:select>
                        </div>
                    </div>
                    <div class="slds-size_3-of-10">
                        <div class="slds-m-around_x-small" style="margin-top:20%">
                            <lightning:button variant="neutral" label="Import Template" onclick="{!c.ImportTemplate}" />
                        </div>
                    </div>
                    <div class="slds-size_3-of-10">
                        <div class="slds-m-around_x-small" style="margin-top:30%">
                            <lightning:button variant="neutral" label="New Job"  onclick="{!c.NewJobRedirect}" />
                        </div>
                    </div>
                    <!--     <div class="slds-size_3-of-10">
                        <div class="slds-m-around_x-small" style="margin-top:25%">
                            <lightning:button variant="neutral" label="Work Order"  onclick="{!c.WorkOrderPageRedirect}" />
                        </div>
                    </div>-->
                </div>
                
                <br/>
                
                
                <aura:if isTrue="{!empty(v.data)}">
                    <b>No records to display</b>
                    <aura:set attribute="else" >
                        
                        
                        <lightning:datatable aura:id="JobsUnderCampaignId"
                                             columns="{! v.columns }"
                                             data="{!v.data}"
                                             keyField="Id"
                                             hideCheckboxColumn="true"
                                             errors="{! v.errors }"
                                             sortedBy="{!v.sortedBy}"
                                             sortedDirection="{!v.sortedDirection}"
                                             onsort="{! c.updateColumnSorting }"
                                             
                                             />
                        
                    </aura:set>
                </aura:if>
            </lightning:card>
            
            </aura:if>
            
            <aura:if isTrue="{!v.isMobile}">
                <div class="slds-size_3-of-10">
                    <div class="slds-m-around_x-small" >
                      <center>  <lightning:button variant="neutral" label="New Job"  onclick="{!c.NewJobRedirect}" /></center>
                    </div>
                </div>
                <div class="slds-size_3-of-10">
                    <div class="slds-m-around_x-small">
                        <lightning:select name="select1" aura:id="pickJob" label="Job Status" onchange="{!c.StatusChange}"   >
                            <aura:iteration items="{!v.statusPicklist}" var="option">
                                <option text="{!option}" value="{!option}" />
                            </aura:iteration>
                        </lightning:select>  
                    </div>
                </div>
                <br/>
                <aura:if isTrue="{!empty(v.data)}">
                    <b>No records to display</b>
                    <aura:set attribute="else" >
                        <aura:iteration items="{!v.data}" var="Job">
                            <table>
                                <tr>
                                    <td colspan="2">
                                        <a href="{!'/'+Job.Id}"> <b> <ui:outputText value="{!Job.Name}"/> (<ui:outputText value="{!Job.Job_Auto_Number__c}"/>)</b></a> 
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40%" style="vertical-align:top;">                                   
                                        <ui:outputText value="{!v.DynamicLabels[0].Status}"/>:                                   
                                    </td>
                                    <td width="60%">
                                        <ui:outputDate value="{!Job.Status__c}"/>	
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40%" >
                                        <ui:outputText value="{!v.DynamicLabels[0].BudgetedCost}"/>:
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!Job.Budgeted_Cost__c}"/>	
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40%" style="vertical-align:top;">                                   
                                        <ui:outputText value="{!v.DynamicLabels[0].EstimateTotal}"/>:                                   
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!Job.Estimate_Total__c}"/>	
                                    </td>
                                </tr>
                                 <tr>
                                    <td width="40%" style="vertical-align:top;">                                   
                                        <ui:outputText value="{!v.DynamicLabels[0].InvoiceActualAmounts}"/>:                                   
                                    </td>
                                    <td width="60%">
                                        <ui:outputText value="{!Job.Invoice_Actual_Amounts__c}"/>	
                                    </td>
                                </tr>
                            </table>
                            <hr style="margin: 0.4rem 0;"/>
                        </aura:iteration>
                        
                    </aura:set>
                </aura:if>
                
            </aura:if>
            
            <!--  </lightning:accordion> -->
        </lightning:accordionSection>
        
        <lightning:accordionSection name="JobNotes" label="{!v.JobNotesSection}">
            
            <lightning:card>
                
                <aura:iteration items="{!v.jobNotes}" var="jnotes">
                    <aura:renderIf isTrue="{!jnotes.value.length>0}">
                        <aura:renderIf isTrue="{!jnotes.key=='Job__Notes'}">
                            
                            <div class="slds-grid slds-wrap">
                                <aura:iteration items="{!jnotes.value}" var="jnotev">
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">   
                                        <ul >
                                            <li class="slds-item">
                                                <lightning:tile label="{!jnotev.ContentDocument.Title}" href="{!'/'+jnotev.ContentDocument.Id}">
                                                    <aura:set attribute="media">
                                                        <lightning:icon iconName="standard:note" size="small"/>
                                                    </aura:set>
                                                    
                                                    <ul class="slds-list_horizontal slds-has-dividers_right">
                                                        <ui:outputURL value="{!'/'+jnotev.LinkedEntityId}" label="{!jnotev.LinkedEntity.Name}" aura:id="JobEnhanceedNotesUrl" target="_blank" />
                                                    </ul> 
                                                </lightning:tile>
                                            </li>
                                        </ul>
                                    </aside>
                                    <hr style="margin: 0.4rem 0;"/>
                                </aura:iteration>
                                
                            </div>
                            
                        </aura:renderIf>
                        <aura:set attribute="else">
                            <b>No records to display</b>
                        </aura:set>     
                    </aura:renderIf>        
                </aura:iteration>
                
            </lightning:card>
            
        </lightning:accordionSection> 
        
        <!-- lightning:accordionSection name="JobAttachments" label="Job Attachments">
            
            <lightning:card>
                
                <aura:iteration items="{!v.jobAttachs}" var="jattchs">
                    <aura:renderIf isTrue="{!jattchs.value.length>0}">
                        <aura:renderIf isTrue="{!jattchs.key=='Job__Attachments'}">
                            <div class="slds-grid slds-wrap">  
                                <aura:iteration items="{!jattchs.value}" var="jattchv">   
                                    <aside >
                                        <ul >
                                            <li class="slds-item">
                                                <lightning:tile  label="{!jattchv.Name}" href="{!'/servlet/servlet.FileDownload?file='+jattchv.Id}">
                                                    <aura:set attribute="media">
                                                        <lightning:icon iconName="doctype:attachment" size="small" />
                                                    </aura:set>
                                                    
                                                    <ul class="slds-list_horizontal slds-has-dividers_right">
                                                        <ui:outputURL value="{!'/'+jattchv.ParentId}" label="{!jattchv.Parent.Name}" aura:id="jobDetailattUrl" target="_blank" />
                                                    </ul>   
                                                </lightning:tile>
                                            </li>
                                        </ul>                     
                                    </aside>
                                </aura:iteration>
                                
                            </div>
                        </aura:renderIf> 
                        <aura:set attribute="else">
                            No records to display
                        </aura:set>
                    </aura:renderIf>
                </aura:iteration>
                
            </lightning:card>
        </lightning:accordionSection> -->
        
        
        <lightning:accordionSection name="JobChatterFiles" label="{!v.JobFilesSection}">
            
            <lightning:card>
                
                <aura:iteration items="{!v.jobChatterFiles}" var="jobchatter">
                    <aura:renderIf isTrue="{!jobchatter.value.length>0}">
                        <aura:renderIf isTrue="{!jobchatter.key=='Job__ChatterFiles'}">
                            
                            <div class="slds-grid slds-wrap">
                                <aura:iteration items="{!jobchatter.value}" var="jchatter">
                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                        <ul >
                                            <li class="slds-item">
                                                <lightning:tile  label="{!jchatter.ContentDocument.Title}"  href="{!'/'+jchatter.ContentDocumentId}">
                                                    <aura:set attribute="media">
                                                        <lightning:icon iconName="standard:file" size="small"  />
                                                    </aura:set>
                                                    <ul class="slds-list_horizontal slds-has-dividers_right">
                                                        <ui:outputURL value="{!'/'+jchatter.LinkedEntityId}" label="{!jchatter.LinkedEntity.Name}" aura:id="jobDetailUrl" target="_blank" />
                                                    </ul> 
                                                    
                                                </lightning:tile>
                                            </li>
                                        </ul>         
                                        
                                    </aside>
                                    
                                </aura:iteration>
                                
                            </div>
                            
                        </aura:renderIf>
                        <aura:set attribute="else">
                            <b>No records to display</b>
                        </aura:set>     
                    </aura:renderIf>        
                </aura:iteration>
                
            </lightning:card>
            
        </lightning:accordionSection> 
        
    </lightning:accordion>
    
</aura:component>