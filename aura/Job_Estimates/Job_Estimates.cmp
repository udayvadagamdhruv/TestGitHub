<aura:component controller="job_Cost_Tab_cmp"  implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,lightning:actionOverride,force:hasRecordId,force:lightningQuickActionWithoutHeader,force:hasSObjectName" access="global" >
    <aura:attribute name="jobrecordId" type="String" />
    <aura:attribute name="simpleRecord" type="Object" />
    <aura:attribute name="recordError" type="Object" />
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="datalenght" type="boolean" default="false"/>
    <aura:attribute name="errors" type="Object"/>
    <aura:attribute name="sortedBy" type="String" default="CreatedDate" />
    <aura:attribute name="sortedDirection" type="String" default="desc" />
    <aura:attribute name="fieldset" type="List"/>
    <aura:attribute name="isEstOpen" type="boolean" default="false"/>
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
    <aura:attribute name="EstRecordid" type="String"/>
    <aura:attribute name="GL_DepartmentRecords" type="Object"/>
    <aura:attribute name="GL_CodeRecords" type="Object"/>
    <aura:attribute name="VendorRecords" type="Object"/>
    <aura:attribute name="record" type="Object"/>
    <aura:attribute name="TotalAmount" type="double" />
    <aura:attribute name="Amount" type="double" />
    <aura:attribute name="ObjectType" type="Object"/>
    <aura:attribute name="Labelname" type="string"/>
    <!-- This attribute will hold the update records from data table-->
    <aura:attribute name="updatedRecord" type="Object[]" />
    <aura:attribute name="isAccess" type="list" /><!-- to check Quote permissions(creatable,editable)-->
    <aura:attribute name="isMobile" type="boolean" />
    <aura:attribute name="DynamicLabels" type="list"/>
    
   
    
    <force:recordData aura:id="record"
                      layoutType="FULL"
                      recordId="{!v.jobrecordId}"
                      targetError="{!v.recordError}"
                      targetRecord="{!v.record}"
                      targetFields ="{!v.simpleRecord}"
                      mode="EDIT"/>    
    
    
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:handler event="c.UpdateRecordsforChanges" action="{!c.recordsUpdateforchanges}" />
    
    <aura:if isTrue="{!!v.isMobile}">
       
        <div align="center" >
            <lightning:button variant="neutral" label="New " title="New" onclick="{!c.EstCreate}"/>
            <aura:if isTrue="{! !empty(v.data)}">
                <lightning:button variant="neutral" label="Print" title="Print" onclick="{!c.RedirectEstimateReport}"/>
            </aura:if>
            
            <!--   <lightning:button variant="neutral" label="Create PO" onclick="{!c.CreatePO}"/>-->
            
        </div>
        <br/>
        <aura:if isTrue="{!empty(v.data)}">
            <b>No records to display</b>
            <aura:set attribute="else" >
                
                <lightning:card>
                    <div>
                        <lightning:datatable class="tablecss"
                                             aura:id="EstimateDataTable"
                                             columns="{!v.columns}"
                                             data="{!v.data}"
                                             keyField="Id"
                                             onsave ="{!c.onSave}"
                                             hideCheckboxColumn="true"
                                             showRowNumberColumn="true"
                                             errors="{!v.errors}"
                                             onsort="{!c.updateColumnSorting}"
                                             sortedBy="{!v.sortedBy}"
                                             sortedDirection="{!v.sortedDirection}" 
                                             onrowaction="{! c.handleRowAction }" />
                    </div>
                    <br/> 
                    <div style="float:right;padding-right:20px;font-size:1.10em;font-style:normal;font-family: 'Calibri';font-weight:bold">
                        <span style="font-style:italic;" > Estimate Total Cost </span>
                        &nbsp;:&nbsp;&nbsp; <ui:outputCurrency value="{!v.TotalAmount}"/>   
                    </div>     
                    
                </lightning:card>
                <aura:if isTrue="{! v.isLoading }">
                    <lightning:spinner alternativeText="Loading"/>
                </aura:if>
            </aura:set>
        </aura:if>
    </aura:if>
    
    <aura:if isTrue="{!v.isMobile}">
        <center><lightning:button variant="neutral" label="New " title="New" onclick="{!c.EstCreate}"/></center>
        <aura:iteration items="{!v.data}" var="Est">
            <table>
                <tr>
                    <td colspan="2">
                        <a href="{!'/'+Est.Id}"> <b> <ui:outputText value="{!Est.Name}"/></b></a> 
                    </td>
                    <td width="20%" style="text-align:right;" class="MobileMoreActions" >
                        <lightning:buttonMenu name="{!Est.Id}" aura:id="EstItem" onselect="{! c.handleEstQuickAction }">
                            <lightning:menuItem value="Dup_Estimate" label="Duplicate"  iconName="action:clone"/>
                            <lightning:menuItem value="Edit_Estimate" label="Edit" disabled="{!Est.Approved__c}" iconName="utility:edit"/>
                            <lightning:menuItem value="Delete_Estimate" label="Delete" disabled="{!Est.Approved__c}" iconName="utility:delete"/>
                            <lightning:menuItem value="Approve_Estimate" label="Approve" disabled="{!Est.Approved__c}" iconName="action:approval"/>
                            <lightning:menuItem value="UnApprove_Estimate" label="Unapprove" disabled="{!!Est.Approved__c}" iconName="utility:close"/>
                        </lightning:buttonMenu>
                    </td>
                </tr>                           
                <tr>
                    <td width="40%" >
                         <ui:outputText value="{!v.DynamicLabels[0].Quantity}"/>:
                    </td>
                    <td width="60%">
                        <ui:outputText value="{!Est.Quantity__c}"/>
                    </td>
                </tr>
                <tr>
                    <td width="40%" >
                         <ui:outputText value="{!v.DynamicLabels[0].TotalCost}"/>:
                    </td>
                    <td width="60%">
                        <p><lightning:formattedNumber value="{!Est.Total_Amount__c}" style="currency" currencyCode="USD"/></p>
                    </td>
                </tr>
            </table>
            <hr style="margin: 0.4rem 0;"/>
        </aura:iteration>
        
    </aura:if>
    
    <aura:if isTrue="{!v.isEstOpen}">
        <lightning:recordEditForm aura:id="JobEstEditform" density="comfy" objectApiName="Estimate_Line_Items__c" recordId="{!v.EstRecordid}" onload="{!c.jobEstload}" onsubmit="{!c.jobEstOnsubmit}" onsuccess="{!c.onEstRecordSuccess}">
            <lightning:messages /> 
            <!--************************************************  MODAL BOX Start *************************************************--> 
            
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- *************************************************** MODAL BOX HEADER Start ***********************************-->
                    <header class="slds-modal__header">
                        <lightning:buttonIcon iconName="utility:close"
                                              onclick="{! c.closeModel }"
                                              alternativeText="close"
                                              variant="bare-inverse"
                                              class="slds-modal__close"/>
                        <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate">{!v.EstRecordid==null?'New ':'Edit '} {!v.Labelname}</h2>
                    </header>
                    <!--*********************************************** MODAL BOX BODY Part Start **************************************************-->
                    <div class="slds-modal__content slds-p-around_medium slds-grid slds-wrap" id="modal-content-id-1">
                        
                        <lightning:layout multipleRows="true">  
                            <aura:iteration items="{!v.fieldset}" var="field">
                                
                                <aura:if isTrue="{!(field=='Job__c') || (field=='GL_Department__c') || (field=='Amount__c') || (field=='GL_Code__c') || (field=='Vendor__c')}">    
                                    <aura:set attribute="else">   
                                        <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                            <lightning:inputField fieldName="{!field}" aura:id="JobEstField"  class="{!'slds-form-element slds-p-horizontal_x-small' + ' ' +((field=='Name') || (field=='Quantity__c')  ? 'frequired' :' ')}" /> 
                                        </lightning:layoutItem>
                                    </aura:set>
                                </aura:if>
                                <aura:if isTrue="{!field=='Job__c'}"> 
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-form-element  slds-p-horizontal_x-small">
                                            <label class="slds-form-element__label" for="text-input-id-1"> {!v.ObjectType.Estimate_Line_Items__c.Job__c.label}</label>
                                            <div class="slds-form-element__control">
                                                <ui:outputText value="{!v.simpleRecord.Name}"  />
                                            </div>
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if>
                                <aura:if isTrue="{!field=='GL_Department__c'}">
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                        <div class=" slds-p-horizontal_x-small">
                                            <lightning:select  name="GLDepatmentselect" aura:id="GLDSelectId" label="{!v.ObjectType.Estimate_Line_Items__c.GL_Department__c.label}"  onchange="{!c.OnChangeGLDepatment}" class="frequired">
                                                <option text="--None--" value="" /> 
                                                <aura:iteration items="{!v.GL_DepartmentRecords}" var="GLD">
                                                    <option text="{!GLD.Name}" value="{!GLD.Id}" />
                                                </aura:iteration>
                                            </lightning:select>
                                            
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if> 
                                <aura:if isTrue="{!field=='GL_Code__c'}">
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-p-horizontal_x-small"> 
                                            <lightning:select  name="GL_Code" aura:id="GLCodeSelectId" label="{!v.ObjectType.Estimate_Line_Items__c.GL_Code__c.label}" onchange="{!c.OnchangeGLCode}" class="frequired">
                                                <option text="--None--" value="" /> 
                                                <aura:iteration items="{!v.GL_CodeRecords}" var="GLC">
                                                    <option text="{!GLC.GL_ID__c +' '+GLC.Name}" value="{!GLC.Id}" />
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if> 
                                <aura:if isTrue="{!field=='Vendor__c'}">
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-p-horizontal_x-small"> 
                                            <lightning:select  name="Vendor" aura:id="VendorId" label="{!v.ObjectType.Estimate_Line_Items__c.Vendor__c.label}" class="frequired" >
                                                <option text="--None--" value="" /> 
                                                <aura:iteration items="{!v.VendorRecords}" var="Ven">
                                                    <option text="{!Ven.Vendor__r.Name}" value="{!Ven.Vendor__c}" />
                                                </aura:iteration>
                                            </lightning:select>
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if> 
                                
                                <aura:if isTrue="{!field=='Amount__c'}">
                                    <lightning:layoutItem size="12" smallDeviceSize="12" mediumDeviceSize="6" largeDeviceSize="6" padding="around-small">
                                        <div class="slds-p-horizontal_x-small frequired"> 
                                        <aura:if isTrue="{!v.EstRecordid==null}">
                                            <lightning:inputfield fieldName="Amount__c" aura:id="JobEstField"  value="{!v.Amount}"/>    
                                            <aura:set attribute="else">
                                                <lightning:inputfield fieldName="Amount__c" aura:id="JobEstField"  />
                                            </aura:set>
                                        </aura:if>
                                        </div>
                                    </lightning:layoutItem>
                                </aura:if> 
                            </aura:iteration>
                            <br></br>
                        </lightning:layout>
                    </div>
                    <!--************************************************ MODAL BOX FOOTER Part Start ****************************************************************-->
                    <footer class="slds-modal__footer">
                        <lightning:button variant="neutral" 
                                          label="Cancel"
                                          title="Cancel"
                                          onclick="{! c.closeModel }"/>
                        <lightning:button variant="brand" 
                                          label="Save"
                                          title="Save"
                                          type="submit" />
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
            <!--************************************************ MODAL BOX Part END Here ***************************************************-->
        </lightning:recordEditForm> 
    </aura:if>
    
</aura:component>