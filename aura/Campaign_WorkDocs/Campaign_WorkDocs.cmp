<aura:component controller="WorkDocDocument" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
    <aura:attribute name="docId" type="string" />
    <aura:attribute name="isActivitiesAdded" type="boolean" default="false" />
    <aura:handler name="init" value="{!this}" action="{!c.fetchActivities}"/>
         {!v.isActivitiesAdded}
</aura:component>