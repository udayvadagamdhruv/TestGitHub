    <fieldUpdates>
        <fullName>Update_Cost_From_Material_Item</fullName>
        <field>Amount__c</field>
        <formula>IF(ISPICKVAL(Calc_Unit__c ,&quot;Size&quot;), 

IF(ISNULL(Material_Item__r.Total_Cost_Per_linear_Foot__c),0, 

Material_Item__r.Total_Cost_Per_linear_Foot__c) * 

(( CEILING(((IF(ISNULL( Length_in_Inches__c ),0, Length_in_Inches__c ) + 0.5)* 

( CEILING(IF(ISNULL( Quantity__c ),0, Quantity__c ) 
/ (Floor((IF(ISNULL(Material_Item__r.Width_inches__c),0,Material_Item__r.Width_inches__c) - 2) / 

(IF(ISNULL( Width_in_Inches__c ),0, Width_in_Inches__c ) + 0.5))))) / 12 )))+1) , 

IF( ISPICKVAL(Calc_Unit__c ,&quot;Each&quot;), (Quantity__c * ( IF(ISNULL(Material_Item__r.Price_Per_Unit__c),0,Material_Item__r.Price_Per_Unit__c) + IF(ISNULL(Material_Item__r.Labor_Charge__c),0,Material_Item__r.Labor_Charge__c) + if( ISNULL(Material_Item__r.Shipping_and_Handling__c),0, Material_Item__r.Shipping_and_Handling__c )) ) 
, 

IF(ISPICKVAL(Calc_Unit__c ,&quot;Sheet&quot;), 
Material_Sheet_Cost_Calculations__c 
,null)))</formula>
        <name>Update Cost From Material Item</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
