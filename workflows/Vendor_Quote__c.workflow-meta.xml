    <rules>
        <fullName>vendor quote is approved and quote status will change</fullName>
        <actions>
            <name>Quote_status_field_changed</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Vendor_Quote__c.Restrict__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
