            <value>True</value>
        </criteriaItems>
        <description>when vendor quote is approved it will be non editable.</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>when vendor quote is Approved new</fullName>
        <actions>
            <name>Quote_field_will_be_updated</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Vendor_Quote__c.Restrict__c</field>
            <operation>equals</operation>
            <value>True</value>
        </criteriaItems>
        <description>when vendor quote is approved its amount will be copied into respected quotes Amount field.</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
