<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>End_Time_can_not_be_before_Start_Time</fullName>
    <active>true</active>
    <description>Sessions End time can not be before its Start time.</description>
    <errorConditionFormula>Start_Time__c  &gt;  End_Time__c</errorConditionFormula>
    <errorDisplayField>End_Time__c</errorDisplayField>
    <errorMessage>End Time must be greater than Start Time</errorMessage>
</ValidationRule>
