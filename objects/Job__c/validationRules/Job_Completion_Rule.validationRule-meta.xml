<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Job_Completion_Rule</fullName>
    <active>false</active>
    <errorConditionFormula>AND(NOT(ISPICKVAL(Status__c,&quot;Completed&quot;)),NOT(ISBLANK(Completion_Date__c)))</errorConditionFormula>
    <errorMessage>Job is not yet completed</errorMessage>
</ValidationRule>
