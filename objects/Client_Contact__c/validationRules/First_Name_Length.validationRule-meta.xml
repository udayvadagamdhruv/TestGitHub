<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>First_Name_Length</fullName>
    <active>true</active>
    <errorConditionFormula>LEN(First_Name__c)   &lt;3</errorConditionFormula>
    <errorDisplayField>First_Name__c</errorDisplayField>
    <errorMessage>First Name must have atleast three characters</errorMessage>
</ValidationRule>
