<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Last_Name_Length</fullName>
    <active>true</active>
    <errorConditionFormula>LEN( Last_Name__c ) &lt; 1</errorConditionFormula>
    <errorDisplayField>Last_Name__c</errorDisplayField>
    <errorMessage>Last Name must have atleast one character</errorMessage>
</ValidationRule>
