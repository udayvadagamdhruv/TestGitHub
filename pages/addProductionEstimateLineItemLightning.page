<apex:page controller="addProductionEstimateLineItem" tabStyle="Job__c" showHeader="false" sidebar="false" applyBodyTag="false" applyHtmlTag="false" docType="html-5.0" standardStylesheets="true">
   <style>     
        .pageHeader
        {
            color:white;
            background-color:#851225;
            height:70px;
            padding-top:15px; 
            position:fixed;
            z-index:999;
            width:100% !important;
            padding-left:22px;
        }
    
        .SectionHeader
        {
            background-color:Grey !important;
            color:white;
        }
        
        .bPageBlock 
        {
             margin: 20px 20px 20px 20px !important;
        }
        
        
        body
        {
                //background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgba(32, 92, 159, 0), rgb(32, 92, 159));
                background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, #d4d7da, #666) !important;
                //background-image:none !important;
                //background-color:#D7D7D7 !important;
                background-repeat: repeat-x;
                background-position: left top;
                background-attachment: fixed; 
                margin:0px !important;
        }
        
        
        .errorM3 .msgIcon, .errorMedium 
        {
            background-image: url(); 
            background-position: 0 0;
            width:0px;
            height: 0px;padding-left: 4px;
        }
        
        </style>
  <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
  <div class="slds">
  
  <apex:form >
  
   <div class="slds-media__body pageHeader">
               <span  class="slds-page-header__title slds-m-right--medium slds-align-middle slds-truncate" style="color:white;font-size:18px;"><b>Add Production Estimate Line Items</b></span>
               <span style="float:right;padding-right:20px;">     
                    
                     <apex:commandButton action="{!Save}" value="Add" title="Click on the button to Add Production Estimate Line Items." styleClass="slds-button slds-button--neutral slds-button-group"/>&nbsp;&nbsp;
                     <apex:commandButton action="{!Back}" value="Go Back" title="Click on the button to go back." styleClass="slds-button slds-button--neutral slds-button-group" />
                 
               </span>
              <!-- <p class="slds-page-header__title slds-m-right--medium slds-align-middle slds-truncate" title="Create Task" style="color:white;font-size:18px;"><b>Create Task</b> </p>-->
         </div> 
         <br/><br/><br/><br/>
  
  
  <apex:pageMessages ></apex:pageMessages>
  
  <apex:outputPanel rendered="{!roleWraps.Size > 0}">
   <div class="slds-card"  style="margin-left: 16px;margin-right: 16px;">
       <div class="slds-card__body" style="margin-left: 16px;margin-right: 16px;">
               <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                 <thead class="slds-truncate">

                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-5" scope="col"> Action</th>
                                        <th class="slds-size--1-of-5" scope="col">{!$ObjectType.Production_Estimate__c.Fields.Name.Label} </th>
                                        <th class="slds-size--1-of-5" scope="col">{!$ObjectType.Production_Estimate__c.Fields.GL_Code__c.Label} </th>
                                       
                                        <th class="slds-size--1-of-5" scope="col">{!$ObjectType.Production_Estimate__c.Fields.Quantity__c.Label} </th>
                                        <th class="slds-size--1-of-5" scope="col">{!$ObjectType.Production_Estimate__c.Fields.Total_Cost__c.Label}</th>
                                        
                                  
                                    </tr>
                   </thead>
                   <tbody>
                   
                   <apex:repeat value="{!roleWraps}" var="p" rendered="{!roleWraps.Size > 0}">
                                      <tr> 
                                          <td class="slds-size--1-of-5" data-label="Action">
                                          
                                          
                                            <div class="slds-form-element">
                                             <label class="slds-checkbox" >
                                            <apex:inputCheckbox value="{!p.checked}" />
                                            <span class="slds-checkbox--faux"></span>
                                            <span class="slds-form-element__label"></span>
                                          </label>
                                         </div>
                                         
                                               
                                            </td>
                                            
                                            
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Production_Estimate__c.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputField value="{!p.e.Name}"  />
                                                </div> 
                                               
                                            </td>
                                            
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Production_Estimate__c.Fields.GL_Code__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!p.e.GL_Code__c}" />
                                                </div> 
                                               
                                            </td>
                                            
                                           
                                            
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Production_Estimate__c.Fields.Quantity__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!p.e.Quantity__c}" />
                                                </div> 
                                               
                                            </td>
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Production_Estimate__c.Fields.Total_Cost__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!p.e.Total_Cost__c}" />
                                                </div> 
                                               
                                            </td>
                                            
                                       </tr>   
                                    </apex:repeat>
                   
                   
                   
                   </tbody>
                   
                   </table>
                   </div>
                   
              
           </div>  
                      
                   
        </apex:outputPanel>
  
  
  <apex:outputPanel rendered="{!roleWraps.size <= 0}"> 
      
        
       
        <div class="slds-card">
         <p><br/>
        &nbsp;&nbsp;   All Approved Production estimate line items for this vendor have already been added to Purchase Orders.
        </p>     
        <div class="slds-card__footer">
     <!---  <apex:commandButton action="{!Back}" value="Go Back" title="Click on the button to go back." styleClass="slds-button slds-button--neutral slds-button-group"/>--->
       </div>
       </div>
    </apex:outputPanel>
  
  
  <!----
  
    <apex:pageBlock rendered="{!roleWraps.size > 0}">
    
        <apex:pageBlockTable value="{!roleWraps}" var="p" id="ProductsTable">
