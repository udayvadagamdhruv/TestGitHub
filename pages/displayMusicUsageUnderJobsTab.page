                        </table>
                    </apex:actionRegion>
              </apex:column>  -->
              
         <!--     <apex:column headerValue="{!$ObjectType.Music_Usage__c.Fields.Music_Usage_Note__c.Label}" width="10%" style="resize:none">
                    <apex:actionRegion >
                        <table border="0" id="table_music_note">
                            <tr>
                                <td border="0">
                                     <apex:outputField value="{!music.Music_Usage_Note__c}" style="resize:none">
                                           <apex:inlineEditSupport event="ondblClick" hideOnEdit="btnAddMusic" showOnEdit="btnSave,btnCancel"/>                                       
                                     </apex:outputField>
                                </td>
                                
                                <td border="0">
                                     <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Note"/>  
                                </td>
                            </tr>
                        </table>
                    </apex:actionRegion>
              </apex:column>   -->


              <apex:column headerValue="{!$ObjectType.Music_Usage__c.Fields.Music_Usage_Start_Date__c.Label}" width="17%" style="resize:none">
                    <apex:actionRegion >
                        <table border="0" id="table_music_start_date">
                            <tr>
                                <td border="0">
                                     <apex:outputField value="{!music.Music_Usage_Start_Date__c}" style="resize:none">
                                           <apex:inlineEditSupport event="ondblClick" hideOnEdit="btnAddMusic" showOnEdit="btnSave,btnCancel"/>                                       
                                     </apex:outputField>
                                </td>
                                
                                <td border="0">
                                     <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Start Date"/>  
                                </td>
                            </tr>
                        </table>
                    </apex:actionRegion>
              </apex:column>
  
              <apex:column headerValue="{!$ObjectType.Music_Usage__c.Fields.Music_Usage_End_Date__c.Label}" width="16%" style="resize:none">
                    <apex:actionRegion >
                        <table border="0" id="table_music_end_date">
                            <tr>
                                <td border="0">
                                     <apex:outputField value="{!music.Music_Usage_End_Date__c}" style="resize:none">
                                           <apex:inlineEditSupport event="ondblClick" hideOnEdit="btnAddMusic" showOnEdit="btnSave,btnCancel"/>                                       
                                     </apex:outputField>
                                </td>
                                
                                <td border="0">
                                     <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit End Date"/>  
                                </td>
                            </tr>
                        </table>
                    </apex:actionRegion>
              </apex:column>

          </apex:pageBlockTable>
          
          <apex:outputPanel rendered="{!lstMU.size<=0}">
              <b>No records to display</b>
          </apex:outputPanel>
      </apex:pageBlock>
      </apex:outputPanel> 
  </apex:form>
</apex:page>
<!-- End of Page -->