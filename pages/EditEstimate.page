<!-- This page is used to edit Estimate Line Item -->
<apex:page standardController="Estimate_Line_Items__c" tabstyle="Job__c" extensions="EditEstimateExtension">
 <apex:form >
  <apex:sectionHeader title="Estimate Line Item Details"/>
     <apex:pageBlock >
         <apex:pagemessages />
             <apex:pageBlockButtons >
                 <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
                 <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton> 
             </apex:pageBlockButtons>
             
             <apex:pageBlockSection title="Information" columns="2" collapsible="true">
                 <apex:pageBlockSectionItem >
                      <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.Name.Label}"/>
                      <apex:inputField value="{!Estimate_Line_Items__c.Name}" required="true"/>
                 </apex:pageBlockSectionItem>
             
                  <apex:pageBlockSectionItem >
                      <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.Job__c.Label}"/>
                      <apex:outputField value="{!Estimate_Line_Items__c.Job__c}"/>
                 </apex:pageBlockSectionItem>
             
               <apex:pageBlockSectionItem >                  
                  <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Department__c.Label}" for="GLDept" ></apex:outputLabel>
                   <apex:actionRegion >
                   <apex:outputPanel >
                  <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                  <div class="requiredBlock"> </div>
                  <apex:selectList id="GLDName" value="{!GLDName}" size="1" >
                  <apex:actionSupport event="onchange" rerender="selectedDepartment"/>
                  <apex:selectOptions value="{!GLDepartments}"></apex:selectOptions>
                  </apex:selectList>
                  </span>
                  </apex:outputPanel> 
                  </apex:actionRegion>  
                  </apex:pageBlockSectionItem>
                  
          
                          
             <apex:pageBlockSectionItem >
                    <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Code__c.Label}" for="usr"></apex:outputLabel>
                   <apex:actionRegion >
                   <apex:outputPanel >
                     <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                     <div class="requiredBlock"> </div>
                     <apex:selectList value="{!GLCName}" multiselect="false" size="1" id="selectedDepartment">
                      <apex:actionSupport event="onchange" reRender="ST,uc" action="{!getamount}" immediate="false"  rendered="true" >  
                      </apex:actionSupport> 
                     
                       <apex:selectOptions value="{!GLCodes}"/>
                    </apex:selectList>
                    </span>
                  </apex:outputPanel> 
                  </apex:actionRegion>
               </apex:pageBlockSectionItem>  
               
               
                <apex:pageBlockSectionItem id="pbs">
                  <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.Vendor__c.Label}" for="JT"></apex:outputLabel>
                  <apex:outputPanel >
                  <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                  <div class="requiredBlock"> </div>
                  <apex:selectList id="ST" value="{!VName}" size="1" title="Vendors">
                  <apex:selectOptions value="{!Vendors}"></apex:selectOptions>
                  </apex:selectList>
                   </span>
                  </apex:outputPanel>  
              </apex:pageBlockSectionItem> 
             
              <apex:pageBlockSectionItem >
                 <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.Quantity__c.Label}"></apex:outputLabel>
                 <apex:inputField value="{!Estimate_Line_Items__c.Quantity__c}" required="true"/>
             </apex:pageBlockSectionItem> 
                          
             
              
              
                <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.Amount__c.Label}"/>
                  <apex:inputField value="{!Estimate_Line_Items__c.Amount__c}" required="true" id="uc"/>
             </apex:pageBlockSectionItem> 
                             
            
            <apex:pageBlockSectionItem rendered="{!($ObjectType.Estimate_Line_Items__c.fields.Shippment_status__c.accessible)}">
                  <apex:outputLabel value="{!$ObjectType.Estimate_Line_Items__c.Fields.Shippment_status__c.Label}"/>
                  <apex:inputField value="{!Estimate_Line_Items__c.Shippment_status__c}" />
             </apex:pageBlockSectionItem> 
                             
                             

      </apex:pageBlockSection>
    </apex:pageBlock>
 </apex:form>
</apex:page>
<!-- End of Page -->