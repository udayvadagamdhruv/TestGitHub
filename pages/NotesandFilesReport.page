<!-- This page is used to display Work Order. -->
<apex:page standardController="Job__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="NotesandFilesExtension" renderAs="PDF">

<head>
<style type="text/css">
    div.tab
    {
        width:100%;
        border:solid black;
    }
    
    @page
  {
        /* Potrait orientation */
        size:potrait;
    
        /* Put page numbers in the bottom right corner of each
        page in the pdf document. */
        @bottom-right {
        content: "Page " counter(page);
        font-family: sans-serif;
        font-size:8pt;
    }
   
    @bottom-left 
    {
        content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
        background-repeat: no-repeat;
        font-size:8pt;
        font-family: sans-serif;
    }
  }

  body 
  {
       font-family: sans-serif;
       font-size:8pt;
  }
  
  th
  {
      font-size:10pt
      font-style:bold;
      font-family: sans-serif;
  }

    td
  {
        font-size:8pt;
        font-family: sans-serif;
  }
  
  div.footer
  {
        position : running(footer) ;
  }
  /* you can even define custom classes that utilize your static resources */
 </style>
</head>

<body>

     <!---------------------------------------------------- Logo and Title Details ---------------------------------------------------------->

        <table width="100%">
            <tr>
                <td style="width:50%">
                  <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
                  <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>
                </td>
                <td style="width:50%;padding-right:10px;text-align:right;font-size:11px;font-family: sans-serif;">
                     <b> <apex:outputText value="Notes and Files" style="font-size:15px;font-family: sans-serif;"/> </b> <br/><br />
                    
                </td>
             </tr>
             <br/>
    
        </table>
        
      <!---------------------------------------------------- End of Logo and Title Details ---------------------------------------------------------->    
        
        

    
      <!---------------------------------------------------- Details ---------------------------------------------------------->

    <table width="100%" style="padding-top:5px;font-family: sans-serif;">
    
        <tr>
          <td align="left">
               <hr color="black" />
          </td>
        </tr>
        
        <tr>
          <td>
            <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                <tr style="page-break-inside: avoid;">
                      <td width = "20%">
                           <b> <apex:outputText value="DETAILS" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/>  </b>
                      </td>
                     
                </tr>
            </table>
           </td>
        </tr>
        
        
        
        <tr width="100%" style="font-size:10px;">
           <td width="100%" align="left" style="padding-left:20px;"><br/>
               <table width="100%" align="left"  >
               
                     
                    <tr >
                        <td  width="20%">
                          <apex:outputLabel value="Campaign" style="font-weight: bold;"/>
                        </td>
                        <td  width="30%">
                          <apex:outputfield value="{!Job__c.Campaign__r.Name}"/> 
                        </td>
                        
                        <td width="20%">
                          <apex:outputLabel value="Client" style="font-weight: bold;"/>
                        </td>
                        <td width="30%">
                          <apex:outputtext value="{!Job__c.JS_Client__r.Name}"/> 
                        </td>
                         
                    </tr>
                     
                    <tr >
                    
                        <td  width="20%">
                          <apex:outputLabel value="{!$ObjectType.Job__c.Fields.name.Label}" style="font-weight: bold;"/>
                        </td>
                        <td  width="30%">
                          <apex:outputfield value="{!Job__c.name}"/> 
                        </td>
                        <td width="20%">
                          <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="font-weight: bold;"/>
                        </td>
                        <td width="30%">
                          <apex:outputfield value="{!Job__c.Job_Auto_Number__c}"/> 
                        </td>
                        
                         
                    </tr>
                    
                   <tr>
                        <td width="20%">
                          <apex:outputLabel value="Media Type" style="font-weight: bold;"/>
                        </td>
                        <td width="30%">
                          <apex:outputfield value="{!Job__c.Media_Types__r.Name}"/> 
                        </td>
                        
                        <td width="20%">
                          <apex:outputLabel value="Schedule Template" style="font-weight: bold;"/>
                        </td>
                        <td width="30%">
                          <apex:outputfield value="{!Job__c.Schedule_Template__r.Name}"/> 
                        </td>
                      
                         
                    </tr>
                   
                    
               
               </table>
           </td>
        </tr>
        
        
     </table>
     
     
     
      <!---------------------------------------------------- End of Details ---------------------------------------------------------->
      
      
      <!---------------------------------------------------- Notes ---------------------------------------------------------->
      
            <table width="100%" style="page-break-inside: avoid;font-family: sans-serif;">
            
               <tr width="100%">
                  <td align="left">
                       <hr color="black" width="100%"/>
                  </td>
                </tr>
                
                <tr width="100%">
                  <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                              <td width="100%">
                                   <b> <apex:outputText value="Notes" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/>  </b>
                              </td>
                        </tr>
                    </table>
                   </td>
                </tr> <br/>
                
                
                <table width="100%" style="font-family: sans-serif; !important;">
                <tr width="100%" style="font-size:10px;">
             
                    <th><b>{!$ObjectType.Note.Fields.Title.Label}</b></th>
                           
                    <th><b>{!$ObjectType.Note.Fields.Body.Label}</b></th>
                    
               </tr> 
                
                 <tr width="100%">
             
                    <td colspan="2">
                        <hr/>
                    </td>
                    
               </tr> 
                
                <tr width="100%" style="font-size:10px;">
                    <td width="100%" colspan="2">
                    
                       <apex:repeat value="{!MyNote}" var="MN" rendered="{!MyNote.Size>0}">
                             <tr width="100%">
                                 <td valign="top" width="30%" style="font-size:10px;">
                                     <apex:outputLabel value="{!MN.Title}" />
                                 </td>
                                  <td width="70%" style="font-size:10px;">
                                 <apex:outputField value="{!MN.Body}"/>
                                 </td>
                             </tr>
                             <br/>
                             
                        </apex:repeat>
                    
                    </td>
                </tr>
                </table><br/>
                
            </table>  
            
            <!---------------------------------------------------- End of Notes ---------------------------------------------------------->
            
            <!---------------------------------------------------- Attachments ---------------------------------------------------------->
            
            <table width="100%" style="page-break-inside: avoid;font-family: sans-serif;">
            
               <tr width="100%">
                  <td align="left">
                       <hr color="black" width="100%"/>
                  </td>
                </tr>
                
                <tr width="100%">
                  <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                              <td width="100%">
                                   <b> <apex:outputText value="Attachments" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/>  </b>
                              </td>
                        </tr><br/>
                    </table>
                   </td>
                </tr> 
                
                
                <table width="100%" style="font-family: sans-serif; !important;">
                <tr width="100%" style="font-size:10px;font-family: sans-serif !important;">
             
                    <th width="20%"><b>{!$ObjectType.Attachment.Fields.Name.Label}</b></th>
                           
                    <th width="50%" ><b><center>Image</center></b></th>
                     <th width="10%"><b></b></th>
                     <th width="20%"><b>Upload date</b></th>
                    
               </tr> 
                
                 <tr width="100%">
             
                    <td colspan="4">
                        <hr/>
                    </td>
                    
               </tr> 
                
                <tr width="100%" style="font-size:10px;font-family: sans-serif; !important;">
                    <td width="100%" colspan="2">
                    
                       <apex:repeat value="{!imagesAttach}" var="MF" rendered="{!imagesAttach.Size>0}">
                             <tr width="100%">
                                 <td width="20%" style="font-size:10px;">
                                     <apex:outputLabel value="{!MF.Name}" />
                                 </td>
                                 
                                 <td width="50%"  style="font-size:10px;">
                                   <!-- <div style="height: 80px; overflow:hidden;">-->
                                    <img src="/servlet/servlet.FileDownload?file={!MF.Id}" title="{!MF.Name}" width="300px" />
                                    
                                 </td>
                                    
                                 <td width="10%" style="font-size:10px;">
                                    <apex:outputLink value="/servlet/servlet.FileDownload?file={!MF.Id}" id="theLink" target="_self" >Click Here</apex:outputLink>
                                 </td>                              
                                 
                                 <td width="20%" style="font-size:10px;">
                                     <apex:outputLabel value="{!MF.createddate}" />
                                 </td>
                             </tr>
                        </apex:repeat>
                        
                        
                        <apex:repeat value="{!docsAttach}" var="MF" rendered="{!docsAttach.Size>0}">
                             <tr width="100%">
                                 <td width="20%" style="font-size:10px;">
                                     <apex:outputLabel value="{!MF.Name}" />
                                 </td>
                                 
                                 <td width="50%"  style="font-size:10px;">
                                       <apex:image value="{!$Resource.Textimage}"/>   
                                      
                                 </td>
                                    
                                 <td width="10%" style="font-size:10px;">
                                    <apex:outputLink value="/servlet/servlet.FileDownload?file={!MF.Id}" id="theLink" target="_self" >Click Here</apex:outputLink>
                                 </td>                              
                                 
                                 <td width="20%" style="font-size:10px;">
                                     <apex:outputLabel value="{!MF.createddate}" />
                                 </td>
                             </tr>
                        </apex:repeat>
                        
                        
                    
                    </td>
                </tr>
                </table>
                
            </table>  <br/>
          
       
       
       
        
    </body>
</apex:page>
<!-- End of Page -->