<apex:page Controller="DisplayClientInvoiceLIController" >

<head>
<style>
#table_id td
        {
            border:0px;
        }
</style>

</head>
 <apex:form id="fromInvLineItems" >
  <apex:pageBlock >
       <span style="padding-left:450px;margin:5px;padding-bottom:20px;">
       <apex:commandButton action="{!add_Eli}" value="Add Estimate Line Items" id="btn1" rendered="{!(Not(ShowProductionEstimate))}"/> 
       <apex:commandButton action="{!add_PEli}" value="Add Production Estimate Line Items" id="btn2"   rendered="{!(ShowProductionEstimate)}"/> 
       <apex:commandButton value="Save" action="{!save}" id="saveButton" reRender="fromInvLineItems" style="display: none;"/>  
       <apex:commandButton value="Cancel" id="cancelButton" reRender="fromInvLineItems" immediate="true" style="display: none;"/> 
       </span>
       
 
  <br/> <br/> 
  
  
   <apex:repeat value="{!MapPE}" var="mpe">
      
      
        <apex:pageBlockSection title="{!mpe}" columns="1">
  
  
     <apex:pageBlockTable value="{!MapPE[mpe]}" var="CILItem" rendered="{!CILI.Size>0}">
         <apex:column headerValue="Action" width="10%">
              <apex:commandButton value="Delete" action="{!deleteCILI}" onclick="if(!confirm('Are you sure?')){return false;}" reRender="fromInvLineItems" status="statusforInvLI">
                  <apex:param name="param2" value="{!CILItem.id}" assignTo="{!strCILI}"></apex:param>
              </apex:commandButton>
          </apex:column>
          
         
        
        <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Estimate_Line_Item__c.Label}" rendered="{!(Not(ShowProductionEstimate))}">
              <apex:outputfield value="{!CILItem.Estimate_Line_Item__c}"/>
          </apex:column>
          
         <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Production_Estimate__c.Label}" rendered="{!(ShowProductionEstimate)}">
              <apex:outputfield value="{!CILItem.Production_Estimate__c}"/>
          </apex:column> 
          
           <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.GL_Code__c.Label}">
              <apex:outputfield value="{!CILItem.GL_Code__c}"/>
          </apex:column> 
          <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.GL_Code_No__c.Label}">
              <apex:outputfield value="{!CILItem.GL_Code_No__c}"/>
          </apex:column>
          
           <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Unit_Type__c.Label}">
              <apex:outputfield value="{!CILItem.Unit_Type__c}"/>
          </apex:column> 
          
           
          
          
          <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Quantity__c.Label}">
              <table border="0" id="table_id">
            <tr>
               <td border="0">
                  <apex:outputfield value="{!CILItem.Quantity__c}">

                  <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2,btn6" />
                  </apex:outputfield> </td>
               <td> 

                  <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Quantity" />  
               </td>
           </tr>
           </table>
          </apex:column> 
          
           <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Billable_Amount__c.Label}">
              <table border="0" id="table_id">
            <tr>
               <td border="0">
                  <apex:outputfield value="{!CILItem.Billable_Amount__c}">

                  <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2,btn6" />
                  </apex:outputfield> </td>
               <td> 

                  <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Billable Amount" />  
               </td>
           </tr>
           </table>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Equipment_Type__c.Label}">
              <apex:outputfield value="{!CILItem.Equipment_Type__c}"/>
          </apex:column> 
          
          
         
          
         <apex:column headerValue="{!$ObjectType.Client_Invoice_Line_Item__c.Fields.Tax__c.Label}">
              <table border="0" id="table_id">
            <tr>
               <td border="0">
                  <apex:outputfield value="{!CILItem.Tax__c}">

                  <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2,btn6" />
                  </apex:outputfield> </td>
               <td> 

                  <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Tax" />  
               </td>
           </tr>
           </table>
          </apex:column>   
     
     </apex:pageBlockTable>
     </apex:pageblocksection>
     </apex:repeat>
     
     
     <apex:actionStatus id="statusforInvLI">
    <apex:facet name="start">
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.25; z-index: 1000; background-color: black;">
        &nbsp;
    </div>
    <div style="position: fixed; left: 0; top: 0; bottom: 0; right: 0; z-index: 1001; margin: 15% 50%">
        <div style="display: inline-block; padding: 2px; background-color: #fff; width: 125px;">
            <img src="/img/loading.gif" style="float: left; margin: 8px;" />
            <span style="display: inline-block; padding: 10px 0px;">Please Wait...</span>
        </div>
    </div>
    </apex:facet>
</apex:actionStatus>
     
     
     
        <apex:pageBlockSection rendered="{!CILI.size <= 0}">
           <apex:pageBlockSectionItem >
               <b>No records to display</b>
           </apex:pageBlockSectionItem>              
        </apex:pageBlockSection> 
      </apex:pageBlock>
 </apex:form>





</apex:page>