<apex:page controller="DisplayInvoiceNewExtension" standardStylesheets="true" showHeader="false" docType="html-5.0" applyHtmlTag="false" applyBodyTag="false">
<apex:slds />
<apex:includeScript value="{!$Resource.Securityfilter}"/>



    <style>
    
    .icon1
           {
              color:darkgrey;
           }
      
           .icon1:hover
           {
              color:black;
           }
        #table_id td
        {
            border:0px;
        }
        #table_dd td
        {
            border:0px;
        }
        #table_s td
        {
            border:0px;
        }
         .hd
             {
             text-align:right;
             padding-right:20px!important;
             }
             
         .slds-scope .slds-card__body {
            margin-bottom: 0rem;
       }    
       .slds .slds-card__body {
            padding: 0px 0;
      }
       .slds .slds-dropdown-trigger .slds-dropdown
           {
                 margin-left: 37px;
           
    
           }
           
           
        @media (max-width: 48em){
               
     .slds .slds-max-medium-table--stacked-horizontal tr {
     display: block;
     border-top:1px ; 
     text-transform: capitalize;
   }   

 }
         .dropdownmenuicon:hover{
            background-color:#16325c !important;
            } 
             .dropdownmenuicon:hover #childmenu {
              color:white !important;
             } 
                  
           
  
    
      
             
    </style>
    
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <head>
     <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <meta name="viewport" content="width=device-width, initial-scale=1"/>
           <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
          <link href="{!URLFOR($Resource.JobPage,'JobPage/MaterialIcons.css')}" rel="stylesheet"/>
         <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
       
    </head>
     <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
     
    <body>
<!--Added this code for edit and delete button. start -->

   <div class="slds">

   <apex:form html-novalidate="novalidate" >

       <apex:actionFunction action="{!deleteRec}" name="deleteILI" reRender="pgb,delete" status="status">
           <apex:param name="di1" assignTo="{!myClient}" value=""/>
       </apex:actionFunction>

       <apex:actionFunction action="{!editRec}" name="editILI" reRender="pgb1" >
           <apex:param name="di2" assignTo="{!myClient}" value=""/>
       </apex:actionFunction>
       
    <script type="text/javascript">
    function statusLI(id1){
//        alert('button pressed..');
        var ist = '{!JSENCODE(HTMLENCODE(inSt))}';
//        alert('Ivoice Line Item ID : '+id1);
//        alert('Invoice Status : '+ ist);
        if(ist == "Paid"){
            alert("You cannot Delete this Invoice Line Item as status of the Invoice is Paid.");
        }
        else{
            if(confirm('The status of Invoice is "'+ist+'". Are you sure want to delete this Invoice Line Item ?')) {
//            alert("You can delete record");
             
            deleteILI(id1);
//            alert('af called');
            }
        }
    } 

    function EditLI(id2){
//        alert('button pressed..');
//       alert('Ivoice Line Item ID : '+id2);
//        alert('Invoice Status : '+ ist);
  //      if({!JSENCODE(HTMLENCODE(poId))!= NULL}){
     //       alert("You cannot edit this Invoice Line Item as it is created from PO.");
   //     }
      //  else
         if({!JSENCODE(HTMLENCODE(inSt)) == 'Paid'}){
            alert("You cannot edit this Invoice Line Item as status of the Invoice is Paid.");
        }
        else{
//            alert("You can Edit record");
                editILI(id2);
//            alert('af called');  
        }
    } 

    </script>
<!--end added code -->


   

      
           <div align="center">
                           <apex:commandButton action="{!add_ILI}" value="Add Line Items" id="btn1"  rendered="{!poId==NULL}"  styleClass="slds-button slds-button--neutral"/> 
                           <apex:commandButton action="{!add_ILI_from_poli}" value="Add Line Items" id="btn6"  rendered="{!poId!=NULL}"  styleClass="slds-button slds-button--neutral"/> 
                           <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display: none;"  styleClass="slds-button slds-button--neutral"/>  
                           <apex:commandButton value="Cancel" id="cancelButton" action="{!cancelme}" style="display: none;" styleClass="slds-button slds-button--neutral"/> 
                </div>
          <br/>
      
    
      
      
          
          <apex:outputPanel id="pgb"> 
                     <apex:outputPanel rendered="{!ILI.Size > 0}"> 
                     
                     <div class="slds-card" style="display:{!IF(ILI.Size> 0,'block','none')}">
                               <div class="slds-card__body" >
                     
           <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                       
            
                             <thead>
                                <tr class="slds-text-title">
                                    
                                      <th class="slds-size--1-of-9" scope="col">Action</th>
                            
                                      <th class="slds-size--1-of-9" scope="col" style="display:{!IF( AND(Not(ShowProductionEstimate),poId!=NULL),'block','none')}" >{!$ObjectType.Invoice_Line_Item__c.Fields.Estimate_Line_Item__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col" style="display:{!IF( AND(ShowProductionEstimate,poId!=NULL),'block','none')}" >{!$ObjectType.Invoice_Line_Item__c.Fields.Production_Estimate__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Department__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Code_No__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Code__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Invoice_Line_Item__c.Fields.Unit_Type__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Invoice_Line_Item__c.Fields.Quantity__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Invoice_Line_Item__c.Fields.Amount__c.Label}</th>
                                      
                                      
                                    </tr>
                                 </thead>
                                 
                                 <tbody>
                                 
                              <apex:repeat value="{!ILI}" var="item" rendered="{!ILI.Size > 0}" id="id1">
                                     <tr class="slds-hint-parent">
                                       
                                    <!----- -----------------------
                                     <td class="slds-size--1-of-9" data-label="Action">
                                            <div class="slds-wrap ">
                                                
                                                <apex:commandButton onClick="statusLI('{!item.ID}')" value="Delete" reRender="pgb"  styleClass="slds-button slds-button--neutral"/>
                                                <apex:commandButton onClick="EditLI('{!item.ID}')" value="Edit" reRender="pgb"  styleClass="slds-button slds-button--neutral" />
                                                
                                            </div>
                                          </td>
                                          ----------------------------------->
                                          <td class="slds-size--1-of-9" data-label="Action">
                                              <div class="slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open ">
                                                     &nbsp;&nbsp;  
                                                         <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small slds-shrink-none dropdownmenuicon ">
                                                                    <i  id="childmenu" style="color:#9faab5;font-size:15px;margin:2px 5px;" class="fa">&#xf0d7;</i>
                                                             </div>
                                                        
                                                        
                                             
                                                        <div class="slds-dropdown slds-dropdown_left">
                                                        
                                                           <ul class="slds-dropdown__list" role="menu">
                                                             
                                                               
                                                               <li class="slds-dropdown__item" role="presentation">
                                                                    
                                                                     
                                                                      <a href="javascript:EditLI('{!item.ID}');" role="menuitem" >
                                                                            <span class="slds-truncate" title="Edit">Edit</span>
                                                                            
                                                                           <!---  <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#edit')}"></use>
                                                                            </svg>
                                                                            ---->
                                                                             &nbsp; &nbsp;&nbsp; &nbsp;&nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">edit</i>
                                                                        </a>
                                                                  
                                                                                                                               
                                                                </li>
                                                                
                                                                <li class="slds-dropdown__item" role="presentation">
                                                                    
                                                                     
                                                                      <a href="javascript:statusLI('{!item.ID}');" role="menuitem"  >
                                                                            <span class="slds-truncate" title="Delete">Delete</span>
                                                                            
                                                                          <!---   <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#delete')}"></use>
                                                                            </svg>
                                                                            ---->
                                                                             &nbsp; &nbsp;&nbsp; &nbsp;&nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">delete</i>
                                                                        </a>
                                                                     
                                                                                                                               
                                                                </li>
                                                              
                                                                 
                                                            </ul>
                                                      </div> 
                                               </div>
                                          
                                          </td>
                                          
                                          
                                          <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.Estimate_Line_Item__c.Label}" style="display:{!IF( AND(Not(ShowProductionEstimate),poId!=NULL),'block','none')}" >
                                             <div class="slds-wrap">
                                                  <apex:outputfield value="{!item.Estimate_Line_Item__r.Name}" rendered="{!AND(Not(ShowProductionEstimate),poId!=NULL)}"/>
                                              </div>
                                          </td>
                                 
                                       <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.Production_Estimate__c.Label}" style="display:{!IF(AND((ShowProductionEstimate),poId!=NULL),'block','none')}" >
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.Production_Estimate__r.Name}" rendered="{!AND(ShowProductionEstimate,poId!=NULL)}" />
                                              </div>
                                          </td>
                                       
                                          
                                          
                                 
                                 
                                       <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Department__c.Label}">
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.GL_Department__c}"/>
                                              </div>
                                          </td>
                                 
                                      <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Code_No__c.Label}">
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.GL_Code_No__c}"/>
                                              </div>
                                          </td>
                                          
                                          <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Code__c.Label}">
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.GL_Code__c}"/>
                                              </div>
                                          </td>
                                          
                                           <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.Unit_Type__c.Label}">
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.Unit_Type__c}"/>
                                              </div>
                                          </td>
                                          
                                           <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.Quantity__c.Label}">
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.Quantity__c}">
                                                <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn6" />
                                                   <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                      </apex:outputfield>
                                               
                                               
                                              </div>
                                          </td>
                                          
                                          
                                              <td class="slds-size--1-of-9" data-label="{!$ObjectType.Invoice_Line_Item__c.Fields.Amount__c.Label}">
                                             <div class="slds-wrap">
                                               <apex:outputfield value="{!item.Amount__c}">
                                                <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn6" />
                                                  <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                      </apex:outputfield>
                                               
                                               
                                              </div>
                                          </td>
                                 
                                     </tr>
                                    </apex:repeat>
                                   
                                 </tbody>
                               
                                 </table>
                              </div>
                            </div>   
                                         
                           </apex:outputPanel>
                          </apex:outputPanel>
                           
                               
       
      
               <apex:outputPanel id="delete"> 
                 <apex:outputPanel rendered="{!ILI.size==0}">
                        <p>  No records to display </p>
                </apex:outputPanel> 
                 </apex:outputPanel> 
       
      
       <apex:outputpanel >
       
        <apex:actionStatus id="status" >
                   <apex:facet name="start">
                      <div class="slds-spinner_container" style="z-index: 99999;position: fixed;">
                         <div role="status" class="slds-spinner slds-spinner--brand slds-spinner--medium">
                           <span class="slds-assistive-text">Loading</span>
                           <div class="slds-spinner__dot-a"></div>
                           <div class="slds-spinner__dot-b"></div>
                         </div></div>
                    </apex:facet>
                </apex:actionStatus>
        
    </apex:outputpanel>
       
    
    </apex:form>
 </div>
  </body>

</html>
</apex:page>