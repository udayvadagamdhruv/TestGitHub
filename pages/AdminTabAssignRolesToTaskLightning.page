                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Job_Task_Role__c.Fields.Name.Label}</th>
                                    
                                      
                                      
                                    </tr>
                                 </thead>
                                 <tbody>
                                     
                                 <apex:repeat value="{!lstSTR}" var="jt" rendered="{!lstSTR.Size > 0}">
                                     
                                     <tr class="slds-hint-parent">
                                          
                                           <td class="slds-size--1-of-9" data-label="{!$ObjectType.Job_Task_Role__c.Fields.Name.Label}">
                                             <div class="slds-warp">
                                                 <apex:outputfield value="{!jt.Name}">
                                                 </apex:outputfield>
                                              </div>
                                          </td>
                                          
                                        </tr>
                                        </apex:repeat>
                              </tbody>
                            </table>
                          
                           <div align="center">
                           </div>
                          
                           
                    </apex:outputPanel> 
               
                   </div>
       
              </div>            
            
             </apex:outputPanel>
             </apex:outputPanel> 
             
               <apex:actionStatus id="LoadingStatus111" >
