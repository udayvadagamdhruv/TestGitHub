    <apex:pageBlockSection rendered="{!purchaseorder1.Size == 0}">
     <apex:pageBlockSectionItem >
          <b>No records to display</b>
     </apex:pageBlockSectionItem>
    </apex:pageBlockSection>
   </apex:pageBlock>
  </apex:form> 
</apex:page>
