<apex:page controller="DisplayPOunderjobtabextension" id="frm">
<head>
<style>
#table_id td
{
    border:0px;
}
#table_dd td
{
border:0px;
}
#table_s td
{
border:0px;
}
 .hd
  {
  text-align:right;
  padding-right:20px!important;
  }
</style>
</head>
  <apex:form id="pb11"> 
  <apex:pageMessages id="pagemsgId4"></apex:pageMessages>
    
   <apex:pageBlock tabStyle="Purchase_Order__c" id="pb" title="Purchase Orders">
      
    <apex:pageBlockButtons location="top">
     <apex:commandButton action="{!CreatePO}" value="New Purchase Order" id="btn1"/>   
   
     <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display: none;"/>  
     <apex:commandButton value="Cancel" id="cancelButton" action="{!cancelme}" style="display: none;" reRender="pb1"/> 
      </apex:pageBlockButtons>
      
         <apex:actionStatus id="mark">
             <apex:facet name="start">
                <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
             </apex:facet>
         </apex:actionStatus> 
      
    <div>
    <apex:pageBlockTable value="{!purchaseorder1}" var="po" rendered="{!purchaseorder1.Size > 0}" id="abc">
    
     
   
    
    <apex:column headerValue="Action">

       <!--  <apex:commandButton value="Approve" action="/apex/ApproveVendorQuote?id={!vquote.id}" onclick="return confirm('Are you sure?You are going to approve this Quote.');"/> -->
        
        
       <!--  <apex:commandLink action="/apex/CreateInvoiceFromPO?id={!po.id}"> 

         <apex:commandButton value="Create Invoice" />
         
         rendered="(!po.Status__c == Sent)"
      
          </apex:commandLink> -->
        
       <!--  <apex:commandButton value="Log Invoice" action="/apex/CreateInvoiceFromPO?id={!po.id}" rendered="{!po.Status__c = 'Sent' && (po.Invoice_Created__c = 'No' || po.Invoice_Created__c = 'Partially')}"/>  -->

        <apex:commandButton value="Log Invoice" action="{!CreateInvoice}" rendered="{!po.Status__c = 'Sent' && (po.Invoice_Created__c = 'No' || po.Invoice_Created__c = 'Partially')}" reRender="Hiddenblock1">
          <apex:param name="param1" value="{!po.id}" assignTo="{!strID}"> </apex:param>
         </apex:commandButton>

             <apex:commandButton value="Log Invoice" onclick="alert('You can not create Invoice as its Invoice is created or its Status is Sent');" rendered="{!po.Invoice_Created__c = 'Created' || (po.Status__c = 'Open' || po.Status__c = 'Cancelled' || po.Status__c = 'Pending' || po.Status__c = null)}" reRender="pb1"/>  
             <apex:commandButton value="Delete" action="{!del}" reRender="hiddenBlock1,pb11" status="mark" rendered="{!po.Invoice_Created__c = 'No'}" onclick="if(!confirm('Are you sure?')){return false;}" >
                 <apex:param name="param1" value="{!po.Id}" assignTo="{!poid}"> </apex:param>
             </apex:commandButton> 
             <apex:commandButton value="Delete" title="Delete PO Line Item" onclick="alert('You can not Delete this PO Line Item because its Invoice is fully or partially created' );" rendered="{!po.Invoice_Created__c != 'No'}" reRender="pb1"/>
         </apex:column> 
    
   
      
      <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Name.Label}">
       <apex:outputLink tabindex="tab1" value="/apex/PODetailpage?id={!po.Id}">{!po.Name}</apex:outputlink>
      </apex:column> 
      
       <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Invoice_Created__c.Label}"> 
            <apex:outputField value="{!po.Invoice_Created__c}"/> 
       </apex:column>
      
       <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Vendor__c.Label}">
            <apex:outputField value="{!po.Vendor__c}"/>
       </apex:column>
          
       <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Issue_Date__c.Label}">
           <table border="0" id="table_id">
           <tr>
               <td border="0">
                  <apex:outputfield value="{!po.Issue_Date__c}">
                  <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,poreport" rendered="{!po.Status__c != 'Sent'}"/></apex:outputfield> </td>
                 <td> <apex:image url="{!$Resource.Plus}" width="9" height="9" rendered="{!po.Status__c != 'Sent'}" title="Edit Issue date"/>  </td>
          </tr>
          </table>
          </apex:column>
           
      
       <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Due_Date__c.Label}">
       <table border="0" id="table_dd">
           <tr>
           <td border="0">
               <apex:outputField value="{!po.Due_Date__c}">
               <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,poreport" rendered="{!po.Status__c != 'Sent'}"/></apex:outputfield> </td>
           <td> <apex:image url="{!$Resource.Plus}" width="9" height="9" rendered="{!po.Status__c != 'Sent'}" title="Edit Due Date"/>  </td>
            </tr>
          </table>
       </apex:column>
      
       <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Status__c.Label}">
        <table border="0" id="table_s">
           <tr>
           <td border="0">
               <apex:outputField value="{!po.Status__c}">
               <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,poreport" rendered="{!po.Status__c != 'Sent'}"/></apex:outputfield> </td>
            <td> <apex:image url="{!$Resource.Plus}" width="9" height="9" rendered="{!po.Status__c != 'Sent'}" title="Edit Status"/>  </td>
            </tr>
          </table>
      </apex:column>   
      
      <apex:column headerValue="{!$ObjectType.Purchase_Order__c.Fields.Total_Amount__c.Label}" style="text-align:right;padding-right:20px;" headerClass="hd">
       <apex:outputField value="{!po.Total_Amount__c}"/>
      </apex:column>
      
    </apex:pageBlockTable>
    <br/>
    
  <div style="float:right;padding-right:20px;font-size:1.10em;font-style:normal;font-family: 'Calibri';font-weight:bold">
    <apex:outputPanel rendered="{!purchaseorder1.Size > 0}">
            <apex:outputLabel value="PO Total    " style="font-style:italic;" /> 
            <apex:outputText value="{0,Number, $###,###,###.00}">
               &nbsp;:&nbsp;&nbsp;<apex:param value="{!sumCash}"/>
            </apex:outputText>
        </apex:outputPanel>
      </div> 
      </div>
      <br/>
 
 
