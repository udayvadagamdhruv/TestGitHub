                                                    <table style="width:100%;display:{!taskroleWrap.size != 0};" class="slds-table slds-table--bordered">
                                                        <tr>
                                                            <td width="2%" valign="top" rowspan="4">{!FLOOR(count)}.</td>
                                                            <td width="88%" colspan="2" style="text-align:left;padding-left:5px;word-wrap: break-word;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink"> 
                                                            <b> 
                                                                   <apex:outputLink tabindex="tab1" style="color:black;text-decoration: none;" value="/{!lst.jobTaskrole.Job_Task__c}" target="_top" rendered="{!lst.color=='Black'}">{!lst.jobTaskrole.Job_Task__r.Name} </apex:outputLink> 
                                                                     <apex:outputLink tabindex="tab1" style="color:red;text-decoration: none;" value="/{!lst.jobTaskrole.Job_Task__c}" target="_top" rendered="{!lst.color=='Red'}" >{!lst.jobTaskrole.Job_Task__r.Name}</apex:outputLink> 
                                                                     <apex:outputLink tabindex="tab1" style="color:green;text-decoration: none;" value="/{!lst.jobTaskrole.Job_Task__c}" target="_top" rendered="{!lst.color=='Green'}" >{!lst.jobTaskrole.Job_Task__r.Name}</apex:outputLink> &nbsp;&nbsp;</b>
                                                            </td>
                                                            <td width="10%">
                                                               
                                                                <div style="float:right;">
                                                                    <div class="slds-dropdown-trigger">
                                                                        <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small btn btn-primary dropdown-toggle " id="menu1" type="button" data-toggle="dropdown"> <span class="caret"></span>
                                                                        </div>
                                                                        <ul class="dropdown-menu slds-dropdown slds-dropdown--right slds-dropdown__list" role="menu" aria-labelledby="menu1">
                                                                            <li style="vertical-align: middle;" role="presentation" class="slds-dropdown__item">
                                                                                <apex:commandLink value="Task Done" action="{!assignMarkedDone1}" reRender="pB" oncomplete="window.location.reload();">
                                                                                    <apex:param name="param5" value="{!lst.jobTaskrole.Job_Task__r.Id}" assignTo="{!strJTID}"></apex:param>&nbsp; &nbsp;<i valign="middle" class="material-icons" style="font-size:24px;color:black">check_circle</i> 
                                                                                </apex:commandLink>
                                                                            </li>
                                                                            <li style="vertical-align: middle;" role="presentation" class="slds-dropdown__item">
                                                                                <apex:commandlink value="TimeSheet Entry" action="{!TsEntry}" reRender="pB" rendered="{!($ObjectType.Timesheet_Entries__c.accessible) && (ShowTsEntryButton)}">
                                                                                    <apex:param name="param6" value="{!lst.jobTaskrole.Job_Task__r.Id}" assignTo="{!strJTID2}"></apex:param>&nbsp; &nbsp; <i class="material-icons" style="font-size:24px;color:black">av_timer</i>
                                                                                </apex:commandlink>
                                                                            </li>
                                                                        </ul>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td style="width:20%;text-align:left;padding-left:5px;word-wrap: break-word;color:black !important;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink" valign="top"><b>{!$ObjectType.Job_Task__c.Fields.Revised_Due_Date__c.Label}</b>
                                                            </td>
                                                            <td style="width:80%;text-align:left;padding-left:15px;word-wrap: break-word;color:black !important;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">
                                                                <apex:outputField value="{!lst.jobTaskrole.Job_Task__r.Revised_Due_Date__c}" />
                                                            </td>
                                                        </tr>
                                                        <tr>
                                                            <td style="width:20%;text-align:left;padding-left:5px;word-wrap: break-word;color:black !important;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink" valign="top"><b>Job Name</b>
                                                            </td>
                                                            <td style="width:80%;text-align:left;padding-left:15px;word-wrap: break-word;color:black !important;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">{!lst.jobTaskrole.Job_Task__r.Job__r.Name} - #{!lst.jobTaskrole.Job_Task__r.Job__r.Job_Auto_Number__c}</td>
                                                        </tr>
                                                    </table>
                                                    ----->
                                                    <apex:variable var="count" value="{!count+ 1}" />
                                                    </apex:repeat>
                                                              <div class="slds-col--padded slds-size--2-of-2 slds-medium-size--6-of-6 slds-large-size--6-of-12">
                                                               </div>
                                                               </div>  
                                                            <br/>
                                            </div>
                                        </aside>
                                    </div>
                                </main>
                            </div>
                            <br/>
                        </apex:outputPanel>
                    </apex:outputPanel>
                    
                    
                </apex:pageBlock>
            </apex:form>
        </div>
    </body>

    </html>
</apex:page>