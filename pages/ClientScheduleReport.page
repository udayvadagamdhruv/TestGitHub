<!-- This page is used to display Schedule Report. -->
<apex:page standardController="Job__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="ClientScheduleReportExtension" renderAs="PDF">
<head>
<style type="text/css">
    div.tab
    {
        width:100%;
        border:solid black;
    }
    
    @page
  {
        /* Landscape orientation */
        size:landscape;
    
        /* Put page numbers in the bottom right corner of each
        page in the pdf document. */
        @bottom-right {
        content: "Page " counter(page);
        font-family: sans-serif;
        font-size:8pt;
    }
   
    @bottom-left 
    {
        content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
        background-repeat: no-repeat;
        font-size:8pt;
        font-family: sans-serif;
    }
  }

  body 
  {
       font-family: sans-serif;
       font-size:8pt;
  }
  
  th
  {
      font-size:10pt
      font-style:bold;
      font-family: sans-serif;
  }

    td
  {
        font-size:8pt;
        font-family: sans-serif;
  }
  
  div.footer
  {
        position : running(footer) ;
  }

  /* you can even define custom classes that utilize your static resources */
 </style>
</head>

<body>
        <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
        <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>
        
        <div style="float:right;padding-right:5px;font-size:15px;font-style:normal;font-family: sans-serif;;font-weight:bold">
            Schedule
        </div>
        
    <br/><br/>

    <table width="100%">
    
        <tr width="100%">
          <td align="left" colspan="2">
               <hr color="black" />
          </td>
        </tr>
        
        <tr width="100%">
          <td  colspan="2">
            <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                <tr style="page-break-inside: avoid;">
                      <td width = "20%">
                           <b> <apex:outputText value="DETAILS" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/>  </b>
                      </td>
                     
                </tr>
            </table>
           </td>
        </tr>
           
         <tr width="100%">
           <td width="100%" align="left" style="padding-left:20px;"><br/>
               <table width="100%" align="left" >
                    
                    
                      <tr width="100%">
                        <td width="25%">
                          <apex:outputLabel value="{!$ObjectType.Job__c.Fields.JS_Client__c.Label}" style="font-weight: bold;"/>
                        </td>
                        <td width="25%">
                          <apex:outputfield value="{!Job__c.JS_Client__r.name}"/> 
                        </td>
                         <td  width="25%">
                          <apex:outputLabel value="{!$ObjectType.Job__c.Fields.name.Label}" style="font-weight: bold;"/>
                        </td>
                        <td width="25%">
                          <apex:outputfield value="{!Job__c.name}"/> 
                        </td>
                        
                    </tr>
                    
                    <tr>
                        <td  width="25%">
                          <apex:outputLabel value="{!$ObjectType.Job__c.Fields.JS_Client_Contact__c.Label}" style="font-weight: bold;"/>
                        </td>
                        <td  width="25%">
                          <apex:outputfield value="{!Job__c.JS_Client_Contact__r.name}"/> 
                        </td>
                         <td width="25%">
                          <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="font-weight: bold;"/>
                        </td>
                        <td width="25%">
                          <apex:outputfield value="{!Job__c.Job_Auto_Number__c}"/> 
                        </td>
                        
                       
                    </tr>
                   
                    
                      </table>
                  </td>
                  
              </tr>
                           
              <tr>
                   <td width="100%" colspan="2">
                     <hr/>
                   </td>
              </tr>
              
              
      <tr width="100%">
          <td  colspan="2">
            <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                <tr style="page-break-inside: avoid;">
                      <td width = "20%">
                           <b><apex:outputText Value="{!Job__c.Schedule_Template__r.name}" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/></b>
                      </td>
                     
                </tr>
            </table>
           </td>
        </tr>
              
            <tr>
                <td colspan="2" width="100%" align="left"> <br/><br/>
                    
                    <apex:dataTable value="{!JobTask}" var="JTask" columns="2" columnsWidth="35%,65%"  width="100%" rendered="{!JobTask.Size>0}">
                        
                        <apex:column headerValue="{!$ObjectType.Job_Task__c.Label}">
                             <apex:outputField value="{!JTask.Name}"/>
                        </apex:column>

                        <apex:column headerValue="{!$ObjectType.Job_Task__c.Fields.Revised_Due_Date__c.Label}"> 
                            <apex:outputField value="{!JTask.Revised_Due_Date__c}"/>
                        </apex:column>
    
                    </apex:dataTable>
               </td>
          </tr>  
          
        
          </table>
</body>
</apex:page>
<!-- End of Page -->