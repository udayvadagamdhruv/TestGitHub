<!-- This page is used to display MI Note. -->
<apex:page standardController="Note" extensions="MIViewNote" showHeader="false" standardStylesheets="true"  applyBodyTag="false" applyHtmlTag="false" docType="html-5.0">
 <style>
       
           
   body{
                
                background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, #d4d7da, #666) !important;
                background-repeat: repeat-x;
                background-position: left top;
                background-attachment: fixed;
                
      }
      .slds-page-header{
              background-color: #851225 !important;
              border-bottom: 3px solid #851255 !important;
              color: white !important;
      }
      .slds-page-header p {
          color: white !important;
      }
      .slds .slds-tabs--scoped__nav {
            background-color: #e2e4e6 !important;
            font-size: 15px;
        }
       .apexp .bPageBlock.apexDefaultPageBlock .pbBody 
       {
         margin: 0px 0px 0px;
       }
       
        .SectionHeader
       {
           background-color:Grey !important;
           color:white;
       }
       
       
        .customImage{ height: 10px; width: 10px; }
         #rcorners1 {
                        border-radius:0%;
                        border: 1px solid #cccccc;
                        padding: 0px; 
                        width: 100%;
                        height: 0%;
                    }
        #pagemessage
                    {
                        color:blue;
                    }
       .required:after { content:" *";  color: Red;font:bold;}
       
       
         .slds table
                   {
                        height: 50px;
                   }
                   body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons
                   {
                        margin-top: -19px; 
                   }
                   .detailPage .bPageBlock, .editPage .bPageBlock
                   {
                      border-top-width: 0px;
                   }
                  
                   .slds .slds-text-heading--large
                   {
                           font-size: 27px;
                   }
                   
                    .pbHeader
                   {
                       background: white !important;
                   }
                   
                   
                   body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons 
                   {
                       background: white;
                   }
                  
                   .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
                   {
                       border:none;
                   }
                   
                   body .bEditBlock .pbBottomButtons, body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons
                   {
                       border:none;
                   }
        
        
                  
       
           <!--- error Mesgg-------------------------------------->
       
       
       .bPageBlock .requiredInput .requiredBlock {
                    background-color:white;
                    position: absolute;
                    left: -4px;
                    width: 3px;
                    top: 1px;
                    bottom: 1px;
                }
       
              errorM6, .errorM4, .errorM3, .errorM2, .errorS1 {
                    border-color: #c00;
                }
                .message {
                    background-color: #c00;
                    border-style: solid;
                    
                    border-width: 0px;
                    color: #000;
                    padding: 0px 0px 0px 0px;
                    margin: 0px 0px;
                }
                .errorM3 .msgIcon, .errorMedium {
                    background-image: url(); 
                    background-position: 0 0;
                    width:0px;
                    height: 0px;
                }
            .pbBody td{
             color:white;
             }
             .message .messageText h4 {
                     font-weight: bold; 
                     display:block;
                     color:white;
                }
                
            <!--- error Mesgg-------------------------------------->
                
    </style>  
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />

     <div class="slds">
                   <div class="slds-page-header" style="width:100%;{!if($User.UITheme == 'Theme1' || $User.UITheme == 'Theme2' || $User.UITheme == 'Theme3','', 'position:fixed;z-index:15;')}" >
                           <div class="slds-grid">
                                <div class="slds-col slds-has-flexi-truncate">
                                    <div class="slds-media slds-no-space slds-grow">
                                        <div class="slds-media__figure">
                                           <svg class="slds-icon slds-icon-standard-user" aria-hidden="true">
                                              <use  xlink:href="{!$Resource.SLDS}/assets/icons/standard-sprite/svg/symbols.svg#note"></use>
                                          </svg>
                                        </div>                        
                                        <div class="slds-media__body">
                                            <p class="slds-text-title slds-line-height--reset">Note</p>
                                            <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-truncate" ><apex:outputField value="{!Note.Title}"/></h1>
                                        </div>
                                   </div>
                                </div>
                          </div>
                     </div>
 
                     <br/>
                     <div class="slds" style="display:{!IF(($User.UITheme="Theme4d"),'block','none')};margin-top:12px">
                          <br/><br/><br/>
                     </div>
 

        
           
      <apex:form html-novalidate="novalidate"  >
          <br/>
          <div style="margin: 0px 15px 0px 15px;">
          <apex:pageBlock mode="edit">    <br/>
           <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" > 
         <apex:pageMessages />
           </div>
          
               <apex:pageBlockButtons style="position:absolute;left:43%" location="bottom">
                    <apex:commandButton action="{!editNote}" value="Edit" styleClass="slds-button slds-button--brand"/>
                    <apex:commandButton action="{!deleteNote}" value="Delete" styleClass="slds-button slds-button--brand"/>
                    <apex:commandButton action="{!cancel}" value="Notes View" styleClass="slds-button slds-button--brand"></apex:commandButton>
               </apex:pageBlockButtons>
               <div class="SectionHeader" style="background-color:SteelBlue;color:white;margin:0px 10px 10px 10px">
             <h3 class="slds-section-title"><b>&nbsp;Note Information</b></h3>
             </div>
             
             
                            <div class="slds-grid slds-wrap">
                                 
                             <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" >
                                            
                                   <div class="slds-grid slds-wrap"> 
                                   
                                           <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>{!$ObjectType.Note.Fields.Title.Label}</b> </label>
                                                                <div class="slds-form-element__control" >
                                                              <apex:outputfield value="{!n.Title}"  StyleClass="slds-input" />
                                                                </div>
                                                            </div>
                                                        </aside>
                                            <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>{!$ObjectType.Note.Fields.IsPrivate.Label}</b> </label>
                                                                <div class="slds-form-element__control" >
                                                                      <label class="slds-checkbox" >
                                                                       <apex:outputfield value="{!n.IsPrivate}" StyleClass="slds-input " />
                                                                      
                                                                       
                                                                      </label>
                                                             </div>
                                                            </div>
                                                        </aside>
                                            <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>{!$ObjectType.Note.Fields.Body.Label}</b> </label>
                                                                <div class="slds-form-element__control" >
                                                              <apex:outputfield value="{!n.body}"  StyleClass="slds-input" />
                                                                </div>
                                                            </div>
                                                        </aside>
                                   </div>
                                   <br/><br/>
                             </main>
                             </div>
             
             
              
        </apex:pageBlock> 
       </div>
    </apex:form>
    </div>
    </html>
</apex:page>
<!-- End of Page -->