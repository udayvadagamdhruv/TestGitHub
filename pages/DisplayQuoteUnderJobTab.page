<apex:page controller="DisplayQuoteUnderJobTab">
<head>
<style>
 #table_rd td
 {
    border:0px;
 }
 #table_dd td
 {
     border:0px;
 }
 .hd
      {
      text-align:right;
      padding-right:20px!important;
      }
.labelCol2{font-size:1.0em};

</style>
</head>

 <apex:form >
 <apex:outputPanel id="pb1">
  <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
   
   <apex:pageBlock title="Quotes">
    
    <apex:pageBlockButtons location="top">
     <apex:commandButton action="{!CreateQuote}" value="New Quote" id="btn1"/>  
      <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display: none;"   />  
    <apex:commandButton value="Cancel" id="cancelButton"  style="display: none;" immediate="true" reRender="pb1"/>   
     </apex:pageBlockButtons>
     
      <div>
      <apex:pageBlockTable value="{!q2}" var="quote" rendered="{!q2.Size > 0}"> <br/><br/><br/> 
       <!--  <apex:column headerValue="Action">
         <apex:commandButton value="Approve" action="/apex/ApproveVendorQuote?id={!vquote.id}"/>
         </apex:column> -->
         
          <apex:column headerValue="{!$ObjectType.Quote__c.Fields.Name.Label}">
        <!--  <apex:outputField value="{!vquote.Name}"/>  -->
          <apex:outputLink tabindex="tab1" value="/apex/Quotedetailpage?id={!quote.Id}">{!quote.Name}</apex:outputLink>
          </apex:column> 
          
         
       
       <!--  <apex:outputLink tabindex="tab2" value="/apex/Quotedetailpage?id={!vquote.Quote__r.id}">{!vquote.Quote__r.Name}</apex:outputLink> -->
       <!--    <apex:column headerValue="Quote">
         <apex:outputText >{!vquote.Quote__r.Name}</apex:outputText>
          </apex:column>  -->
          
           <apex:column headerValue="{!$ObjectType.Quote__c.Fields.GL_Department__c.Label}">
          <apex:outputfield value="{!quote.GL_Department__r.Name}"/>
          </apex:column>
          
          
          <apex:column headerValue="{!$ObjectType.Quote__c.Fields.GL_Code__c.Label}">
          <apex:outputField value="{!quote.GL_Code__r.Name}"/>
          </apex:column>
          
          
          
           <apex:column headerValue="{!$ObjectType.Quote__c.Fields.Unit_Type__c.Label}">
          <apex:outputfield value="{!quote.Unit_Type__c}"/>
          </apex:column>
         
          <apex:column headerValue="{!$ObjectType.Quote__c.Fields.Request_Date__c.Label}">
           <apex:actionRegion >
               <table border="0" id="table_rd">
               <tr>
               <td border="0">
                 <apex:outputField value="{!quote.Request_Date__c}">
                 <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1" rendered="{!quote.Approved__c = false}"/> </apex:outputfield> </td> 
               <td> <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Request Date" rendered="{!quote.Approved__c = false}"/>  </td>
               </tr>
              </table>
          </apex:actionRegion>
        </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Quote__c.Fields.Due_Date__c.Label}">
           <apex:actionRegion >
               <table border="0" id="table_dd">
               <tr>
               <td border="0">
                 <apex:outputField value="{!quote.Due_Date__c}">
                 <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1" rendered="{!quote.Approved__c = false}"/> </apex:outputfield> </td> 
               <td> <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Due Date" rendered="{!quote.Approved__c = false}"/>  </td>
               </tr>
              </table>
          </apex:actionRegion>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Quote__c.Fields.Amount__c.Label}" style="text-align:right;padding-right:20px;" headerClass="hd">
          <apex:outputfield value="{!quote.Amount__c}"  />
          </apex:column>
          
          <apex:column headerValue="{!$ObjectType.Quote__c.Fields.Approved__c.Label}">
          <apex:outputField value="{!quote.Approved__c}"/>
          </apex:column>   
          
      </apex:pageBlockTable>
      <apex:pageBlockSection rendered="{!q2.size <= 0}">
           <apex:pageBlockSectionItem >
           <b>No records to display</b>
           </apex:pageBlockSectionItem>              
         </apex:pageBlockSection> 
      </div>
   </apex:pageBlock>
   </apex:outputPanel>
 </apex:form>
</apex:page>
<!-- End of Page -->