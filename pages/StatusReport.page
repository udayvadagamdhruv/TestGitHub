<!-- This VF page is uesd to display Status Report. Status Report displays all Active Jobs with their Next Active Task Due-->
<apex:page Controller="StatusReportExtensionsNew" sidebar="false" showHeader="false" standardStylesheets="false" readOnly="true" renderAs="PDF">
    <head> 
        <style type="text/css">
            div.tab
            {
                width:100%;
                border:solid black;
            }
            @page
            {
               /* Landscape orientation */
                size:landscape;
                /* Put page numbers in the bottom right corner of each
                page in the pdf document. */
               @bottom-right 
               {
                  content: "Page " counter(page);
                  font-family: sans-serif;
                  font-size:8pt;
                }
                 @bottom-left 
                 {
                    content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
                    background-repeat: no-repeat;
                    font-size:8pt;
                    font-family: sans-serif;
                  }
             }
          body 
          {
               font-family: sans-serif;
               font-size:8pt;
          }
           th
          {
              font-size:10pt
              font-style:bold;
              font-family: sans-serif;
          }
        td
        {
            font-size:8pt;
            font-family: sans-serif;
          }
  
   div.footer {
    position : running(footer) ;
}
  /* you can even define custom classes that utilize your static resources */
