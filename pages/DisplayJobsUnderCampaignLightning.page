<!-- This page is used to display Jobs related to selected Campaign -->
<apex:page controller="DisplayJobsUnderCampaignController" showHeader="false" sidebar="flase" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" standardStylesheets="true">

    <head>
        <style>
        
         .slds .slds-tabs--scoped__nav 
       {
       background-color: #e2e4e6 !important;
       font-size: 15px;
       }

        
            .hd {
                text-align: right;
                padding-right: 20px!important;
            }
            
            .slds .slds-card__footer {
                padding: 0px 16px 0px 0px;
            }
            
            .slds .slds-card__header {
                padding: 0px 10px 0px 0px;
            }
            
            .slds .slds-card__body {
                padding: 0px;
            }
            
            .slds .slds-card {
                padding: 0;
                border-radius: 0px;
                background-clip: padding-box;
                background-color: white;
            }
            
            .slds .slds-table--bordered {
                border-top: 0px solid #d8dde6;
                border-bottom: 1px solid #d8dde6;
            }
            
            .slds .slds-card__body {
                margin-bottom: -0.25rem;
                margin-top: -0.15rem;
            }
            
            
            
            <!--- error Mesgg-------------------------------------->
       
       
       .bPageBlock .requiredInput .requiredBlock {
                    background-color:white;
                    position: absolute;
                    left: -4px;
                    width: 3px;
                    top: 1px;
                    bottom: 1px;
                }
       
              errorM6, .errorM4, .errorM3, .errorM2, .errorS1 {
                    border-color: #c00;
                }
                .message {
                    background-color: #c00;
                    border-style: solid;
                    
                    border-width: 0px;
                    color: #000;
                    padding: 0px 0px 0px 0px;
                    margin: 0px 0px;
                }
                .errorM3 .msgIcon, .errorMedium {
                    background-image: url(); 
                    background-position: 0 0;
                    width:0px;
                    height: 0px;
                }
            .pbBody td{
             color:white;
             }
             .message .messageText h4 {
                     font-weight: bold; 
                     display:block;
                     color:white ! important;
                }
                
                .messageText br
            {
               display:none !important;
            }
            .messageTable tr
            {
               padding-top:10px !important;
               padding-bottom:10px !important;
            }
            .slds-notify, .slds-text-heading--small, .slds-theme--error, .message, .errorM3
            {
                border-radius: 15px !important;
            }
            .pbBody
            {
                padding:10px !important;
            }
            .messageCell{
            color:white !important;
            }
                
            <!--- error Mesgg-------------------------------------->
                
             
            
            
        </style>
    </head>

    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />

    <div class="slds">

        <apex:form html-novalidate="novalidate" id="CjobsId">

            <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
                <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
            </div>

           
            
            <table >
                <tr>
                    <td width="15%" align="left" style="padding-top:10px;padding-left:1%;">
                        <apex:outputLabel value="Job Status"></apex:outputLabel>
                        <br/>
                        <apex:selectList id="StatusList" value="{!strStatus}" size="1" styleClass="slds-select slds-m-right--medium" style="width:80%" >
                            <apex:selectOptions value="{!StatusList}"></apex:selectOptions>
                            <apex:actionSupport event="onchange" rerender="pgt11,pgt2,foot" action="{!populateJobList}" status="Jobstatus" />
                            <apex:actionStatus id="Jobstatus">
                                <apex:facet name="start">
                                    <div class="slds-spinner_container" style="z-index: 99999;position: fixed;">
                                        <div role="status" class="slds-spinner slds-spinner--brand slds-spinner--medium">
                                            <span class="slds-assistive-text">Loading</span>
                                            <div class="slds-spinner__dot-a"></div>
                                            <div class="slds-spinner__dot-b"></div>
                                        </div>
                                    </div>
                                </apex:facet>
                            </apex:actionStatus>
                        </apex:selectList>
                    </td>
                    
                    <td align="left"  style="padding-top:10px;">
                       <apex:outputLabel value="Campaign Template"></apex:outputLabel>
                        <br/>
                        <apex:selectList id="campTemplist" value="{!selectedCTemp}" size="1" styleClass="slds-select slds-m-right--medium" style="width:20%">
                     
                            <apex:selectOptions value="{!CampTemp}"></apex:selectOptions>
                          </apex:selectList>
                          
                          <apex:commandbutton value="Import Jobs" action="{!ImpCampTempJobs}" styleclass="slds-button slds-button--neutral"  rerender="pgt11,pgt2,foot,CjobsId" /> &nbsp;&nbsp;&nbsp;&nbsp;
                         
                          
                          <apex:commandbutton value="New Job" action="{!createNewJob}" styleclass="slds-button slds-button--neutral" />
                    </td>
                    
                </tr>
            </table>
            
          

            <br/>

            <b> <apex:outputLabel value="You are Viewing recent thousand Jobs" rendered="{!lstJob.size == 1000}" /></b>

            <apex:outputPanel id="pgt11">
             
                <apex:outputPanel rendered="{!lstJob.size!=0}">
                
                 

                    <div class="slds-card">

                        <div class="slds-card__body">

                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <thead class="slds-truncate">

                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.Name.Label}
                                        </th>
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.JS_Client__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.Status__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.Budgeted_Cost__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.Estimate_Total__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-7" scope="col">
                                            {!$ObjectType.Job__c.Fields.Invoice_Actual_Amounts__c.Label}
                                        </th>

                                    </tr>
                                </thead>
                                <tbody>

                                    <apex:repeat value="{!lstJob}" var="jt" rendered="{!lstJob.Size!= 0}">

                                        <tr class="slds-hint-parent">

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}">
                                                <div>
                                                    <apex:outputText value="{!jt.Job_Auto_Number__c}"></apex:outputText>
                                                </div>
                                            </td>

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputLink tabindex="tab1" value="/apex/JobdetailpageLightening07?id={!jt.id}">
                                                        {!jt.Name}
                                                    </apex:outputLink>
                                                </div>
                                            </td>

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.JS_Client__c.Label}">
                                                <div>
                                                    <apex:outputText value="{!jt.JS_Client__r.name}"></apex:outputText>
                                                </div>
                                            </td>

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.Status__c.Label}">
                                                <div>
                                                    <apex:outputText value="{!jt.Status__c} "></apex:outputText>
                                                </div>
                                            </td>

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.Budgeted_Cost__c.Label}">
                                                <div>
                                                    <apex:outputText value="{!jt.Budgeted_Cost__c}"></apex:outputText>
                                                </div>
                                            </td>

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.Estimate_Total__c.Label}">
                                                <div>
                                                    <apex:outputText value="{!jt.Estimate_Total__c}"></apex:outputText>
                                                </div>
                                            </td>

                                            <td class="slds-size--1-of-7" data-label="{!$ObjectType.Job__c.Fields.Invoice_Actual_Amounts__c.Label}">
                                                <div>
                                                    <apex:outputText value="{!jt.Invoice_Actual_Amounts__c}"></apex:outputText>
                                                </div>
                                            </td>

                                        </tr>

                                    </apex:repeat>
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <br/>
                    <br/>
                    
                    
        <!------------------------------------------------------------------------- Notes Sections -------------------------------------------------------------------------------------------------->
              
                    <div style=" background-color:#e2e4e6 !important;padding: 0 0.6rem;font-size: 1.2em; font-weight: normal;color: darkslategrey;line-height: 1.875rem;">
                        <b>  Notes Section </b>
                    </div>

                    <br/>

                    <div class="slds-grid slds-wrap">

                        <apex:repeat value="{!lstJobNotes}" var="na">
                            <apex:repeat value="{!na.Notes}" var="Notes">
                                <div class="slds-col--padded slds-size--2-of-2 slds-medium-size--6-of-6 slds-large-size--6-of-12">
                                    <div class="slds-media slds-tile slds-hint-parent">

                                        
                                        <div class="slds-media__body">
                                            <div class="slds-grid slds-grid--align-spread slds-has-flexi-truncate">
                                                <p class="slds-tile__title slds-truncate">
                                                  <b> Job: </b>  <apex:outputLink tabindex="tab1" value="/apex/JobdetailpageLightening07?id={!na.Id}"><font color="#0070d2">{!na.Name} - {!na.Job_Auto_Number__c} </font></apex:outputLink>
                                                </p>
                                            </div>
                                        

                                        <div class="slds-tile__detail slds-text-body--small">
                                            <p class="slds-tile__title slds-truncate">
                                                <b>Title: </b>
                                                <apex:outputLink tabindex="tab1" value="/apex/JobNoteDetailPageLightning?id={!Notes.Id}"><font color="#0070d2">{!Notes.Title}</font></apex:outputLink>
                                            </p>
                                        </div>

                                        <div class="slds-tile__detail slds-text-body--small">
                                            <p><b>Body: </b>{!Notes.body}</p>
                                        </div>
                                    </div>
                                    </div>
                                </div><br/><br/><br/><br/>

                            </apex:repeat>
                        </apex:repeat>
                    </div>
     <!------------------------------------------------------------------------- End of Notes Sections -------------------------------------------------------------------------------------------------->
     
     
     <!------------------------------------------------------------------------- Attachment Sections -------------------------------------------------------------------------------------------------->
     
                   <div style=" background-color: #e2e4e6 !important;padding: 0 0.6rem;font-size: 1.2em; font-weight: normal;color: darkslategrey;line-height: 1.875rem;">
                        <b>  Attachments Section </b>
                    </div>

                    <br/>

                    <div class="slds-grid slds-wrap">

                        <apex:repeat value="{!lstJobAttach}" var="na">
                            <apex:repeat value="{!na.Attachments}" var="Att">
                                <div class="slds-col--padded slds-size--2-of-2 slds-medium-size--6-of-6 slds-large-size--6-of-12">
                                    <div class="slds-media slds-tile slds-hint-parent">

                                        
                                        <div class="slds-media__body">
                                            <div class="slds-grid slds-grid--align-spread slds-has-flexi-truncate">
                                                <p class="slds-tile__title slds-truncate">
                                                   <b>Job: </b><apex:outputLink tabindex="tab1" value="/apex/JobdetailpageLightening07?id={!na.Id}"><font color="#0070d2">{!na.Name} - {!na.Job_Auto_Number__c} </font></apex:outputLink>
                                                </p>
                                            </div>
                                        

                                        <div class="slds-tile__detail slds-text-body--small">
                                            <p class="slds-tile__title slds-truncate">
                                              <b> File: </b>  <apex:outputLink tabindex="tab1" value="/servlet/servlet.FileDownload?file={!Att.Id}"><font color="#0070d2">{!Att.Name}</font></apex:outputLink>
                                            </p>
                                        </div>

                                       
                                    </div>
                                    </div>
                                </div><br/><br/><br/>

                            </apex:repeat>
                        </apex:repeat>
                    </div>
     
     
     <!------------------------------------------------------------------------- End of Attachment Sections -------------------------------------------------------------------------------------------------->               
                    
      <!------------------------------------------------------------------------- Chatter Sections -------------------------------------------------------------------------------------------------->
                     
                       <div style=" background-color: #e2e4e6 !important;padding: 0 0.6rem;font-size: 1.2em; font-weight: normal;color: darkslategrey;line-height: 1.875rem;">
                        <b>  Chatter Files Section </b>
                    </div>

                    <br/>

                    <div class="slds-grid slds-wrap">

                        <apex:repeat value="{!lstJobChatter}" var="nf4">
                            <apex:repeat value="{!nf4.ContentDocumentLinks}" var="Chat">
                                <div class="slds-col--padded slds-size--2-of-2 slds-medium-size--6-of-6 slds-large-size--6-of-12">
                                    <div class="slds-media slds-tile slds-hint-parent">

                                        
                                        <div class="slds-media__body">
                                            <div class="slds-grid slds-grid--align-spread slds-has-flexi-truncate">
                                                <p class="slds-tile__title slds-truncate">
                                                <b> Job: </b> <apex:outputLink tabindex="tab1" value="/apex/JobdetailpageLightening07?id={!nf4.Id}"><font color="#0070d2">{!nf4.Name} - {!nf4.Job_Auto_Number__c} </font></apex:outputLink>
                                                </p>
                                            </div>
                                        

                                        <div class="slds-tile__detail slds-text-body--small">
                                            <p class="slds-tile__title slds-truncate">
                                                <b>Title: </b>
                                                <apex:outputLink tabindex="tab1" value="/{!Chat.ContentDocumentId}"><font color="#0070d2">{!Chat.ContentDocument.Title}</font></apex:outputLink>
                                            </p>
                                        </div>

                                        
                                    </div>
                                    </div>
                                </div><br/><br/><br/><br/>

                            </apex:repeat>
                        </apex:repeat>
                    </div>
                     
     <!------------------------------------------------------------------------- End of Chatter Sections -------------------------------------------------------------------------------------------------->               
                    
                    
                </apex:outputpanel>

            </apex:outputpanel>
            <br/>
            <br/>

            <apex:outputPanel id="foot">
                <apex:outputPanel rendered="{!lstJob.size==0}">
                    No records to display
                </apex:outputPanel>
            </apex:outputPanel>

        </apex:form>
    </div>

    </html>

</apex:page>
<!-- End of Page -->