<apex:page controller="printStatusReport" id="pageId"  action="{!clearForm}">
    <head>
    

    <style type="text/css">
        .rotate_text
        {
            -moz-transform: rotate(-90deg);
            -moz-transform-origin: top left;
            -webkit-transform: rotate(-90deg);
            -webkit-transform-origin: top left;
            -o-transform: rotate(-90deg);
            -o-transform-origin: top left;
            position: relative;
            top: 20px;
            font-weight:bold;
        }
        @page
                {
                    /* Landscape orientation */
                    size:landscape;

                    /* Put page numbers in the bottom right corner of each
                    page in the pdf document. */
                    @bottom-right 
                    {
                        content: "Page " counter(page);
                        font-family:Arial;
                        font-size:8pt;
                    }
                   @bottom-left 
                   {
                        content: "<apex:outputText value="{0,date,MM'/'dd'/'yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
                        background-repeat: no-repeat;
                        font-size:8pt;
                        font-family:Arial;
                   }
                  }
    </style>
    <!--<![endif]-->
    <style type="text/css">
     
       td .rotated_cell
        {
            padding-bottom: 5px;          
            height: 120px;
            vertical-align: bottom;
            white-space:nowrap;
        }
    </style>
    <style type="text/css">
       td .b
        {
            text-align: left;
            vertical-align: bottom;
            font-weight: bold;
        }
    </style>    
    
    
    
   
<style type="text/css"> 


.a
{
-webkit-transform: rotate(-90deg);
-moz-transform: rotate(-90deg);
text-align:left;
Padding-left:30px;


}
 
   

</style>

         <script type="text/javascript">
          function doSearch() {
            searchServer
            (
                              
                 document.getElementById("CampaignList").options[document.getElementById("CampaignList").selectedIndex].value,
                 document.getElementById("scheduleTempList").options[document.getElementById("scheduleTempList").selectedIndex].value,
                 document.getElementById("JobList").options[document.getElementById("JobList").selectedIndex].value,
                 document.getElementById("statusList").options[document.getElementById("statusList").selectedIndex].value,
                 document.getElementById("JobTeamList").options[document.getElementById("JobTeamList").selectedIndex].value,   
                 document.getElementById("clientList").options[document.getElementById("clientList").selectedIndex].value,
                 document.getElementById("startdt1").value,
                 document.getElementById("MediaList").options[document.getElementById("MediaList").selectedIndex].value
            );
          }
          
           function clearFields()
      {
           
             document.getElementById("CampaignList").selectedIndex = 0;
             document.getElementById("scheduleTempList").selectedIndex = 0;
             document.getElementById("JobList").selectedIndex = 0;
             document.getElementById("statusList").selectedIndex = 0;
             document.getElementById("JobTeamList").selectedIndex = 0;
             document.getElementById("clientList").selectedIndex = 0;        
             document.getElementById("startdt1").value = "";
             document.getElementById("MediaList").selectedIndex = 0;
            
      }
          </script>
    </head>
    <apex:form id="formId">
        <apex:actionFunction name="searchServer" action="{!searchJobs}" reRender="results,debug">          
            <apex:param name="CampaignList" value=""/> 
             <apex:param name="scheduleTempList" value=""/>           
            <apex:param name="JobList" value=""/>
            <apex:param name="statusList" value=""/>
            <apex:param name="JobTeamList" value=""/>
             <apex:param name="clientList" value=""/>
            <apex:param name="startdt1" value=""/>   
             <apex:param name="MediaList" value=""/>        
        </apex:actionFunction>
        <apex:pageMessages id="pgMsg"/>
            <apex:pageBlock id="pbSearch"   title="Print Status Report">
            
         <table >
        <tr>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Job__c.Fields.Campaign__c.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <select id="CampaignList" tabindex="1" style="width: 180px;">
                    <apex:repeat value="{!CampaignList}" var="lst">
                                            <option value="{!lst}">{!lst}</option>
                                        </apex:repeat>
                </select>
            </td>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Job__c.Fields.Status__c.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <select id="statusList" tabindex="2" style="width: 180px;">
                    <apex:repeat value="{!jobStatus}" var="status">
                                                <option value="{!status}">{!status}</option>
                                            </apex:repeat>
                </select>
            </td>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Job__c.Fields.JS_Client__c.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <select id="clientList" tabindex="3" style="width: 180px;">
                    <apex:repeat value="{!clientList}" var="client">
                                                <option value="{!client}">{!client}</option>
                                            </apex:repeat>
                </select>
            </td>
        </tr>
        <tr>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Job__c.Fields.Schedule_Template__c.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <select id="scheduleTempList" tabindex="7" style="width: 180px;">
                    <apex:repeat value="{!scheduleTempList}" var="template">
                                                <option value="{!template}">{!template}</option>
                                            </apex:repeat>
                </select>
            </td>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Staff__c.Fields.Name.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <select id="JobTeamList" tabindex="1" style="width: 180px;">
                    <apex:repeat value="{!JobTeamList}" var="jlst">
                                            <option value="{!jlst}">{!jlst}</option>
                                        </apex:repeat>
                </select>
            </td>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Job__c.Fields.Start_Date__c.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <input type="text" id="startdt1" name="sdt1" onfocus="DatePicker.pickDate(false,'startdt1', false);"
                    size="10" tabindex="4" style="width:120px"/>
            </td>
        </tr>
        <tr>
            <td style="font-weight: bold; width: 150px; white-space: nowrap">
                {!$ObjectType.Job__c.Fields.Name.Label}
            </td>
            <td style="width: 280px; white-space: nowrap">
                <select id="JobList" tabindex="7" style="width:180px;">
                    <apex:repeat value="{!JobList}" var="JobList">
                                                <option value="{!JobList}">{!JobList}</option>
                                            </apex:repeat>
                </select>
            </td>
            <td style="font-weight: bold;width:150px;white-space:nowrap">
                {!$ObjectType.Job__c.Fields.Media_Types__c.Label}
            </td>
            <td style="width: 280px;white-space:nowrap">
                <select id="MediaList" tabindex="1" style="width: 180px;">
                   <apex:repeat value="{!MediaList}" var="mlst">
                                            <option value="{!mlst}">{!mlst}</option>
                                        </apex:repeat> 
                </select>
            </td>
            <td>
            </td>
            <td>
            </td>
        </tr>
        <tr>
            <td colspan="3" style="text-align: right; padding-top: 20px;">
                <apex:commandbutton value="Search" onclick="if(!doSearch()) return false;" rerender="results"
                    tabindex="10" />
                &nbsp;
            </td>
            <td colspan="3" style="text-align: left; padding-top: 20px;">
                <apex:commandbutton value="Clear" onclick="clearFields();" rerender="results" action="{!clearForm}"
                    tabindex="11" />
            </td>
        </tr>
    </table>
                   
                 </apex:pageBlock> 
                 
    <apex:pageBlock id="results">
                    
 <table border="0" cellpadding="0" cellspacing="0">
              
                    <tr>
            <td width="60px;" class="b">
               {!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}
            </td>
            
            
            <td width="750px" class="b">
               {!$ObjectType.Job__c.Fields.Name.Label}
            </td>
            
                       
            <td width="500px" class="b">
                {!$ObjectType.Job__c.Fields.Dummy_Text_1__c.Label}
            </td>
       
        </tr>
                   
                   <tr>
                         <td colspan="3"><hr color="black"/></td>
                   </tr>
                  </table>   
                    
                    
                    <apex:datatable value="{!cWrapper }" var="w" id="repeat1" width="100%" columnswidth="100%">
                      <apex:column >
                 <div style="background-color:#DFDFDF;width:100%;">    <b> <apex:outputText value="{!w.strClient}" style="font-size:14px;padding:left:2px;" /> </b> </div>
                      <!--    <hr color="black" style="height:.1px;"/>-->
                          
                           <apex:repeat value="{!w.jobWrapper}" var="jobr"  >
                             <table border="0" style="font-size:12px; padding-top:5px;"   cellspacing="0" cellpadding="0"><tr><td >
                                       <b> <apex:outputText value="{!jobr.job.Job_Auto_Number__c}"  style="vertical-align:top;padding-right:8px;font-size:14px;"/> </b>
                                     
                                       <b> <apex:outputText value="  AS {!jobr.job.Name}"  style="vertical-align:top; font-size:14px;;font-weigth:bold;"> </apex:outputText></b>                                
                            </td></tr>
                          <tr><td> <table border="0"  style="padding-top:5px;"> <tr>
                            <td width="300px">  
                            <table width="300px" cellspacing="0" cellpadding="0" border="0"><tr>
                            <td  width="150px">
                           <b>   <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Dummy_Text_2__c.Label}  " /></b> </td><td  width="150px">
                               <apex:outputText value="{!jobr.job.Dummy_Text_2__c}"  style="vertical-align:top;padding-right:8px;font-size:12px;"/> </td></tr>
                                <tr><td  width="150px"> 
                                 <b> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Dummy_Text_5__c.Label}  " /></b> </td><td  width="150px">  <apex:outputText value=" {!jobr.job.Dummy_Text_5__c}"  style="vertical-align:top; font-size:12px;"> </apex:outputText>   
                                 </td></tr></table> 
                                  
                            </td>
                            <td width="500px">
                                         <table border="0" width="500px" cellspacing="0" cellpadding="0">
                                          <apex:repeat value="{!jobr.jobTasksWrapper}" var="jtaskWrapper">
                                          <tr><td  width="150px">
                                            <b> <apex:outputText value="{!jtaskWrapper.jobTasks.Name}">
                                              
                                             </apex:outputText></b></td>
                                           <td width="80px">  <apex:outputText value="{0,date,MM'/'dd'/'yy}" >
                                                <apex:param value="{!jtaskWrapper.jobTasks.Revised_Due_Date__c}"/> 
                                             </apex:outputText></td>  
                                           <td width="120px">        
                                                 <apex:outputText value="{!jtaskWrapper.jobTasksRole.User__c}" ></apex:outputText>
                                             </td>
                                             <td width="140px">        
                                                 <apex:outputText value="{!jtaskWrapper.jobTasksRole.Name}" ></apex:outputText>
                                             </td></tr>
                                          </apex:repeat></table>
                                       </td><td width="550px">
                                           <apex:outputField value="{!jobr.job.Dummy_Text_1__c}" />
                                        </td> </tr></table>
                         </td></tr><tr><td>   <hr color="black"  style="border: none; height: 1px; color: black; background: black;" /></td></tr></table>
                         </apex:repeat>
                      </apex:column>       
                    </apex:datatable>
                     
                    
                    <apex:outputPanel rendered="{!(cWrapper.size == 0) && (isTrue == True)}">
                        <b>No records to display </b>
                    </apex:outputPanel>
                    
                    <div align="right"  style="padding-top:20px;padding-right:32px;">
                       <apex:commandButton value="Print" action="{!exportToPDF}" rendered="{!(cWrapper.size > 0)}" tabindex="12"/>
                    </div>
                           
           </apex:pageBlock>  
      </apex:form> 
     <script>
         function setFocusOnLoad(){}
     </script>
</apex:page>
<!-- End of Page -->