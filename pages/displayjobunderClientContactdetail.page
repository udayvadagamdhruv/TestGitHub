<apex:page Controller="DisplayJobUnderClientContactDetail" readOnly="true">
<head>
    <style>
        .hd{text-align:right;padding-right:20px!important;}
        .labelCol2{font-size:1.0em};
    </style>
</head>
 <apex:form >
     <apex:pageBlock tabStyle="Job__c">
     <table>
          <tr>
              <td> <apex:image url="{!$Resource.BigTop}" width="25" height="25" /> </td>
              <td>  <h1 class="mainTitle">Jobs</h1> </td>
          </tr>
      </table>  
     <div>
     <apex:outputPanel layout="block"  rendered="{!job.size > 0}" style="overflow:auto;height:150px;">
      <apex:pageBlockTable value="{!job}" var="j" width="100%" > <br/><br/><br/> 
      
          <apex:column headerValue="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="text-align:right;padding-right:20px;" headerClass="hd" width="8%">
              <apex:outputfield value="{!j.Job_Auto_Number__c}"/>
          </apex:column>
           
          <apex:column headerValue="{!$ObjectType.Job__c.Fields.Name.Label}" width="50%">
              <apex:outputLink value="/apex/JobListView?id={!j.id}" tabindex="tab1">{!j.Name}</apex:outputLink>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Job__c.Fields.Start_Date__c.Label}" style="text-align:right;padding-right:20px;" headerClass="hd" width="10%">
              <apex:outputfield value="{!j.Start_Date__c}"/>
          </apex:column>
                    
          <apex:column headerValue="{!$ObjectType.Job__c.Fields.Completion_Date__c.Label}" style="text-align:right;padding-right:20px;" headerClass="hd" width="10%">
              <apex:outputfield value="{!j.Completion_Date__c}"/>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Job__c.Fields.Due_Date__c.Label}" style="text-align:right;padding-right:20px;" headerClass="hd" width="10%">
              <apex:outputField value="{!j.Due_Date__c}"/>
          </apex:column>  
      
           <apex:column headerValue="{!$ObjectType.Job__c.Fields.Status__c.Label}" width="8%">
              <apex:outputField value="{!j.Status__c}"/>
           </apex:column>  
      </apex:pageBlockTable>
      </apex:outputPanel>
            
         <apex:pageBlockSection rendered="{!job.size <= 0}">
           <apex:pageBlockSectionItem >
         <b>No records to display</b>
           </apex:pageBlockSectionItem>              
         </apex:pageBlockSection> 
      </div>
   </apex:pageBlock>
 </apex:form>
</apex:page>
<!-- End of Page -->