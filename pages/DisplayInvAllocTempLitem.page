<apex:page Controller="DisplayInvAllocTempLitemController">
  
  <head>
<style>
 #table_id td
        {
            border:0px;
        }
</style>

</head>
 
 <apex:form >
  <apex:pageBlock >
       <span style="padding-left:450px;margin:5px;padding-bottom:20px;">
    <apex:commandButton action="{!createIATLI}" value="Add Invoice Allocation Template Line Items" id="btn2" rendered="{!$ObjectType.Invoice_Allocation_Template_Line_Item__c.Createable}"/> 
       
       </span>
       
 
  <br/> <br/> 
  
       <apex:pageBlockTable value="{!IATLI}" var="Item" rendered="{!IATLI.Size>0}">
         <apex:column headerValue="Action" width="10%">
         
             <apex:commandButton value="Edit" action="{!EditIATLI}" reRender="hiddenBlock2" rendered="{!$ObjectType.Invoice_Allocation_Template_Line_Item__c.Updateable}">
                  <apex:param name="param1" value="{!Item.id}" assignTo="{!strIATLI}" ></apex:param>
              </apex:commandButton>
         
              <apex:commandButton value="Delete" action="{!deleteIATLI}" onclick="if(!confirm('Are you sure?')){return false;}" reRender="hiddenBlock2" rendered="{!$ObjectType.Invoice_Allocation_Template_Line_Item__c.Deletable}">
                  <apex:param name="param2" value="{!Item.id}" assignTo="{!strIATLI}"></apex:param>
              </apex:commandButton>
          </apex:column>
          
         
        
        
          
          <apex:column headerValue="{!$ObjectType.Invoice_Allocation_Template_Line_Item__c .Fields.Client__c.Label}">
              <apex:outputfield value="{!Item.Client__c}"/>
          </apex:column>
          
          
          <apex:column headerValue="{!$ObjectType.Invoice_Allocation_Template_Line_Item__c.Fields.Allocation_Qty__c.Label}">
              <apex:outputfield value="{!Item.Allocation_Qty__c}"/>
          </apex:column>
          
          
         </apex:pageBlockTable>
     
     
    
   
     
        <apex:pageBlockSection rendered="{!IATLI.size <= 0}">
           <apex:pageBlockSectionItem >
               <b>No records to display</b>
           </apex:pageBlockSectionItem>              
        </apex:pageBlockSection> 
     </apex:pageBlock>
 </apex:form> 
          
          
</apex:page>