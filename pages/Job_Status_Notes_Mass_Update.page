                    </span>
                    <p class="slds-page-header__title slds-m-right--medium slds-align-middle slds-truncate"  style="color:black;font-size:18px;"><b>Status Notes Update</b></p>
                </div> 
                <br/><br/><br/><br/>
                
            <div class="slds">
            <apex:pageBlock >
                <apex:pageMessages />
                <apex:outputPanel rendered="{!jblist.size>0}"> 
                    
                     <div id="scroller">
