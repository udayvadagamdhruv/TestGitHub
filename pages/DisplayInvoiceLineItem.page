<!-- This Page is used to display list of Invoice Line item under Vendor invoices tab for a particular Job -->
<apex:page controller="DisplayInvoiceExtension">
<apex:includeScript value="{!$Resource.Securityfilter}"/>
    <head>
    <style>
        #table_id td
        {
            border:0px;
        }
        #table_dd td
        {
            border:0px;
        }
        #table_s td
        {
            border:0px;
        }
         .hd
             {
             text-align:right;
             padding-right:20px!important;
             }
    </style>
    </head>
    <body>
<!--Added this code for edit and delete button. start -->
   <apex:form >

       <apex:actionFunction action="{!deleteRec}" name="deleteILI" reRender="pgb">
           <apex:param name="di1" assignTo="{!myClient}" value=""/>
       </apex:actionFunction>

       <apex:actionFunction action="{!editRec}" name="editILI" reRender="pgb" >
           <apex:param name="di2" assignTo="{!myClient}" value=""/>
       </apex:actionFunction>
       
    <script type="text/javascript">
    function statusLI(id1){
//        alert('button pressed..');
        var ist = '{!JSENCODE(HTMLENCODE(inSt))}';
//        alert('Ivoice Line Item ID : '+id1);
//        alert('Invoice Status : '+ ist);
        if(ist == "Paid"){
            alert("You cannot Delete this Invoice Line Item as status of the Invoice is Paid.");
        }
        else{
            if(confirm('The status of Invoice is "'+ist+'". Are you sure want to delete this Invoice Line Item ?')) {
//            alert("You can delete record");
            deleteILI(id1);
//            alert('af called');
            }
        }
    } 

    function EditLI(id2){
//        alert('button pressed..');
//       alert('Ivoice Line Item ID : '+id2);
//        alert('Invoice Status : '+ ist);
        if({!JSENCODE(HTMLENCODE(poId)) != NULL}){
            alert("You cannot edit this Invoice Line Item as it is created from PO.");
        }
        else if({!JSENCODE(HTMLENCODE(inSt)) == 'Paid'}){
            alert("You cannot edit this Invoice Line Item as status of the Invoice is Paid.");
        }
        else{
//            alert("You can Edit record");
                editILI(id2);
//            alert('af called');  
        }
    } 

    </script>
<!--end added code -->
        <apex:pageBlock >
           <div>
             <b>Invoice Line Items </b>
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
           &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
        
           <apex:commandButton action="{!add_ILI}" value="Add Line Items" id="btn1"  rendered="{!poId==NULL}"/> 
           <apex:commandButton action="{!add_ILI_from_poli}" value="Add Line Items" id="btn6"  rendered="{!poId!=NULL}"/> 
           <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display: none;"/>  
           <apex:commandButton value="Cancel" id="cancelButton" action="{!cancelme}" style="display: none;"/> 
      </div>
      <br/>
         <apex:pageBlockTable value="{!ILI}" var="item" rendered="{!ILI.Size>0}">
<!--added this column-->
           <apex:column ><!-- rendered="{!poId==NULL}"> -->
              <!-- call function. -->
              <apex:commandButton onClick="statusLI('{!item.ID}')" value="Delete" reRender="pgb" />&nbsp;&nbsp;
              <apex:commandButton onClick="EditLI('{!item.ID}')" value="Edit" reRender="pgb" />
           </apex:column> 
<!--end of column -->

           <apex:column headerValue="{!$ObjectType.Invoice_Line_Item__c.Fields.Estimate_Line_Item__c.Label}" rendered="{!poId!=NULL}">
              <apex:outputfield value="{!item.Estimate_Line_Item__r.Name}" rendered="{!poId!=NULL}"/>
           </apex:column> 
           
            <apex:column headerValue="{!$ObjectType.Invoice_Line_Item__c.Fields.GL_Code__c.Label}">
                  <apex:outputfield value="{!item.GL_Code__c}"/>
            </apex:column>
           
            <apex:column headerValue="{!$ObjectType.Invoice_Line_Item__c.Fields.Unit_Type__c.Label}">
                  <apex:outputfield value="{!item.Unit_Type__c}"/>
           </apex:column> 
          
      
           
            <apex:column headerValue="{!$ObjectType.Invoice_Line_Item__c.Fields.Amount__c.Label}">
            <table border="0" id="table_id">
            <tr>
               <td border="0">
                  <apex:outputfield value="{!item.Amount__c}">
<!-- Inline edit is true only if PO field is blank -->
                  <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn6" rendered="{!poId=NULL}"/>
                  </apex:outputfield> </td>
               <td> 
<!-- Icon is visible only if PO field is blank -->
                  <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Amount" rendered="{!poId=NULL}"/>  
               </td>
           </tr>
           </table>
           </apex:column> 
       </apex:pageBlockTable>
       
       <apex:pageBlockSection rendered="{!ILI.size <= 0}">
           <apex:pageBlockSectionItem >
                <b>   No records to display </b>
           </apex:pageBlockSectionItem>              
       </apex:pageBlockSection> 
      </apex:pageBlock>
    </apex:form>
        </body>
</apex:page>
<!-- End of Page -->