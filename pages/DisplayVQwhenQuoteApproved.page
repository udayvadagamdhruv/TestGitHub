<apex:page standardController="Quote__c" extensions="DisplayVQwhenQuoteApproved">

 <apex:form > 
<apex:pageBlock tabStyle="Vendor_Quote__c"> 
     <h1 class="labelCol2">Vendors</h1> <br/><br/>
      <apex:pageBlockTable value="{!vq}" var="vqli" rendered="{!vq.size > 0}"> <br/><br/><br/> 
      
          <apex:column headerValue="{!$ObjectType.Vendor_Quote__c.Fields.Name.Label}">
              <apex:outputText >{!vqli.name}</apex:outputText>
          </apex:column>
          
          <apex:column headerValue="{!$ObjectType.Vendor_Quote__c.Fields.Vendor__c.Label}">
            <apex:outputLink tabindex="tab1" value="/apex/VendorListView?id={!vqli.Vendor__r.Id}">{!vqli.Vendor__r.Name}</apex:outputLink> 
       <!--  <apex:outputText value="{!vqli.Vendor__r.Name}"/> -->
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Vendor_Quote__c.Fields.Date__c.Label}">
             <apex:outputField value="{!vqli.Date__c}"/>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Vendor_Quote__c.Fields.Amount__c.Label}">
         <apex:outputField value="{!vqli.Amount__c}"/>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.Vendor_Quote__c.Fields.Restrict__c.Label}">
         <apex:outputField value="{!vqli.Restrict__c}"/>
          </apex:column> 
          
     <!--     <apex:column headerValue="Unit Price">
         <apex:outputField value="{!vqli.Unit_Price__c}"/>
          </apex:column> 
          
          <apex:column headerValue="Quantity">
          <apex:outputField value="{!vqli.Quantity__c}"/>
          </apex:column> 
          
          <apex:column headerValue="Total Amount">
          <apex:outputField value="{!vqli.Total_Amount__c}"/>
          </apex:column> --> 
       
      </apex:pageBlockTable>
      
       <apex:pageBlockSection rendered="{!vq.size <= 0}">
           <apex:pageBlockSectionItem >
               <b>No records to display</b>
           </apex:pageBlockSectionItem>              
         </apex:pageBlockSection> 
   </apex:pageBlock> 
  </apex:form> 
</apex:page>
<!-- End of Page -->