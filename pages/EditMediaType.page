<!-- This page is used to edit Media Type. -->
<apex:page standardController="Media_Type__c" showHeader="true" sidebar="true" extensions="EditMediaTypeExtension" tabStyle="MyAdmin__tab">
<apex:sectionHeader title="{!Media_Type__c.Name}"/>
  <apex:form >
        <apex:pageBlock mode="edit">
        <apex:pageMessages />
            <apex:pageBlockButtons >
                    <apex:commandButton action="{!saveme}" value=" Save "></apex:commandButton>
                    <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
                 </apex:pageBlockButtons>
              
              <apex:pageBlockSection title="Media Type Information" columns="2" collapsible="false"> 
                  <apex:pageBlockSectionItem >
                      <apex:outputLabel Value="{!$ObjectType.Media_Type__c.Fields.Name.Label}"></apex:outputLabel>
                      <apex:inputField value="{!Media_Type__c.Name}" required="true" />
              </apex:pageBlockSectionItem>
           </apex:pageBlockSection>
           
             <apex:pageBlockSection collapsible="false">
               
               <apex:repeat value="{!$ObjectType.Media_Type__c.fieldsets.Media_Type_Field_Sets}" var="fieldValue">
               
                 <apex:Inputfield value="{!Media_Type__c[fieldValue]}"/>
                     
             </apex:repeat>   
               
               
             </apex:pageBlockSection>
         
           
           
             </apex:pageBlock>
    </apex:form>
</apex:page>