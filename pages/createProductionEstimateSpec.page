            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Production_Estimate_Spec_Item__c.Fields.Description__c.Label}"/>
               <apex:inputtextarea value="{!Production_Estimate_Spec_Item__c.Description__c}" cols="55" rows="4" style="resize:none;"/>
            </apex:pageBlockSectionItem>
         </apex:pageBlockSection>
      </apex:pageBlock>
   </apex:form>    

