            <apex:commandButton action="{!cancel}" value="Cancel"></apex:commandButton>
         </apex:pageBlockButtons>
             
         <apex:pageBlockSection title="Information" columns="2" collapsible="true">
            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Production_Estimate_Spec_Item__c.Fields.Name.Label}"/>
               <apex:inputField value="{!Production_Estimate_Spec_Item__c.Name}" required="true"/>
