<!-- This page is used to assign roles to selected Schedule Task from its detail page.(Overriding Add Role Button) -->
<apex:page standardController="ScheduleTaskRole__c" extensions="SchedTaskRoleunderschedtempExt" tabStyle="MyAdmin__tab" sidebar="true" docType="html-5.0" applyBodyTag="false" standardStylesheets="true" applyHtmlTag="False"  showHeader="False">
   
   
     <style>
         .pageHeader
       {
           color:white;
           background-color:#851225;
           height:70px;
           padding-top:15px; 
           position:fixed;
           z-index:999;
           width:100% !important;
           padding-left:22px;
       }
   
       .SectionHeader
       {
           background-color:Grey !important;
           color:white;
       }
       
       .bPageBlock 
       {
            margin: 20px 20px 20px 20px !important;
       }
       
       
       body
       {
               //background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgba(32, 92, 159, 0), rgb(32, 92, 159));
               background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, #d4d7da, #666) !important;
               //background-image:none !important;
               //background-color:#D7D7D7 !important;
               background-repeat: repeat-x;
               background-position: left top;
               background-attachment: fixed; 
               margin:0px !important;
       }
          .customImage{ height: 10px; width: 10px; }
          #rcorners1 
          {
                 border-radius:0%;
                 border: 1px solid #cccccc;
                 padding: 0px; 
                 width: 100%;
                 height: 0%;
          }
          #pagemessage
          {
              color:blue;
          }
          
          .required:after { content:" *";  color: Red;font:bold;}
           
           .slds table
           {
                height: 50px;
           }
           body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons
           {
               margin-top: -19px; 
           }
           .detailPage .bPageBlock, .editPage .bPageBlock
           {
               border-top-width: 0px;
           }
          
           .slds .slds-text-heading--large
           {
                font-size: 27px;
           }
           
           .pbHeader
           {
               background: white !important;
           }
           
           body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons 
           {
               background: white;
           }
          
           .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
           {
               border:none;
           }
           
           body .bEditBlock .pbBottomButtons, body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons
           {
               border:none;
           }
                       
           .slds .slds-checkbox .slds-checkbox--faux 
           {
                width: 20px;
                height: 20px;
                display: inline-block;
                position: relative;
                vertical-align: middle;
                border-width: 2px;
                border-style: solid;
                border-color: lightgrey;
                border-image: initial;
                border-radius: 2px;
                background: white;
                transition: border 0.1s linear, background-color 0.1s linear;
           }
            
           .slds .slds-checkbox [type=checkbox]:checked > .slds-checkbox--faux:after, .slds .slds-checkbox [type=checkbox]:checked ~ .slds-checkbox--faux:after 
           {
                height: 6px;
                width: 11px;
           }
           
           .bPageBlock .requiredInput .requiredBlock 
           {
                background-color:white;
                position: absolute;
                left: -4px;
                width: 3px;
                top: 1px;
                bottom: 1px;
            }
           
            errorM6, .errorM4, .errorM3, .errorM2, .errorS1 
            {
                  border-color: #c00;
            }
            .message 
            {
                background-color: #c00;
                border-style: solid;
                border-width: 0px;
                color: #000;
                padding: 0px 0px 0px 0px;
                margin: 0px 0px;
            }
            .errorM3 .msgIcon, .errorMedium 
            {
                background-image: url(); 
                background-position: 0 0;
                width:0px;
                height: 0px;
            }
            .pbBody td
            {
                color:white;
            }
            .message .messageText h4 
            {
                 font-weight: bold; 
                 display:block;
                 color:white;
            }
                .messageText br
{
   display:none !important;
}
.messageTable tr
{
   padding-top:10px !important;
   padding-bottom:10px !important;
}
.slds-notify, .slds-text-heading--small, .slds-theme--error, .message, .errorM3
{
    border-radius: 15px !important;
}
.pbBody
{
    padding:10px !important;
}
            <!----------------------------------- error Mesgg-------------------------------------->
   .slds a{color:white !important;}    
       
    </style>  
    
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
            
           <body>
            <!-- REQUIRED SLDS WRAPPER -->
              <div class="slds">
              
              
                  
              
              
                  <apex:form html-novalidate="novalidate">
                      
                      <div class="slds-media__body pageHeader">
  <span  class="slds-text-title--caps slds-line-height--reset" style="color:white"><b>Assign Roles</b></span>
  <span style="float:right;padding-right:20px;">     
 <b>  <apex:commandButton action="{!save}" value=" Save" styleClass="slds-button slds-button--neutral"></apex:commandButton>
                               <apex:commandButton action="{!Cancel}" value="Cancel" immediate="true" styleClass="slds-button slds-button--neutral"></apex:commandButton></b>
  </span>
  <p class="slds-page-header__title slds-m-right--medium slds-align-middle slds-truncate" style="color:white;font-size:18px;"><b><apex:outputField value="{!ScheduleTaskRole__c.Schedule_Task__c}"/></b> </p>
</div> 
<br/><br/><br/><br/>
                       
                      <apex:pageBlock mode="edit">
         
                         
                           <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" >
                                <apex:pageMessages />
                           </div> <br/>
                           
                            <div style="background-color:SteelBlue;color:white;" class="SectionHeader">
                           <h3 class="slds-section-title"><b>&nbsp;Roles</b></h3></div>
                           <br/>
                           
                           <div class="slds-grid slds-wrap">
                                 
                             <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" >
                                            
                                   
                                             
                                              <div class="slds-grid slds-wrap">  
                                                  <apex:repeat value="{!roleWraps}" var="r">
                                                       <div class="slds-col--padded slds-size--2-of-2 slds-medium-size--3-of-6 slds-large-size--4-of-12">&nbsp;&nbsp;
                                                       <label class="slds-checkbox" >
                                                          <apex:inputCheckbox value="{!r.checked}"/>
                                                               <span class="slds-checkbox--faux"></span>
                                                        </label>&nbsp;&nbsp;
                                                       <apex:outputField value="{!r.u.Name}"/> 
                                                       <hr style="margin:10px"/>
                                                       </div>
                                                  </apex:repeat>
                                              </div>
                                 </main>
                              </div><br/><br/>
                    </apex:pageBlock>
              </apex:form>     
           </div> 
        </body>
    </html>
   
   
</apex:page>
<!-- End of Page -->