<!-- This page is used to display Staff Tab. -->
<apex:page controller="UserandStaffList" tabStyle="MyAdmin__tab" sidebar="flase" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" showHeader="false" standardStylesheets="true">

      <head>
        <style>
        
        
          body
       {
               //background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgba(32, 92, 159, 0), rgb(32, 92, 159));
               background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, #d4d7da, #666) !important;
               //background-image:none !important;
               //background-color:#D7D7D7 !important;
               background-repeat: repeat-x;
               background-position: left top;
               background-attachment: fixed; 
              
              
               
       }

        
           .icon1
           {
              color:darkgrey;
           }
      
           .icon1:hover
           {
              color:black;
           }
        
        
            .slds .slds-dropdown-trigger .slds-dropdown
           {
                 margin-left: 37px;
    
           }
        
            .slds .slds-max-medium-table--stacked-horizontal td:before {
                text-transform: none;
            }
            
            .customImage {
                height: 10px;
                width: 10px;
            }
            
            #rcorners1 {
                border-radius: 0%;
                border: 1px solid #cccccc;
                padding: 0px;
                width: 100%;
                height: 0%;
            }
            
            #pagemessage {
                color: blue;
            }
            
            .required:after {
                content: " *";
                color: Red;
                font: bold;
            }
            
            .slds table {
                height: 50px;
            }
            
            body .bPageBlock,
            body .bPageBlock .pbBody,
            body .bPageBlock .pbBottomButtons {
                margin-top: -19px;
            }
            
            .detailPage .bPageBlock,
            .editPage .bPageBlock {
                border-top-width: 0px;
            }
            
            .slds .slds-text-heading--large {
                font-size: 27px;
            }
            
            .pbHeader {
                background: white !important;
            }
            
            body .bPageBlock,
            body .bPageBlock .pbBody,
            body .bPageBlock .pbBottomButtons {
                background: white;
            }
            
            .slds .slds-list--vertical.slds-has-dividers > .slds-list__item {
                border: none;
            }
            
            body .bEditBlock .pbBottomButtons,
            body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons {
                border: none;
            }
            
            .slds b,
            .slds strong,
            .slds dfn {
                font-weight: unset;
            }
            
            .slds .slds-table tr > td:first-child {
                padding-left: 6px;
                padding: 15px;
            }
            
             .slds .slds-card__footer {
               padding: 0px 16px 0px 0px;
          }
          .slds .slds-card__header {
            padding: 0px 10px 0px 0px;
            }
           .slds .slds-card__body {
                padding: 0px ;
            }
            
          .slds .slds-card {
                padding: 0;
                border-radius: 0px;
                background-clip: padding-box;
                background-color:white;
                }
            
            .slds .slds-table--bordered {
                border-top: 0px solid #d8dde6;
                border-bottom: 1px solid #d8dde6;
              }
                        
            .slds .slds-card__body {
                margin-bottom: -0.25rem;
                margin-top: -0.15rem;
               }
        
        .SectionHeader
       {
           background-color:Grey !important;
           color:white;
       }
        .slds .slds-table tr > td:first-child {
    padding-left: 24px !important;
    padding: 7px;
}  
       
        
     </style>
   </head>     

        
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    
    <div class="slds" >
       
        <apex:form html-novalidate="novalidate">
        
        
               <div class="slds-page-header" style="width:100%;{!if($User.UITheme == 'Theme1' || $User.UITheme == 'Theme2' || $User.UITheme == 'Theme3','position:fixed', 'position:fixed;z-index:15;')}" >
                           <div class="slds-grid">
                                <div class="slds-col slds-has-flexi-truncate">
                                    <div class="slds-media slds-no-space slds-grow">
                                        <div class="slds-media__figure">
                                           <svg class="slds-icon slds-icon-standard-user" aria-hidden="true">
                                <use xlink:href="{!$Resource.SLDS}/assets/icons/custom-sprite/svg/symbols.svg#custom103"></use>
                            </svg>
                        
                   
                                        </div>                        
                                        <div class="slds-media__body">
                                            <span class="slds-text-title slds-line-height--reset">Staff</span >
                                          
                                          <span style="float:right;padding-right:10px;">     
                                                 <b>  
                                                     
                             <apex:commandButton action="{!CreateStaffandUser}" value="New Staff/User" immediate="true" styleClass="slds-button slds-button--neutral slds-button-group" />
                                                        
                                                           
                                                 </b>
                                              </span>
                                          
                                        </div>
                                   </div>
                                </div>
                          </div>
                     </div>
        
        
        
        

             <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
                  <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
             </div>  <br/>

             <br/><br/><br/> 
                               
        
       
            
             
                     
             <apex:outputPanel id="dq"> 
                <apex:outputPanel rendered="{!list_user.size > 0}"> 
                  <div class="slds-card" style="margin:0px 10px 10px 10px ! important;">
                  
                  
           
                  
                   <div class="SectionHeader" style="background-color:SteelBlue;color:white;margin:10px 10px 15px 10px ! important;">
                 <h3 class="slds-section-title"><b>&nbsp;Licensed User List</b></h3>
                 </div>
             
                  
                      <div class="slds-card__body">
                      
                            <apex:outputPanel id="dv"> 
                            <apex:outputPanel rendered="{!list_user.size > 0}">  

                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <thead class="slds-truncate">
                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.User.Fields.Name.Label}</th>
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.User.Fields.Email.Label}</th>
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.User.Fields.Username.Label}</th>
                                        <th class="slds-size--1-of-4" scope="col">Role</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    <apex:repeat value="{!list_user}" var="user" id="usertable" rendered="{!list_user.size > 0}">

                                        <tr class="slds-hint-parent">
                                        
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.User.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputLink value="/apex/StaffandUserDetailPageLightning?id={!user.Id}" tabindex="tab1">{!user.Name}</apex:outputLink> 
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.User.Fields.Email.Label}">
                                                <div>
                                                    <apex:outputField value="{!user.Email}"/>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.User.Fields.Username.Label}">
                                                <div>
                                                   <apex:outputField value="{!user.Username}"/>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-4" data-label="Role">
                                                <div>
                                                   <apex:outputField value="{!user.UserRole.name}"/>
                                                </div>
                                            </td>
                                        </tr>
                                    </apex:repeat>
                                </tbody>
                            </table>
                        </apex:outputPanel>
                       </apex:outputPanel> 
                    </div>
                 </div>
              </apex:outputPanel>
           </apex:outputPanel>
           
           
          <apex:outputPanel id="deqt" >
              <apex:outputPanel rendered="{!list_user.size <= 0}">
                  <div>  <b> No User to display</b>  </div>
              </apex:outputPanel>
          </apex:outputPanel>
           
          <br/>         
       <!------------------------------------------------------------ Staff List -------------------------------------------------------------------------------->   
          
          
              
          
             
            
                     
             <apex:outputPanel > 
                <apex:outputPanel rendered="{!list_staff.size > 0}"> 
                  <div class="slds-card"  style="margin:0px 10px 10px 10px ! important;">
                  
                         
            <div class="SectionHeader"  style="background-color:SteelBlue;color:white;margin:10px 10px 15px 10px ! important;">
                 <h3 class="slds-section-title"><b>&nbsp;Unlicensed Staff List</b></h3>
             </div>
                      <div class="slds-card__body">
                      
                            <apex:outputPanel > 
                            <apex:outputPanel rendered="{!list_staff.size > 0}">  

                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <thead class="slds-truncate">
                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.Staff__c.Fields.Name.Label}</th>
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.Staff__c.Fields.Email__c.Label}</th>
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.Staff__c.Fields.Username__c.Label}</th>
                                        <th class="slds-size--1-of-4" scope="col">{!$ObjectType.Staff__c.Fields.Role__c.Label}</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    <apex:repeat value="{!list_staff}" var="staff" id="stafftable" rendered="{!list_staff.size > 0}">

                                        <tr class="slds-hint-parent">
                                        
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.Staff__c.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputLink value="/apex/StaffDetailPageLightning?id={!staff.Id}" >{!staff.Name}</apex:outputLink>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.Staff__c.Fields.Email__c.Label}">
                                                <div>
                                                     <apex:outputField value="{!staff.Email__c}"/>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.Staff__c.Fields.Username__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!staff.Username__c}"/>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-4" data-label="{!$ObjectType.Staff__c.Fields.Role__c.Label}">
                                                <div>
                                                   <apex:outputField value="{!staff.Role__c}"/>
                                                </div>
                                            </td>
                                        </tr>
                                    </apex:repeat>
                                </tbody>
                            </table>
                        </apex:outputPanel>
                       </apex:outputPanel> 
                    </div>
                 </div>
              </apex:outputPanel>
           </apex:outputPanel>
           
           
          <apex:outputPanel >
              <apex:outputPanel rendered="{!list_staff.size <= 0}">
                  <div>  <b>No Staff to display</b> </div>
              </apex:outputPanel>
          </apex:outputPanel>
          
      
          
             
        </apex:form>
      </div>
    </html>
</apex:page>
<!-- End of Page -->