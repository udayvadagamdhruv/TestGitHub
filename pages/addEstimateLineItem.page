<!-- This page is used to add Estimate Line Item for a Purchase order -->
<apex:page controller="addEstimateLineItem" tabStyle="Job__c" sidebar="true">
<apex:form >
    <apex:pageBlock rendered="{!roleWraps.size > 0}">
        <apex:pageBlockTable value="{!roleWraps}" var="p" id="ProductsTable">
            <apex:column headerValue="Action">
                <apex:inputCheckbox value="{!p.checked}"/>
            </apex:column>
            <apex:column value="{!p.e.Name}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Name.Label}" />
            <apex:column value="{!p.e.GL_Code__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Code__c.Label}" />
            <apex:column value="{!p.e.Unit_Type__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Unit_Type__c.Label}" />
            <apex:column value="{!p.e.Quantity__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Quantity__c.Label}" />
            <apex:column value="{!p.e.Total_Amount__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Total_Amount__c.Label}" />
        </apex:pageBlockTable>
        <br/>
        <apex:commandButton action="{!Save}" value="Add" title="Click on the button to Add Estimate Line Items."/>&nbsp;&nbsp;
        <apex:commandButton action="{!Back}" value="Go Back" title="Click on the button to go back."/>
    </apex:pageBlock>
    <br/>
    
    <apex:pageBlock rendered="{!roleWraps.size <= 0}"> 
        <p>
          All Approved estimate line items for this vendor have already been added to Purchase Orders.
        </p>       
        <br/>
        <apex:commandButton action="{!Back}" value="Go Back" title="Click on the button to go back."/>
   </apex:pageBlock>
</apex:form> 
</apex:page>
<!-- End of Page  -->