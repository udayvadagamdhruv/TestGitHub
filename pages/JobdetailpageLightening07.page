     <script>
       
        function getParameterByName(name, url) {
       
            if (!url) url = window.location.href;
            name = name.replace(/[\[\]]/g, "\\$&");
            var regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
                results = regex.exec(url);
            if (!results) return null;
            if (!results[2]) return '';
            return decodeURIComponent(results[2].replace(/\+/g, " "));
        }
        
        
        
        
        j$(document).ready(function () {
            // Handler for .ready() called.
            
            document.getElementById('DetailsSectionDiv').style.display='block';
            if(getParameterByName('section') != null){
                
                  //alert(getParameterByName('section'));
                
                j$('html, body').animate({
              
                    scrollTop: j$('#'+getParameterByName('section')).offset().top-200
                }, 'fast');
            }
            
           
            
        });
        
        
       
     
 
 j$(window).scroll(function() {

    if (j$(this).scrollTop()>0)
     {
        
        j$('.slds-page-header__detail-row').hide();
        j$('#progressBartd').hide();
        j$('#barchart').show();
        
     }
    else
     {
       j$('.slds-page-header__detail-row').show();
       j$('#progressBartd').show();
       j$('#barchart').hide();
     }
 });
 



        
        
        
        
        
