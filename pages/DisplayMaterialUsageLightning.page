<apex:page controller="DisplayMaterialUsageController"  id="frm" sidebar="flase" docType="html-5.0" applyHtmlTag="false" applyBodyTag="false" showHeader="false" standardStylesheets="true">
  
        <head>
        <style>

           .icon1
           {
              color:darkgrey;
           }
      
           .icon1:hover
           {
              color:black;
           }
        
            .slds .slds-dropdown-trigger .slds-dropdown
           {
                 margin-left: 37px;
    
           }
        
            .slds .slds-max-medium-table--stacked-horizontal td:before {
                text-transform: none;
            }
            
            .customImage {
                height: 10px;
                width: 10px;
            }
            
            #rcorners1 {
                border-radius: 0%;
                border: 1px solid #cccccc;
                padding: 0px;
                width: 100%;
                height: 0%;
            }
            
            #pagemessage {
                color: blue;
            }
            
            .required:after {
                content: " *";
                color: Red;
                font: bold;
            }
            
            .slds table {
                height: 50px;
            }
            
            body .bPageBlock,
            body .bPageBlock .pbBody,
            body .bPageBlock .pbBottomButtons {
                margin-top: -19px;
            }
            
            .detailPage .bPageBlock,
            .editPage .bPageBlock {
                border-top-width: 0px;
            }
            
            .slds .slds-text-heading--large {
                font-size: 27px;
            }
            
            .pbHeader {
                background: white !important;
            }
            
            body .bPageBlock,
            body .bPageBlock .pbBody,
            body .bPageBlock .pbBottomButtons {
                background: white;
            }
            
            .slds .slds-list--vertical.slds-has-dividers > .slds-list__item {
                border: none;
            }
            
            body .bEditBlock .pbBottomButtons,
            body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons {
                border: none;
            }
            
            .slds b,
            .slds strong,
            .slds dfn {
                font-weight: unset;
            }
            
            .slds .slds-table tr > td:first-child {
                padding-left: 6px;
                padding: 15px;
            }
            
             .slds .slds-card__footer {
               padding: 0px 16px 0px 0px;
          }
          .slds .slds-card__header {
            padding: 0px 10px 0px 0px;
            }
           .slds .slds-card__body {
                padding: 0px ;
            }
            
          .slds .slds-card {
                padding: 0;
                border-radius: 0px;
                background-clip: padding-box;
                background-color:white;
                }
            
            .slds .slds-table--bordered {
                border-top: 0px solid #d8dde6;
                border-bottom: 1px solid #d8dde6;
              }
                        
            .slds .slds-card__body {
                margin-bottom: -0.25rem;
                margin-top: -0.15rem;
               }
        
        .dateOnlyInput input {
            width: 10.5em !important;
        }
               
               
       .dropdownmenuicon:hover{
            background-color:#16325c !important;
            } 
             .dropdownmenuicon:hover #childmenu {
              color:white !important;
             }
                         
                        
     </style>
     
       
        
    </head>
    
    
    <meta http-equiv="Content-type" content="text/html; charset=utf-8" />

    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
    
         <meta name="viewport" content="width=device-width, initial-scale=1"/>
          <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
          <link href="{!URLFOR($Resource.JobPage,'JobPage/MaterialIcons.css')}" rel="stylesheet"/>
         <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
     
   <apex:slds />
    

         <apex:outputPanel id="pbload"> 
            <div class="slds">
              
                <apex:form html-novalidate="novalidate" id="frmid">
              
                
                 <apex:pageBlock mode="edit">
                      <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" >
                         <apex:pageMessages />
                      </div><br/>
                      
                       <div align="center">
                          <apex:commandButton action="{!createMU}" value="Add Material Usage" id="btn2" rendered="{!$ObjectType.Material_Usage_line_item__c.Deletable}" styleClass="slds-button slds-button--neutral slds-button-group"/> 
                        </div>
                        
                        <br/>
                        
                        <apex:outputPanel rendered="{!MU.Size>0}">
                          <div class="slds-card" >             
                               <div class="slds-card__body">     
                               
                               
                                 <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover" >
                                        <thead class="slds-truncate">
                                            <tr class="slds-text-title">
                                                <th class="slds-size--1-of-7" scope="col">Action</th>
                                                <th class="slds-size--1-of-7" scope="col">{!$ObjectType.Material_Usage_line_item__c.Fields.Date__c.Label}</th>
                                                <th class="slds-size--1-of-7" scope="col">{!$ObjectType.Material_Usage_line_item__c.Fields.Type__c.Label}</th>
                                                <th class="slds-size--1-of-7" scope="col">{!$ObjectType.Material_Usage_line_item__c.Fields.Description__c.Label}</th>
                                                <th class="slds-size--1-of-7" scope="col">{!$ObjectType.Material_Usage_line_item__c.Fields.Debit__c.Label}</th>
                                                <th class="slds-size--1-of-7" scope="col">{!$ObjectType.Material_Usage_line_item__c.Fields.Credit__c.Label}</th>
                                                <th class="slds-size--1-of-7" scope="col">{!$ObjectType.Material_Usage_line_item__c.Fields.Qty_On_Hand__c.Label}</th>
                                            </tr>
                                        </thead>
                                 
                                        <tbody> 
                                           <apex:variable value="{!0}" var="rowNumber" />
                                             <apex:repeat value="{!MU}" var="MUItem" rendered="{!MU.Size>0}"> 
                      
                                                <tr class="slds-hint-parent">
                                                    <td class="slds-size--1-of-85" data-label="Action">
                                                           <div class="slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open quotebutton">
                                                                 &nbsp;&nbsp;  
                                                                    <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small slds-shrink-none dropdownmenuicon ">
                                                                           <i  id="childmenu" style="color:#9faab5;font-size:15px;margin:2px 5px;" class="fa">&#xf0d7;</i>
                                                                    </div>
                                                                    
                                                         
                                                                    <div class="slds-dropdown slds-dropdown__left slds-dropdown_xx--small quoteclass">
                                                                    
                                                                       <ul class="slds-dropdown__list" role="menu">
                                                                         
                                                                            <li class="slds-dropdown__item" role="presentation">
                                                                              <apex:variable var="rowNumber" value="{!rowNumber+1}" />
                                                                              
                                                                                <apex:commandLink value="Delete" action="{!deleteMU}" onclick="if(!confirm('Are you sure?')){return false;}" reRender="frm" rendered="{!rowNumber == 1}">
                                                                                    <apex:param name="param2" value="{!MUItem.id}" assignTo="{!strMU}"></apex:param>
                                                                                     &nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">delete</i> 
                                                                                </apex:commandLink>
                                                                              
                                                                            </li>
                                                                        
                                                                        </ul>
                                                                  </div> 
                                                           </div>
                                                        </td>
                                                        
                                                        <td class="slds-size--1-of-7" data-label="{!$ObjectType.Material_Usage_line_item__c.Fields.Date__c.Label}">
                                                            <div>
                                                                  <apex:outputfield value="{!MUItem.Date__c}"/>
                                                            </div>
                                                        </td>
                                                                                                              
                                                       <td class="slds-size--1-of-7" data-label="{!$ObjectType.Material_Usage_line_item__c.Fields.Type__c.Label}">
                                                            <div>
                                                                  <apex:outputfield value="{!MUItem.Type__c}"/>
                                                            </div>
                                                        </td>
                                                        
                                                        <td class="slds-size--1-of-7" data-label="{!$ObjectType.Material_Usage_line_item__c.Fields.Description__c.Label}">
                                                            <div>
                                                                  <apex:outputfield value="{!MUItem.Description__c}"/>
                                                            </div>
                                                        </td>
                                                        
                                                        <td class="slds-size--1-of-7" data-label="{!$ObjectType.Material_Usage_line_item__c.Fields.Debit__c.Label}">
                                                            <div>
                                                                  <apex:outputfield value="{!MUItem.Debit__c}"/>
                                                            </div>
                                                        </td>
                                                        
                                                        <td class="slds-size--1-of-7" data-label="{!$ObjectType.Material_Usage_line_item__c.Fields.Credit__c.Label}">
                                                            <div>
                                                                  <apex:outputfield value="{!MUItem.Credit__c}"/>
                                                            </div>
                                                        </td>
                                                        
                                                        <td class="slds-size--1-of-7" data-label="{!$ObjectType.Material_Usage_line_item__c.Fields.Qty_On_Hand__c.Label}">
                                                            <div>
                                                                  <apex:outputfield value="{!MUItem.Qty_On_Hand__c}"/>
                                                            </div>
                                                        </td>
                                                                                                              
                                                </tr>
            
                                            </apex:repeat> 
                                      </tbody>
                            </table> 
                           </div>
                        </div> 
                     </apex:outputPanel>  
                     
                       <apex:outputPanel rendered="{!MU.size <= 0}">
                             <b>No records to display</b>
                       </apex:outputPanel>  
                      
                         
                        
                    </apex:pageBlock> 
              </apex:form>
          </div>
      </apex:outputPanel>
      
    </html>
      
                               
                               
                                       
</apex:page>