        <script>
           // var j$ = jQuery.noConflict();
            
            var fixHelperModified = function(e, tr) {
                var $originals = tr.children();
                var $helper = tr.clone();
                $helper.children().each(function(index) {
                    $(this).width($originals.eq(index).width())
                });
                return $helper;
            },
            updateIndex = function(e, ui) {
                    
                    $('td.index', ui.item.parent()).each(function (i) {
                        //$(this).html(i + 1);
                        $(this).children("input")[0].value = i+1;
                        
                    });
                    
                    
                    var scheduleCalc = '{!JobRecord.Schedule_Calc__c }';
                    var taskIds = document.getElementsByClassName('TaskId');
                    var taskIdsLength = taskIds.length;
                    
                    if(scheduleCalc == 'Start Date'){
                        var startDate = document.getElementsByClassName('StartDate')[0].value;
                        var taskId = taskIds[0].innerHTML;
                        document.getElementsByClassName('dt')[0].value = startDate;
                        document.getElementsByClassName('taskId123')[0].value = taskId;                       
                    }
                    else if(scheduleCalc == 'End Date'){
                        var endDate = document.getElementsByClassName('EndDate')[0].value;
                        var taskId = taskIds[taskIdsLength-1].innerHTML;
                        document.getElementsByClassName('dt')[0].value = endDate;
                        document.getElementsByClassName('taskId123')[0].value = taskId;
                    }
                    saveOrder();
            };
    
            j$("table.sortable>tbody").sortable({ helper: fixHelperModified, stop: updateIndex});
            j$("#subsortsortable>tbody").disableSelection();
        </script>
        
        
        
