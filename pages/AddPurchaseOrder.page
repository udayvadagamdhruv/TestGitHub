<!-- This page is used to add Purchase Order For Invoice record. -->
<apex:page controller="AddPurchaseOrderExtension" tabStyle="Job__c">
    <apex:form >
            <apex:pageBlock rendered="{!roleWraps.size > 0}">
                <apex:pageBlockTable value="{!roleWraps}" var="p" id="ProductsTable">
                     <apex:column >
                        <apex:inputCheckbox value="{!p.checked}"/>
                     </apex:column>
                    
                     <apex:column value="{!p.e.Name}" headerValue="{!$ObjectType.Purchase_Order__c.Fields.Name.Label}" />
                    
                    <apex:column value="{!p.e.Total_Amount__c}" headerValue="{!$ObjectType.Purchase_Order__c.Fields.Total_Amount__c.Label}" />
                </apex:pageBlockTable>
                <br/>

                <apex:commandButton action="{!Save}" value="Add"/>&nbsp;&nbsp;
                <apex:commandButton action="{!Back}" value="Go Back"/>
            </apex:pageBlock>
            
            <br/>
            <apex:pageBlock rendered="{!roleWraps.size <= 0}"> 
                <p>
                     There is no more Purchase Orders for Selected Vendor. 
                </p>       
                <br/>
                <apex:commandButton action="{!Back}" value="Go Back"/>
            </apex:pageBlock>
    </apex:form> 
</apex:page>
<!-- End of Page -->