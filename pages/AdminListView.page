    <apex:tab label="{!$ObjectType.Tag_Template__c.label}s" name="Tag Template" id="tagTemp" styleClass="labelCol" style="width:140px" rendered="{!$ObjectType.Tag_Template__c.accessible}">
     <apex:include pageName="TagTempEnhancedList"/>  
