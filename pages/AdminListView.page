    <!-- Tab label for Production Estimate Templates -->
     <apex:tab label="{!$ObjectType.Production_Estimate_Template__c.label}s" name="Production Estimate Templates" id="ProductionsEst" style="width:220px;" styleClass="labelCol" rendered="{!$ObjectType.Production_Estimate_Template__c.accessible}">
       <apex:include pageName="ProductionEstTempEnhancedList"/>
     </apex:tab> 
  <!-- End of Production Estimate Templates -->
 
 
   <!-- Tab label for Holiday --> 
     <apex:tab label="{!$ObjectType.Holiday__c.label}s" name="Holidays" id="holidays" styleClass="labelCol" rendered="{!$ObjectType.Holiday__c.accessible}">
        <apex:enhancedList type="Holiday__c" height="500" rowsPerPage="50" id="Holidaylist" customizable="false"/> 
     </apex:tab>  
   <!-- End of Holiday Tab --> 
  
  <!-- Tab Label For Invoice Allocation template -->
   
     <apex:tab label="{!$ObjectType.Invoice_Allocation_Template__c.label}s" name="Invoice Allocation Templates" id="InvoiceAllocation" styleClass="labelCol" style="width:220px" rendered="{!$ObjectType.Invoice_Allocation_Template__c.accessible}">
         <apex:include pageName="InvAllocationTempEnhancedList"/>
     </apex:tab> 
     
   <!--End of Invoice Allocation template Tab --> 
 
 
   <!-- Tab label for Staff --> 
     <apex:tab label="Staff" id="staffs" styleClass="labelCol" name="Staff">
        <apex:include pageName="StaffTab"/>
     </apex:tab> 
   <!-- End of Staff Tab -->   
 
   <!-- Tab label for Role --> 
     <apex:tab label="Roles" id="roles" Name="Roles" styleClass="labelCol">
        <apex:include pageName="RoleTab"/> 
</apex:tab>  
   <!-- End of Role Tab -->   
   
   <!-- Tab label for Campaign -->  
 <!--    <apex:tab label="Campaigns" name="Campaign" id="campaign" styleClass="labelCol">
        <apex:enhancedList type="Campaign__c" height="300" rowsPerPage="50" id="Campaignlist" customizable="false"/> 
     </apex:tab>  -->
   <!-- End of Campaign Tab -->   
 
   <!-- Tab Label For Media Type -->
     <apex:tab label="{!$ObjectType.Media_Type__c.label}s" name="Media Type" id="mediatype" styleClass="labelCol" style="width:120px" rendered="{!$ObjectType.Media_Type__c.accessible}">
         <apex:include pageName="MediaTypeEnhancedList"/>
     </apex:tab> 
     
   <!--End of Media Type Tab --> 
 
   <!-- Tab Label For GL Department -->
     <apex:tab label="{!$ObjectType.GL_Department__c.label}s" name="GL Department" id="GLDept" styleClass="labelCol" style="width:140px" rendered="{!$ObjectType.GL_Department__c.accessible}">
         <apex:include pageName="GLDepartmentEnhancedList"/>  
     </apex:tab>   
     
   <!--End of GL Department Tab --> 
 
