<apex:page standardController="Job__c" extensions="OnlineJobRequestForm" showHeader="false" >

    <style>
    
         td,th 
         {
            font-size:13px; font-family:Arial;
         }
         input ,select,textarea
         {
           
            background-color: #EEEEEE;
        }
    
    </style>
    
  <div style="padding-left:40px;padding-right:25px;">
   <apex:image id="JS_logo" value="" rendered="{!imageNotFound == True}" />
      <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>
        
       <br/>
        
         <div style="font-size:15px; font-family:Arial;font-weight:bold;">
            <marquee behavior="alternate" direction="left"> <font color="red" size="2px;"> Please fill out ALL fields so we can provide you with excellent service!  </font></marquee> 
         </div>
        <br/>
         <div style="font-weight:bold;font-size:24px;font-family:Arial;">
               <center> Job Request Form</center>       
        </div><br/>
         <apex:pageMessages />
         <apex:form >
            <table width="100%">
                 <tr width="100%">
                  <td width="100%">
                    <table width="100%" style = "background-color:#A9A9A9;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                              <td width="100%">
                                   <b> <apex:outputText value="JOB DETAILS" style="font-size:14px;font-weight:bold;color:white;font-family:Arial;"/>  </b>
                              </td>
                        </tr>
                    </table>
                   </td>
                </tr> 
            </table>
            
            
            
                   
                   <apex:actionRegion >
                       <apex:actionFunction name="calSpecs" action="{!specList}" reRender="pgbt"/> <br/><br/>
                   
                         <table width="90%" style="padding-left:30px;" >
                         
                            
                         
                             <tr width="100%"  height="30px;">
                             
                                 <th width="10%">
                                      <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Name.Label}:"></apex:outputLabel>
                                 </th>
                                 <td width="40%">
                                     <apex:outputPanel >
                                         <apex:inputField value="{!Job__c.Name}" html-placeholder="Enter Job Name " />
                                          </apex:outputPanel>
                                 </td>
                                 
                                
                                 <th width="10%">
                                      <apex:outputLabel value="Due Date:" />
                                 </th>
                                 <td width="40%">
                                    <apex:outputPanel >
                                      <apex:inputfield value="{!Job__c.Due_Date__c}" html-placeholder="Enter Date "/>
                                    </apex:outputPanel>
                                 </td>
                             </tr>
                             
                              <tr width="100%"   height="30px;">
                              
                                 <th width="10%">
                                      <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Media_Types__c.Label}:" for="MediaTypeName" >
                                      </apex:outputLabel>
                                 </th>
                                 <td width="40%">
                                      <apex:actionRegion >
                                         <apex:outputPanel >
                                            <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;"> 
                                            <!--span Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;"-->
                                               <div class="requiredBlock"> </div>
                                               <div> </div>
                                               <apex:selectList id="MtName" value="{!MTName}" size="1" >
                                                  <apex:actionSupport event="onchange" rerender="ST"/>
                                                  <apex:selectOptions value="{!MediaTypes}">
                                                  </apex:selectOptions> 
                                               </apex:selectList>
                                            </span>
                                         </apex:outputPanel>  
                                      </apex:actionRegion>
                                 </td>
                                
                                
                                 <th width="10%">
                                      <apex:outputLabel value="Job Type:"  for="JT" ></apex:outputLabel> 
                                 </th>
                                 <td width="40%">
                                     <apex:outputPanel >
                                         <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                                            <div class="requiredBlock"></div>
                                            <div></div>
                                            <apex:selectList id="ST" value="{!ScheduleTemp}" size="1" onselect="{!Job__c.Schedule_Template__c}"  >
                                               <apex:selectOptions value="{!ScheduleTemplates}" >
                                               </apex:selectOptions>
                                            </apex:selectList>
                                         </span>
                                      </apex:outputPanel> 
                                 </td>
                                 
                                 
                             </tr>
                             
                              <tr width="100%"  height="30px;">
                                 
                                  
                                 <th width="10%">
                                      <apex:outputLabel value="Creative Brief:" for="SpecTemp" />
                                 </th>
                                 <td width="40%">
                                       <apex:selectList id="SpecTempName" value="{!SpecTempName}" size="1" onchange="calSpecs();" >
                                           <apex:selectOptions value="{!SpecificationTemplates}" ></apex:selectOptions>
                                       </apex:selectList>  
                                 </td>
                                
                              <!--   <th width="10%">
                                      <apex:outputLabel value="Requested By:"/>
                                 </th>
                                 <td width="40%">
                                    <apex:inputText value="{!Job__c.Dummy_Text_3__c}" html-placeholder="Enter Your Name " / >
                                 </td>-->
                                
                             </tr>
                             
                             
                              <tr width="100%" height="30px;">
                              
                                 <th width="10%" valign="top">
                                     <apex:outputLabel value="Job Description:"/>
                                 </th>
                                 <td width="90%"  colspan="4">
                                     <apex:inputTextarea value="{!Job__c.Job_Description__c}" rows="6" cols="100"  style="resize:none" html-placeholder="Enter Description "/> 
                                 </td>
                                 
                             </tr>
                       </table>
                     
                   <br/>
                   
                    <apex:outputPanel id="pgbt"  >  
                    
                         <table width="100%">
                             <tr width="100%">
                              <td width="100%">
                                <table width="100%" style = "background-color:#A9A9A9;margin-bottom:-10px;">
                                    <tr style="page-break-inside: avoid;">
                                          <td width="100%">
                                               <b> <apex:outputText value="Job Specs" style="font-size:14px;font-weight:bold;color:white;font-family:Arial;"/>  </b>
                                          </td>
                                    </tr>
                                </table>
                               </td>
                            </tr> <br/>
                        </table>
                        
                        <br/><br/>
                        <table width="70%" style="padding-left:30px;">
                            <apex:repeat value="{!lstspecItems}" var="lst"  rendered="{!(  lstspecItems.size != null)}"> 
                               <tr width="100%" height="30px" style="padding-left:20px;">
                                  <td width="35%"><b> <apex:outputField value="{!lst.Name}" style="font-size:14px;font-weight:bold;font-color:#999999ff;"/></b></td>
                                  <td width="65%" style="text-align:left;" ><apex:inputTextarea value="{!lst.Description__c}" rows="1" cols="100"/> </td>
                               </tr> 
                            </apex:repeat>
                        </table>
            
                          
                    </apex:outputPanel>  
                   
                   
            </apex:actionRegion>
            
            
            
            <br/><br/>
            <table width="70%" style="padding-left:50px;">
                   
            </table>
            
            
               <br/><br/>
                     <center>
                        <apex:commandButton value="Save" action="{!saveme}" style="font-size:16px;"/>
                        <apex:commandbutton value="Cancel" action="{!cancel}" style="font-size:16px;"/>
                     </center><br/><br/>
          </apex:form>
          </div>
</apex:page>