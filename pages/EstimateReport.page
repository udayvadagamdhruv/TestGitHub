<!-- This page is used to display Estimate Report. -->
<apex:page standardController="Job__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="EstimateReportExtension" renderAs="pdf">
<head>
    <style type="text/css">

    .rightalign
    {
        text-align:right;
    }
    .leftalign
    {
        text-align:left;
    }
    .centeralign
    {
        text-align:center;
    }

    div.tab
    {
        width:100%;
        border:solid black;
    }
    @page
    {

        /* Landscape orientation */
        size:landscape;

        /* Put page numbers in the bottom right corner of each
        page in the pdf document. */
        @bottom-right {
          content: "Page " counter(page);
          font-family: sans-serif;
          font-size:8pt;
        }
   
        @bottom-left 
         {
            content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
            background-repeat: no-repeat;
            font-size:8pt;
            font-family: sans-serif;
        }
      }

  body 
  {
   font-family: sans-serif;
   font-size:10pt;
  }
  
  th
  {
      font-size:10pt
      font-style:bold;
      font-family: sans-serif;
  }


  td
  {
    font-size:8pt;
    font-family: sans-serif;
  }
  
  div.footer {
    position : running(footer) ;
}

  /* you can even define custom classes that utilize your static resources */
 

</style>
</head>

<body>
   <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
    <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>
<div style="float:right;padding-right:15px;font-size:15px;font-style:normal;font-family: sans-serif;font-weight:bold">
ESTIMATE
</div>
<br/><br/>

<table width="100%">

     <tr width="100%">
                  <td align="left">
                       <hr color="black" width="100%"/>
                  </td>
                </tr>
                
                <tr width="100%">
                  <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                              <td width="100%">
                                   <b> <apex:outputText value="DETAILS" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/>  </b>
                              </td>
                        </tr>
                    </table>
                   </td><br/>
                </tr> 



              <tr>
                 <td width="50%" align="left" style="padding-left:20px;">
                    <table width="100%" align="left">
                    
                        <tr>
                        <td > <apex:outputLabel value="{!$ObjectType.Job__c.Fields.JS_Client__c.Label}" style="font-weight: bold;"/> </td>
                        <td align="left"> <apex:outputText value="{!Job__c.JS_Client__r.Name}"/> </td>
                       </tr>
                       <tr>
                        <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Campaign__c.Label}" style="font-weight: bold;"/> </td>
                        <td width="80%" align="left"> <apex:outputText value="{!Job__c.Campaign__r.name}"/> </td>
                       </tr>
                       <tr>
                        <td align="left"  width="20%"> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="font-weight: bold;"/> </td>
                        <td  width="80%" align="left"><apex:outputText value="{!Job__c.Job_Auto_Number__c}"/> </td>
                       </tr>
                       <tr>
                        <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Name.Label}" style="font-weight: bold;"/> </td>
                        <td  width="80%" align="left"> <apex:outputText value="{!Job__c.Name}"/> </td>
                       </tr>
                       <tr>
                        <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Description__c.Label}" style="font-weight: bold;"/> </td>
                        <td  width="80%" align="left"> <apex:outputText value="{!Job__c.Job_Description__c}"/> </td>
                       </tr>
                      
                     <!-- <apex:outputText value="Job # : {!Job__c.Job_Id__c}" style="align:left;"/> <br/>
                      <apex:outputText value="Job Name : {!Job__c.Name}" style="align:right;"/> <br/>
                      <apex:outputText value="Job Description : {!Job__c.Job_Description__c}" style="align:right;"/> <br/> -->
                      </table>
                  </td>
                  <td width="50%" align="left">
                    <!--  <apex:panelGrid columns="1" width="50%"> -->
                     <table align="left">
                     
                       <tr>
                        <td > <apex:outputLabel value="{!$ObjectType.Job__c.Fields.JS_Client_Contact__c.Label}" style="font-weight: bold;"/> </td>
                        <td align="left"> <apex:outputText value="{!Job__c.JS_Client_Contact__r.Name}"/> </td>
                       </tr>
                       <tr>
                        <td > <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Schedule_Template__c.Label}" style="font-weight: bold;"/> </td>
                        <td align="left"> <apex:outputText value="{!Job__c.Schedule_Template__r.Name}"/> </td>
                       </tr>
                       <tr>
                        <td> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Status__c.Label}" style="font-weight: bold;"/> </td>
                        <td align="left"> <apex:outputText value="{!Job__c.Status__c}"/> </td>
                       </tr>
                       <tr>
                        <td> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Start_Date__c.Label}" style="font-weight: bold;"/> </td>
                        <td align="left"> <apex:outputfield value="{!Job__c.Start_Date__c}"/> </td>
                       </tr>
                       <tr>
                        <td> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Due_Date__c.Label}" style="font-weight: bold;"/> </td>
                        <td align="left"> <apex:outputfield value="{!Job__c.Due_Date__c}"/> </td>
                       </tr>
                      
                     <!-- <apex:outputText value="Job # : {!Job__c.Job_Id__c}" style="align:left;"/> <br/>
                      <apex:outputText value="Job Name : {!Job__c.Name}" style="align:right;"/> <br/>
                      <apex:outputText value="Job Description : {!Job__c.Job_Description__c}" style="align:right;"/> <br/> -->
                      </table>
                      
                   <!--  </apex:panelGrid> -->
                  </td>
                  
              </tr>
              <tr>
               <td width="100%" colspan="2">
                 <hr/>
               </td>
              </tr>
             
         
        <!-- 
          <tr>
              <td colspan="2" width="50%" align="left"> <b> TEAM </b>
              <apex:dataTable value="{!vq}" var="vquote" columns="2" columnsWidth="50%,50%" width="50%" rendered="{!vq.Size>0}">
              
                <apex:column value="{!vquote.Name}" headerValue="Role"/>
              
                <apex:column value="{!vquote.GL_Code__r.Name}" headerValue="Staff"/>
              
            </apex:dataTable>
            </td>
          </tr>
          <tr>
               <td width="100%" colspan="2">
                 <hr/>
               </td>
          </tr>  -->
             
             
         <tr width="100%">
          <td colspan="2" width="100%" align="left">
            <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                <tr style="page-break-inside: avoid;">
                      <td width = "20%">
                           <b> <apex:outputText value="ESTIMATE LINE ITEMS" style="font-size:12px;font-weight:bold;font-color:#0000FF;"/>  </b>
                      </td>
                     
                </tr>
            </table>
           </td>
        </tr>
        
        <br/>
     
         <table width="100%"> 
           <tr width="100%">
            <td colspan="2" width="100%" align="left"> 
            
             <tr width="100" style="padding-left:20px;">
             
                <th width="20%"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.Name.Label}</b></th>
                        
                <th width="20%"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.Vendor__c.Label}</b></th>
                          
                <th width="20%"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Code__c.Label}</b></th>
                
                <th width="10%"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.Unit_Type__c.Label}</b></th>
                          
                <th width="10%" style="text-align:right;"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.Quantity__c.Label}</b></th>
                
                <th width="10%" style="text-align:right;"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.Amount__c.Label}</b></th>
                
                <th width="10%" style="text-align:right;"><b>{!$ObjectType.Estimate_Line_Items__c.Fields.Total_Amount__c.Label}</b></th>
               
          </tr> 
          
          <tr width="100%">
              <td align="left" colspan="7">
                   <hr color="black" width="100%"/>
              </td>
          </tr>
          
          <apex:repeat value="{!vq}" var="vquote"  rendered="{!vq.Size>0}"> 
                    
               <tr width="100" style="padding-left:20px;">
                               
                  <td width="20%"><apex:outputField value="{!vquote.Name}"/></td>
                  <td width="20%"><apex:outputField value="{!vquote.Vendor__r.Name}"/></td>
                  <td width="20%"><apex:outputField value="{!vquote.GL_Code__r.Name}"/></td>
                  <td width="10%"><apex:outputField value="{!vquote.Unit_Type__c}"/></td> 
                  <td width="10%" style="text-align:right;"><apex:outputField value="{!vquote.Quantity__c}"/></td>
                  <td width="10%" style="text-align:right;"><apex:outputField value="{!vquote.Amount__c}"/></td>
                  <td width="10%" style="text-align:right;"><apex:outputField value="{!vquote.Total_Amount__c}"/></td>
         
              </tr>
              
         </apex:repeat>
          
          <br/><br/><br/><br/>
            
            <div style="float:right;font-size:1.10em;font-style:normal;font-family: sans-serif;font-weight:bold">
                <apex:outputPanel rendered="{!vq.Size > 0}">
                     <apex:outputLabel value="Estimated Total Cost"  /> 
                         <apex:outputText value="{0,Number, $###,###,###.00}">
                              &nbsp;:&nbsp;&nbsp;<apex:param value="{!sumCash}"/>
                         </apex:outputText>
                </apex:outputPanel>
            </div>
           </td>
          </tr>  
          
          <tr>
               <td width="100%" colspan="2">
               <apex:form >
                  <apex:pageBlock >
                      <apex:pageBlockSection >
                              <apex:pageBlockSectionItem rendered="{!vq.size <= 0}">
                                   <center>   <b>No records to display</b> </center>
                              </apex:pageBlockSectionItem>
                      </apex:pageBlockSection>
                  </apex:pageBlock>
               </apex:form>
                
               </td>
          </tr> 
          </table>
          </table>
</body>
