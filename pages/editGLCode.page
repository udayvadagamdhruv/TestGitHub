<!-- This page is used to Edit New GL Code-->

<apex:page standardController="GL_Code__c" showHeader="true" sidebar="true" extensions="EditGLCodeExtension" tabStyle="MyAdmin__tab">
<apex:sectionHeader title="{!GL_Code__c.GL_ID__c}"/> 
  <apex:form >
        <apex:pageBlock mode="edit">
        <apex:pageMessages />
            <apex:pageBlockButtons >
                    <apex:commandButton action="{!saveme}" value=" Save "></apex:commandButton>
                    <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
            </apex:pageBlockButtons>
              
              <apex:pageBlockSection title="GL Information" columns="2" collapsible="false"> 
                    <apex:pageBlockSectionitem > 
                         <apex:outputLabel value="{!$ObjectType.GL_Code__c.Fields.GL_ID__c.Label}"></apex:outputLabel>
                         <apex:inputField value="{!GL_Code__c.GL_ID__c}" required="true"/> 
                    </apex:pageBlockSectionitem> 
                    
                      <apex:pageBlockSectionitem > 
                         <apex:outputLabel value="{!$ObjectType.GL_Code__c.Fields.Unit_Type__c.Label}"/>
                         <apex:inputField value="{!GL_Code__c.Unit_Type__c}" required="true"/>
                    </apex:pageBlockSectionitem>  
                                       
                  <apex:pageBlockSectionItem >
                        <apex:outputLabel value="{!$ObjectType.GL_Code__c.Fields.Name.Label}"></apex:outputLabel>
                     <apex:inputField value="{!GL_Code__c.Name}" required="true"/>         
                 </apex:pageBlockSectionItem>
                 
                 <apex:pageBlockSectionItem ></apex:pageBlockSectionItem>
                 
                 <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.GL_Code__c.Fields.Unit_Cost__c.Label}"></apex:outputLabel>
                     <apex:inputfield value="{!GL_Code__c.Unit_Cost__c}"/>
                 </apex:pageBlockSectionItem>
                 
                <apex:pageBlockSectionItem ></apex:pageBlockSectionItem>
                
                    <apex:pageBlockSectionItem >                  
                          <apex:outputLabel value="{!$ObjectType.GL_Code__c.Fields.GL_Department__c.Label}" for="GLDept" ></apex:outputLabel>
                               <apex:actionRegion >
                               <apex:outputPanel >
                                  <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                                      <div class="requiredBlock"> </div>
                                      <apex:selectList id="GLDName" value="{!GLDName}" size="1" >
                                          <apex:selectOptions value="{!GLDepartments}"></apex:selectOptions>
                                      </apex:selectList>
                                  </span>
                              </apex:outputPanel> 
                            </apex:actionRegion>  
                  </apex:pageBlockSectionItem> 
                  
            </apex:pageBlockSection>
         </apex:pageBlock>
      </apex:form>
</apex:page>
<!-- End of Page -->