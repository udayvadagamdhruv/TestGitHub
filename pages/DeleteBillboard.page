<!-- This Page is used to handle delete functionality of Vendor -->
<apex:page standardController="Billboard__c" extensions="DeleteBillboard" showHeader="false" sidebar="false">
  
  <script>
           window.onload=function()
           {
             doInit();
           };
        </script> 
     
        <apex:pageMessages id="msg"></apex:pageMessages>
        
        <apex:form >
            <apex:actionFunction name="doInit" action="{!checkDelete}" rerender="msg,po"/> 
            <apex:outputPanel id="po">
               <center> <apex:outputLink value="/apex/BillboardsTabOverride" rendered="{!(isError!=False)}">Click here to Go to List</apex:outputLink> </center>
            </apex:outputPanel>
        </apex:form>
  
  
  
</apex:page>