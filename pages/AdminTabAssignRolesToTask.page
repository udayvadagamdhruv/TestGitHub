<!-- This Page is Used to assign multiple roles to SChedule Task. -->
<apex:page controller="AdminTabAssignRolesToTaskExtension">
     <apex:form >
         <table>
            <tr>
                <td> <apex:image url="{!$Resource.BigTop}" width="40" height="40" /> </td>
                <td>  <h1 class="mainTitle">Roles</h1> </td>
            </tr>
         </table>  
   
         <apex:pageBlock tabStyle="Job_Task_Role__c">
            <div align="center"> 
                <apex:commandButton value="Assign Roles" action="{!assignTheRole}"> </apex:commandButton>
            </div> 
            <br/>
   
            <apex:pageBlockTable value="{!lstSTR}" var="jt" rendered="{!lstSTR.Size > 0}"> 
               <apex:column headerValue="{!$ObjectType.Job_Task_Role__c.Fields.Name.Label}" value="{!jt.Name}">  </apex:column>
            </apex:pageBlockTable>
    
           <apex:pageBlockSection rendered="{!lstSTR.size <= 0}">
              <apex:pageBlockSectionItem >
                 <b>No records to display</b>
              </apex:pageBlockSectionItem>              
           </apex:pageBlockSection> 
         </apex:pageBlock>
     </apex:form>
</apex:page>
<!-- End of Page -->