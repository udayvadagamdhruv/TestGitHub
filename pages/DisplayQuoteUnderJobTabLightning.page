<apex:page controller="DisplayQuoteUnderJobTab" sidebar="flase" docType="html-5.0" id="pageid" applyHtmlTag="false" applyBodyTag="false" showHeader="false" standardStylesheets="true">
    

    <head>
        <style>

           .icon1
           {
              color:darkgrey;
           }
      
           .icon1:hover
           {
              color:black;
           }
        
        
            .slds .slds-dropdown-trigger .slds-dropdown
           {
                 margin-left: 37px;
    
           }
        
            .slds .slds-max-medium-table--stacked-horizontal td:before {
                text-transform: none;
            }
            
            .customImage {
                height: 10px;
                width: 10px;
            }
            
            #rcorners1 {
                border-radius: 0%;
                border: 1px solid #cccccc;
                padding: 0px;
                width: 100%;
                height: 0%;
            }
            
            #pagemessage {
                color: blue;
            }
            
            .required:after {
                content: " *";
                color: Red;
                font: bold;
            }
            
            .slds table {
                height: 50px;
            }
            
            body .bPageBlock,
            body .bPageBlock .pbBody,
            body .bPageBlock .pbBottomButtons {
                margin-top: -19px;
            }
            
            .detailPage .bPageBlock,
            .editPage .bPageBlock {
                border-top-width: 0px;
            }
            
            .slds .slds-text-heading--large {
                font-size: 27px;
            }
            
            .pbHeader {
                background: white !important;
            }
            
            body .bPageBlock,
            body .bPageBlock .pbBody,
            body .bPageBlock .pbBottomButtons {
                background: white;
            }
            
            .slds .slds-list--vertical.slds-has-dividers > .slds-list__item {
                border: none;
            }
            
            body .bEditBlock .pbBottomButtons,
            body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons {
                border: none;
            }
            
            .slds b,
            .slds strong,
            .slds dfn {
                font-weight: unset;
            }
            
            .slds .slds-table tr > td:first-child {
                padding-left: 6px;
                padding: 15px;
            }
            
             .slds .slds-card__footer {
               padding: 0px 16px 0px 0px;
          }
          .slds .slds-card__header {
            padding: 0px 10px 0px 0px;
            }
           .slds .slds-card__body {
                padding: 0px ;
            }
            
          .slds .slds-card {
                padding: 0;
                border-radius: 0px;
                background-clip: padding-box;
                background-color:white;
                }
            
            .slds .slds-table--bordered {
                border-top: 0px solid #d8dde6;
                border-bottom: 1px solid #d8dde6;
              }
                        
            .slds .slds-card__body {
                margin-bottom: -0.25rem;
                margin-top: -0.15rem;
               }
        
        .dateOnlyInput input {
            width: 10.5em !important;
        }
               
               
       .dropdownmenuicon:hover{
            background-color:#16325c !important;
            } 
             .dropdownmenuicon:hover #childmenu {
              color:white !important;
             }
                         
                        
     </style>
        
        
        
        
       

   
    </head>

<meta http-equiv="Content-type" content="text/html; charset=utf-8" />

    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
    
         <meta name="viewport" content="width=device-width, initial-scale=1"/>
          <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
          <link href="{!URLFOR($Resource.JobPage,'JobPage/MaterialIcons.css')}" rel="stylesheet"/>
         <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
     
   <apex:slds />
   
    
       <div class="slds" >

        <apex:form html-novalidate="novalidate" id="pb1">
            <apex:actionFunction name="inlinesaveQuote" rerender="pb1" action="{!inlineQuoteSave}"   status="LoadingStatus" >
                <apex:param name="firstParam" assignTo="{!rowIndex}" value="" />
                 <apex:param name="secondParam" assignTo="{!qtEditField}" value="" />
              </apex:actionFunction>
              
            
              
         
            <div class="slds-notify slds-text-heading--small slds-theme--error errorclass" role="alert" id="jobquote_Error">
                <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
              </div> 
               
           
            
            <br/>

            <div align="center">
                <apex:commandButton value="New Quote" action="{!CreateQuote}" id="btn1" title="Press to create New Quote" styleClass="slds-button slds-button--neutral slds-button-group" />
                <apex:commandButton value="Save" action="{!save}" id="qsaveButton" style="display:none;"    styleClass="slds-button slds-button--brand slds-button-group"/>
                <apex:commandButton value="Cancel" id="qcancelButton"  immediate="true"  style="display: none;" reRender="pb1" styleClass="slds-button slds-button--neutral slds-button-group" />
            </div>
                               
           <br/>
           
                                  
           <apex:outputPanel id="dq"> 
           <apex:outputPanel rendered="{!lst.size > 0}"> 
              
                 
            <div class="slds-card "   style="display:{!IF(lst.size>0,'block','none')}">
                            
                <div class="slds-card__body" >
                      
                   <apex:outputPanel id="dv"> 
                   <apex:outputPanel rendered="{!lst.size > 0}">   
               <div class="qtsco1"   style="height:{!if(lst.size==1,'165px',if(lst.size==2,'215px',if(lst.size==3,'265px','')))};background-color:#f4f6f9;">
                         
                    <div   style="overflow:auto;overflow-y:hidden;width: 100%;height:100%;">
                                 
                         
                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover" >
                                <thead class="slds-truncate">
                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-9" scope="col">Action</th>
                                        <th class="slds-size--1-of-9" scope="col"> {!$ObjectType.Quote__c.Fields.Name.Label} </th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.GL_Department__c.Label} </th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.GL_Code__c.Label} </th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.Unit_Type__c.Label} </th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.Request_Date__c.Label}</th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.Due_Date__c.Label}</th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.Amount__c.Label}</th>
                                        <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Quote__c.Fields.Approved__c.Label}</th>
                                    </tr>
                                </thead>
                                
                                
                                  <script>
                                                                  
                      $(document).ready(function(){
                      
                      
                       $(".quotebutton").mouseover(function(){
                            var qut1=$(this).children(".quoteclass");
                            
                          if(($(this).offset().top+$(this).outerHeight()-$(".qtsco1").offset().top)+qut1.outerHeight()>$(".qtsco1").outerHeight()){
                          
                            $(this).children(".slds-dropdown_xx--small").addClass('slds-dropdown--bottom');
                            
                            }
                            
                           else{
                        
                             $(this).children(".slds-dropdown_xx--small").removeClass('slds-dropdown--bottom');
                           }
                                  
                        });
                       
                         
                      });
                      
                    </script>
                    
                                
                                
                                <tbody>

                                    <apex:repeat value="{!lst}" var="quote" rendered="{!lst.size > 0}">

                                        <tr class="slds-hint-parent">
                                        
                                            <td class="slds-size--1-of-9" data-label="Action">
                                                  <div class="slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open quotebutton">
                                                     &nbsp;&nbsp;  
                                                        <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small slds-shrink-none dropdownmenuicon ">
                                                           <!-- &nbsp;<svg aria-hidden="true" class="slds-button__icon slds-button__icon--hint slds-button__icon--small">
                                                                 <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/utility-sprite/svg/symbols.svg#down')}"></use>
                                                            </svg>
                                                            <span class="slds-assistive-text">Show More</span>--->
                                                               <i  id="childmenu" style="color:#9faab5;font-size:15px;margin:2px 5px;" class="fa">&#xf0d7;</i>
                                                        </div>
                                                        
                                             
                                                        <div class="slds-dropdown slds-dropdown__left slds-dropdown_xx--small quoteclass">
                                                        
                                                           <ul class="slds-dropdown__list" role="menu">
                                                             
                                                               
                                                               <li class="slds-dropdown__item" role="presentation">
                                                                   <!--  <apex:commandLink value="Edit"  rendered="{!if(vquote.Approved__c==false,true,false)}" status="LoadingStatus" reRender="div1,div2">
                                                                         <apex:param name="param3" value="{!vquote.id}" assignTo="{!strPEID}"></apex:param>                   
                                                                    </apex:commandLink>  -->  
                                                                     
                                                                      <a href="/apex/EditQuoteLightning?id={!quote.qtrec.id}" role="menuitem" tabindex="0" style="display:{!IF(quote.qtrec.Approved__c==false, 'block','none')};">
                                                                            <span class="slds-truncate" title="Edit">Edit</span>
                                                                            
                                                                             <!---<svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#edit')}"></use>
                                                                            </svg>-------->
                                                                             &nbsp; &nbsp;&nbsp; &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; <i  class="material-icons" style="font-size:20px;color:black">edit</i> 
                                                                        </a>
                                                                    
                                                                                                                               
                                                                </li>
                                                                
                                                                <li class="slds-dropdown__item" role="presentation">
                                                                     <apex:commandLink title="Delete" value="Delete" action="{!del}" rendered="{!if(quote.qtrec.Approved__c==false,true,false)}"  reRender="dv1,dv,deqt,dq" status="LoadingStatus">
                                                                          <apex:param name="param3" value="{!quote.qtrec.id}" assignTo="{!strPEID}"></apex:param>    
                                                                       
                                                                       <!--- <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                            <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#delete')}"></use>
                                                                        </svg>---->   
                                                                          &nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">delete</i> 
                                                                    </apex:commandLink> 
                                                                    
                                                                                                                                  
                                                                </li>
                                                                
                                                                <li class="slds-dropdown__item" role="presentation" style="display:{!if(quote.qtrec.Approved__c,'block','None')}">
                                                                       
                                                                       &nbsp; &nbsp;<apex:outputLabel title="No Action" value="None" rendered="{!if(quote.qtrec.Approved__c==True,true,false)}" >
                                                                     </apex:outputLabel>  
                                                                 </li> 
                                                                 
                                                                
                                                              
                                                            </ul>
                                                      </div> 
                                               </div>
                                            </td>
                                      
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputLink tabindex="tab1" value="/apex/QuoteDetailPageLightning?id={!quote.qtrec.Id}">{!quote.qtrec.Name}</apex:outputLink>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.GL_Department__c.Label}">
                                                <div>
                                                    <apex:outputfield value="{!quote.qtrec.GL_Department__r.Name}" />
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.GL_Code__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!quote.qtrec.GL_Code__r.Name}" />
                                                </div>

                                            </td>
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.Unit_Type__c.Label}">
                                                <div>
                                                    <apex:outputfield value="{!quote.qtrec.Unit_Type__c}" />
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.Request_Date__c.Label}">
                                                
                                              <div>
                                                 <apex:outputPanel id="req" > 
                                                     <apex:actionSupport event="ondblclick" rerender="pb1" rendered="{!AND(NOT(quote.isEditReq),NOT(quote.qtrec.Approved__c))}" action="{!inlineQuoteEdit}"   status="LoadingStatus" focus="QtRequestDate">
                                                         <apex:param name="rowNumber" value="{!quote.rowNo}" assignTo="{!rowIndex}"/>
                                                         <apex:param name="rowField" value="QuoteRequestDate" assignTo="{!qtEditField}"/>
                                                      </apex:actionsupport>
                                                        <apex:outputField value="{!quote.qtrec.Request_Date__c}" rendered="{!Not(quote.isEditReq)}">
                                                         <span style="display:{!IF(quote.qtrec.Request_Date__c==null,'inline','none')}" >&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
                                                        <i class="material-icons icon1" style="float:right;font-size:15px;display:{!if(quote.qtrec.Approved__c == true,'none','inline')}">&#xe254;</i>
                                                       </apex:outputField>
                                                       
                                                        <apex:inputField style="width:90%" value="{!quote.qtrec.Request_Date__c}" id="QtRequestDate"  rendered="{!quote.isEditReq}"  onchange="inlinesaveQuote({!quote.rowNo},'QuoteRequestDate');"   /> 
                                                   </apex:outputPanel>
                                                  </div>
                                                  
                                              </td>


                                     
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.Due_Date__c.Label}">
                                                
                                                 <div>
                                                   <apex:outputPanel id="due"> 
                                                      <apex:actionSupport event="ondblclick" rerender="pb1" rendered="{!AND(NOT(quote.isEditDue),NOT(quote.qtrec.Approved__c))}" action="{!inlineQuoteEdit}"   status="LoadingStatus" focus="QtDueDate">
                                                             <apex:param name="rowNumber" value="{!quote.rowNo}" assignTo="{!rowIndex}"/>
                                                             <apex:param name="rowField" value="QuoteDueDate" assignTo="{!qtEditField}"/>
                                                       </apex:actionsupport>    
                                                             <apex:outputField value="{!quote.qtrec.Due_Date__c}" rendered="{!Not(quote.isEditDue)}">
                                                              <span style="display:{!IF(quote.qtrec.Due_Date__c==null,'inline','none')}" >&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span>
                                                           <i class="material-icons icon1" style="float:right;font-size:15px;display:{!if(quote.qtrec.Approved__c == true,'none','inline')}">&#xe254;</i>
                                                         </apex:outputField>
                                                       
                                                        <apex:inputField style="width:90%"  value="{!quote.qtrec.Due_Date__c}"  id="QtDueDate"  rendered="{!quote.isEditDue}"   onchange="inlinesaveQuote({!quote.rowNo},'QuoteDueDate');"   />
                                                   </apex:outputPanel> 
                                                 </div>
                                                   
                                               
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.Amount__c.Label}">
                                                <div>
                                                    <apex:outputfield value="{!quote.qtrec.Amount__c}" />
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.Quote__c.Fields.Approved__c.Label}">
                                                <div>
                                                    <apex:outputfield value="{!quote.qtrec.Approved__c}" />
                                                </div>
                                            </td>

                                            
                                        </tr>

                                    </apex:repeat>
                                </tbody>
                            </table>
                            </div> 
                           </div> 
                            
                        </apex:outputPanel>
                       </apex:outputPanel> 
                      
                    </div>
                   
                   
                   
                   <apex:outputPanel id="dv1" >
                  <apex:outputPanel rendered="{!q2.size>5}"><br/>
                      <div class="slds-card__footer">
                            <apex:commandLink value="View All ({!lst.size}{!IF(q2.size>5,'+','')})" action="{!ViewAllQuote}" rendered="{!ViewAll}" status="LoadingStatus"  reRender="pb1"/>
                            <apex:commandLink value="Show Less ({!lst.size})" action="{!ShowLessQuote}" rendered="{!ShowLess}" status="LoadingStatus"  reRender="pb1"/>
                      </div>
                  </apex:outputPanel>  
                  </apex:outputPanel>
                            
                    
                    
              </div>
              </apex:outputPanel>
             </apex:outputPanel>  
                 
                 
                 <apex:actionStatus id="LoadingStatus" >
                   <apex:facet name="start">
                      <div class="slds-spinner_container" style="z-index: 99999;position: fixed;">
                         <div role="status" class="slds-spinner slds-spinner--brand slds-spinner--medium">
                           <span class="slds-assistive-text">Loading</span>
                           <div class="slds-spinner__dot-a"></div>
                           <div class="slds-spinner__dot-b"></div>
                         </div></div>
                    </apex:facet>
                </apex:actionStatus>
                 
                 
           <apex:outputPanel id="deqt" >
            <apex:outputPanel rendered="{!lst.size <=0}" >
               <div> <b> No records to display </b></div>
            </apex:outputPanel>
          </apex:outputPanel>
          
    
                 
     
        </apex:form>
      </div>
  
      
    </html>
</apex:page>
<!-- End of Page -->