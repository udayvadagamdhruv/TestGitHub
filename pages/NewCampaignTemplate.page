<apex:page standardController="Campaign_Template__c"  showHeader="true" sidebar="true" tabStyle="MyAdmin__tab" extensions="CreateCT" >
<apex:sectionHeader title="Campaign Template"/>
   <apex:form >
      <apex:pageBlock mode="edit">
         <apex:pageMessages />
         
        
            <apex:pageBlockButtons >
            <apex:commandButton action="{!saveme}" value=" Save "></apex:commandButton>
            <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
         </apex:pageBlockButtons>
        
              
         <apex:pageBlockSection title="Campaign Template Information" columns="2" collapsible="false"> 
            <apex:pageBlockSectionItem >
                      <apex:outputLabel Value="{!$ObjectType.Campaign_Template__c.Fields.Name.Label}"></apex:outputLabel>
                      <apex:inputField value="{!Campaign_Template__c.Name}" required="true" />
              </apex:pageBlockSectionItem>
         </apex:pageBlockSection>
         
         
      </apex:pageBlock>
   </apex:form>

  
</apex:page>