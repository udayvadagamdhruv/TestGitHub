        <script>
    
    
        //We need to wrap everything in a doc.ready function so that the code fires after the DOM is loaded

        $(document).ready(function() {   
          
            //Call the fullCallendar method. You can replace the '#calendar' with the ID of the dom element where you want the calendar to go. 
           

            $('#calendar').fullCalendar({

                 customButtons: { Print: { text: 'Print', click: function() {  window.print();  } } },
                header: {

                   center: 'prev title next today',
                
                   right:'',
                   
                   left: ''

                },
               defaultView: 'basicWeek',
                editable: true,
                themeSystem: 'jquery-ui',
                eventDurationEditable: true,
                eventStartEditable: true,
                firstDay: 0,
                height: 350,
                // contentHeight: 600,
                

                events:

                [

                    //At run time, this APEX Repeat will reneder the array elements for the events array

                    <apex:repeat value="{!events}" var="e">

                        {

                            title: "{!e.title}",

                            start: '{!e.startString}',

                            end: '{!e.endString}',

                            //url: '{!e.url}',

                            allDay: {!e.allDay},
                            
                            color:'{!e.color} !important',
                            
                            jn: '{!e.JN1}',
                             
                            client: '{!e.client1}',
                            
                            staff: '{!e.Staff}',
                            
                            className: '{!e.className}'
                            
                        },

                    </apex:repeat>

                ],
                
               eventMouseover: function(event, jsEvent) {
                   // alert('invokeddd...........');
                   event.title = event.title.split(' - ')[0]+', Job - # '+event.title.split(' - ')[1];
                  if(event.title.substring(0, 3)== 'Job'){
                    var tooltip = '<div class="tooltipevent" style="width:250px;height:100px;background: linear-gradient(to right, rgb(234,185,45) 0%,rgb(199,152,16) 100%);position:absolute;z-index:10001;">' +
                                        '<B>Job Name: </B>'+ event.title.substring(5, event.title.length) +
                                        '<br>'+'<B>Campaign : </B>'+event.staff+
                                        '<br>'+'<B>Job Client : </B>'+event.client+
                                        '<br>'+'<B>Start Date: </B>'+event.start.format()+
                                        '<br>'+'<B>End Date: </B>'+event.end.format()+
                                        
                                   '</div>';
                    var tooltip = '<div class="tooltipevent" style="box-shadow: 4px 4px 4px 4px '+event.color+';padding:10px;background-color:'+event.color+';color:white;position:absolute;z-index:10001;">' +
                            '<B>Job Name: </B>' + event.title.substring(5, event.title.length) +
                            '<br>' + '<B>Campaign : </B>' + event.staff +
                            '<br>' + '<B>Job Client : </B>' + event.client +
                            '<br>' + '<B>Start Date: </B>' + event.start.format() +
                            '<br>' + '<B>End Date: </B>' + event.end.format() +

                            '</div>';
                    $("body").append(tooltip);
                    $(this).mouseover(function(e) {
                        $(this).css('z-index', 10000);
                        $('.tooltipevent').fadeIn('500');
                        $('.tooltipevent').fadeTo('10', 1.9);
                        }).mousemove(function(e) {
                                $('.tooltipevent').css('top', e.pageY + 10);
                                $('.tooltipevent').css('left', e.pageX + 20);
                        });}
                        
                        // task Mouse Over
                    //
                    else if(event.title.substring(0, 11) != 'JS Campaign'){
                    //alert('event.title.substring(0, 11) :::'+event.title.substring(0, 11));
                   
                    //Substringing the event tile to get Job# and Task name
                    var titlepos = event.title.indexOf(",");
                    var taskName = event.title.substring(0, titlepos);
                    var jobNo = event.title.substring(titlepos+7,event.title.length); 
                    
                    //Substringing the event JN to get Job Name and campaign name
                    var jnpos = event.jn.indexOf(":");
                    var campName = event.jn.substring(0, jnpos );
                    var jobName = event.jn.substring(jnpos +2,event.jn.indexOf("id="));
                    
                    
                    var tooltip = '<div class="tooltipevent" style="width:250px;height:120px;background: linear-gradient(to right, rgb(234,185,45) 0%,rgb(199,152,16) 100%);position:absolute;z-index:10001;">' +
                                        '<br>'+
                                         '<B>Job : </B>'+jobName+' - '+jobNo+'<br>'+
                                         '<B>'+ taskName +' :: '+event.start.format()+'</B>'+'<br>'+
                                         '<B>Client : </B>'+event.client+'<br>'+
                                         '<B>Campaign: </B>'+campName +'<br>'+
                                         '<B>Staff: </B>'+event.staff+'<br>'+
                                         
                                   '</div>';
                    var tooltip = '<div class="tooltipevent" style="box-shadow: 4px 4px 4px 4px '+event.color+';padding:10px;background-color:'+event.color+';color:white;position:absolute;z-index:10001;">' +
                            '<B>Job : </B>' + jobName + ' - ' + jobNo + '<br>' +
                            '<B>' + taskName + ' :: ' + event.start.format() + '</B>' + '<br>' +
                            '<B>Client : </B>' + event.client + '<br>' +
                            '<B>Campaign: </B>' + campName + '<br>' +
                            '<B>Staff: </B>' + event.staff + '<br>' +

                            '</div>';
                  // alert('event.title.substring(0, 11) :::'+event.title.substring(0, 11));
                    $("body").append(tooltip);
                    $(this).mouseover(function(e) {
                        $(this).css('z-index', 10000);
                        $('.tooltipevent').fadeIn('500');
                        $('.tooltipevent').fadeTo('10', 1.9);
                        }).mousemove(function(e) {
                                $('.tooltipevent').css('top', e.pageY + 10);
                                $('.tooltipevent').css('left', e.pageX + 20);
                        });}
                    },

                    eventMouseout: function(event, jsEvent)
                    {
                         $(this).css('z-index', 8);
                         $('.tooltipevent').remove();
                    },
                
              // Drag and Drop Calendar event

                eventDrop: function(event, delta, revertFunc) {
                    // alert('Dragged Event');
                    // alert('Event start date :'+event.start.format());
                    // alert('Event end date :'+event.end.format());
                    if (!confirm("Do you want to Update..!!!!!")) {
                        revertFunc();
                    } else {
                        // alert('Invoked..................');
                        if (event.title.substring(0, 3) == 'Job' || event.title.substring(0, 11) == 'JS Campaign') {
                            var enddate = event.end.format();
                            var startdate = event.start.format();
                        } else {

                            var enddate = event.start.format();
                            var startdate = event.start.format();
                        }
                        //          alert('Invoked..................'+enddate );
                        var cntctName = event.title;
                        var jn1 = event.jn;
                        
                        taskDrag(cntctName, event.url, enddate, startdate, jn1);
                    }
                },

                // Resize the events 

                eventResize: function(event, delta, revertFunc) {
                    
                      
                        revertFunc();
                    
                    
                },
              
              
                
                eventRender: function(event, element) { 
                    element.bind('dblclick', function() { 
                        //alert(event.className);
                        makeInProgress(event.className); 
                    }); 
                } 

            });

             var ele = $("h2");
             var eleData  = ele.html();
            // alert(eleData);
             
        });
     

    </script>
        
        
