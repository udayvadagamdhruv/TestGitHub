      {
       
         table-layout: fixed;
         width: 100%; /*Table width must be set or it wont resize the cells*/
      }
       td .rotated_cell
        {
            padding-bottom: 5px;          
            height: 120px;
            vertical-align: bottom;
            white-space:nowrap;
        }
    </style>
