<!-- This Page is used for create functionality of Tag Template (override create button of Tag Template Object) -->
<apex:page standardController="Tag_Template__c" showHeader="true" sidebar="true" extensions="createTagTemp">
   <apex:sectionHeader title="Tag Template"/>
   <apex:form >
      <apex:pageBlock mode="edit">
         <apex:pageMessages />
         
         <apex:pageBlockButtons >
            <apex:commandButton action="{!saveme}" value=" Save "></apex:commandButton>
            <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
         </apex:pageBlockButtons>
              
         <apex:pageBlockSection title="Tag Template Information" columns="2" collapsible="false"> 
            <apex:pageBlockSectionItem >
                      <apex:outputLabel Value="{!$ObjectType.Tag_Template__c.Fields.Name.Label}"></apex:outputLabel>
                      <apex:inputField value="{!Tag_Template__c.Name}" required="true" />
              </apex:pageBlockSectionItem>
         </apex:pageBlockSection>
      </apex:pageBlock>
   </apex:form>
</apex:page>
<!-- End of Page -->