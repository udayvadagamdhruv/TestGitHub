<apex:page controller="DisplayInvoiceunderjobtabExtension" sidebar="flase" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" showHeader="false" standardStylesheets="true">
     <head>
         <style>
         
        
      
       #icon1:hover{
        color:black;
        }
        
       
        
         
             #table_dr td
             {
                border:0px;
             }
             #table_amount td
             {
                 border:0px;
