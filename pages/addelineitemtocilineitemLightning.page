<apex:page controller="addELineItemToCILineItem" sidebar="true"  showHeader="false" >
<apex:slds />
<style>
 .lookupHoverDetail{
                display: none !important;
        }
</style>
  <apex:form >
    <apex:outputPanel rendered="{!roleWraps.size > 0}">
    <apex:pageMessages ></apex:pageMessages>
        <apex:dataTable value="{!roleWraps}" var="p" id="ProductsTable" styleClass="slds-table slds-table_bordered">
            <apex:column headerValue="Action">
                <apex:inputCheckbox value="{!p.checked}" Styleclass="slds-checkbox"/>
            </apex:column>
            <apex:column value="{!p.e.Name}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Name.Label}" />
            <apex:column value="{!p.e.GL_Code__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Code__c.Label}" />
            <apex:column value="{!p.e.Unit_Type__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Unit_Type__c.Label}" />
            <apex:column value="{!p.e.Quantity__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Quantity__c.Label}" />
            <apex:column value="{!p.e.Total_Amount__c}" headerValue="{!$ObjectType.Estimate_Line_Items__c.Fields.Total_Amount__c.Label}" />
        </apex:dataTable>
        <br/>
        <apex:commandButton styleclass="slds-button slds-button_neutral" action="{!Save}" value="Add" title="Click on the button to Add Estimate Line Items."/>&nbsp;&nbsp;
        <apex:commandButton styleclass="slds-button slds-button_neutral" action="{!Back}" value="Go Back" title="Click on the button to go back."/>
    </apex:outputPanel>
    <br/>
    
    <apex:outputPanel rendered="{!roleWraps.size <= 0}"> 
        <p>
          <b> No Records to display.</b>
        </p>       
        <br/>
        <apex:commandButton action="{!Back}"  styleclass="slds-button slds-button_neutral" value="Go Back" title="Click on the button to go back."/>
   </apex:outputPanel> 
</apex:form> 
</apex:page>