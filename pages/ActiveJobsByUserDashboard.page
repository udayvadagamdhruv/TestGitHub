<apex:page standardController="Job__c" extensions="ActiveJobsByUserDashboardExt"  sidebar="flase" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" showHeader="false" standardStylesheets="true">
     <script src="{!URLFOR($Resource.JQuery,'jquery-ui-1.11.4.custom/external/jquery/jquery.js')}"></script>
     <script src="{!URLFOR($Resource.JQuery)}"> </script>
     
     
     <style> 
      
      
            .customImage{ height: 10px; width: 10px; }
                     #rcorners1 {
                                    border-radius:0%;
                                    border: 1px solid #cccccc;
                                    padding: 0px; 
                                    width: 100%;
                                    height: 0%;
                                }
                    #pagemessage
                                {
                                    color:blue;
                                }
                  .required:after { content:" *";  color: Red;font:bold;}
                  .detailPage .bPageBlock, .editPage .bPageBlock
                  {
                      border-top-width: 0px;
                  }
                  
                  .slds .slds-p-top--medium
                  {
                      padding-top: 0px;
                  }
                  
                  
                  .slds .slds-table--bordered td, .slds .slds-table--bordered th
                  {
                      border-top: none;
                  }
                  
                  .slds .slds-table .slds-truncate 
                  {
                        min-width: 52px !important;
                        max-width: 125px !important;
                  }
                  .slds table 
                  {
                      height: 47px !important;
                  }

                 
     </style>  
     
     
          <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
           <apex:stylesheet value="{!URLFOR($Resource.SLDS0122, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
          
                <body>
                        
                      <div class="slds">
                             <ul class="slds-list--vertical slds-has-dividers">
                                   <li class="slds-list__item slds-large-size">  
                                        <div class="slds-text-heading--large"><center>My Active Jobs</center></div> 
                                   </li>
                              </ul>
    
                      
                             <div class="slds" >
                                                
                                 <apex:form html-novalidate="novalidate">
                                       
                                          <apex:pageBlock mode="edit" id="p">
                                          
                                                <apex:pageBlockButtons location="bottom" style="position:absolute;left:30%;height:400px;">
                                                         
                                                  <apex:commandButton value="Prev" rerender="p" action="{!previous}" disabled="{!prev}" styleClass="slds-button slds-button--neutral"/>
                                                  <apex:commandButton value="Next" rerender="p" action="{!next}" disabled="{!nxt}" styleClass="slds-button slds-button--neutral"/>
                                                       
                                               </apex:pageBlockButtons>
                                              
                                                       
                                                         <apex:pageMessages id="msg"></apex:pageMessages>
                                               
                                                              <div class="slds-grid slds-wrap">
                                 
                                                                 <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" >
                                                                                
                                                                       <div class="slds-grid slds-wrap">  
                                                                                                              
                                                                           <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                                                 <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                    
                                                                                                 <table  style="width:100%;display:{!jobs.size != 0};"  class="slds-table slds-table--bordered">
                                                                                                       <tr  class="slds-text-heading--label">
                                                                                                           <th style="width:8%;text-align:left;padding-left:5px;word-wrap: break-word;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">Job#</th>
                                                                                                            <th style="width:82%;text-align:left;padding-left:5px;word-wrap: break-word;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">Job Name</th>
                                                                                                            <th style="width:10%;text-align:left;padding-left:5px;word-wrap: break-word;" class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">Client</th>
                                                                                                       </tr>
                                                                                                        <apex:repeat value="{!jobs}" var="lst" >
                                                                                                       <tr>
                                                                                                            <td width="30%" style="text-align:left;padding-left:5px;word-wrap: break-word;"  class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">
                                                                                                               <apex:outputField value="{!lst.Job_Auto_Number__c}"/>
                                                                                                            </td>
                                                                                                       
                                                                                                            <td  width="50%" style="text-align:left;padding-left:5px;word-wrap: break-word;"  class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink">
                                                                                                              <b> <apex:outputLink tabindex="tab1" style="color:black;text-decoration: none;" value="/apex/JobRequestFormdetailpageMobile?id={!lst.Id}" target="_top">{!lst.Name} </apex:outputLink> 
                                                                                                              </b>
                                                                                                            </td>
                                                                                                            <td width="20%" style="text-align:left;padding-left:5px;word-wrap: break-word;"  class="slds-truncate" styleClass="slds-cell-wrap slds-cell-shrink" valign="top">
                                                                                                               {!lst.JS_Client__r.name}
                                                                                                            </td>
                                                                                                       </tr>
                                                                                                         </apex:repeat>
                                                                                                   </table>
                                                                    
                                                                                       </div> 
                                                                                   </aside>                         
                                                                                 </div>       
                                                                             </main>
                                                                          </div> 
                                                                    </apex:pageBlock>    
                                </apex:form> 
                           </div>  
                      </div>     
                </body>
          </html>
       
</apex:page>