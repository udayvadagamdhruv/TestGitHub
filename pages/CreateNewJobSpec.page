<!-- This Page is used to override the create button of Job Spec object -->
<apex:page standardController="Job_Spec__c" tabStyle="Job__c" extensions="extension_JobSpec">
   <apex:sectionHeader title="Creative Brief Details"/> 
   <apex:form >
      <apex:pageBlock >
         <apex:pagemessages /> 
            <apex:pageBlockButtons >
               <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
               <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
            </apex:pageBlockButtons>
            
            <apex:pageBlockSection title="Information" columns="2" collapsible="false">
               <apex:pageblockSectionItem >
                  <apex:outputLabel Value="{!$ObjectType.Job_Spec__c.Fields.Name.Label}"/>
                  <apex:inputField value="{!Job_Spec__c.Name}" required="true"/>
               </apex:pageblockSectionItem>
             
               <apex:pageBlockSectionItem >
                  <apex:outputLabel Value="{!$ObjectType.Job_Spec__c.Fields.Job__c.Label}"/>
                  <apex:outputLabel value="{!strJob}"/> 
                 <!-- <apex:outputText value="{!Job_Spec__c.Job__c}"> </apex:outputText>--->
               </apex:pageBlockSectionItem>
             
             <apex:pageBlockSectionItem >
            
                 <apex:outputLabel Value="{!$ObjectType.Job_Spec__c.Fields.Sort_Order__c.Label}"></apex:outputLabel>
                 <apex:inputField value="{!Job_Spec__c.Sort_Order__c}"/>
            </apex:pageBlockSectionItem>
             
               <apex:pageBlockSectionItem >
                  <apex:outputLabel Value="{!$ObjectType.Job_Spec__c.Fields.Description__c.Label}"/>
                  <apex:inputTextarea value="{!Job_Spec__c.Description__c}" rows="3" cols="55" style="resize:none"/> 
               </apex:pageBlockSectionItem>
             
            </apex:pageblocksection>
      </apex:pageBlock>  
   </apex:form>
</apex:page>
<!-- End of Page -->