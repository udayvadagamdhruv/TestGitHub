<!-- This page is used to display detail information of each job to Client Contact -->

<apex:page standardController="Job__c" showHeader="true" tabStyle="Client_Job__tab" extensions="JobListViewExtension" sidebar="false">
<head>
<script type="text/javascript">
     function InlineSave()
        {
          // alert("Marketing Request Submitted");
