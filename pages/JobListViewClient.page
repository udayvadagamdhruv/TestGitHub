    <apex:tabPanel switchType="client" value="{!tabInFocus}" id="JobTabPanel" tabClass="activeTab" activeTabClass="activeTab" inactiveTabClass="inactiveTab" width="100%" contentClass="tabContent" styleClass="theTabPanel">
               
     <!--     <script> alert("{!JSENCODE(HTMLENCODE(tabInFocus))}");</script>         -->
         
      <!-- Detail Tab-->
      <apex:tab label="Details" name="Details" id="tabdetails" styleClass="labelCol" style="width:100px;">
       
         <apex:detail relatedList="false" showChatter="false" title="true" rendered="{!Job__c.Status__c='Active'}"/>
         <apex:detail relatedList="false" inlineEdit="true" showChatter="false" title="true" oncomplete="parent.location.href = '/apex/JobListViewClient?id={!Job__c.Id}'" rendered="{!Job__c.Status__c!='Active'}"/>
      </apex:tab>
      <!-- End of Detail Tab -->
      
      <!-- Start Job Spec Tab -->        
          <apex:tab label="Specs" name="Job Specs" id="tabjobspecs" styleClass="labelCol">
          <apex:relatedList subject="{!Job__c}" list="Job_Specs__r"/>  
          <!--  <apex:include pageName="DisplayJobSpecInJobTab" rendered="true"/> -->
      </apex:tab>
      <!-- End Job Spec Tab -->
      
   </apex:tabPanel>
   <!-- End Of Tab Panel -->
 </apex:page>
 <!-- End of Page -->