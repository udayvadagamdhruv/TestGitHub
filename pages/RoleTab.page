<apex:page standardController="UserRole" extensions="RoleList" tabStyle="MyAdmin__tab" >
<apex:form >

  <head>
   <!-- Style Code Goes here -->
    <style>
        .actionLink 
        {
            color: #015BA7 !important;
            font-weight: normal;
            text-decoration: none;
        }

     .activeTab
      {
          font-size:1.25em;font-style:normal;font-family: 'Calibri';font-weight:bold;background-color: #3090C7; color:white;width:60px;height:20px;background-image:none;border: 0px solid #747e96;border-bottom: 0px solid #fff; 
         -moz-border-radius-topleft: 10px;
         -moz-border-radius-topright: 10px;
         -moz-border-radius-bottomright: 0px;
         -moz-border-radius-bottomleft: 0px;
         border-top-left-radius: 10px;
         border-top-right-radius: 10px;
         border-bottom-left-radius: 0 px;
         border-bottom-right-radius: 0 px;
      }

    .inactiveTab
     {
         font-size:1.25em;font-style:normal;font-family: 'Calibri';font-weight:bold;background-color: #E0FFFF; color:black;width:60px;height:20px;background-image:none;border: 0px solid #747e96;border-bottom: 0px solid #fff; 
        -moz-border-radius-topleft: 10px;
        -moz-border-radius-topright: 10px;
        -moz-border-radius-bottomright: 0px;
        -moz-border-radius-bottomleft: 0px;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
        border-bottom-left-radius: 0 px;
        border-bottom-right-radius: 0 px;
        background: url("/img/alohaSkin/tabbar_sprite.png") repeat-x scroll left -73px transparent;
    }

   .labelCol
   {
         font-size:1.10em;vertical-align: middle!important;
   }
   
   .labelCol2{font-size:1.0em}  <!-- This is for Third level Tab -->

   body .btn{font-size:0.8em;font=weight:bold;font-family: 'Calibri';font-style:normal;}

   body .bodyDiv .bFilterView select, .listViewportWrapper .listViewport .topNav .title{font-size:0.9em;font-style:normal;font-weight:normal}
        
   .tabContent 
    {
        background: #fff;
    }

    body .rich-tabpanel-content
    {
        border: 1px solid #D4DADC;
        border-top: 3px solid #3090C7;
        -moz-border-radius: 0px;
        -webkit-border-radius: 0px;
        background-color: #F8F8F8;
        padding: 6px;
    } 

    body td[id$="Tab_lbl"] 
    {
        padding: 8px;
        background-color: #f8f8f8;
        border: 1px solid #eaeaea;
        -moz-border-radius: 4px;
        -webkit-border-radius: 4px;
    }

    .tabNavigation 
    {
        background: url("/img/alohaSkin/tabbar_sprite.png") repeat-x scroll left -73px transparent;
        margin: 0 5px;
        padding: 3px 0 0;
        position: relative;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        border-bottom-left-radius: 0 px;
        border-bottom-right-radius: 0 px;
    }
    
    .theTabPanel 
    {
        background: url("/img/alohaSkin/tabbar_sprite.png") repeat-x scroll left -73px transparent;
        margin-top: 0.05em !important;
        padding-top: 0px;
        border-top-left-radius: 8px;
        border-top-right-radius: 15px;
        border-bottom-left-radius: 0 px;
        border-bottom-right-radius: 0 px;
    }

    .theTabPanel img
    {
        margin: 0px;
    }

     .rich-tabhdr-side-cell 
    {
        border-top-style: solid;
        border-top-width: 0px;
    }

    .rich-tabhdr-side-border 
    {
        background-image: url("/img/alohaSkin/tabbar_sprite.png");
        background-position: center top;
        background-repeat: no-repeat;
    }

    .activeTab:hover 
    {
       cursor:pointer;
       cursor:hand; 
       text-decoration:underline;
       color: white;
    }

    .inactiveTab:hover 
    {
       cursor:pointer;
       cursor:hand; 
       text-decoration:underline;
       color: #007FFF;
    }      
    </style>
<!-- End Of Style -->
</head>

 
 <table class="slds-table">
          <tr>
              <td align="left"> <apex:image url="{!$Resource.BigTop}" width="40" height="40" /> </td>
              <td valign="bottom"><apex:commandButton action="{!createNewRole}" value="New Role" /></td>
          </tr>
      </table>
 
    <apex:pageBlock >
    <apex:pageMessages id="pm" />
     <apex:pageBlockTable value="{!roles}" var="role" title="Roles" rendered="{!roles.size > 0}">
     <!--
         <apex:column headerValue="Action" width="7%">
              <apex:outputLink value="/apex/EditRole?id={!role.Id}" styleClass="actionLink">Edit</apex:outputLink>&nbsp; | &nbsp;
         <apex:commandLink action="{!deleteRole}" onclick="return confirm(' Are You sure? You Want to delete this Role.');" styleClass="actionLink">Del
               <apex:param name="id" value="{!role.id}" assignTo="{!roleId}"/> </apex:commandLink> 
        </apex:column> 
      -->  
       <apex:column >
         <apex:facet name="header">   
           <apex:commandLink action="{!ViewData}" value="Roles{!IF(sortExpression=='name',IF(sortDirection='ASC','▼','▲'),'')}" id="cmdSort">
             <apex:param value="name" name="column" assignTo="{!sortExpression}" ></apex:param>
           </apex:commandLink>
         </apex:facet>
            <apex:outputLink value="/apex/RoleDetailPage?id={!role.Id}" tabindex="tab1">{!role.Name}</apex:outputLink>
      </apex:column>
  </apex:pageBlockTable>
  <apex:outputPanel rendered="{!roles.size <= 0}">
      <b>No records to display</b>
  </apex:outputPanel>
 </apex:pageBlock>
</apex:form>  
</apex:page>

<!-- End of Page -->