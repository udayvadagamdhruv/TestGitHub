<apex:page Controller="DisplayPOLIExTension" sidebar="flase" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" showHeader="false" standardStylesheets="true" >


<head>
<style>
.labelCol2{font-size:1.0em};

     #table_dr td
             {
                border:0px;
             }
             #table_amount td
             {
                 border:0px;
             }
             .hd
             {
             text-align:right;
             padding-right:20px!important;
             }
             .slds .slds-dropdown-trigger .slds-dropdown
             {
                margin-left: 46px;
    
             }
             .slds .slds-card__footer 
                    {
                       padding: 0px 16px 0px 0px;
                    }
                    .slds .slds-card__header 
                    {
                        padding: 0px 10px 0px 0px;
                    }
                    .slds .slds-card__body 
                    {
                        padding: 0px ;
                    }
                    
                    .slds .slds-card 
                    {
                        padding: 0;
                        border-radius: 0px;
                        background-clip: padding-box;
                        background-color:white;
                    }
                    
                    .slds .slds-table--bordered 
                    {
                        border-top: 0px solid #d8dde6;
                        border-bottom: 1px solid #d8dde6;
                    }
                    
                    .slds .slds-card__body 
                    {
                        margin-bottom: -0.25rem;
                        margin-top: -0.15rem;
                    }
      


</style>

</head>
<html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
<body>

  <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
 <div class="slds">
 
 <apex:form html-novalidate="novalidate" >
 
  
  
  
    <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
                   <apex:pageMessages id="pagemsgId5"></apex:pageMessages>
              </div>
  
      <div align="center">
       
       <apex:commandButton action="{!add_Eli}"  value="Add Estimate Line Items" id="btn1" rendered="{!AND(Not(ShowProductionEstimate),$ObjectType.Estimate_Line_Items__c.accessible)}" styleClass="slds-button slds-button--neutral slds-button-group" /> 
       <apex:commandButton action="{!add_PEli}" value="Add Production Estimate Line Items" id="btn2" rendered="{!AND(ShowProductionEstimate,$ObjectType.Production_Estimate__c.accessible)}" styleClass="slds-button slds-button--neutral slds-button-group" />
       </div>
        <br/> 
        <apex:outputPanel rendered="{!POLI.size>0}"> 
              <div class="slds-card" >
      
                   <div class="slds-card__body">
                   
                   
                   
                       <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                             <thead class="slds-truncate">
                                    <tr class="slds-text-title">
                                       
                                        <th class="slds-size--1-of-9" scope="col">Action</th>
                                        <apex:outputPanel rendered="{!AND(Not(ShowProductionEstimate),$ObjectType.Estimate_Line_Items__c.accessible)}">
                                        <th class="slds-size--1-of-9" scope="col">
                                            {!$ObjectType.PO_Line_Item__c.Fields.Estimate_Line_Item__c.Label} 
                                        </th>
                                        </apex:outputPanel>
                                        <apex:outputPanel rendered="{!AND(ShowProductionEstimate,$ObjectType.Production_Estimate__c.accessible)}">
                                            <th class="slds-size--1-of-9" scope="col"> 
                                                {!$ObjectType.PO_Line_Item__c.Fields.Production_Estimate__c.Label} 
                                            </th>
                                        </apex:outputPanel>
                                        <th class="slds-size--1-of-9" scope="col" > {!$ObjectType.PO_Line_Item__c.Fields.GL_Code__c.Label} </th>
                                        
                                        <apex:outputPanel rendered="{!(Not(ShowProductionEstimate))}">
                                            <th class="slds-size--1-of-9" scope="col">
                                                 {!$ObjectType.PO_Line_Item__c.Fields.Unit_Type__c.Label}
                                            </th> 
                                        </apex:outputPanel>
                                        
                                          <apex:outputPanel rendered="{!(Not(ShowProductionEstimate))}">
                                              <th class="slds-size--1-of-9"  scope="col" >
                                                    {!$ObjectType.PO_Line_Item__c.Fields.Quantity__c.Label} 
                                              </th>
                                          </apex:outputPanel>
                                          
                                           <apex:outputPanel rendered="{!(ShowProductionEstimate)}">
                                                <th class="slds-size--1-of-9" scope="col">
                                                    {!$ObjectType.PO_Line_Item__c.Fields.Quantity_production__c.Label} 
                                                </th>
                                            </apex:outputPanel>
                                       
                                        
                                        
                                        <th class="slds-size--1-of-9" scope="col"> {!$ObjectType.PO_Line_Item__c.Fields.Amount__c.Label} </th>
                                        <th class="slds-size--1-of-9" scope="col"> {!$ObjectType.PO_Line_Item__c.Fields.Invoice_Created__c.Label} </th>
                                   </tr>
                             </thead>
                             
                                <tbody>
                                
                                  <apex:repeat value="{!POLI}" var="POLItem" rendered="{!POLI.Size > 0}">
                                  <tr>
                                       <td class="slds-size--1-of-9" data-label="Action">
                                                <div>
                                                     <apex:commandButton value="Delete"  title="Delete" action="{!deletePOLI}" onclick="if(!confirm('Are you sure?')){return false;}" reRender="hiddenBlock2" styleClass="slds-button slds-button--neutral slds-button-group ">
                                                          <apex:param name="param2" value="{!POLItem.id}" assignTo="{!strPOLI}"></apex:param>
                                                     </apex:commandButton>
                                                </div>
                                        </td>
                                  
                                     
                                     <apex:outputPanel rendered="{!AND(Not(ShowProductionEstimate),$ObjectType.Estimate_Line_Items__c.accessible)}">
                                      <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Estimate_Line_Item__c.Label}"  >
                                                <div>
                                                     
                                                    <apex:outputLink value="/apex/estimatedetailpageLightning?id={!POLItem.Estimate_Line_Item__c}" >{!POLItem.Estimate_Line_Item__r.name}</apex:outputLink>
                                                </div>
                                        </td>
                                        </apex:outputPanel>
                                       <apex:outputPanel rendered="{!AND(ShowProductionEstimate,$ObjectType.Production_Estimate__c.accessible)}"> 
                                        <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Production_Estimate__c.Label}"   >
                                                <div>
                                                     <apex:outputfield value="{!POLItem.Production_Estimate__c}"/> 
                                                </div>
                                        </td>
                                        </apex:outputPanel>
                                        
                                         <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.GL_Code__c.Label}">
                                                <div>
                                                     <apex:outputfield value="{!POLItem.GL_Code__c}"/> 
                                                </div>
                                            </td>
                                           <apex:outputPanel rendered="{!(Not(ShowProductionEstimate))}"> 
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Unit_Type__c.Label}">
                                                <div>
                                                     <apex:outputfield value="{!POLItem.Unit_Type__c}"/> 
                                                </div>
                                            </td>
                                            </apex:outputPanel>
                                            
                                             <apex:outputPanel rendered="{!(Not(ShowProductionEstimate))}">
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Quantity__c.Label}" >
                                                <div>
                                                     <apex:outputfield value="{!POLItem.Quantity__c}"/> 
                                                </div>
                                            </td> 
                                            </apex:outputPanel>
                                            
                                            
                                             <apex:outputPanel rendered="{!(ShowProductionEstimate)}">
                                           
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Quantity_production__c.Label}" >
                                                <div>
                                                     <apex:outputfield value="{!POLItem.Quantity_production__c}"/> 
                                                </div>
                                            </td>
                                            </apex:outputPanel>
                                            
                                          
                                            
                                             <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Amount__c.Label}">
                                                <div>
                                                     <apex:outputfield value="{!POLItem.Amount__c}"/> 
                                                </div>
                                            </td>
                                        
                                            <td class="slds-size--1-of-9" data-label="{!$ObjectType.PO_Line_Item__c.Fields.Invoice_Created__c.Label}">
                                                <div>
                                                     <apex:outputfield value="{!POLItem.Invoice_Created__c}"/> 
                                                </div>
                                            </td>
                                        
                                        </tr>
                                   </apex:repeat>
                             
                                </tbody>
                               
                            </table>
                       
                      </div>
                      </div>
       </apex:outputPanel> 
       
       <apex:outputPanel rendered="{!POLI.size <= 0}">
               <p>No records to display</p>
       </apex:outputPanel>
        
     
 </apex:form>
 </div>
 </body>
 </html>
</apex:page>
<!-- End of Page -->