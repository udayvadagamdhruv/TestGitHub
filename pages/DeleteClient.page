<!-- this Page is used to override the delete button of Account object -->

<apex:page standardController="Client__c" extensions="DeleteClient" sidebar="false" showHeader="false">
 
   <script>
      window.onload=function()
        {
          doInit();
        };
   </script>  

   <apex:pageMessages id="msg"></apex:pageMessages>
   
   <apex:form >
      
      <apex:actionFunction name="doInit" action="{!CheckDelete}" reRender="msg,po"/>
      <apex:outputPanel id="po">
         <center> <apex:outputLink value="/{!oId}" rendered="{!(isError!=False)}">Click here to Go to List</apex:outputLink> </center>
      </apex:outputPanel>

   </apex:form>

</apex:page>
<!-- End of Page -->