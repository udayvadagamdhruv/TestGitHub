<!-- This page is used to edit Staff record. -->
<apex:page standardController="Staff__c" extensions="staffEditExtension" tabStyle="MyAdmin__tab">
<apex:sectionHeader title="{!(objJTR.First_Name__c+' '+objJTR.Last_Name__c)}"/> 
    <apex:form >
     <apex:pageMessages />
      <apex:pageBlock mode="edit" id="ebc">
            <apex:pageBlockButtons >
                    <apex:commandButton action="{!Saveme}" value=" Save "></apex:commandButton>
                    <apex:commandButton action="{!Cancel}" value="Cancel"></apex:commandButton>
             </apex:pageBlockButtons>
             
              <apex:pageBlockSection title="Staff Detail" columns="2" collapsible="false" > 
                    <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.User_Type__c.Label}"></apex:outputLabel>
                         <apex:inputField value="{!objJTR.User_Type__c}"></apex:inputField> 
                     </apex:pageBlockSectionItem> 
                    <apex:pageBlockSectionItem ></apex:pageBlockSectionItem>
                  
                     <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.First_Name__c.Label}"/>
                         <apex:inputField value="{!objJTR.First_Name__c}" required="true"/>
                     </apex:pageBlockSectionItem>
                     
                      <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Active__c.Label}"/>
                         <apex:inputCheckbox value="{!objJTR.Active__c}"/>
                     </apex:pageBlockSectionItem>  
                                    
                     <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Last_Name__c.Label}"/>
                         <apex:inputField value="{!objJTR.Last_Name__c}" required="true"/>
                  </apex:pageBlockSectionItem> 
 
                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Username__c.Label}"></apex:outputLabel>
                         <apex:inputField value="{!objJTR.Username__c}" required="true"/> 
                  </apex:pageBlockSectionItem>

                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Department__c.Label}"/>
                         <apex:inputField value="{!objJTR.Department__c}"/>
                  </apex:pageBlockSectionItem>
                                                     
                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Email__c.Label}"/>
                         <apex:inputField value="{!objJTR.Email__c}" required="true"/>
                  </apex:pageBlockSectionItem>                   
                  
                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Phone_1__c.Label}"/>
                         <apex:inputField value="{!objJTR.Phone_1__c}"/>
                  </apex:pageBlockSectionItem> 
                  
                  
                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Staff__c.Fields.Fax__c.Label}"/>
                         <apex:inputField value="{!objJTR.Fax__c}"/>
                  </apex:pageBlockSectionItem> 
                  
                  <apex:pageBlockSectionItem >
                    <apex:outputLabel value="Profile" for="prol"></apex:outputLabel> 
                       <apex:outputPanel >
                            <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                               <div class="requiredBlock"> </div>
                               <apex:selectList value="{!ProfileName}" multiselect="false" size="1"> 
                                   <apex:selectOptions value="{!Profile}"/>
                               </apex:selectList> 
                            </span>
                       </apex:outputPanel>
                   </apex:pageBlockSectionItem> 
                    
                 <apex:pageBlockSectionItem >
                   <apex:outputLabel value="Role" for="rl"></apex:outputLabel> 
                    <apex:outputPanel >
                        <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                              <div class="requiredBlock"> </div>
                               <apex:selectList value="{!RoleName}" multiselect="false" size="1">
                                     <apex:selectOptions value="{!Role}"/>
                                </apex:selectList>
                        </span>
                     </apex:outputPanel>
                  </apex:pageBlockSectionItem> 
                  
                 
                       
     </apex:pageBlockSection>
</apex:pageBlock>            
</apex:form>
</apex:page>
<!-- End of Page -->