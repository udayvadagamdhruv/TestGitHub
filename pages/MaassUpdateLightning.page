     <script src="{!URLFOR($Resource.jQueryScheduleUpadate,'/js/jquery-1.5.1.min.js')}" type="text/javascript" />
    <script src="{!URLFOR($Resource.jQueryScheduleUpadate,'/js/jquery-ui-1.8.13.custom.min.js')}" type="text/javascript" />
    <apex:stylesheet value="{!URLFOR($Resource.jQueryScheduleUpadate,'/css/ui-lightness/jquery-ui-1.8.13.custom.css')}" />
    <script>

   var PEboo;
    
    
    
      var j$ = jQuery.noConflict();
         
         
         j$(document).ready(function(){
         j$( "#dialog-confirm1").dialog({
            autoOpen: false,
            resizable: false,
            height:150,
            modal: true,
            buttons: {
                "Yes": function() {
                    
                     
                 var retVal =   document.getElementById('{!$Component.frm1.hidden}').value = 'true';
                 
                  myFunc(retVal);
                    
                    j$( this ).dialog( "close" );
                },
                "No": function() {
                 var retVal =   document.getElementById('{!$Component.frm1.hidden}').value = 'false';
                 
                  myFunc(retVal);
                    j$( this ).dialog( "close" );
                }
            }
        });
        
        
        
        });
            
        function confirmBox(peboo)
        {
           if(peboo==true)
           { 
                j$( "#dialog-confirm1" ).dialog( "open" ); 
           }
         
        }    
    
    
</script>
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
         <meta name="viewport" content="width=device-width, initial-scale=1"/>
          <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
          <link href="{!URLFOR($Resource.JobPage,'JobPage/MaterialIcons.css')}" rel="stylesheet"/>
         <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>
         
         
        
     
           <body>
     
             <!-- REQUIRED SLDS WRAPPER -->
              <div class="slds">
              
                  <apex:form html-novalidate="novalidate" id="frm1">
                  
                  <apex:actionFunction name="myFunc" action="{!Complete}" reRender="pb,tstpopup2" status="mark">
                        <apex:param name="itemsConfirm" assignTo="{!completeItems}"   value="" />
                  </apex:actionFunction>
                  <apex:outputPanel id="pb">
                  
                       <div class="slds-media__body pageHeader">
                            <div class="slds-media slds-no-space slds-grow" >
                                <div class="slds-media__figure">
                                   <img src="{!$Resource.JobLogo}" width="50px" height="50px" style="margin-top: -15px;"/> 
                                </div>                        
                                <div class="slds-media__body">
                                    <h1 class="slds-page-header__title slds-m-right--small slds-align-middle slds-truncate"><b>Jobs</b></h1>
                                </div>
                                  <apex:commandButton value="Mark Complete"   onclick="confirmBox({!ShowPELI});" reRender="none" styleclass="slds-button slds-button--neutral"/>
                                           
                                    <apex:actionStatus id="mark">
                                         <apex:facet name="start">
                                            <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
                                         </apex:facet>
                                     </apex:actionStatus> &nbsp;&nbsp;
                                  <apex:commandButton value="Cancel" action="{!CancelBut}" styleclass="slds-button slds-button--neutral"/>&nbsp;&nbsp;
                            </div>
                        </div>
                        
                     <br/><br/><br/><br/>
                       
                       <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" >
                           <apex:pageMessages id="ff"/>
                       </div> <br/>
                       
                       
                          
                          <table style="width:100% !important;">
                              <tr>
                                
                        <!--*********************************************************** Search Section *******************************************************************-->            
                                
                                    <td id="searchsection" style="padding-right:0px !important;" valign="top" width="17%">
                                       <div style="margin-left: -17px !important;">
                                           <apex:pageBlock mode="edit">
                                                <div style="background-color:SteelBlue;color:white;" class="SectionHeader">
                                                    <h3 class="slds-section-title"><b>&nbsp;Search</b></h3>
                                                </div>
                                                
                                                <div class="slds-grid slds-wrap">
                                                    <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--12-of-12" >
                                                    
                                                         <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--12-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>Campaign</b> </label>
                                                                <div class="slds-form-element__control" styleClass="slds-input">
                                                                     <apex:selectList id="campg" value="{!strCampaignName}" multiselect="true" size="3" onchange="campp()">
                                                                           <apex:selectOptions value="{!Campaigns}"></apex:selectOptions>
                                                                           <apex:actionFunction name="campp" action="{!updatejob}"/>
                                                                       </apex:selectList>
                                                                </div>
                                                            </div>
                                                        </aside>
                                                        
                                                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--12-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>Media Type</b> </label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:selectList id="media" value="{!strmediatype}"  multiselect="true" size="3" onchange="media()">
                                                                       <apex:selectOptions value="{!Mediatype}"></apex:selectOptions>
                                                                            <apex:actionFunction name="media" action="{!updatejob}"/>
                                                                   </apex:selectList>
                                                                </div>
                                                            </div>
                                                        </aside>
                                                        
                                                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--12-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>Schedule Template</b> </label>
                                                                <div class="slds-form-element__control" >
                                                                     <apex:selectList id="schd" value="{!strscheduletemp}"  multiselect="true" size="3" onchange="schd()">
                                                                           <apex:selectOptions value="{!scheduletemp}"></apex:selectOptions>
                                                                           <apex:actionFunction name="schd" action="{!updatejob}"/>
                                                                       </apex:selectList>
                                                                </div>
                                                            </div>
                                                        </aside>
                                                        
                                                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-1 slds-large-size--12-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>Client</b> </label>
                                                                <div class="slds-form-element__control" styleClass="slds-input">
                                                                    <apex:selectList id="client" value="{!strClientName}" multiselect="true" size="3" onchange="clien()">
                                                                       <apex:selectOptions value="{!Clients}"></apex:selectOptions>
                                                                          <apex:actionFunction name="clien" action="{!updatejob}"/>
                                                                   </apex:selectList>
                                                                </div>
                                                            </div>
                                                        </aside>
                                                        
                                                    </main>
                                               </div>
                                               <br/><br/>
                                                   <apex:pageBlockButtons location="bottom" >
                                                      <apex:commandButton value="Reset" action="{!Reset}" styleclass="slds-button slds-button--neutral"/>
                                                  </apex:pageBlockButtons>
                                          </apex:pageBlock>
                                      </div>
                                  </td>
                           <!--*********************************************************** End of Search Section *******************************************************************-->


                           <!--*********************************************************** Print Section **************************************************************************-->         
                                   
                                      
                                   <td style="width:83% !important;" valign="top">
                                       <apex:pageBlock mode="edit" id="results">
                                           <div style="background-color:SteelBlue;color:white;" class="SectionHeader">
                                               <h3 class="slds-section-title"><b>&nbsp;Result</b></h3>
                                           </div><br/>
                                           
                                         
                                            
                                              
                                            
                                        <br/><br/>
                                            <apex:outputPanel id="tb">
                                           <apex:variable var="ind" value="{!-1}">
                                               <div class="slds-card">             
                                                   <div class="slds-card__body"  style="padding: 0px;">   
                                                  
                                                 <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                                 
                                                        <thead class="slds-truncate">
                        
                                                            <tr class="slds-text-title">
                                                            
                                                                <th class="slds-size--1-of-10" scope="col">
                                                                   Action
                                                                </th>
                                                                <th class="slds-size--1-of-10" scope="col"> 
                                                                    Job#
                                                                </th>
                                                                <th class="slds-size--1-of-10" scope="col">
                                                                   Job Name       
                                                                </th>
                                                                
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                       
                                                            <apex:repeat value="{!jobsInnerObj}" var="inner">
                                                                <tr class="slds-hint-parent">
                                                                   
                                                                    <td class="slds-size--1-of-10" data-label="Action" style="color:black;"  valign="top">
                                                                        <div>
                                                                          <apex:inputCheckbox value="{!inner.isSelected}"/>
                                                                        </div>
                                                                    </td>
                                                                    
                                                                     <td class="slds-size--1-of-10" data-label="Job#" style="color:black;"  valign="top">
                                                                        <div>
                                                                          <apex:outputField value="{!inner.jobs.Job_Auto_Number__c }"/> 
                                                                        </div>
                                                                    </td>
                                                                    
                                                                     <td class="slds-size--1-of-10" data-label="Job Name" style="color:black;"  valign="top">
                                                                        <div>
                                                                           <apex:variable var="ind" value="{! ind +1}"/>
                                                                           <apex:outputField value="{!inner.jobs.name}"/> 
                                                                        </div>
                                                                    </td>
                                                                    
                                                                    
                                                                </tr>
                                                            </apex:repeat> 
                                                        
                                                        </tbody>
                                                         
                                                   </table>
                                                   
                                              </div>  
                                            </div> <br/>
                                          
                                   </apex:variable>
                                  <apex:commandButton value="<<Previous" action="{!previous}" rendered="{!hasPrevious}" status="edstatus" rerender="tb"/>
                                  <apex:commandButton value="Next >>" action="{!next}" rendered="{!hasNext}" status="edstatus1" rerender="tb"/>
                             
                                    <apex:actionStatus id="edstatus">
                                         <apex:facet name="start">
                                            <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
                                         </apex:facet>
                                     </apex:actionStatus> 
                      
                                     <apex:actionStatus id="edstatus1">
                                         <apex:facet name="start">
                                              <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
                                         </apex:facet>
                                     </apex:actionStatus> 
                                      </apex:outputPanel> 
                                    <apex:outputPanel id="tstpopup2">
                                    <apex:outputPanel styleClass="popupBackground" layout="block" rendered="{!load}"/>
                                    <apex:outputPanel styleClass="custPopup" layout="block" rendered="{!load}" ><br/>
                                        <center>
                                            <b><Font style="color:orange;font-size:25px;">Sucessfully Updated {!size} Jobs</Font></b><br/><br/>
                                           
                                            <b> <apex:commandButton value="OK" action="{!CancelBut}" style="width:20%;height:40%;font-size:160%;"/> </b>
                                        </center>
                                   </apex:outputPanel>
                                   </apex:outputPanel>
        
        
                                    <div id="dialog-confirm1" title="Status complete" style="display:{!if(ShowPELI==true,"block","none")}">
                                        <p>
                                            Do you want to Aprrove  all Production Estimate Line Items?
                                        </p>
                                    </div>
                              </apex:pageBlock>
                           </td> 
                        </tr>
                    </table>
            <apex:inputhidden value="{!ApprovePe}" id="hidden" />
        
         </apex:outputPanel>
        
    </apex:form>
    
     <style type="text/css">
        .custPopup{
            background-color: white;
            border: 2px solid orange;
            border-radius: 20px;
            z-index: 9999;
            left: 50%;
            padding:10px;
            position: absolute;
            /* These are the 3 css properties you will need to change so the popup 
            displays in the center of the screen. First set the width. Then set 
            margin-left to negative half of what the width is. You can add 
            the height property for a fixed size pop up if you want.*/
            width: 500px;
            margin-left: -250px;
            top:50px;
        }
        .popupBackground{
            background-color:lightblue;
            opacity: 0.20;
            filter: alpha(opacity = 20);
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 9998;
        }
        .a:focus {
            background-color:orange;
        }

    </style>
           </div> 
        </body>
    </html>
 
</apex:page>