<apex:page standardController="Job__c" extensions="MassUpdateController" recordSetVar="job" tabStyle="Job__c" sidebar="true" docType="html-5.0" standardStylesheets="true" showHeader="false" applyBodyTag="false" applyHtmlTag="false">
 
     
