<!-- This page is used to edit Purchase Order. -->
<apex:page standardController="Purchase_Order__c" extensions="editPurchaseorderExtension" tabStyle="Job__c">
 <apex:form >
  <apex:sectionHeader title="Purchase Order Details"/>
     <apex:pageBlock >
         <apex:pagemessages />
             <apex:pageBlockButtons >
                 <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
                 <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
             </apex:pageBlockButtons>
             
             <apex:pageBlockSection title="Information" columns="2" collapsible="true">
             
              <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Name.Label}"/>
                  <apex:outputField value="{!Purchase_Order__c.Name}"/>
             </apex:pageBlockSectionItem>   
             
               <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Job__c.Label}"/>
                  <apex:outputField value="{!Purchase_Order__c.Job__c}"/>
             </apex:pageBlockSectionItem>
             
             <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Vendor__c.Label}"/>
                  <apex:outputField value="{!Purchase_Order__c.Vendor__c}"/>
             </apex:pageBlockSectionItem>
                         
             
            <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Invoice_Created__c.Label}"/>
                  <apex:outputField value="{!Purchase_Order__c.Invoice_Created__c}"/>
             </apex:pageBlockSectionItem> 
             
            <apex:pageBlockSectionItem >
               <apex:outputLabel Value="{!$ObjectType.Purchase_Order__c.Fields.Vendor_Contact__c.Label}"/>
               <apex:selectList value="{!Purchase_Order__c.Vendor_Contact__c}" multiselect="false" size="1" id="vc" >                        
                        <apex:selectOptions value="{!VendorContact}"/>
               </apex:selectList>
            </apex:pageBlockSectionItem> 
             
              <apex:pageBlockSectionItem >
                <Apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Status__c.Label}"></Apex:outputLabel>            
                <apex:inputField value="{!Purchase_Order__c.Status__c}"/>
              </apex:pageBlockSectionItem> 
             
                <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Notes__c.Label}"/>
                  <apex:inputField value="{!Purchase_Order__c.Notes__c}"/>
             </apex:pageBlockSectionItem>  
              
  
                      
  
           
             <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Issue_Date__c.Label}"/>
                  <apex:inputField value="{!Purchase_Order__c.Issue_Date__c}" required="true"/>
             </apex:pageBlockSectionItem>
             
               <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Due_Date__c.Label}"/>
                  <apex:inputField value="{!Purchase_Order__c.Due_Date__c}" required="true"/>
             </apex:pageBlockSectionItem>  
             
              <apex:pageBlockSectionItem >  
                  <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Approved_By_Staff__c.Label}" for="Staff" ></apex:outputLabel>
                  <apex:selectList id="Staff" value="{!StaffName}" size="1">
                  <apex:selectOptions value="{!Staffs}"></apex:selectOptions>
                  </apex:selectList> 
             </apex:pageBlockSectionItem>
             
          
             
             <apex:pageBlockSectionItem ></apex:pageBlockSectionItem>
             
             <!-- Start Dummy (Variable) fields here -->
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Text_1__c.Label!='Dummy Text 1'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Text_1__c.Label}"/>
                        <apex:inputField value="{!Purchase_Order__c.Dummy_Text_1__c}"/>
             </apex:pageBlockSectionItem>    
                
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Date_1__c.Label!='Dummy Date 1'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Date_1__c.Label}"/>
                    <apex:inputField value="{!Purchase_Order__c.Dummy_Date_1__c}"/>
             </apex:pageBlockSectionItem> 
             
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Text_2__c.Label!='Dummy Text 2'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Text_2__c.Label}"/>
                        <apex:inputField value="{!Purchase_Order__c.Dummy_Text_2__c}"/>
             </apex:pageBlockSectionItem>    
                
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Date_2__c.Label!='Dummy Date 2'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Date_2__c.Label}"/>
                    <apex:inputField value="{!Purchase_Order__c.Dummy_Date_2__c}"/>
             </apex:pageBlockSectionItem>        
             
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Text_3__c.Label!='Dummy Text 3'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Text_3__c.Label}"/>
                        <apex:inputField value="{!Purchase_Order__c.Dummy_Text_3__c}"/>
             </apex:pageBlockSectionItem>    
                
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Date_3__c.Label!='Dummy Date 3'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Date_3__c.Label}"/>
                    <apex:inputField value="{!Purchase_Order__c.Dummy_Date_3__c}"/>
             </apex:pageBlockSectionItem> 
             
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Picklist_1__c.Label!='Dummy Picklist 1'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Picklist_1__c.Label}"/>
                    <apex:inputField value="{!Purchase_Order__c.Dummy_Picklist_1__c}"/>
             </apex:pageBlockSectionItem> 
             
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Picklist_2__c.Label!='Dummy Picklist 2'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Picklist_2__c.Label}"/>
                    <apex:inputField value="{!Purchase_Order__c.Dummy_Picklist_2__c}"/>
             </apex:pageBlockSectionItem> 
             
             <apex:pageBlockSectionItem rendered="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Picklist_3__c.Label!='Dummy Picklist 3'}">
                    <apex:outputLabel value="{!$ObjectType.Purchase_Order__c.Fields.Dummy_Picklist_3__c.Label}"/>
                    <apex:inputField value="{!Purchase_Order__c.Dummy_Picklist_3__c}"/>
             </apex:pageBlockSectionItem> 
             
        <!-- End of Dummy Fields-->
            
            
      </apex:pageBlockSection>
    </apex:pageBlock>
  </apex:form>
</apex:page>
<!-- End of Page -->