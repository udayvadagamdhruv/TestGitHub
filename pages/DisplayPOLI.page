<apex:page Controller="DisplayPOLIExTension" >
<head>
<style>
.labelCol2{font-size:1.0em};
</style>

</head>
 <apex:form >
 <apex:pageMessages > </apex:pageMessages>
  <apex:pageBlock >
       <span style="padding-left:450px;margin:5px;padding-bottom:20px;">
       <apex:commandButton action="{!add_Eli}" value="Add Estimate Line Items" id="btn1" rendered="{!AND(Not(ShowProductionEstimate),$ObjectType.Estimate_Line_Items__c.accessible)}"/> 
       <apex:commandButton action="{!add_PEli}" value="Add Production Estimate Line Items" id="btn2" rendered="{!AND(ShowProductionEstimate,$ObjectType.Production_Estimate__c.accessible)}"/>
       
       </span>
       
  <!-- <apex:commandButton action="{!URLFOR($Action.PO_Line_Item__c.New)}" value="Add POLI" id="btn2"  /> -->
  <br/> <br/> 
  
     <apex:pageBlockTable value="{!POLI}" var="POLItem" rendered="{!POLI.Size>0}">
         <apex:column headerValue="Action" width="10%">
              <apex:commandButton value="Delete" action="{!deletePOLI}" onclick="if(!confirm('Are you sure?')){return true;}" reRender="hiddenBlock2">
                  <apex:param name="param2" value="{!POLItem.id}" assignTo="{!strPOLI}"></apex:param>
              </apex:commandButton>
          </apex:column>
          
         <!--
              <apex:column headerValue="Name">
                  <apex:outputfield value="{!POLItem.Name}"/>
              </apex:column> 
          -->
          
          
          
        
        <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Estimate_Line_Item__c.Label}" rendered="{!AND(Not(ShowProductionEstimate),$ObjectType.Estimate_Line_Items__c.accessible)}">
              <apex:outputfield value="{!POLItem.Estimate_Line_Item__c}"/>
          </apex:column>
          
        <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Production_Estimate__c.Label}" rendered="{!AND(ShowProductionEstimate,$ObjectType.Production_Estimate__c.accessible)}">
              <apex:outputfield value="{!POLItem.Production_Estimate__c}"/>
          </apex:column>  
          
           <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.GL_Code__c.Label}">
              <apex:outputfield value="{!POLItem.GL_Code__c}"/>
          </apex:column> 
          
           <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Unit_Type__c.Label}" rendered="{!(Not(ShowProductionEstimate))}">
              <apex:outputfield value="{!POLItem.Unit_Type__c}"/>
          </apex:column> 
          
          <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Quantity__c.Label}" rendered="{!(Not(ShowProductionEstimate))}">
              <apex:outputfield value="{!POLItem.Quantity__c}"/>
          </apex:column>
          
          <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Quantity_production__c.Label}" rendered="{!(ShowProductionEstimate)}">
              <apex:outputfield value="{!POLItem.Quantity_production__c}"/>
          </apex:column> 
            
          
           <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Amount__c.Label}">
              <apex:outputfield value="{!POLItem.Amount__c}"/>
          </apex:column> 
          
          
          
            <apex:column headerValue="{!$ObjectType.PO_Line_Item__c.Fields.Invoice_Created__c.Label}">
          <apex:outputfield value="{!POLItem.Invoice_Created__c}"/>
          </apex:column> 
     
     </apex:pageBlockTable>
     
        <apex:pageBlockSection rendered="{!POLI.size <= 0}">
           <apex:pageBlockSectionItem >
               <b>No records to display</b>
           </apex:pageBlockSectionItem>              
        </apex:pageBlockSection> 
      </apex:pageBlock>
 </apex:form>
</apex:page>
<!-- End of Page -->