<!-- This page is used to displta Tag Template under Jobs Tab -->
<apex:page standardController="Job__c" extensions="displayTagsUnderJobTab_New" id="thePage" tabStyle="Job__c">
    <head>
        <style>
            #table_title td
            {
                border:0px;
            }
            #table_tag_start_date td
            {
                border:0px;
            }
            #table_tag_end_date td
            {
                border:0px;
            }
            #table_tag_due_date td
            {
                border:0px;
            }
            #table_tag_air_date td
            {
                border:0px;
            }
            #table_tag_air_time td
            {
                border:0px;
            }
            #table_tag_lengths td
            {
                border:0px;
            }
        </style>
    </head>
    <apex:form id="pb1">
     
    <apex:pageMessages id="PgMSGId"></apex:pageMessages>
    <apex:pageblock id="pb">    
    <table width="100%" >
                          <tr>
                          <td colspan="2">
                           <h1 ><b>{!$ObjectType.Tag__c.Label}</b></h1>
                          </td>
                          </tr>
                          <tr>
                               <td align="left" width="40%" style="padding-top:10px;" >
                                     <apex:outputLabel value="{!$ObjectType.Tag__c.Label} Templates "/>&nbsp;
                                            <apex:selectList id="theSelectList" value="{!TagTempName}" size="1" >
                                                  <apex:selectOptions value="{!TagTemplates}" id="sp"></apex:selectOptions>
                                              </apex:selectList> &nbsp;
                                           <apex:commandButton value="Import {!$ObjectType.Tag__c.Label}" action="{!importTags}" onclick="if(!confirm('This will import new tags')){return false;}" id="btn1"></apex:commandButton>&nbsp;
                               </td>      
                               
                               <td align="left">  
                                     <apex:commandButton value="Add {!$ObjectType.Tag__c.Label}" action="{!addNewJobTag}" id="addspec"/>&nbsp;
                                     <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display:none;"/>&nbsp;
                                     <apex:commandButton value="Cancel" id="cancelButton" action="{!cancelme}" style="display:none;" reRender="pb1"/>&nbsp;                                     
                                </td>
                           </tr>
                     </table><br/>
        
                     <apex:pageBlockTable value="{!lstJobTag}" var="lst" rendered="{!lstJobTag.size>0}" id="results">
                          <apex:column headerValue="Action" width="13%" style="vertical-align:top;">
                              <apex:commandButton value="Edit" action="{!editJobTag}" reRender="hiddenBlock1" rendered="{!$ObjectType.Tag__c.updateable}">
                                    <apex:param name="param1" value="{!lst.id}" assignTo="{!tagId}"></apex:param>
                                </apex:commandButton> &nbsp;
                
                                <apex:commandButton value="Delete" action="{!deleteJobTag}" onclick="if(!confirm('Are you sure?')){return false;}" reRender="hiddenBlock2" rendered="{!$ObjectType.Tag__c.deletable}">
                                    <apex:param name="param2" value="{!lst.id}" assignTo="{!tagId}"> </apex:param>
                                </apex:commandButton>&nbsp; 
                                <!--Added by yogini on 18-Sep-13 -->
                                <apex:commandButton value="Copy" action="{!DuplicateTag}" reRender="hiddenBlock1" rendered="{!$ObjectType.Tag__c.updateable}">
                                    <apex:param name="param3" value="{!lst.id}" assignTo="{!tagId}"></apex:param>
                                </apex:commandButton> &nbsp;        
                                                           
                        </apex:column>
            
                       
                        <apex:repeat var="f" value="{!$ObjectType.Tag__c.FieldSets.TagsFieldsets}">
                        
                        
                              <apex:column width="20%" rendered="{!OR(CONTAINS(LOWER(f) , LOWER('name')))}">
                                 <apex:facet name="header">   
                                   <apex:commandLink action="{!LoadTags}" value="{!f.label}{!IF(sortExpression=='name',IF(sortDirection='ASC','▼','▲'),'')}" id="cmdSort">
                                     <apex:param value="name" name="column" assignTo="{!sortExpression}" ></apex:param>
                                   </apex:commandLink>
                                 </apex:facet>
                                 <apex:outputLink tabindex="tab1" value="apex/TagDetailPage?id={!lst.id}">{!lst.Name}</apex:outputLink>
                               </apex:column>
                              
                              
                               <apex:column headerValue="{!f.label}" width="20%" rendered="{!OR(CONTAINS(LOWER(f) , LOWER('Job__c')))}">
                                     <apex:outputField value="{!lst[f]}"/>
                              </apex:column>
                              
                              <apex:column rendered="{!NOT(OR(CONTAINS(LOWER(f) , LOWER('name')),(CONTAINS(LOWER(f) , LOWER('Job__c')))))}">
                              
                                 <apex:facet name="header">   
                                   <apex:commandLink action="{!LoadTags}" value="{!f.label}{!IF(sortExpression=='{!f}',IF(sortDirection='ASC','▼','▲'),'')}" >
                                     <apex:param value="{!f}" name="{!f}" assignTo="{!sortExpression}" ></apex:param>
                                   </apex:commandLink>
                                 </apex:facet>
                              
                                   <apex:outputField value="{!lst[f]}">
                                        <apex:inlineEditSupport event="ondblclick" hideOnEdit="addspec" showOnEdit="saveButton,cancelButton"/>
                                       &nbsp;&nbsp; <apex:image url="{!$Resource.Plus}" width="9" height="9" rendered="{!NOT(OR(CONTAINS(LOWER(f) , LOWER('name'))))}"/> 
                                    </apex:outputField>
                              </apex:column>
                              
                       </apex:repeat>
                   
                  
                                                                                                          
        </apex:pageBlockTable> 
         <apex:pageBlockSection rendered="{!lstJobTag.size <= 0}">
               <apex:pageBlockSectionItem >
                   <b>No records to display</b>
               </apex:pageBlockSectionItem>              
         </apex:pageBlockSection> 
    </apex:pageBlock> 
 </apex:form>
</apex:page>
<!-- End of Page -->