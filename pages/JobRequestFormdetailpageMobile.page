        <script>
            var section;
            if ("{!section}" == 'timesheet') {
                section = 3;
                }
           else if("{!section}" == 'JobFiles') {
                section = 4;
            } 
            else if("{!section}" == 'CreativeBrief') {
                section = 2;
            } else if ("{!section}" == 'Schedule') {
                section = 1;
            } else {
                section = 0;
            }
            $(function() {
                $("#accordion").accordion({
                    collapsible: true,
                    heightStyle: "content",
                    
                   active: section

                });

            });
            
           $(function(){
                $("#accordion>h1").click(function(){
                $('body').animate({scrollTop:0},"fast");
                  });
               }); 
            
        </script>

