<apex:page standardController="Timesheet_Entries__c" extensions="MyTimesheetlistviewController" sidebar="false" showHeader="false"  docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" standardStylesheets="true" tabStyle="Timesheet_Entries__c">
     <style>
   
          .slds .slds-card__footer {
               padding: 0px 16px 0px 0px;
          }
          .slds .slds-card__header {
            padding: 0px 10px 0px 0px;
            }
           .slds .slds-card__body {
                padding: 0px ;
            }
            
          .slds .slds-card {
                padding: 0;
                border-radius: 0px;
                background-clip: padding-box;
                background-color:white;
                }
            
            .slds .slds-table--bordered {
                border-top: 0px solid #d8dde6;
                border-bottom: 1px solid #d8dde6;
              }
                        
            .slds .slds-card__body {
                margin-bottom: -0.25rem;
                margin-top: -0.15rem;
               }
               
               .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
               {
                        border-bottom: 0px solid #d8dde6; 
               }
               
            
            
        </style>
   
   
   
   
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />

    
   
    <div class="slds">
    
    
        <apex:form html-novalidate="novalidate">

         <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
              <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
         </div> 

         <div align="center">
           <!-- <apex:commandlink action="{!NewMethod}" target="_blank" style="text-decoration: none;"  styleClass="slds-button slds-button--neutral">New </apex:commandLink> 
               <apex:commandButton value="New"  action="{!NewMethod}" styleClass="slds-button slds-button--neutral"/> --->
            <apex:outputLink target="_self" value="/apex/TimesheetEntriesLightning?Page=HomePage" styleClass="slds-button slds-button--neutral"> New  </apex:outputLink>
                                                                     
                                                                      
                                                                    
           
         </div>  
         
         <br/>
         
         <apex:outputlabel rendered="{!TsEnty.size == 0}">
              <b>No records to display</b>
         </apex:outputLabel>
        
        <apex:outputPanel id="p">
         <div class="slds-card">
                            
                      <div class="slds-card__body">

                        <apex:outputPanel layout="block" rendered="{!TsEnty.size != 0}">

                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <thead class="slds-truncate">

                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-5" scope="col"> 
                                            {!$ObjectType.Timesheet_Entries__c.Fields.Name.Label}
                                        </th>
                                        <th class="slds-size--1-of-5" scope="col">
                                              {!$ObjectType.Job__c.Fields.Name.Label}
                                        </th>
                                        <th class="slds-size--1-of-5" scope="col">
                                            {!$ObjectType.Timesheet_Entries__c.Fields.Task_Name__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-5" scope="col">
                                            {!$ObjectType.Timesheet_Entries__c.Fields.Date__c.Label}
                                        </th>
                                        <th class="slds-size--1-of-5" scope="col">
                                            {!$ObjectType.Timesheet_Entries__c.Fields.Hours_Worked__c.Label}
                                        </th>
                                       
                                    </tr>
                                </thead>
                                <tbody>

                                    <apex:repeat value="{!TsEnty}" var="ci" rendered="{!TsEnty.size != 0}" >

                                        <tr class="slds-hint-parent">
                                        
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Timesheet_Entries__c.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputLink tabindex="tab1" value="/{!ci.Id}">{!ci.Name}</apex:outputlink>
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Job__c.Fields.Name.Label}">
                                                <div>
                                                    <apex:outputField value="{!ci.Job__r.Name}"/>
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Timesheet_Entries__c.Fields.Task_Name__c.Label}">
                                                <div>
                                                   <apex:outputField value="{!ci.Task_Name__c}"/> 
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-5" data-label="{!$ObjectType.Timesheet_Entries__c.Fields.Date__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!ci.Date__c}"/>
                                                </div>
                                            </td>
                                            
                                           <td class="slds-size--1-of-5" data-label="{!$ObjectType.Timesheet_Entries__c.Fields.Hours_Worked__c.Label}">
                                                <div>
                                                    <apex:outputField value="{!ci.Hours_Worked__c}"/>
                                                </div>
                                            </td>
                                            
                                        </tr>

                                    </apex:repeat>
                                </tbody>
                            </table>
                        </apex:outputpanel>
                    </div>
                   
                    
                    </div>
                    <br/>
                     <div align="center">
                         <apex:commandButton value="Prev" rerender="p" action="{!previous}" disabled="{!prev}" styleClass="slds-button slds-button--neutral"/>
                         <apex:commandButton value="Next" rerender="p" action="{!next}" disabled="{!nxt}" styleClass="slds-button slds-button--neutral"/>
                    </div>
               </apex:outputPanel>               
                      </apex:form>
      </div>
      

    </html>
</apex:page>