     </style>
        
        

   <script>
   
        function glview() {
            glview1();
            document.getElementById('glviewlink').style.display = 'none';
            document.getElementById('gllesslink').style.display = 'block';
            
          }
        
        function glless() {
            glless1();
            document.getElementById('glviewlink').style.display = 'block';
            document.getElementById('gllesslink').style.display = 'none';
            
         }
         
         function popup() 
         {
               window.open('/apex/EditQuoteLightning?jobid={!theId}');
         }
              
     
            function popup() {
               window.open('/apex/CreateNewQuoteLightning?jobid={!theId}');
            }
              
        
        
        </script>




    </head>


    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
    
       <div class="slds" >
        <apex:form html-novalidate="novalidate">

            <apex:actionFunction action="{!ViewAll}" name="glview1" reRender="dv" status="LoadingStatus"  />
            
            <apex:actionFunction action="{!Showless}" name="glless1" reRender="dv" status="LoadingStatus"  />

         <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
                <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
                
            </div>  

            
                                 <div align="center">
                             
                                   
                                   
                             
                                                                                  
                                         
                                         
                                   <apex:commandButton value="New Purchase Order" action="{!CreateQuote}" id="btn1" styleClass="slds-button slds-button--neutral slds-button-group" />
                                    
                                   </div>
                               
                                <br/>
             
                     
