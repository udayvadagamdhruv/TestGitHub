                                        <th   scope="col" > PO# </th>
                                        
                                  
                                    </tr>
                                </thead>
                                <tbody>

                                    <apex:repeat value="{!q}" var="quote" rendered="{!q.Size > 0}">

                                        <tr class="slds-hint-parent">
                                        
                                            <td   data-label="Action">
                                                  <div class="slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open">
                                                     &nbsp;&nbsp;  
                                                        <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small slds-shrink-none">
                                                            &nbsp;<svg aria-hidden="true" class="slds-button__icon slds-button__icon--hint slds-button__icon--small">
                                                                 <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/utility-sprite/svg/symbols.svg#down')}"></use>
                                                            </svg>
                                                            <span class="slds-assistive-text">Show More</span>
                                                        </div>
                                                        
                                             
                                                        <div class="slds-dropdown slds-dropdown_left">
                                                        
                                                           <ul class="slds-dropdown__list" role="menu">
                                                             
                                                               
                                                               <li class="slds-dropdown__item" role="presentation">
                                                                  
                                                                      <a href="/apex/editPurchaseorderLightning?id={!quote.id}" role="menuitem" tabindex="0" >
                                                                            <span class="slds-truncate" title="Edit">Edit</span>&nbsp; &nbsp;&nbsp; &nbsp;&nbsp; 
                                                                            
                                                                             <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:30px !important;height:15px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#edit')}"></use>
                                                                            </svg>
                                                                        </a>
                                                                    
                                                                                                                               
                                                                </li>
                                                                
                                                                
                                                               <li class="slds-dropdown__item" role="presentation">
                                                                  
                                                                      <a href="/apex/deletePO?id={!quote.id}" role="menuitem" tabindex="0" >
                                                                            <span class="slds-truncate" title="Delete">Delete</span>&nbsp; &nbsp;&nbsp; &nbsp;&nbsp; 
                                                                            
                                                                             <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:30px !important;height:15px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#delete')}"></use>
                                                                            </svg>
                                                                        </a>
                                                                    
                                                                                                                               
                                                                </li>
                                                                 
                                                                 
                                                                 
                                                                 
                                                                 
                                                                 
                                                            </ul>
                                                      </div> 
                                               </div>
                                            </td>
                                      
                                       
                                        
                                           
                                            <td  >
                                                <div>
                                                    <apex:outputLink tabindex="tab1" value="/apex/PODetailPageLightning?id={!quote.id}">{!quote.Name}</apex:outputLink>
                                                    
                                                </div>
                                            </td>
                                            

                                            
                                        </tr>

                                    </apex:repeat>
                                </tbody>
                            </table>
                        </apex:outputPanel>
                       </apex:outputPanel> 
                      
                    </div>
                   
                            
                           
                   <apex:outputPanel id="dv1"> 
                         <div class="slds-card__footer" style="display:{!IF(q2.size>4,'block','none')}"  >
                            <br/>

                            <a href="javascript:glview();" id="glviewlink">View All ({!q.size}{!IF(q2.size>4,'+','')})
                               <span class="slds-assistive-text" style="float:right">entity type</span>
                            </a>
                            <a href="javascript:glless();" id="gllesslink" style="display:none">Show Less ({!q2.size})
                                  <span class="slds-assistive-text" style="float:right">entity type</span>
                            </a>
                        </div>
                    </apex:outputPanel>
                    
              </div>
              </apex:outputPanel>
             </apex:outputPanel>  
                 
                 
                 <apex:actionStatus id="LoadingStatus" >
