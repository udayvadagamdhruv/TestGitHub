<!-- This page is used to edit vendor quotes for particuale quote under one job -->
<apex:page standardController="Vendor_Quote__c" extensions="EditVendorQuoteExtensions">

<!-- <apex:sectionHeader title="Edit Vendor Quote"/> -->
 <apex:form >
 <apex:sectionHeader title="Vendor Details"/>
     <apex:pageBlock >
         <apex:pagemessages />
             <apex:pageBlockButtons >
                 <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
                 <apex:commandButton action="{!cancel}" value="Cancel"></apex:commandButton>
             </apex:pageBlockButtons>
             
             <apex:pageBlockSection title="Information" columns="2" collapsible="true">
          
             <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Name.Label}"/>
                  <apex:inputField value="{!Vendor_Quote__c.Name}" required="true"/>
             </apex:pageBlockSectionItem>
             
            <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Quote__c.Label}"/>
                  <apex:outputField value="{!Vendor_Quote__c.Quote__c}"/>
             </apex:pageBlockSectionItem>  
             
             <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Vendor__c.Label}"/>
                <!--  <apex:inputField value="{!Vendor_Quote__c.Vendor__c}"/> -->
                <apex:outputField value="{!Vendor_Quote__c.Vendor__c}"/>
             </apex:pageBlockSectionItem>
             
              <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Date__c.Label}"/>
                  <apex:inputField value="{!Vendor_Quote__c.Date__c}"/>
             </apex:pageBlockSectionItem>
             
              <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Amount__c.Label}"/>
                  <apex:inputField value="{!Vendor_Quote__c.Amount__c}"/>
             </apex:pageBlockSectionItem>
            
      <!--      <apex:pageBlockSectionItem >
                  <apex:outputLabel value="Amount"/>
                  <apex:inputField value="{!Vendor_Quote__c.Amount__c}"/>
             </apex:pageBlockSectionItem> -->
  </apex:pageBlockSection>
</apex:pageBlock>
</apex:form>
</apex:page>
<!-- End of Page -->