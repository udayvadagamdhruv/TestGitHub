<apex:page standardController="Task" extensions="SforceTaskDetailPageExt" TabStyle="Job__c">
  
  <apex:form >
  
  <apex:pageblock title="Email Details" mode="Edit">
  <apex:pageBlockButtons location="Top">
  <apex:commandButton value="Back" action="{!back}"/>
  <apex:commandButton value="Delete" action="{!Del}"/>
  
  </apex:pageBlockButtons>
  <apex:pageBlockSection >
      
       
       <apex:pageblockSectionItem >
                    <apex:outputLabel value="To"/>
                     <apex:outputField value="{!Task.Sender_Address__c}"/>     
                       
        </apex:pageblockSectionItem>
       
       <apex:pageblockSectionItem >
                        
                        <apex:outputLabel value="Related To"/>
                        <apex:outputField value="{!Task.whatid}"/> 
       
       
       </apex:pageblockSectionItem>
       
      
       <apex:pageblockSectionItem >
                        
                        <apex:outputLabel value="{!$ObjectType.Task.Fields.Subject.Label}"/>
                        <apex:outputField value="{!Task.Subject}"/> 
       
       
       </apex:pageblockSectionItem>
       
       
        <apex:pageblockSectionItem >
                        
                        <apex:outputLabel value="{!$ObjectType.Task.Fields.Status.Label}"/>
                        <apex:outputField value="{!Task.Status}"/> 
       
       
       </apex:pageblockSectionItem>
       
       
       
       
       <apex:pageblockSectionItem >
                    <apex:outputLabel value="Body"/>
                     <apex:outputField value="{!Task.Description}"/>     
                       
        </apex:pageblockSectionItem>
        
         <apex:pageblockSectionItem >
                   
        </apex:pageblockSectionItem>
        
        
        
        <apex:pageblockSectionItem >
            
           <apex:commandLink action="{!SendReplayMethod}" value="Reply" style="margin-left:235px;color:blue;" rendered="{!Replylink}"/>
                   
        </apex:pageblockSectionItem>
        
        <apex:pageblockSectionItem >
                   
        </apex:pageblockSectionItem>
        
        
           <apex:pageblockSectionItem rendered="{!Reply}">
            
                    <apex:outputLabel value="Reply Body"/>
                    <apex:inputTextarea value="{!ReplayBody}" style=" width: 100%;height:200px" rows="5"/>     
                      
           </apex:pageblockSectionItem>
           
          
           
            <apex:pageBlockSectionItem rendered="{!Reply}">
                  <apex:outputLabel >File Storage :</apex:outputLabel>
                  <apex:inputFile value="{!commandButton1}" fileName="{!filename1}" />
            </apex:pageBlockSectionItem>  
            
            
             <apex:commandButton value="Send Email" action="{!sendmail}" rendered="{!Reply}"/>   
           
 
        
        
  </apex:pageBlockSection>
  
   <apex:pageBlockSection title="Attachments Section" columns="1">
                   <apex:pageBlocktable value="{!n2}" var="n" rendered="{!n2.Size > 0}" width="100%">
                       
  
                        <apex:column headerValue="{!$ObjectType.Attachment.Fields.Name.Label}" style="width:85%">
                              <apex:outputLink value="/servlet/servlet.FileDownload?file={!n.Id}" tabindex="tab1" target="_blank">{!n.Name}</apex:outputLink>
                        </apex:column>
                   </apex:pageBlocktable>
            </apex:pageBlockSection>

           <apex:pageBlockSection rendered="{!n2.size <= 0}">
               <apex:pageBlockSectionItem >
                       <b>No Attachments to display</b>
               </apex:pageBlockSectionItem>              
       </apex:pageBlockSection>
  </apex:pageblock>
  
  </apex:form>
  
  
  
</apex:page>