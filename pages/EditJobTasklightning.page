       <script>

           var PEboo;
           var str,sch;
           
            
              var j$ = jQuery.noConflict();
                 
                 j$(document).ready(function(){
                 j$( "#dialog-confirm1").dialog({
                    autoOpen: false,
                    resizable: false,
                    height:150,
                    modal: true,
                    buttons: {
                        "Yes": function() {
                            
                           // alert(document.getElementById('{!$Component.frm1}').value );
                             document.getElementById('{!$Component.frm1}').value = 'true';
                         
                             j$( this ).dialog( "close" );
                        },
                        "No": function() {
                        
                            sch.value = str;  
                            j$( this ).dialog( "close" );
                           
                        }
                    }
                });
                
                
                
                 j$( "#dialog-confirm2").dialog({
                    autoOpen: false,
                    resizable: false,
                    height:150,
                    modal: true,
                    buttons: {
                        "Yes": function() {
                            
                             document.getElementById('{!$Component.frm1}').value = 'true';
                         
                             j$( this ).dialog( "close" );
                        },
                        "No": function() {
                        
                            sch.value = str;  
                            j$( this ).dialog( "close" );
                           
                        }
                    }
                });
                
                
                
                
                
                });
                    
                function scheduleRevisedDateUpdate(strvalue,scheduleCalc)
                {
                    str=strvalue;
                    sch=scheduleCalc;
                   
                    
                    j$( "#dialog-confirm1" ).dialog( "open" ); 
                }    
            
      
                
                function scheduleDaysUpdate(strvalue,schedule)
                {  
                
                      j$( "#dialog-confirm2" ).dialog( "open" ); 
                
                    str=strvalue;
                    sch=schedule;
                      
                }
                
            </script>
