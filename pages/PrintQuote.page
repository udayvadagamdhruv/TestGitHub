<!-- This page is used to display Quote Report. -->
<apex:page standardController="Vendor_Quote__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="PrintQuoteExtension" renderAs="pdf">
    <head>
    <style type="text/css">

        .rightalign
        {
        text-align:right;
        }

        .leftalign
        {
        text-align:left;
        }

        .centeralign
        {
        text-align:center;
        }

        div.tab
        {
        width:100%;
        border:solid black;
        }

        @page
        {
            /* Landscape orientation */
            size:landscape;

            /* Put page numbers in the bottom right corner of each
            page in the pdf document. */
        
            @bottom-right
            {
            content: "Page " counter(page);
            font-family:Arial;
            font-size:8pt;
            }
   
            @bottom-left 
            {
            content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
            background-repeat: no-repeat;
            font-size:8pt;
            font-family:Arial;
            } 
        }

        body 
        {
        font-family: Arial Unicode MS;
        font-size:9pt;
        }
  
        th
        {
        font-size:13pt
        font-style:bold;
        font-family:Arial;
        }

        td
        {
        font-size:11pt;
        font-family:Arial;
        }
  
        div.footer
        {
        position : running(footer) ;
        }

    </style>
    </head>

    <body>
        <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
        <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>

        <div style="float:right;padding-right:35px;font-size:2.0em;font-style:normal;font-family: 'Calibri';font-weight:bold">
        Quote Report
        </div>
        <br/><br/>

        <table width="100%">
           <tr>
            
              <td width="50%" align="left">
            
                 <table width="100%" align="left">
            
                       <tr>
                          <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Name.Label}" style="font-weight: bold;"/> </td>
                          <td width="80%" align="left"> <apex:outputText value="{!Vendor_Quote__c.Quote__r.Name}"/> </td>
                       </tr>
                
                       <tr>
                          <td align="left"  width="30%"> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.GL_Department__c.Label}" style="font-weight: bold;"/> </td>
                          <td  width="70%" align="left"><apex:outputText value="{!Vendor_Quote__c.Quote__r.GL_Department__r.Name}"/> </td>
                       </tr>
           
                       <tr>
                          <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.GL_Code__c.Label}" style="font-weight: bold;"/> </td>
                          <td  width="80%" align="left"> <apex:outputText value="{!Vendor_Quote__c.Quote__r.GL_Code__r.Name}"/> </td>
                       </tr>
                       
                       <tr>
                          <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Unit_Type__c.Label}" style="font-weight: bold;"/> </td>
                          <td  width="80%" align="left"> <apex:outputfield value="{!Vendor_Quote__c.Quote__r.Unit_Type__c}"/> </td>
                       </tr>
                       
                       <tr>
                          <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Quantity__c.Label}" style="font-weight: bold;"/> </td>
                          <td  width="80%" align="left"> <apex:outputField value="{!Vendor_Quote__c.Quote__r.Quantity__c}"/> </td>
                       </tr>
                       
                       <tr>
                          <td align="left" width="20%" valign="top"> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Description__c.Label}" style="font-weight: bold;"/> </td>
                          <td  width="80%" align="left"> <apex:outputField value="{!Vendor_Quote__c.Quote__r.Description__c}"/> </td>
                       </tr>
                  
                 </table>
              
              </td>
              
              <td width="50%" align="Right">
              
                 <table align="right">
                     
                       <tr>
                          <td > <apex:outputLabel value="{!$ObjectType.Vendor_Quote__c.Fields.Vendor__c.Label}" style="font-weight: bold;"/> </td>
                          <td align="left"> <apex:outputfield value="{!Vendor_Quote__c.Vendor__r.Name}"/> </td>
                       </tr>
                       
                       <tr>
                          <td> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="font-weight: bold;"/> </td>
                          <td align="left"> <apex:outputText value="{!Vendor_Quote__c.Quote__r.Job__r.Job_Auto_Number__c}"/></td>
                       </tr>
                       
                       <tr>
                          <td> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Job__c.Label}" style="font-weight: bold;"/> </td>
                          <td align="left"> <apex:outputText value="{!Vendor_Quote__c.Quote__r.Job__r.Name}"/> </td>
                       </tr>
                       
                        <tr>
                          <td> <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Schedule_Template__c.Label}" style="font-weight: bold;"/> </td>
                          <td align="left"> <apex:outputText value="{!Vendor_Quote__c.Quote__r.Job__r.Schedule_Template__r.Name}"/> </td>
                       </tr>
                                            
                       <tr>
                          <td> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Request_Date__c.Label}" style="font-weight: bold;"/> </td>
                          <td align="left"> <apex:outputField value="{!Vendor_Quote__c.Quote__r.Request_Date__c}"/></td>
                       </tr>
     
                       <tr>
                          <td> <apex:outputLabel value="{!$ObjectType.Quote__c.Fields.Due_Date__c.Label}" style="font-weight: bold;"/> </td>
                          <td align="left"> <apex:outputField value="{!Vendor_Quote__c.Quote__r.Due_Date__c}"/> </td>
                       </tr>
                                         
                 </table>
                      
              </td>
                  
           </tr>
              
           <tr>
           
              <td width="100%" colspan="2">
                 <hr/>
              </td>
          
           </tr> 
             
           <tr>
              <td colspan="2" width="100%" align="left" valign="top"> <b>SPEC ITEMS</b>
                 
                 <apex:dataTable value="{!vqli}" var="li" columns="2" columnsWidth="25%,75%" width="100%" rendered="{!vqli.Size>0}">
              
                    <apex:column value="{!li.Name}" headerValue="{!$ObjectType.Vendor_Quote_Line_Item__c.Fields.Name.Label}" style="vertical-align:top;"/> 
              
                    <apex:column value="{!li.Description__c}" headerValue="{!$ObjectType.Vendor_Quote_Line_Item__c.Fields.Description__c.Label}"/>
              
                 </apex:dataTable>
              
              </td>
          
           </tr>
           
           <tr>
              <td width="100%" colspan="2">
                 <hr/>
              </td>
          </tr>  
        </table>
    </body>
</apex:page>
<!-- End of Page -->