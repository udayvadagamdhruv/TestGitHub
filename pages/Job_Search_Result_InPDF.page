<apex:page controller="JobSearchController" sidebar="false" showHeader="false" standardStylesheets="false" readOnly="true" renderAs="PDF">
 
<head>
    <style type="text/css">

        .rightalign
        {
        text-align:right;
        }

        .leftalign
        {
        text-align:left;
        }

        .centeralign
        {
        text-align:center;
        }

        div.tab
        {
        width:100%;
        border:solid black;
        }

        @page
        {
            /* Landscape orientation */
            size:landscape;

            /* Put page numbers in the bottom right corner of each
            page in the pdf document. */
        
            @bottom-right
            {
            content: "Page " counter(page);
            font-family:Arial;
            font-size:8pt;
            }
   
            @bottom-left 
            {
            content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
            background-repeat: no-repeat;
            font-size:8pt;
            font-family:Arial;
            } 
        }

        body 
        {
        font-family: Arial Unicode MS;
        font-size:9pt;
        }
  
        th
        {
        font-size:13pt
        font-style:bold;
        font-family:Arial;
        }

        td
        {
        font-size:11pt;
        font-family:Arial;
        }
  
        div.footer
        {
        position : running(footer) ;
        }

    </style>
    </head> 
    
   <apex:form >  
   <apex:pageBlock >
     <body>
         <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
         <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>
         
         <div style="float:right;padding-right:35px;font-size:2.0em;font-style:normal;font-family: 'Calibri';font-weight:bold">
             Search Result
        </div>
        <br/><br/>

        <table width="100%">
           <tr>
               <td colspan="2" width="100%" align="left" valign="top"> <b></b>
                  <apex:pageBlockTable value="{!jobs1}" var="j" columns="8" columnsWidth="6%,16%,7%,25%,18%,8%,8%,12%" width="100%" rendered="{!jobs1.Size>0}">
              
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Job_Auto_Number__c.label}" style="vertical-align:top;text-align:left;padding-right:20px;">
                    <apex:outputText value="{!j.Job_Auto_Number__c}" rendered="{!!ISNULL(j.Job_Auto_Number__c)}" />
                    <apex:outputText value="--" rendered="{!ISNULL(j.Job_Auto_Number__c)}"/>
                    </apex:column>
              
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Name.label}" style="vertical-align:top;">
                    <apex:outputText value="{!j.Name}" rendered="{!!ISNULL(j.Name)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.Name)}" style="text-align:center;"/>
                    </apex:column>
                    
                    
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Status__c.label}" style="vertical-align:top;">
                    <apex:outputText value="{!j.Status__c}" rendered="{!!ISNULL(j.Status__c)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.Status__c)}" style="text-align:right;"/>
                    </apex:column>
                    
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.JS_Client__c.label}" style="vertical-align:top;"> 
                    <apex:outputText value="{!j.JS_Client__r.Name}" rendered="{!!ISNULL(j.JS_Client__r.Name)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.JS_Client__r.Name)}" style="text-align:right;"/>
                    </apex:column>
                    
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Campaign__c.label}" style="vertical-align:top;">
                    <apex:outputText value="{!j.Campaign__r.Name}" rendered="{!!ISNULL(j.Campaign__r.Name)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.Campaign__r.Name)}" style="text-align:right;"/>
                    </apex:column>
                    
                    
                    
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Start_Date__c.label}" style="vertical-align:top;text-align:right;padding-right:10px;">
                    <apex:outputfield value="{!j.Start_Date__c}" rendered="{!!ISNULL(j.Start_Date__c)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.Start_Date__c)}"/>
                    </apex:column>
                    
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Due_Date__c.label}" style="vertical-align:top;text-align:right;padding-right:10px;" >
                    <apex:outputfield value="{!j.Due_Date__c}" rendered="{!!ISNULL(j.Due_Date__c)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.Due_Date__c)}" />
                    </apex:column>
                    
                    <apex:column headerValue="{!$ObjectType.Job__c.fields.Completion_Date__c.label}" style="vertical-align:top;text-align:right;padding-right:10px;">
                    <apex:outputfield value="{!j.Completion_Date__c}" rendered="{!!ISNULL(j.Completion_Date__c)}"/>
                    <apex:outputText value="--" rendered="{!ISNULL(j.Completion_Date__c)}"/>
                    </apex:column>
                 </apex:pageBlockTable>
                 
                 <apex:outputPanel rendered="{!jobs1.size <= 0}">
                     <br/><b><p>No records to display</p></b>
                 </apex:outputPanel>
              </td>
           </tr>
        </table>
    </body></apex:pageBlock>
    </apex:form>
</apex:page>
<!-- End of Page -->