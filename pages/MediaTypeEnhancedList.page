<!-- This page is used to display Media Type records in enhanced list of Media Types tab under Admin Tab -->
<apex:page standardController="Media_Type__c" tabStyle="MyAdmin__tab" extensions="displayMediaTypesInAdminTab">
    <head>
        <style>
         .actionLink 
        {
            color: #015BA7 !important;
            font-weight: normal;
            text-decoration: none;
        }
        </style>
    </head>
<apex:form >
<apex:pageMessages ></apex:pageMessages>
     <table>
          <tr>
              <td align="left"> <apex:image url="{!$Resource.BigTop}" width="40" height="40" /> </td>
              <td valign="bottom"><apex:commandButton action="{!createNewMediaType}" value="New {!$ObjectType.Media_Type__c.Label}" /></td>
          </tr>
      </table>
    <apex:pageBlock >
        <apex:pageBlockTable value="{!lstMediaTypes}" var="mediaType" rendered="{!lstMediaTypes.size > 0}">
            <apex:column headerValue="Action" width="6%">
                <apex:commandLink value="Edit" action="{!editMediaType}" styleClass="actionLink">
                      <apex:param id="param1" name="param1" assignTo="{!strMediaType}" value="{!mediaType.Id}"/>  
                </apex:commandLink>
                &nbsp; | &nbsp;
                <apex:commandLink action="{!deleteMediaType}" onclick="return confirm(' Are You sure? You Want to delete this Media Type.');" styleClass="actionLink">Del
                    <apex:param id="param2" name="param2" assignTo="{!strMediaType}" value="{!mediaType.Id}"/>
                </apex:commandLink>
            </apex:column>
            <apex:column headerValue="{!$ObjectType.Media_Type__c.Fields.Name.Label}" width="80%">
                <apex:outputLink value="/apex/mediatypedetailpage?id={!mediaType.Id}">{!mediaType.Name}</apex:outputLink>
            </apex:column>
        </apex:pageBlockTable>
        <apex:outputPanel rendered="{!lstMediaTypes.size <= 0}">
            <b> No records to display</b>
        </apex:outputPanel>
    </apex:pageBlock>
    </apex:form>
</apex:page>
<!-- End of Page -->