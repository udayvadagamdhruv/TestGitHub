       <apex:pageBlock >      
    <table width="100%" >
                          <tr>
                          <td colspan="2">
                           <h1 class="mainTitle">Specs</h1>
                          </td>
                          </tr><tr>
                               <td align="left" width="40%" style="padding-top:10px;" >
                                     <apex:outputLabel value="Creative Brief Template" for="SpecTemp" ></apex:outputLabel>&nbsp;
                                              <apex:selectList id="theSelectList" value="{!SpecTempName}" size="1" >
                                                  <apex:selectOptions value="{!SpecificationTemplates}" id="sp"></apex:selectOptions>
                                              </apex:selectList> &nbsp; 
                                            <!--
                                              <script> var options = document.getElementById("{!$Component.theSelectList}"); </script> 
                                               <apex:commandButton value="Import Spec"  onclick="f1();" id="btn1"></apex:commandButton>&nbsp; 
                                           -->
                                           <apex:commandButton value="Import Spec" action="{!importSpecs}"  id="btn1" reRender="pb1" status="importstatus"></apex:commandButton>&nbsp;
                               </td> 
                               
                                
                                 
                               
                               
                               
                                    
                               
                               <td align="left">  
                                     <apex:commandButton value="Add Spec" action="{!addNewJobSpec}" id="addspec"/>&nbsp;
                                     <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display:none;"/>&nbsp;
                                     <apex:commandButton value="Cancel" id="cancelButton" action="{!cancelme}" style="display:none;" reRender="pb1"/>&nbsp;
                                     <apex:commandButton value="Print Creative Brief" rendered="{! (lstJobSpec.size>0)&&($ObjectType.Job_Team__c.accessible) && ($ObjectType.Job__c.accessible) && $ObjectType.Job_Spec__c.accessible}" onClick="window.open('/apex/creativebriefreport?id={!$CurrentPage.Parameters.Id}');" reRender="frm" id="cbreport1"/>&nbsp;

                                   <!--  <apex:commandButton value="Print Creative Brief" rendered="{! (lstJobSpec.size>0)&&($ObjectType.Job_Team__c.accessible) && ($ObjectType.Job__c.accessible) && $ObjectType.Job_Spec__c.accessible}" onClick="window.open('/apex/creativebriefreport?id={!$CurrentPage.Parameters.Id}');" reRender="frm" id="cbreport"/> -->
                                </td>
                           </tr>
                     </table><br/>
        
        
        
        <apex:repeat value="{!MapCB}" var="mc">
        
            <apex:pageBlockSection title="{!mc}" columns="1">
            
                <apex:pageBlockTable value="{!MapCB[mc]}" var="lst">
                        
                         <apex:column headerValue="Action" width="20%" style="vertical-align:top;">
                                <apex:commandButton value="Edit" action="{!editJobSpec}" reRender="hiddenBlock1" rendered="{!$ObjectType.Job_Spec__c.updateable}">
                                    <apex:param name="param1" value="{!lst.id}" assignTo="{!specId}"></apex:param>
                                </apex:commandButton> &nbsp;
                
                                <apex:commandButton value="Delete" action="{!deljobspec}" onclick="if(!confirm('Are you sure?')){return false;}" reRender="pb1" rendered="{!$ObjectType.Job_Spec__c.deletable}" status="importstatus">
                                    <apex:param name="param2" value="{!lst.id}" assignTo="{!specId}"> </apex:param>
                                </apex:commandButton>    
                         </apex:column>
            
                         <apex:column headerValue="{!$ObjectType.Job_Spec__c.Fields.Name.Label}" width="20%" style="vertical-align:top;">
                               <apex:outputLink tabindex="tab1" value="/apex/JobSpecDetailPage?id={!lst.id}">{!lst.Name}</apex:outputLink>
                         </apex:column>
                         
                       
                         <apex:column headerValue="{!$ObjectType.Job_Spec__c.Fields.Description__c.Label}">
                                <table border="0" id="table_qty">
                                    <tr>
                                        <td border="0">
                                            <apex:outputfield value="{!lst.Description__c}"> 
                                                <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,addspec,cbreport"/></apex:outputfield> 
                                        </td>
                                        <td>
                                                <apex:image url="{!$Resource.Plus}" width="9" height="9" id="img" title="Edit Description"/>  
                                       </td>
                                    </tr>
                                </table>
                       </apex:column>
                        
                
                </apex:pageBlockTable>
            
            
            </apex:pageBlockSection>
            
        
        
        </apex:repeat>
        
        
      
                          <apex:actionStatus id="importstatus" >
                                  <apex:facet name="start">
                                    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; opacity: 0.25; z-index: 1000; background-color: black;">
                                        &nbsp;
                                    </div>
                                    <div style="position: fixed; left: 0; top: 0; bottom: 0; right: 0; z-index: 1001; margin: 15% 50%">
                                        <div style="display: inline-block; padding: 2px; background-color: #fff; width: 125px;">
                                            <img src="/img/loading.gif" style="float: left; margin: 8px;" />
                                            <span style="display: inline-block; padding: 10px 0px;">Please Wait...</span>
                                        </div>
                                    </div>
                                    </apex:facet>
                                  </apex:actionStatus>
        
        
        
        
        
