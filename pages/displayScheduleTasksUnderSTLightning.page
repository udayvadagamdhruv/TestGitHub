                   {
                       border:none;
                   }
                   .slds b, .slds strong, .slds dfn 
                   {
                        font-weight: unset;
                   }
                    
                   .slds .slds-table tr > td:first-child 
                   {
                        padding-left: 6px;
                        padding: 15px;
                   }
                   
                   .slds-checkbox .slds-checkbox--faux
                   {
                       border: 1px solid lightslategrey !important;
                    }    
