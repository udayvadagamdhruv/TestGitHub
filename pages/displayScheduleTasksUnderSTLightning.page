<!-- This Page is used to display list of Estimate Line Item under Estimate tab of Job detail page -->
<apex:page Controller="displayScheduleTaskUnderScheduleTemp" id="frm" sidebar="flase" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" showHeader="false" standardStylesheets="true">
<apex:slds />

<head>

      <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
            
             <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
              <meta name="viewport" content="width=device-width, initial-scale=1"/>
           <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
          <link href="{!URLFOR($Resource.JobPage,'JobPage/MaterialIcons.css')}" rel="stylesheet"/>
         <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>

    
    <style>
            
           .icon1
           {
              color:darkgrey;
           }
      
           .icon1:hover
           {
              color:black;
           }
    
          .slds .slds-dropdown-trigger .slds-dropdown
           {
               margin-left: 56px;
    
           }
         .hd
          {
              text-align:right;
              padding-right:20px!important;
          }
          .cellstyle
          {
              text-align:right;
              padding-right:20px;
          }
        #table_qty td
        {
        border:0px;
        }
        
        #table_uc td
        {
        border:0px;
        }

        #table_rd1 td
        {
        border:0px;
        }

        .labelCol2{font-size:1.0em};
        
      
        .slds .slds-max-medium-table--stacked-horizontal td:before
        {
             text-transform:none;
        }
          
        .customImage{ height: 10px; width: 10px; }
        #rcorners1 {
                        border-radius:0%;
                        border: 1px solid #cccccc;
                        padding: 0px; 
                        width: 100%;
                        height: 0%;
                    }
        #pagemessage
                    {
                        color:blue;
                    }
       .required:after { content:" *";  color: Red;font:bold;}
       
                   .slds table
                   {
                        height: 50px;
                   }
                   body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons
