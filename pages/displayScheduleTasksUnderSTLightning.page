</head>



        <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        
        
         
           <body>    
           
           
               <div class="slds">
           
           
                <apex:form html-novalidate="novalidate" id="pb1" >
                 
                         <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" >
                              <apex:pageMessages id="pg">  </apex:pageMessages> 
                         </div>
                             
                         <div align="center">
                                <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display: none;"  styleClass="slds-button slds-button--brand"/>  &nbsp;
                                <apex:commandButton value="Cancel" id="cancelButton" action="{!cancel}" style="display: none;" reRender="pb1"  styleClass="slds-button slds-button--neutral"/>
                         </div> 
                                
                                 <br/>
                             
                <apex:outputPanel id="pdiv">
                       <apex:outputPanel rendered="{!lstST.Size > 0}"> 
                       
                              
                <div class="slds-card">             
                   <div class="slds-card__body">
                       <apex:outputPanel id="div1" layout="block"> 
                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover" >
                                <thead>
                                    <tr class="slds-text-title">
                                    
                                      <th class="slds-size--1-of-9" scope="col">Action</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Name.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Roles__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.GL_Code__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Days__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Locked__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Report__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Hours__c.Label}</th>
                                      <th class="slds-size--1-of-9" scope="col">{!$ObjectType.Schedule_Task__c.Fields.Task_Order__c.Label}</th>
                                      
                                      
                                    </tr>
                                 </thead>
                                 <tbody>
                                     
                                 <apex:repeat value="{!lstST}" var="st" rendered="{!lstST.Size > 0}">
                                     
                                     <tr class="slds-hint-parent">
                                          
                                         <td class="slds-size--1-of-9" data-label="Action" >
                                            
                                              <div class="slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open" >
                                                     &nbsp;&nbsp;  
                                                        <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small slds-shrink-none dropdownmenuicon "  >
                                                           <!---- &nbsp;<svg aria-hidden="true" class="slds-button__icon slds-button__icon--hint slds-button__icon--small">
                                                                 <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/utility-sprite/svg/symbols.svg#down')}"></use>
                                                            </svg>
                                                            <span class="slds-assistive-text">Show More</span>-------->
                                                             
                                                              <i  id="childmenu" style="color:#9faab5;font-size:15px;margin:2px 5px;" class="fa">&#xf0d7;</i>
                                                                
                                                        </div>
                                                        
                                             
                                                        <div class="slds-dropdown slds-dropdown_left " >
                                                        
                                                           <ul class="slds-dropdown__list" role="menu">
                                                                 <li class="slds-dropdown__item" role="presentation">
                                                                    <a href="/apex/editScheduleTaskLightning?id={!st.id}" role="menuitem" tabindex="0">
                                                                        <span class="slds-warp" title="Edit">Edit</span>
                                                                        <!---<svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                            <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#edit')}"></use>
                                                                        </svg>---->
                                                                         &nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">edit</i>   
                                                                    </a>
                                                                </li>
                                                                
                                                                <li class="slds-dropdown__item" role="presentation">
                                                                    <apex:commandLink value="Delete" action="{!DeleteTask}" status="LoadingStatus111" reRender="div1,div2,esdel,pdiv">
                                                                         <apex:param name="param3" value="{!st.id}" assignTo="{!strSTID}"></apex:param>  
                                                                        <!--- <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                            <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#delete')}"></use>
                                                                        </svg> ---->
                                                                         &nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">delete</i>                   
                                                                    </apex:commandLink>                                                               
                                                                </li>
                                                                
                                                                 <li class="slds-dropdown__item" role="presentation">
                                                                    <apex:commandLink value="Insert Task" action="{!insertTask}" status="LoadingStatus111" reRender="div1,div2,esdel,pdiv">
                                                                         <apex:param name="param1" value="{!st.Id}" assignTo="{!strSTID}"> </apex:param>   
                                                                        <!---- <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                           <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/utility-sprite/svg/symbols.svg#relate')}"></use>
                                                                        </svg>----> 
                                                                          
                                                                          &nbsp; &nbsp; <i class="fa fa-tasks" style="font-size:20px;color:black"></i>                 
                                                                    </apex:commandLink>                                                               
                                                                </li>
                                                                
                                                                  <li class="slds-dropdown__item" role="presentation">
                                                                    <a href="/apex/assignroletoSTunderschedtempLightning?scheduleTaskId={!st.Id}" role="menuitem" tabindex="0">
                                                                        <span class="slds-warp" title="Add/Edit Roles">Add/Edit Roles</span>
                                                                        <!---
                                                                        <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                            <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/utility-sprite/svg/symbols.svg#adduser')}"></use>
                                                                        </svg>
                                                                        ------>
                                                                        
                                                                           &nbsp; &nbsp; <i class="fa fa-user-plus" style="font-size:20px;color:black"></i> 
                                                                    </a>
                                                                </li>
                                                               
                                                                
                                                           </ul>
                                                           
                                                      </div> 
                                               </div>
                                                  
                                           </td>
                                         
                                          <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.Name.Label}">
                                            <div class="slds-warp">
                                                <apex:outputLink tabindex="tab1" value="/apex/ScheduleTaskDetailPageLightning?id={!st.Id}">{!st.Name}</apex:outputLink>
                                            </div>
                                          </td>
                                          
                                      
                                          <td class="slds-size--1-of-9" width="15%" data-label="{!$ObjectType.Schedule_Task__c.Fields.Roles__c.Label}" title="{!st.Roles__c}">
                                             <div  class="slds-truncate">
                                                <apex:outputfield value="{!st.Roles__c}"/>
                                              </div>
                                          </td>
                                          
                                          <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.GL_Code__c.Label}">
                                            <div class="slds-warp">
                                                 <apex:outputfield value="{!st.GL_Code__c}"/>
                                             </div>
                                          </td>
                                          
                                          <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.Days__c.Label}" valign="middle">
                                             <div class="slds-warp">
                                                      <apex:outputfield value="{!st.Days__c}" style="display:inline !important;"> 
                                                         <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2"/>
                                                         <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                     </apex:outputfield>
                                              </div>
                                          </td>
                                          
                                          <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.Locked__c.Label}">
                                             <div class="slds-warp">
                                                 <apex:outputfield value="{!st.Locked__c}">
                                                     <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2"/>
                                                     <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                 </apex:outputfield>
                                              </div>
                                          </td>
                                          
                                           <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.Report__c.Label}">
                                             <div class="slds-warp">
                                                 <apex:outputfield value="{!st.Report__c}">
                                                     <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2"/>
                                                     <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                 </apex:outputfield>
                                              </div>
                                          </td>
                                          
                                           <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.Hours__c.Label}">
                                             <div class="slds-warp">
                                                 <apex:outputfield value="{!st.Hours__c}">
                                                     <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2"/>
                                                     <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                 </apex:outputfield>
                                              </div>
                                          </td>
                                          
                                           <td class="slds-size--1-of-9" data-label="{!$ObjectType.Schedule_Task__c.Fields.Task_Order__c.Label}">
                                             <div class="slds-warp">
                                                 <apex:outputfield value="{!st.Task_Order__c}">
                                                     <apex:inlineEditSupport event="ondblClick" showOnEdit="saveButton,cancelButton" changedStyleClass="myBoldClass" hideOnEdit="btn1,btn2"/>
                                                     <i class="material-icons icon1" style="float:right;font-size:15px;">&#xe254;</i>
                                                 </apex:outputfield>
                                              </div>
                                          </td>
                                          
                                        </tr>
                                        </apex:repeat>
                              </tbody>
                            </table>
                           
                           
                           
                    </apex:outputPanel> 
               
                   </div>
       
              </div>            
            
             </apex:outputPanel>
             </apex:outputPanel> 
             
               <apex:actionStatus id="LoadingStatus111" >
                   <apex:facet name="start">
                      <div class="slds-spinner_container" style="z-index: 99999;position: fixed;">
                         <div role="status" class="slds-spinner slds-spinner--brand slds-spinner--medium">
                           <span class="slds-assistive-text">Loading</span>
                           <div class="slds-spinner__dot-a"></div>
                           <div class="slds-spinner__dot-b"></div>
                         </div></div>
                    </apex:facet>
                </apex:actionStatus>
                     
               <apex:outputPanel id="esdel" >
              <apex:outputPanel rendered="{!lstST.Size <= 0}">
                 
                   <div> <b> No records to display </b></div>
                   </apex:outputPanel>       
              </apex:outputPanel> 
      <br/>
     
                   <div align="center">
                       <apex:commandButton action="{!insertTaskBelow}" value="Insert Task Below" styleClass="slds-button slds-button--neutral"/>
                   </div>
                   <br/><br/>
                   
                </apex:form>
                
             </div>
        </body>
    </html>
</apex:page>
