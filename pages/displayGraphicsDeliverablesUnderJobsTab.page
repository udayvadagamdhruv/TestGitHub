                </apex:pageBlockTable>
                <apex:outputPanel rendered="{!lstGD.size = 0}">
                  <b>No records to display</b>
              </apex:outputPanel>
          </apex:pageBlock>
          
          </apex:outputPanel>
      </apex:form>
</apex:page>