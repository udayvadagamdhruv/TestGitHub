                                       </apex:outputField>
                                 </td>
                                 
                                 <td>
                                     <apex:image url="{!$Resource.Plus}" width="9" height="9" title="Edit Description"/>  
                                 </td>
                              </tr>
                          </table>                     
                    </apex:actionRegion>
                       
                    </apex:column>     
                   
                    <apex:column headerValue="{!$ObjectType.Graphics_Deliverables__c.Fields.Graphics_Note__c.Label}" width="30%">
                        <apex:actionRegion >
                         <table id="table_graphics_note" border="0">
                             <tr>
                                 <td border="0">
                                       <apex:outputField value="{!gd.Graphics_Note__c}"> 
                                           <apex:inlineEditSupport event="ondblClick" showOnEdit="btnSave,btnCancel" hideOnEdit="btnAddTag"/>
