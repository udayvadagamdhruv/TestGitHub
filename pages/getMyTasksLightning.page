<apex:page controller="getMyTasksController" sidebar="false" showHeader="false" tabStyle="Job__c" docType="html-5.0" applyBodyTag="false" applyHtmlTag="false" standardStylesheets="true">
 
    <style>
          
          .slds .slds-card__footer {
            padding: 0px 16px 0px 0px;
          }
          .slds .slds-card__header {
            padding: 0px 10px 0px 0px;
            }
            
           .slds .slds-card__body {
                padding: 0px ;
            }
            
          .slds .slds-card {
                padding: 0;
                border-radius: 0px;
                background-clip: padding-box;
                background-color:white;
                }
            
            .slds .slds-table--bordered {
                border-top: 0px solid #d8dde6;
                border-bottom: 1px solid #d8dde6;
              }
                        
            .slds .slds-card__body {
                margin-bottom: -0.25rem;
                margin-top: -0.15rem;
               }
               
               .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
               {
                border-bottom: 0px solid #d8dde6; 
               }
               
            
           .dropdownmenuicon:hover{
            background-color:#16325c !important;
            } 
            
           .dropdownmenuicon:hover #childmenu {
              color:white !important;
             }
             
             .slds .slds-dropdown__item > a{
             padding:4px 2px !important;
             }
                  
            
        </style>
   
   
   
   
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
    <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
    
     <meta name="viewport" content="width=device-width, initial-scale=1"/>
           <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"/>
          <link href="{!URLFOR($Resource.JobPage,'JobPage/MaterialIcons.css')}" rel="stylesheet"/>
         <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet"/>

    
   
    <div class="slds">
    
    
        <apex:form html-novalidate="novalidate">

         <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
              <apex:pageMessages id="pagemsgId2"></apex:pageMessages>
         </div> 

         
         
         <apex:outputlabel rendered="{!taskroleWrap.size == 0}">
              <b>No task to display</b>
         </apex:outputLabel>
        
        <apex:outputPanel id="p">
        
        <div align="center">
           <!--- <apex:commandButton value="My Calendar"   onclick="window.open('/apex/TaskCalendarNewHome','_top')" styleClass="slds-button slds-button--neutral"></apex:commandButton>  --->
             <a class="slds-button slds-button--neutral" href="/one/one.app#/alohaRedirect/apex/TaskCalendarNewHome">My Calendar </a>
            <apex:commandButton value="Prev" rerender="p" action="{!previous}" disabled="{!prev}" styleClass="slds-button slds-button--neutral"/>
            <apex:commandButton value="Next" rerender="p" action="{!next}" disabled="{!nxt}" styleClass="slds-button slds-button--neutral"/>
         </div>  
        
         <br/>
         <div class="slds-card">
                            
                      <div class="slds-card__body">

                        <apex:outputPanel layout="block" rendered="{!taskroleWrap.size != 0}">

                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <thead class="slds-truncate">

                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-6" scope="col"> 
                                             <apex:commandLink action="{!ViewData}" value="{!$ObjectType.Job__c.Fields.Name.Label}{!IF(sortExpression=='Job_Task__r.Job__r.Name',IF(sortDirection='ASC','▼','▲'),'')}" id="cmdSort2" style="color:black;">
                                                      <apex:param value="Job_Task__r.Job__r.Name" name="column" assignTo="{!sortExpression}" ></apex:param>
                                              </apex:commandLink>
                                        </th>
                                        <th class="slds-size--1-of-6" scope="col">
                                              <apex:commandLink action="{!ViewData}"  value="Task Name{!IF(sortExpression=='Job_Task__r.Name',IF(sortDirection='ASC','▼','▲'),'')}" id="cmdSort" style="color:black;">
                                                 <apex:param value="Job_Task__r.Name" name="column" assignTo="{!sortExpression}" ></apex:param>
                                              </apex:commandLink>
                                        </th>
                                        <th class="slds-size--1-of-6" scope="col">
                                            <apex:commandLink action="{!ViewData}" value="Task Due{!IF(sortExpression=='Job_Task__r.Revised_Due_Date__c',IF(sortDirection='ASC','▼','▲'),'')}" id="cmdSort1" style="color:black;">
                                               <apex:param value="Job_Task__r.Revised_Due_Date__c" name="column" assignTo="{!sortExpression}" ></apex:param>
                                            </apex:commandLink>
                                        </th>
                                      <!--  <th class="slds-size--1-of-6" scope="col">Status</th>-->
                                        <th class="slds-size--1-of-6" scope="col">
                                            <apex:commandLink action="{!ViewData}" value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}{!IF(sortExpression=='Job_Task__r.Job__r.Job_Auto_Number__c',IF(sortDirection='ASC','▼','▲'),'')}" id="cmdSort3" style="color:black;">
                                                 <apex:param value="Job_Task__r.Job__r.Job_Auto_Number__c" name="column" assignTo="{!sortExpression}" ></apex:param>
                                            </apex:commandLink>
                                        </th>
                                        <th class="slds-size--1-of-6" scope="col">
                                           Action
                                        </th>
                                       
                                    </tr>
                                </thead>
                                <tbody>

                                    <apex:repeat value="{!ViewData}" var="lst" rendered="{!taskroleWrap.size != 0}" >

                                        <tr class="slds-hint-parent">
                                        
                                            <td class="slds-size--1-of-6" data-label="Job Name">
                                                <div>
                                                    <apex:outputLink value="/one/one.app#/alohaRedirect/apex/JobdetailpageLightening07?id={!lst.jobTaskrole.Job_Task__r.Job__c}" target="_parent">
                                                         {!lst.jobTaskrole.Job_Task__r.Job__r.Name}
                                                     </apex:outputLink>
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-6" data-label="Name">
                                                <div>
                                                    <apex:outputLink tabindex="tab1" style="color:black;" value="/one/one.app#/alohaRedirect/apex/JobTaskDetailPageLightning?id={!lst.jobTaskrole.Job_Task__c}" target="_parent" rendered="{!lst.color=='Black'}">{!lst.jobTaskrole.Job_Task__r.Name}</apex:outputLink>
                                                    <apex:outputLink tabindex="tab1" style="color:red;"   value="/one/one.app#/alohaRedirect/apex/JobTaskDetailPageLightning?id={!lst.jobTaskrole.Job_Task__c}" target="_parent" rendered="{!lst.color=='Red'}" >{!lst.jobTaskrole.Job_Task__r.Name}</apex:outputLink>
                                                    <apex:outputLink tabindex="tab1" style="color:green;" value="/one/one.app#/alohaRedirect/apex/JobTaskDetailPageLightning?id={!lst.jobTaskrole.Job_Task__c}" target="_parent" rendered="{!lst.color=='Green'}" >{!lst.jobTaskrole.Job_Task__r.Name}</apex:outputLink>
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-6" data-label="Task Due">
                                                <div>
                                                   
                                                   <apex:outputField value="{!lst.jobTaskrole.Job_Task__r.Revised_Due_Date__c}"/>
                                                </div>
                                            </td>
                                            
                                        <!--    <td class="slds-size--1-of-6" data-label="Status">
                                                <div>
                                                    {!lst.jobTaskrole.Job_Task__r.Status__c}
                                                </div>
                                            </td>-->
                                            
                                            <td class="slds-size--1-of-6" data-label="Job#">
                                                <div>
                                                   {!lst.jobTaskrole.Job_Task__r.Job__r.Job_Auto_Number__c}
                                                </div>
                                            </td>
                                            
                                            <td class="slds-size--1-of-6" data-label="Action">
                                            
                                                <div class="slds-dropdown-trigger slds-dropdown-trigger_click slds-is-open">
                                                     &nbsp;&nbsp; 
                                                      
                                                        <div class="slds-button slds-button--icon-border-filled slds-button--icon-x-small slds-shrink-none dropdownmenuicon ">
                                                                    <i  id="childmenu" style="color:#9faab5;font-size:15px;margin:2px 5px;" class="fa">&#xf0d7;</i>
                                                           </div>
                                                        
                                             
                                                        <div class="slds-dropdown slds-dropdown--right">
                                                        
                                                           <ul class="slds-dropdown__list" role="menu">
                                                                <li class="slds-dropdown__item" role="presentation">
                                                                      <apex:commandLink value="Task Done" action="{!assignMarkedDone1}" reRender="pB" oncomplete="window.location.reload();">
                                                                             <apex:param name="param5" value="{!lst.jobTaskrole.Job_Task__r.Id}" assignTo="{!strJTID}" > </apex:param>
                                                                            <!--- <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:15px !important;height:15px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#approval')}"></use>
                                                                             </svg> 
                                                                             --->  
                                                                              &nbsp; &nbsp;&nbsp; &nbsp;&nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">check</i>             
                                                                     </apex:commandLink>                                                              
                                                                 </li> 
                                                                 
                                                                 <li class="slds-dropdown__item" role="presentation">
                                                                   <!--- 
                                                                     <apex:commandlink target="_self"  value="TimeSheet Entry" action="{!TsEntry}" style="text-decoration: none;"  rendered="{!($ObjectType.Timesheet_Entries__c.accessible) && (ShowTsEntryButton)}">
                                                                          <apex:param name="param6" value="{!lst.jobTaskrole.Job_Task__r.Id}" assignTo="{!strJTID2}" > </apex:param>
                                                                           <apex:commandlink target="_blank"  value="TimeSheet Entry" action="{!TsEntry}" >
                                                                               <apex:param name="param7" value="{!lst.jobTaskrole.Job_Task__r.Id}" assignTo="{!strJTID2}" > </apex:param>
                                                                           <svg class="slds-icon slds-icon_x-small slds-icon-text-default slds-m-left_small slds-shrink-none" aria-hidden="true" style="fill:#333;width:35px !important;height:23px !important;">
                                                                                <use href="{!URLFOR($Resource.SLDS0122, '/assets/icons/standard-sprite/svg/symbols.svg#today')}"></use>
                                                                             </svg> 
                                                                            
                                                                            
                                                                          </apex:commandlink>  
                                                                          
                                                                           &nbsp; &nbsp;&nbsp; &nbsp;&nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">av_timer</i>
                                                                     </apex:commandlink>   ---> 
                                                                     
                                                                     <apex:outputLink target="_self" value="/one/one.app#/alohaRedirect/apex/newtsentrieshometasksLightning?tid={!lst.jobTaskrole.Job_Task__r.Id}"> TimesheetEntry 
                                                                     
                                                                      &nbsp; &nbsp;&nbsp; &nbsp;&nbsp; &nbsp; <i  class="material-icons" style="font-size:20px;color:black">av_timer</i>
                                                                     
                                                                     </apex:outputLink>
                                                                     
                                                                                                                               
                                                                 </li> 
                                                                 
                                                                 
                                                                 
                                                            </ul>
                                                      </div> 
                                               </div>
                                            
                                               
                                            </td>
                                            
                                        </tr>

                                    </apex:repeat>
                                </tbody>
                            </table>
                        </apex:outputpanel>
                    </div>
                    </div>
               </apex:outputPanel>               
                      </apex:form>
      </div>
      

    </html>
 
</apex:page>