                   <apex:param name="ssnIdParam" value="{!Session.id}" assignTo="{!ssnIdChosen}"/>
                  </apex:commandButton> 
                  
                  <apex:commandButton value="Delete" onclick="alert('You can not Delete this Session because its Status is Booked');" rendered="{!Session.Session_Status__c = 'Booked'}" reRender="pb1"/>  
             
                  
              </apex:column>
            
              <apex:column headerValue="{!$ObjectType.Session__c.Fields.Name.Label}">
                    <apex:outputLink tabindex="tab1" value="/apex/SessionDetailPage?id={!Session.Id}">{!Session.Name}</apex:outputLink>
              </apex:column>
              
