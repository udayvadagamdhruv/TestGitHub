<!-- This page is used to display Sessions under Job. -->
<apex:page controller="displaySessionsUnderJobTab" tabStyle="Job__c">
  <head>
  
   <script>
   function stopRedirect(toStopRedirect)
   {
        if(toStopRedirect) 
        alert('You can not edit this Session,Because Estimate Line Item created from this Session is approved.');
   }
  </script>
 
  <style>
       #table_session_type td
            {
                border:0px;
            }
       
       #table_quantity td
            {
                border:0px;
            }
        
       #table_unit_cost td
