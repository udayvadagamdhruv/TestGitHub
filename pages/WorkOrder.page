<!-- This page is used to display Work Order. -->
<apex:page standardController="Job__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="WorkOrderExtension" renderAs="pdf">
    
    <head>
        <style type="text/css">
            div.tab
            {
            width:100%;
            border:solid black;
            }
            
            @page
            {
            /* Potrait orientation */
            size:potrait;
            
            /* Put page numbers in the bottom right corner of each
            page in the pdf document. */
            @bottom-right {
            content: "Page " counter(page);
            font-family: sans-serif;
            font-size:8pt;
            }
            
            @bottom-left 
            {
            content: "<apex:outputText value="{0,date,MMMM dd,yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>";
            background-repeat: no-repeat;
            font-size:8pt;
            font-family: sans-serif;
            }
            }
            
            body 
            {
            font-family: sans-serif;
            font-size:10pt;
            }
            
            th
            {
            font-size:10pt
            font-style:bold;
            font-family: sans-serif;
            }
            
            td
            {
            font-size:10pt;
            font-family:sans-serif;
            }
            
            div.footer
            {
            position : running(footer) ;
            }
            /* you can even define custom classes that utilize your static resources */
        </style>
    </head>
    
    
    <body>
        
        <!---------------------------------------------------- Logo and Title Details ---------------------------------------------------------->
        
        <table width="100%">
            <tr>
                <td style="width:50%">
                    <apex:image id="JS_logo" value="{!$Resource.JSCloudLogo}" rendered="{!imageNotFound == True}"/>
                    <apex:image url="{!imageBody}" rendered="{!imageNotFound == False}"/>
                </td>
                <td style="width:50%;padding-right:10px;text-align:right;font-size:11px;font-family: sans-serif;">
                    <b> <apex:outputText value="WORK ORDER" style="font-size:15px; font-family: sans-serif;"/> </b> <br/><br />
                    <apex:outputText value="{!$Organization.Street} " rendered="{!$Organization.Street!=''}" style="font-size:10px;"/> <br/>   
                    <apex:outputText value="{!$Organization.City}"></apex:outputText> <apex:outputText value=", " rendered="{!$Organization.City!=''}" style="font-size:10px;"/>                                           
                    <apex:outputText value=" {!$Organization.State}" rendered="{!$Organization.State!=''}"  style="font-size:10px;"/>                  
                    <apex:outputText value="{!$Organization.Country}" rendered="{!$Organization.Country!=''}" style="font-size:10px;"></apex:outputText><br/> 
                    Phone:&nbsp;<apex:outputtext value=" {!$Organization.Phone}" rendered="{!$Organization.Phone!=''}" style="font-size:10px;"/>
                    <!-- &nbsp; Fax:&nbsp;<apex:outputtext value="{!$Organization.Fax}" rendered="{!$Organization.Fax!=''}" /> -->
                </td>
            </tr>
            <br/>
