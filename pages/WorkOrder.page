<apex:outputText value="{!Job__c.createdby.name}"/><br/>
<apex:outputText value="{!Job__c.Lastmodifiedby.name}"/>
</td>

</tr> -->
        </table>
        <!---------------------------------------------------- End of Logo and Title Details ---------------------------------------------------------->    
        
        <!---------------------------------------------------- Details ---------------------------------------------------------->
        <table width="100%" style="padding-top:5px;">
            <tr>
                <td align="left">
                    <hr color="black" />
                </td>
            </tr>
            <tr>
                <td>
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width = "20%">
                                <b> <apex:outputText value="DETAILS" style="font-size:13px;font-weight:bold;font-color:#0000FF;"/>  </b>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
            <br/>
            <tr width="100%">
                <td width="100%" align="left" style="padding-left:20px;">
                    <table width="110%" align="left">
                        <tr width="100%">
                            <td width="20%">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Auto_Number__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputfield value="{!Job__c.Job_Auto_Number__c}"/> 
                            </td>
                            <td  width="20%">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Due_Date__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%">
                                <apex:outputfield value="{!Job__c.Due_Date__c}"/> 
                            </td>
                        </tr> 
                        
                        <tr width="100%">
                            <td  width="20%" valign="top">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.name.Label}" style="font-weight: bold;"/>
                            </td>
                            <td  width="30%" valign="top">
                                <apex:outputfield value="{!Job__c.name}"/> 
                            </td>
                            <td width="20%" valign="top">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Media_Types__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%" valign="top">
                                <apex:outputfield value="{!Job__c.Media_Types__r.Name}"/> 
                            </td>
                        </tr>
                        
                        <tr width="100%">
                            <td  width="20%" valign="top">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Campaign__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td  width="30%" valign="top">
                                <apex:outputfield value="{!Job__c.Campaign__r.Name}"/> 
                            </td>
                            <td width="20%" valign="top">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Schedule_Template__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%" valign="top">
                                <apex:outputfield value="{!Job__c.Schedule_Template__r.Name}"/> 
                            </td>
                        </tr>
                        
                        
                        <tr width="100%">
                            <td width="20%" valign="top">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.JS_Client__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%" valign="top">
                                <apex:outputtext value="{!Job__c.JS_Client__r.Name}"/> 
                            </td>
                            <td width="20%" valign="top">
                                <apex:outputText value="Created By" style="font-weight: bold;"/>
                            </td>
                            <td width="30%" valign="top">
                                <apex:outputText value="{!Job__c.createdby.name}"/>
                            </td>
                        </tr>
                        
                        
                        <tr width="100%">
                            <td width="20%"  valign="top">
                                <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Job_Description__c.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%" valign="top">
                                <apex:outputfield value="{!Job__c.Job_Description__c}"/> 
                            </td>
                            <td width="20%" valign="top">
                                <apex:outputText value="{!$ObjectType.Job__c.Fields.CreatedDate.Label}" style="font-weight: bold;"/>
                            </td>
                            <td width="30%" valign="top">
                                <apex:outputText value="{0,date,MM'/'dd'/'yyyy}"> <apex:param value="{!Job__c.createddate}" /> </apex:outputText>
                            </td>
                        </tr>
                        
                        
                        <tr style="display: {!IF(($ObjectType.Job__c.Fields.Dummy_Date_2__c.Label != 'Dummy Date 2'), 'table-row' , 'none')}" width="100%">
                            <td align="left" width="20%" valign="top" > 
                                <b> <apex:outputLabel rendered="{!$ObjectType.Job__c.Fields.Dummy_Date_2__c.Label!='Dummy Date 2'}" Value="{!$ObjectType.Job__c.Fields.Dummy_Date_2__c.Label}" />&nbsp;</b>
                            </td>
                            <td width="30%">
                                <apex:outputField rendered="{!$ObjectType.Job__c.Fields.Dummy_Date_2__c.Label!='Dummy Date 2'}"  value="{!Job__c.Dummy_Date_2__c}"/> 
                            </td>
                        </tr>  
                        
                        <tr style="display: {!IF(($ObjectType.Job__c.Fields.Dummy_Date_1__c.Label != 'Dummy Date 1'), 'table-row' , 'none')}" width="100%">
                            <td align="left" width="20%" valign="top" >
                                <b> <apex:outputLabel Value="{!$ObjectType.Job__c.Fields.Dummy_Date_1__c.Label}" rendered="{!$ObjectType.Job__c.Fields.Dummy_Date_1__c.Label!='Dummy Date 1'}" />&nbsp; </b>
                            </td>
                            <td width="30%">
                                <apex:outputField rendered="{!$ObjectType.Job__c.Fields.Dummy_Date_1__c.Label!='Dummy Date 1'}" value="{!Job__c.Dummy_Date_1__c}"/> 
                            </td>
                        </tr>
                        
                        <tr style="display: {!IF(($ObjectType.Job__c.Fields.Dummy_Text_5__c.Label != 'Dummy Text 5'), 'table-row' , 'none')}">
                            <td align="left" width="20%" valign="top" > 
                                <b> <apex:outputLabel rendered="{!$ObjectType.Job__c.Fields.Dummy_Text_5__c.Label!='Dummy Text 5'}" Value="{!$ObjectType.Job__c.Fields.Dummy_Text_5__c.Label}" />&nbsp; </b>
                            </td>
                            <td width="30%">
                                <apex:outputText rendered="{!$ObjectType.Job__c.Fields.Dummy_Text_5__c.Label!='Dummy Text 5'}" value="{!Job__c.Dummy_Text_5__c}"/> 
                            </td>
                        </tr>
                        
                        <tr style="display: {!IF(($ObjectType.Job__c.Fields.Dummy_Text_4__c.Label != 'Dummy Text 4'), 'table-row' , 'none')}">
                            <td align="left" width="20%" valign="top" > 
                                <b> <apex:outputLabel rendered="{!$ObjectType.Job__c.Fields.Dummy_Text_4__c.Label!='Dummy Text 4'}" Value="{!$ObjectType.Job__c.Fields.Dummy_Text_4__c.Label}" />&nbsp; </b>
                            </td>
                            <td width="30%">
                                <apex:outputText rendered="{!$ObjectType.Job__c.Fields.Dummy_Text_4__c.Label!='Dummy Text 4'}" value="{!Job__c.Dummy_Text_4__c}"/> 
                            </td>
                        </tr>
                        
                        <tr style="display: {!IF(($ObjectType.Job__c.Fields.Dummy_Picklist_1__c.Label != 'Dummy Picklist 1'), 'table-row' , 'none')}">
                            <td align="left" width="20%" valign="top" > 
                                <b> <apex:outputLabel Value="{!$ObjectType.Job__c.Fields.Dummy_Picklist_1__c.Label}" />&nbsp; </b>
                            </td>
                            <td width="30%">
                                <apex:outputField rendered="{!$ObjectType.Job__c.Fields.Dummy_Picklist_1__c.Label!='Dummy Picklist 1'}"  value="{!Job__c.Dummy_Picklist_1__c}"/> 
                            </td>
                        </tr>
                        
                        <br/><br/>
                        
                    </table>
                </td>
            </tr>
        </table>
        <br/>
        
        
        <!---------------------------------------------------- End of Details ---------------------------------------------------------->
        
        
        <!---------------------------------------------------- Status Note ---------------------------------------------------------->
        
        <table width="100%">
            
            <tr width="100%">
                <td align="left">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <tr width="100%">
                <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width="100%">
                                <b> <apex:outputText value="{!upper($ObjectType.Job__c.Fields.Creative_Overview__c.Label)}" style="font-size:13px;font-weight:bold;font-color:#0000FF;"/>  </b>
                            </td>
                            
                        </tr>
                    </table>
                </td>
            </tr> <br/>
            <tr>
                <td align="left" width="100%" style="padding-left:20px;">
                    <apex:outputField value="{!Job__c.Creative_Overview__c}"/> 
                </td>
            </tr>
            
        </table>  <br/>
        
        
        <!---------------------------------------------------- End of Status Note ---------------------------------------------------------->
        
        
        
        <!---------------------------------------------------- Team  ---------------------------------------------------------->
        
        <table width="100%" >
            
            <tr width="100%">
                <td align="left">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <tr width="100%">
                <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width="100%">
                                <b> <apex:outputText value="{!upper($ObjectType.Job_Team__c.Label)}" style="font-size:13px;font-weight:bold;font-color:#0000FF;"/>  </b>
                            </td>
                            
                        </tr>
                    </table>
                </td>
            </tr> <br/>
            
            <tr>
                <td colspan="2" width="100%" align="left" style="padding-left:20px;"> 
                    <apex:dataTable value="{!JobTeam}" var="JT" columns="2"  width="100%" rendered="{!JobTeam.Size>0}">
                        <apex:column value="{!JT.Role__c}"  width="30%"/> 
                        <apex:column value="{!'    '}     "/>
                        <apex:column value="{!JT.Staff__c}" width="50%"/> 
                    </apex:dataTable>
                </td>
            </tr>
            
            
        </table>  <br/>
        
        <!---------------------------------------------------- End of Team Section ---------------------------------------------------------->  
        
        
        <!---------------------------------------------------- SCHEDULE Section ---------------------------------------------------------->     
        
        <table width="100%" >
            
            <tr width="100%">
                <td align="left">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <tr width="100%">
                <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width="100%">
                                <b> <apex:outputText value="SCHEDULE" style="font-size:13px;font-weight:bold;font-color:#0000FF;"/>  </b>
                            </td>
                            
                        </tr>
                    </table>
                </td>
            </tr> <br/>
            
        </table>
        
        <table width="100%" >
            
            <tr width="100%" style="padding-left:20px;">
                
                <th width="30%"><b>{!$ObjectType.Job_Task__c.Label}</b></th>
                
                <!--     <th width="15%"><b>{!$ObjectType.Job_Task__c.Fields.Due_Date__c.Label}</b></th> -->
                
                <th width="15%"><b>Due Date</b></th>
                
                <th width="15%"><b>{!$ObjectType.Job_Task__c.Fields.Marked_Done__c.Label}</b></th>
                
                <th width="40%"  ><b>{!$ObjectType.Job_Task__c.Fields.Assigned_Users__c.Label}</b></th>
                
                
                
            </tr> 
            
            <tr width="100%">
                <td align="left" colspan="5" width="100%">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <apex:repeat value="{!JobTask}" var="JTask"  rendered="{!JobTask.Size>0}"> 
                
                <tr width="100%" style="padding-left:20px;">
                    
                    <td width="32%" height="5"> <apex:outputField value="{!JTask.Name}"/></td>
                    <!--  <td width="15%" height="5"><apex:outputField value="{!JTask.Due_Date__c}"/></td>  -->
                    <td width="15%" height="5"><apex:outputField value="{!JTask.Revised_Due_Date__c}"/></td>
                    <td width="10%" height="5" ><apex:outputField value="{!JTask.Marked_Done__c}"/></td> 
                    <td width="40%" height="5"><apex:outputField value="{!JTask.Assigned_Users__c}"/></td>
                    
                </tr>
                
                
            </apex:repeat>
            
            
            
        </table>  <br/>
        
        
        <!---------------------------------------------------- End of SCHEDULE Section ---------------------------------------------------------->     
        
        
        <!---------------------------------------------------- Specs Section ---------------------------------------------------------->     
        
        <table width="100%" style="page-break-inside: avoid;">
            
            <tr width="100%">
                <td align="left">
                    <hr color="black" width="100%"/>
                </td>
            </tr>
            
            <tr width="100%">
                <td width="100%">
                    <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                        <tr style="page-break-inside: avoid;">
                            <td width="100%">
                                <b> <apex:outputText value="{!upper($ObjectType.Job_Spec__c.Label)}" style="font-size:13px;font-weight:bold;font-color:#0000FF;"/>  </b>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr> <br/>
            
            
            <table width="100%" >
                <tr width="100%">
                    
                    <th width="30%"><b>Spec Name</b></th>
                    
                    <th width="70%"><b>Description</b></th>
                    
                </tr> 
                
                <tr width="100%">
                    
                    <td colspan="2">
                        <hr/>
                    </td>
                    
                </tr>
                
                <tr width="100%" style="font-size:10pt;">
                    <td width="100%" colspan="2">
                        
                        <apex:repeat value="{!MapCB}" var="mc" >
                            
                            
                            <b> {!mc} </b>
                            <apex:repeat value="{!MapCB[mc]}" var="JS" >
                                
                                <table width="100%">
                                    <tr style="font-size:10pt;">
                                        
                                        <td width="30%" style="text-align:left;"  valign="top"><apex:outputField value="{!JS.Name}"/></td> 
                                        <td width="70%" style="text-align:leftt;" valign="top"><apex:outputField value="{!JS.Description__c}"/></td>
                                        
                                    </tr>
                                </table>
                                
                            </apex:repeat><br/>
                            
                            
                        </apex:repeat>
                        
                    </td>
                </tr>
            </table>
            
        </table>  <br/>
        
        <!---------------------------------------------------- End of SPECS Section ---------------------------------------------------------->     
        
        <!---------------------------------------------------- Tags Section ---------------------------------------------------------->     
                <apex:outputPanel rendered="{!Tagrender}" >
            <table width="100%"  style="display:{!IF( Tags.size>0 , 'false', 'true')}">
                
                <tr width="100%">
                    <td align="left">
                        <hr color="black" width="100%"/>
                    </td>
                </tr>
                <tr width="100%">
                    <td width="100%">
                        <table width="100%" style = "background-color:#EEEEEE;margin-bottom:-10px;">
                            <tr style="page-break-inside: avoid;">
                                <td width="100%">
                                    <b> <apex:outputText value="{!$ObjectType.Tag__c.Label}" style="font-size:13px;font-weight:bold;font-color:#0000FF;"/>  </b>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr> <br/>
            </table>  
            <apex:pageblock >
                <apex:pageBlockSection columns="1">   
                    <apex:dataTable value="{!Tags[0]}" var="lst">
                        <apex:repeat var="f" value="{!$ObjectType.Tag__c.FieldSets.TagsFieldsets}">
                            <apex:column width="10%" rendered="{!NOT(OR(CONTAINS(LOWER(f) , LOWER('Job__c')),(CONTAINS(LOWER(f) , LOWER('name')))))}"> <b> <center><apex:outputText Value="{!f.label}"><br/></apex:outputText></center></b></apex:column>
                            <apex:column width="15%" rendered="{!OR(CONTAINS(LOWER(f) , LOWER('name')))}"> <b> <center>  <apex:outputText Value="{!f.label}"><br/></apex:outputText></center></b> </apex:column> 
                        </apex:repeat>       
                    </apex:dataTable>
                    <hr/>  
                    <apex:pageBlockTable value="{!Tags}" var="lst" rendered="{!Tags.size>0}">
                        <apex:repeat var="f" value="{!$ObjectType.Tag__c.FieldSets.TagsFieldsets}">
                            <apex:column rendered="{!NOT(OR(CONTAINS(LOWER(f) , LOWER('Job__c')),(CONTAINS(LOWER(f) , LOWER('name')))))}" width="10%"><br/>
                                <center>   <apex:outputField value="{!lst[f]}" rendered="{!NOT(OR(CONTAINS(LOWER(f) , LOWER('Job__c')),(CONTAINS(LOWER(f) , LOWER('name')))))}">
                                    </apex:outputField></center>
                            </apex:column>
                            <apex:column rendered="{!OR(CONTAINS(LOWER(f) , LOWER('name')))}" width="15%"><br/>
                                <apex:outputField value="{!lst[f]}" rendered="{!OR(CONTAINS(LOWER(f) , LOWER('name')))}">
                                </apex:outputField>
                            </apex:column>
                        </apex:repeat>
                    </apex:pageBlockTable> 
                </apex:pageBlockSection> 
            </apex:pageblock>  
        </apex:outputPanel>
        <br/>
        <!---------------------------------------------------- End of Tag Section ---------------------------------------------------------->     
    </body>
</apex:page>
<!-- End of Page -->