<apex:page controller="JobRequestPromoHighlightsUserNew1" tabstyle="Job__c" sidebar="false">
 <apex:form id="frm">
 <apex:pageMessages id="pgMsg"></apex:pageMessages>
   <apex:pageBlock title="Bulk Job Create" id="pbMain">
   
        <apex:pageBlockSection columns="1">
        
