<apex:page standardController="Job__c" recordSetVar="Jobs" extensions="jobsTabExt" sidebar="true" docType="html-5.0" applyBodyTag="False" standardStylesheets="false" applyHtmlTag="False"  showHeader="False">

     <style>
        .customImage{ height: 10px; width: 10px; }
         #rcorners1 {
                        border-radius:0%;
                        border: 1px solid #cccccc;
                        padding: 0px; 
                        width: 100%;
                        height: 0%;
                    }
        #pagemessage
                    {
                        color:blue;
                    }
       .required:after { content:" *";  color: Red;font:bold;}
       
       .slds:not(html), .slds body
       {
           background: white;
       }
       
       .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
       {
           border-bottom: none;
       }
       
       .slds .slds-text-heading--large
       {
               font-size: 27px;
       }
       
       .slds .slds-text-heading--label
       {
       
               color: #16325c;
       
       }
     
      .slds .slds-text-heading--large
      {
      
          line-height: 0.50;
      }
      
       
       
    </style>  
    
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        
        
        <body>
     
             <!-- REQUIRED SLDS WRAPPER -->
              <div class="slds">
                  <ul class="slds-list--vertical slds-has-dividers">
                       <li class="slds-list__item slds-large-size">  
                            <div class="slds-text-heading--large"><center>Job List</center></div> 
                       </li>
                  </ul><br/>
    
                  <apex:form html-novalidate="novalidate">
                       
                      <apex:pageBlock mode="edit"  id="job_list">
         
                           <apex:pageBlockButtons style="position:absolute;left:43%" location="Top" >
                               <b><apex:commandButton value="New" action="{!NewMethod}" styleClass="slds-button slds-button--neutral"></apex:commandButton></b>
                            
                               <!--<apex:commandLink action="{!NewMethod}">
                                    <!--<apex:image value="{!URLFOR($Resource.Mobile_Icons,'Mobile_Icons/NewButton.jpg')}" height="25px" width="35px" style="text-align:left;" />     
                                    
                                     <span class="slds-icon_container--circle slds-icon-action-new" title="New" style="border-radius:50%;width:32px !important;">
                                      <svg class="slds-icon" aria-hidden="true" style="width:18px !important;">
                                        <use xlink:href="{!URLFOR($Resource.SLDS0122, '/assets/icons/action-sprite/svg/symbols.svg#new')}" ></use>
                                      </svg>
                                      <span class="slds-assistive-text">Edit</span>
                                    </span>
                                                   
                               </apex:commandLink>-->
                          
                           </apex:pageBlockButtons>
                           
                           
                             <div class="slds-grid slds-wrap">
                                 
                             <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" >
                                            
                                             <div class="slds-grid slds-wrap">  
                                  
                                                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-2 slds-large-size--12-of-12">
                                                             <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                 <label class="slds-form-element__label required" ><b>Filter</b></label>
                                                                 <div class="slds-form-element__control" >
                                                                  <apex:selectList value="{!filterId}" size="1" styleClass="slds-input">
                                                                    <apex:selectOptions value="{!listViewOptions}"/>
                                                                    <apex:actionSupport event="onchange" reRender="job_list"/>
                                                                </apex:selectList>
                                                                 </div>
                                                             </div>
                                                        </aside>
                                                        <br/><br/><br/>
                                        
                                                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                             <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                   <!--<apex:pageBlockTable value="{!Jobs}" var="j" styleClass="slds-table slds-table--bordered slds-m-top--medium slds-max-medium-table--stacked">>
                                                                       
                                                                        <apex:column html-data-label="Job #" value="{!j.Job_Auto_Number__c}" styleClass="slds-cell-wrap slds-cell-shrink" style="word-wrap: break-word;"/>
                                                                        <apex:column html-data-label="Name" headerValue="Name" styleClass="slds-cell-wrap slds-cell-shrink" style="word-wrap: break-word;">
                                                                              <apex:outputLink value="/apex/JobRequestFormdetailpageLightning?id={!j.Id}" >{!j.name}</apex:outputLink>
                                                                        </apex:column> 
                                                                        <apex:column html-data-label="Due Date" value="{!j.Due_Date__c}" styleClass="slds-cell-wrap slds-cell-shrink" style="word-wrap: break-word;"/>
                                                                        <apex:column html-data-label="Client" value="{!j.JS_Client__c}" styleClass="slds-cell-wrap slds-cell-shrink" style="word-wrap: break-word;"/>
                                                                       
                                                                   </apex:pageBlockTable>-->
                                                                   
                                                                   <table style="width:100%" class="slds-table slds-table--bordered">
                                                                       <tr  class="slds-text-heading--label">
                                                                           <th style="width:10%;text-align:left;padding-left:5px;" class="slds-truncate"><b>Job #</b></th>
                                                                           <th style="width:20%;text-align:left;padding-left:25px;" class="slds-truncate"><b>Name</b></th>
                                                                           <!-- <th style="width:10%;text-align:left;padding-left:25px;" class="slds-truncate" >Due Date</th>
                                                                            <th style="width:25%;text-align:left;padding-left:25px;" class="slds-truncate" >Client</th>-->
                                                                       </tr>
                                                                       <apex:repeat value="{!Jobs}" var="j">
                                                                       <tr>
                                                                           <td style="width:10%;text-align:left;padding-left:5px;" class="slds-truncate">{!j.Job_Auto_Number__c}</td>
                                                                           <td style="width:20%;text-align:left;padding-left:25px;" class="slds-truncate"><apex:outputLink value="/apex/JobRequestFormdetailpageMobile?id={!j.Id}" >{!j.name}</apex:outputLink></td>
                                                                           <!-- <td width = "10%" style="font-size:12px;padding-left:25px;" valign="top" class="slds-truncate">
                                                                               <apex:outputText value="{0,date,MM'/'dd'/'yy}">
                                                                                   <apex:param value="{!j.Due_Date__c}" /> 
                                                                               </apex:outputText>
                                                                            </td>
                                                                           <td style="width:25%;text-align:left;padding-left:25px;" class="slds-truncate">{!j.JS_Client__r.name}</td>-->
                                                                       </tr>
                                                                       </apex:repeat>
                                                                   </table>
                                                                   
                                                             </div>
                                                        </aside>
                                         </div> 
                                 </main>
                              </div><br/><br/>
                              
                            <div class="slds-grid slds-wrap">
                                 
                             <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--4-of-12" >
                                            
                                             <div class="slds-grid slds-wrap">  
                                  
                                                        <aside class="slds-col slds-size--1-of-1 slds-medium-size--2-of-6 slds-large-size--4-of-12">
                                                             <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                             
                                                                                       <center>    <apex:commandButton action="{! Previous }" value="«Previous" rendered="{!HasPrevious}" styleClass="slds-button slds-button--neutral"/>
                                                                                           
                                                                                           <apex:outputText style="color: #ccc;" value="«Previous" rendered="{! NOT(HasPrevious) }"/>
                                                                                            
                                                                                            &nbsp;&nbsp; 
                                                                                            
                                                                                           
                                                                                            <apex:commandButton action="{! Next }" value="Next»" rendered="{! HasNext }" styleClass="slds-button slds-button--neutral"/>
                                                                                           <apex:outputText style="color: #ccc;" value="Next»" rendered="{! NOT(HasNext) }"/>
                                                                                           
                                                                                            </center>
                                                                                           
                                                                 <table style="width: 99%" Class="slds-table--bordered"><tr>
                                                                
                                                                    <td style="width: 33%" >
                                                                    
                                                                                   Page: <apex:outputText value=" {!PageNumber} of {! CEILING(ResultSize / PageSize) }"/>
                                                                                
                                                                    </td>            
                                                                
                                                                    <td style="width: 33%;text-align:center;">
                                                                       
                                                                                         
                                                                                        
                                                                                         
                                                                                     
                                                                                 
                                                                    </td>
                                                                    
                                                                    <td align="right" style="width: 33%;text-align:right">
                                                                     
                                                                                    Records per page:
                                                                                    <apex:selectList value="{! PageSize }" size="1">
                                                                                        <apex:selectOption itemValue="10" itemLabel="10"/>
                                                                                        <apex:selectOption itemValue="20" itemLabel="20"/>
                                                                                        <apex:selectOption itemValue="50" itemLabel="50"/>
                                                                                        <apex:actionSupport event="onchange" reRender="job_list"/>
                                                                                    </apex:selectList>
                                                                                   
                                                                    </td>
                                                                
                                                                </tr></table>
                                                             </div>
                                                        </aside>
                                         </div> 
                                 </main>
                              </div><br/><br/>
                              
                              
                           
       
                   </apex:pageBlock>
              </apex:form>     
           </div> 
        </body>
    </html>
    
    
    
    
    

</apex:page>