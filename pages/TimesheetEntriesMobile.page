<apex:page standardController="Timesheet_Entries__c" extensions="TimesheetEntriesExt" sidebar="false" docType="html-5.0" applyBodyTag="False" standardStylesheets="true" applyHtmlTag="False"  showHeader="False">

    
    
    <style>
    
     html,html body{
   overflow: auto;
   -webkit-overflow-scrolling:touch;
   }
   body{
   position:absolute;
   left:0;right:0;top:0;bottom:0;
   margin:0px !important;
   }
   .pbBody{
   margin:0px 2px 0px 2px !important;
   }
    
      body.lookupTab, .secondaryPalette, .bPageBlock, body.popupTab, .secondaryPalette, .bPageBlock, body.UserTagStatsPage, .secondaryPalette, .bPageBlock 
     {
            background-color: #ffff !important;
            border-bottom: 0px solid #eaeaea !important;
            border-left: 0px solid #eaeaea !important;
            border-right: 0px solid #eaeaea !important;
     }
    
        .customImage{ height: 10px; width: 10px; }
         #rcorners1 {
                        border-radius:0%;
                        border: 1px solid #cccccc;
                        padding: 0px; 
                        width: 100%;
                        height: 0%;
                    }
        #pagemessage
                    {
                        color:blue;
                    }
       .required:after { content:" *";  color: Red;font:bold;}
       
       .detailPage .bPageBlock, .editPage .bPageBlock
                  {
                      border-top-width: 0px;
                  }
                  
       .slds table{     height: 50px; }
       body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons{     margin-top: -19px; }
       
       
       .dateInput {
     white-space: inherit;
                }
                
                
        .slds .slds-text-heading--large
       {
               font-size: 27px;
               
                line-height: 0.50;
       }
       
        .pbHeader
                   {
                       background: white !important;
                   }
                   
                   
                   body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons 
                   {
                       background: white;
                   }
                   
                    .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
                   {
                       border:none;
                   }
                   
                   body .bEditBlock .pbBottomButtons, body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons
                   {
                       border:none;
                   }
                   
                   
                   .bPageBlock {
                    border-top: 0px solid white !important; 
                   }
                    <!--- error Mesgg-------------------------------------->
      
      
      .bPageBlock .requiredInput .requiredBlock {
                   background-color:white;
                   position: absolute;
                   left: -4px;
                   width: 3px;
                   top: 1px;
                   bottom: 1px;
               }
      
             errorM6, .errorM4, .errorM3, .errorM2, .errorS1 {
                   border-color: #c00;
               }
               .message {
                   background-color: #c00;
                   border-style: solid;
                   
                   border-width: 0px;
                   color: #000;
                   padding: 0px 0px 0px 0px;
                   margin: 0px 0px;
               }
               .errorM3 .msgIcon, .errorMedium {
                   background-image: url(); 
                   background-position: 0 0;
                   width:0px;
                   height: 0px;
               }
           .pbBody td{
            color:white;
            }
            .message .messageText h4 {
                    font-weight: bold; 
                    display:block;
                    color:white;
               }
               
               .messageText br
               {
                  display:none !important;
               }
               .messageTable tr
               {
                  padding-top:10px !important;
                  padding-bottom:10px !important;
               }
               .slds-notify, .slds-text-heading--small, .slds-theme--error, .message, .errorM3
               {
                   border-radius: 15px !important;
               }
               .pbBody
               {
                  padding:10px !important;
                
               }
               
                .slds td {
                   padding: 0;
                   
               }
               
           <!--- error Mesgg-------------------------------------->
                   
                   
                   
        .slds .slds-grid--pull-padded, .slds .slds-col--padded > .slds-grid {
                margin-right: 0px;
                margin-left: 0px;
            }
          
           
         .slds .slds-text-heading--small {
          line-height: 1.8 !important;
         }           
        
                   
                   
                   
     
    </style>  
    
    
    
    <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
       
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <script src="{!URLFOR($Resource.smoothness,'smoothness/jquery-ui-1.11.4.custom/external/jquery/jquery.js')}"></script>
           <script>
                   var j$ = jQuery.noConflict();
                   
                   
                            j$(document).ready(function(){
                            j$(".errorMsg").css("color","red");
                            j$("div .messageText h4").css("color","white"); 
                                       clearValue();    
                            });
                            function messagelink()
                            {
                            j$(".errorMsg").css("color","red");
                            j$("div .messageText h4").css("color","white"); 
                            
                            }
                            
                    function clearValue()
                    {
                
                        j$(".startcls").val("");
                        j$(".endcls").val("");
                
                    }
                    
                    
           </script>
       
           <body>
           
                <div class="slds">
                      
                     <apex:form html-novalidate="novalidate" >
                     
                    
                        <div class="slds slds-page-header" style="position:fixed;z-index:999;width:100% !important;border-bottom: 3px solid #ccc !important;padding: 0px 0px 0px 0px !important;">
                        <div class="slds-media__body pageHeader">
                            <div class="slds-grid" style="width:100%;">
                                <div class="slds-size--7-of-12" style="padding: 8px;">
                                    <div class="slds-col slds-has-flexi-truncate">
                                       <div class="slds-media slds-no-space slds-grow">
                                       
                                          <div class="slds-media__figure" style="margin-right: 7px;">
                                              <svg class="slds-icon slds-icon-standard-user" aria-hidden="true" style="background-color:#7AD17D !important;">
                                                 <use xlink:href="{!$Resource.SLDS}/assets/icons/custom-sprite/svg/symbols.svg#custom95"></use>
                                              </svg>
                                          </div>
                                          <div class="slds-media__body">
                                            
                                             <h1  style="color:#333;height: 14px;font-size: 11px;">Timesheet Entry</h1>
                                             <p style="font-size: 14px;" class="slds-truncate"><b>New Timesheet Entry</b></p>
                                           
                                          </div>
                                       </div>
                                    </div>
                                </div>
                                <div class="slds-size--5-of-12" style="padding: 8px;">
                                    <apex:commandButton action="{!Cancel}" style="float:right ! important;margin-left:3px; padding: 0px 12px 0px 12px;line-height: 30px;" value="Cancel" immediate="true" styleClass="slds-button slds-button--neutral"></apex:commandButton>
                                    <apex:commandButton action="{!save}" style="float:right ! important; padding: 0px 12px 0px 12px;line-height: 30px;" value=" Save" styleClass="slds-button slds-button--brand"></apex:commandButton>
                                </div>
                            </div>
                        </div>
                   </div>
                      
                          
             <br/><br/><br/>
             
              <apex:pageBlock id="pg_ts" >
                        
                          
                               <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert" >
                                    <apex:pageMessages id="pgMsg"/>
                               </div> 
                               
                               <br/>
                               
                               <div style="background-color:SteelBlue;color:white;border-radius:5px;padding-left:10px;display:{!watchRender};" onclick="toggle('watchsection');">
                                   
                                   <h3 class="slds-section-title" id='watchsectionheading'>
                                   &nbsp;<img src="{!URLFOR($Resource.Mobile_Icons,'Mobile_Icons/LeftArrow.png')}" width="20px" height="20px" id="img"/>
                                       <b>Watch Section</b>
                                   </h3>
                               </div>
                               
                               <div id="watchsection">
                                <br/>
                               <apex:outputPanel id="pbs1">
                                  <apex:pageMessage summary=" End watch should  be greater than Start watch. " rendered="{!error}" id="pgMsgs1" severity="" strength="1" />
                              <div class="slds-grid slds-wrap"  style="display:{!watchRender};" >
                                  
                                  <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--2-of-8 slds-large-size--3-of-12" >
                                     
                                   
                                       <div class="slds-grid slds-wrap">  
                                       
                                       
                                          <table>
                                               <tr>
                                                    <td style="width:60%">
                                                       <label class="slds-form-element__label"><b>Start Watch</b></label>
                                                        <apex:actionRegion >
                                                            <apex:inputfield value="{!objTSDetail.Start_Watch__c}"   styleClass="slds-input startcls" id="start" type="datetime-local" showDatePicker="false" >
                                                                <apex:actionSupport event="onchange" reRender="pbs,pgMsgs"/> 
                                                            </apex:inputfield>
                                                        </apex:actionRegion>
                                                   </td>
                                                   <td style="width:40%">
                                                        &nbsp; <apex:commandButton value="Start Time" reRender="Start,pbs1,tde" action="{!start}" styleClass="slds-button slds-button--neutral" style="margin-top: 22px;"/>
                                                   </td>
                                                </tr>   
                                                <tr>   
                                                    <td style="width:60%">
                                                         <label class="slds-form-element__label"><b>End Watch</b></label>
                                                        <apex:actionRegion >
                                                            <apex:inputfield value="{!objTSDetail.End_Watch__c}"  styleClass="slds-input endcls" id="End" type="datetime-local" showDatePicker="false">
                                                                <apex:actionSupport event="onchange" reRender="pbs,pgMsgs"/> 
                                                            </apex:inputfield>
                                                        </apex:actionRegion>
                                                   </td>
                                                   <td style="width:40%">
                                                       &nbsp; <apex:commandButton value="End Time" reRender="pbs,pbs1,tde" action="{!End}" styleClass="slds-button slds-button--neutral" style="margin-top: 22px;"/> 
                                                   </td>
                                               </tr>
                                           </table>
                                       
                                          
                                       </div> 
                                      
                                  </main>
                                   
                              </div>
                              
                                  <br/> 
                                           
                                     <center>   <apex:commandButton value="Clear" onclick="clearValue()" reRender="End,,pbs1,tde" styleClass="slds-button slds-button--neutral" /> </center>   
                               </apex:outputPanel>
                         </div>
                              
                              <br/><br/>
                              
                              
                              <!-- ************************************************************** Entry Section ********************************************************************************* -->
                              
                              
                              <div style="background-color:SteelBlue;color:white;border-radius:5px;padding-left:10px;">
                                   <h3 class="slds-section-title">
                                       <b>&nbsp;Entry Section</b>
                                   </h3>
                               </div>
                               
                               
                              <div class="slds-grid slds-wrap"  >
                                 
                                  <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" >
                                  
                                  <apex:outputPanel id="pbs">
                                       <div class="slds-grid slds-wrap" >  
                                       
                                                   <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                        <label class="slds-form-element__label required" ><b> Job Name </b></label>
                                                        <div class="slds-form-element__control" >
                                                            <apex:actionRegion >
                                                                 <apex:outputPanel >
                                                                      <span Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                                                                           <div> </div>
                                                                           <apex:selectList value="{!JobNameStr}" size="1" styleClass="slds-select slds-m-right--medium">
                                                                                <apex:actionSupport event="onchange" rerender="txtTask,txtGL,txtHrs,txtRemain"/>
                                                                                     <apex:selectOptions value="{!JobName}">
                                                                                </apex:selectOptions> 
                                                                           </apex:selectList>
                                                                       </span>
                                                                  </apex:outputPanel>  
                                                             </apex:actionRegion>
                                                        </div>
                                                        </div>
                                                    </aside>
                                                    
                                                    
                                                    
                                                   <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                        <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                        <label class="slds-form-element__label required"><b> Task Name </b></label>
                                                        <div class="slds-form-element__control" >
                                                            <apex:actionRegion >
                                                                 <apex:outputPanel >
                                                                      <span Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                                                                           <div> </div>
                                                                           <apex:selectList value="{!JobTaskNameStr}" size="1" styleClass="slds-select slds-m-right--medium" id="txtTask">
                                                                                <apex:actionSupport event="onchange"  reRender="txtGL,txtHrs,txtRemain"/>
                                                                                     <apex:selectOptions value="{!TaskName}">
                                                                                </apex:selectOptions> 
                                                                           </apex:selectList>
                                                                       </span>
                                                                  </apex:outputPanel>  
                                                             </apex:actionRegion>
                                                        </div>
                                                        </div>
                                                    </aside>
                                                    
                                                    
                                                    <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label "><b>Date</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:inputField value="{!objTSDetail.Date__c}" type="date" showDatePicker="false"   styleClass="slds-input" />
                                                                </div>
                                                            </div>
                                                    </aside> 
                                                    
                                                    
                                                     <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" style="display:{!IF((objTSDetail.Start_Watch__c == null && objTSDetail.End_Watch__c == null), 'block','none')};">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label"><b>Total Hours Worked</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:inputField value="{!objTSDetail.Hours_Worked__c}" styleClass="slds-input" />
                                                                </div>
                                                            </div>
                                                     </aside> 
                                                     
                                                     
                                                      <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" id="td" style="display:{!IF((objTSDetail.Start_Watch__c != null ), 'block','none')};">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label " ><b>Total Hours Worked</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:outputText value="{!calcTimeDiff}"  id="tde" styleClass="slds-output" />
                                                                </div>
                                                            </div>
                                                  </aside> 
                                                    
                                                    
                                                     <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label "><b>Notes</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:inputTextarea value="{!objTSDetail.Notes__c}"  styleClass="slds-input" />
                                                                </div>
                                                            </div>
                                                     </aside> 
                                                     
                                                     
                                                      <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12" style="display:{!IF(($Profile.Name =='System Administrator' ), 'block','none')};">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                  <main class="slds-col slds-col--padded slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12 slds-m-top--medium " >
                                                                    <c:lookup SelectedID="{!objTSDetail.User__c}" CmpId="ULookupComp" SelectedValue="{!CompUser}" ObjectApi="User" Fields="{!UFields}" >
                                                                    </c:lookup>
                                                                </main>    
                                                            </div>
                                                     </aside>
                                                   
                                                  
                                                    
                                                    
                                                   <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label "><b>GL Code</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:outputText value="{!GLCodeOfTask}"  id="txtGL" styleClass="slds-output" />
                                                                </div>
                                                            </div>
                                                  </aside> 
                                                  
                                                   <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label "><b>Total Hours Estimated</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:outputText value="{!if(GLCodeOfTask<>'',TotalHours,'0.00')}"  id="txtHrs" styleClass="slds-output" />
                                                                </div>
                                                            </div>
                                                  </aside> 
                                                  
                                                   <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label "><b>Total Hours Remaining</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:outputText value="{!if(GLCodeOfTask<>'',RemainHours,'0.00')}"  id="txtRemain" styleClass="slds-output" />
                                                                </div>
                                                            </div>
                                                  </aside> 
                                                  
                                                  
                                                  
                                                  
                                                  <aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12"  style="display:{!IF((objTSDetail.Start_Watch__c != null ), 'block','none')};">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                               
                                                            </div>
                                                  </aside> 
                                                  
                                                   <!-- aside class="slds-col slds-size--1-of-1 slds-medium-size--1-of-2 slds-large-size--6-of-12">
                                                            <div class="slds-form-element slds-p-top--medium slds-p-left--medium">
                                                                <label class="slds-form-element__label " style="display:{!$Profile.Name =='System Administrator'};"><b>User</b></label>
                                                                <div class="slds-form-element__control" >
                                                                    <apex:inputField value="{!objTSDetail.User__c}"  styleClass="slds-lookup" rendered="{!$Profile.Name =='System Administrator'}"/>
                                                                </div>
                                                            </div>
                                                  </aside -->

                                                  
                                                  
                                                  
                                                    
                                                     <br/>
                                                    
                                                    
                                       
                                       </div> </apex:outputPanel>
                                       
                                  </main>
                                  
                              </div>
                              
                              
                              
                              <br/><br/>
                              
                              
                              
                        
                          
                          <script>
                                
                                document.getElementById('watchsection').style.display = "none";
                                function toggle(id){
                                    var t = document.getElementById(id);
                                    if(t.style.display == "none"){
                                        t.style.display = "block";
                                        document.getElementById('img').setAttribute('src', "{!URLFOR($Resource.Mobile_Icons,'Mobile_Icons/down.png')}");
                                    }
                                    else{
                                        t.style.display = "none";
                                        document.getElementById('img').setAttribute('src', "{!URLFOR($Resource.Mobile_Icons,'Mobile_Icons/LeftArrow.png')}");
                                    }
                                }
                          </script>
                           </apex:pageBlock>     
                     </apex:form>  
                   
                </div> 
          
           </body>
          
    </html>

</apex:page>