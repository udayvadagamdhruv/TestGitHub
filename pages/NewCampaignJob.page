<apex:page standardController="Campaign_Jobs__c" extensions="NewCampaignJobExt">
 
 <apex:sectionHeader title="Campaign Job"/>
   <apex:form >
      <apex:pageBlock mode="edit">
         <apex:pageMessages />
         
         <apex:pageBlockButtons >
            <apex:commandButton value="Save" action="{!SaveCampaignJob}"></apex:commandButton>
            <apex:commandButton value="Cancel" action="{!cancel}" immediate="true" ></apex:commandButton>
         </apex:pageBlockButtons>
              
         <apex:pageBlockSection title="Campaign Job Information" columns="2" collapsible="false"> 
            <apex:pageBlockSectionItem >
                      <apex:outputLabel Value="{!$ObjectType.Campaign_Jobs__c.Fields.Name.Label}"></apex:outputLabel>
                      <apex:inputField value="{!Campaign_Jobs__c.Name}" required="true" />
              </apex:pageBlockSectionItem>
              
                <apex:pageBlockSectionItem >
                      <apex:outputLabel Value="{!$ObjectType.Campaign_Jobs__c.Fields.Campaign_Template__c.Label}"></apex:outputLabel>
                      <apex:outputText value="{!CTempName}" />
              </apex:pageBlockSectionItem>
              
              
              
              <apex:pageBlockSectionItem rendered="{!$ObjectType.Campaign_Jobs__c.fields.Media_Type__c.accessible}">                  
                  <apex:outputLabel value="{!$ObjectType.Campaign_Jobs__c.Fields.Media_Type__c.Label}" for="MediaTypeName" >
                  </apex:outputLabel>
                  <apex:actionRegion >
                     <apex:outputPanel >
                        <!--span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">-->
                        <span  class="requiredInput"  Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                           <div class="requiredBlock"> </div>
                          <!-- <div> </div>-->
                           <apex:selectList id="MtName" value="{!MTName}" size="1" >
                              <apex:actionSupport event="onchange" rerender="ST"/>
                              <apex:selectOptions value="{!MediaTypes}">
                              </apex:selectOptions> 
                           </apex:selectList>
                        </span>
                     </apex:outputPanel>  
                  </apex:actionRegion>
               </apex:pageBlockSectionItem>
              
              
          
          
              <apex:pageBlockSectionItem id="pbs" rendered="{!($ObjectType.Campaign_Jobs__c.fields.Schedule_Template__c.accessible)}">
                  <apex:outputLabel value="{!$ObjectType.Campaign_Jobs__c.Fields.Schedule_Template__c.Label}" >
                  </apex:outputLabel>
                  <apex:outputPanel >
                     <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                        <div class="requiredBlock"></div>
                      <!--   <div></div>-->
                        <apex:selectList id="ST" value="{!ScheduleTemp}" size="1" >
                           <apex:selectOptions value="{!ScheduleTemplates}">
                           </apex:selectOptions>
                        </apex:selectList>
                     </span>
                  </apex:outputPanel>  
               </apex:pageBlockSectionItem>  
          
          
          </apex:pageBlockSection>
          
         
         
      </apex:pageBlock>
   </apex:form>
</apex:page>