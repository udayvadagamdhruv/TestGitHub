<!-- This page is used to Edit Production Spec Item for Production Spec Template. (Overriding Edit button of Production Spec Item object) -->
<apex:page standardController="Production_Spec_Item__c" extensions="EditProductionSpecItemExtension" tabStyle="MyAdmin__tab">
  <apex:form >
      <apex:pageBlock >
         <apex:pagemessages />
     
         <apex:pageBlockButtons >
            <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
            <apex:commandButton action="{!cancel}" value="Cancel"></apex:commandButton>
         </apex:pageBlockButtons>
         
         <apex:pageBlockSection title="Spec Item Detail" columns="2" collapsible="true">
         
             <apex:pageBlockSectionItem >
                 <apex:outputLabel Value="{!$ObjectType.Production_Spec_Item__c.Fields.Name.Label}"></apex:outputLabel>
                 <apex:inputField value="{!Production_Spec_Item__c.Name}" required="true"/>
             </apex:pageBlockSectionItem>
             
             <apex:pageBlockSectionItem >
                 <apex:outputLabel Value="{!$ObjectType.Production_Spec_Item__c.Fields.Production_Spec_Template__c.Label}"></apex:outputLabel>
                 <apex:outputField value="{!Production_Spec_Item__c.Production_Spec_Template__c}"/>
             </apex:pageBlockSectionItem>
             
            <apex:pageBlockSectionItem >
               <apex:outputLabel Value="{!$ObjectType.Production_Spec_Item__c.Fields.Description__c.Label}"/>
               <apex:inputField value="{!Production_Spec_Item__c.Description__c}" style="width:95%;resize:none;height:150%;"/>
            </apex:pageBlockSectionItem>
             
         </apex:pageblocksection>
      </apex:pageBlock>  
   </apex:form>
</apex:page>
<!-- End of Page -->