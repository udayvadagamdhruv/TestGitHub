<!-- This page is used to create New Vendor Contact (Overriding create new button of Vendor Contact object) -->
<apex:page standardController="Vendor_Contact__c" extensions="CreateNewVendorContactController" tabStyle="Vendor__c">
   <head>
   </head>
   <apex:sectionHeader title="{!$ObjectType.Vendor_Contact__c.Label} Details" />
   
   <apex:form >
      <apex:pageBlock mode="edit">
         <apex:pageMessages />
       
         <apex:pageBlockButtons >
            <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
            <apex:commandButton action="{!cancel}" value="Cancel"></apex:commandButton>
         </apex:pageBlockButtons>
              
         <apex:pageBlockSection title="{!$ObjectType.Vendor_Contact__c.Label}" columns="2" collapsible="false"> 
         
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.First_Name__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.First_Name__c}" required="true"/>
            </apex:pageBlockSectionitem>
                  
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Last_Name__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.Last_Name__c}" required="true"/>
            </apex:pageBlockSectionitem>
            
         </apex:pageBlockSection>
                   
         <apex:pageBlockSection title="Contact" columns="2" collapsible="false">          
         
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Phone_1__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.Phone_1__c}"/>
            </apex:pageBlockSectionitem>

            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Email__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.Email__c}" required="true"/>
            </apex:pageBlockSectionitem> 
            
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Phone_2__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.Phone_2__c}"/>
            </apex:pageBlockSectionitem>  
            
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.User_Name__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.User_Name__c}" required="true"/>
            </apex:pageBlockSectionitem> 
                   
            <apex:pageBlockSectionitem > 
            </apex:pageBlockSectionitem>

    
                   
         </apex:pageBlockSection>  
                    
         <apex:pageBlockSection title="Other" collapsible="false" columns="2">
         
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Vendor__c.Label}"/>
               <apex:outputfield value="{!Vendor_Contact__c.Vendor__c}"/>
            </apex:pageBlockSectionitem>
            
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Active__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.Active__c}"/>
            </apex:pageBlockSectionitem>
            
            <apex:pageBlockSectionItem >
                <apex:outputLabel value="Role" for="rl"></apex:outputLabel> 
                <apex:outputPanel >
                    <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                        <div class="requiredBlock"> </div>
                        <apex:selectList value="{!RoleId}" multiselect="false" size="1" id="selectedRoleId" >
                            <apex:selectOptions value="{!Role}" />
                        </apex:selectList>
                    </span>
                </apex:outputPanel>
            </apex:pageBlockSectionItem>
            
            <apex:pageBlockSectionitem > 
               <apex:outputLabel value="{!$ObjectType.Vendor_Contact__c.Fields.Salesforce_User__c.Label}"/>
               <apex:inputfield value="{!Vendor_Contact__c.Salesforce_User__c}"/>
            </apex:pageBlockSectionitem>
         </apex:pageBlockSection>
              
      </apex:pageBlock>
   </apex:form>
</apex:page>
<!-- End of Page -->