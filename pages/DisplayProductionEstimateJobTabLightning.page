                                                <div>
                                                  <apex:outputfield value="{!vquote.Total_Cost__c}"/>
                                                </div>
                                            </td>
                                            
                                             <td class="slds-size--1-of-11" data-label="{!$ObjectType.Production_Estimate__c.Fields.Approved__c.Label}">
                                                <div>
                                                   <apex:outputField value="{!vquote.Approved__c}"/> 
