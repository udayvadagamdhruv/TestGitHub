                                             <apex:commandButton action="{!createPO}" value="Create PO" id="btn2" rendered="{!peli.Size>0}" title="Press to create new Purchase Order" styleClass="slds-button slds-button--neutral"/>
                                          
                                             <apex:commandButton value="Print Estimate" id="estreport" rendered="{!vq.Size>0}" onClick="window.open('/apex/ProductionEstimateReport?id={!$CurrentPage.Parameters.Id}');" reRender="frm" title="Press to view Production Estimate Report" styleClass="slds-button slds-button--neutral"/>    &nbsp;
                                          
                                             <apex:commandButton value="Save" action="{!save}" id="saveButton" style="display:none;" title="Click to save" styleClass="slds-button slds-button--neutral"/>  
                                          
                                             <apex:commandButton value="Cancel" id="cancelButton" action="{!cancelme}" style="display:none;" reRender="pb1" title="Click to cancel" styleClass="slds-button slds-button--neutral"/>                                
                                        </td>
                                          
