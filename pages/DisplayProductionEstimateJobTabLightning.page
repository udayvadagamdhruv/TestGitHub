                      <apex:outputPanel rendered="{!vq.size>5}">
                          <div class="slds-card__footer">
                                <apex:commandLink value="View All ({!vq.size}{!IF(vq.size>5,'+','')})" action="{!ViewAllPE}" rendered="{!ViewAll}" status="EstLoadingStatus"  reRender="frmid"/>
                                <apex:commandLink value="Show Less ({!vq.size})" action="{!ShowLessPE}" rendered="{!ShowLess}" status="EstLoadingStatus"  reRender="frmid"/>
                          </div>
                      </apex:outputPanel>  
                      </apex:outputPanel>-->
              
           
                 <apex:actionStatus id="PELoadingStatus" >
