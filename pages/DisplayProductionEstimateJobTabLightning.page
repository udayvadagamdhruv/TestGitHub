                                             <td class="slds-size--1-of-11" data-label="{!$ObjectType.Production_Estimate__c.Fields.PO_Created__c.Label}">
                                                <div>
                                                  <apex:outputField value="{!vquote.PO_Created__c}"/>
                                                </div>
                                            </td>
                                            
                                             <td class="slds-size--1-of-11" data-label="PO #">
                                                <div>
                                                  <apex:outputLabel value="{!vquote.PO__c}" />  
                                                </div>
                                            </td>-->
                                         
                                    </tr>

                                </apex:repeat> </tbody>
                            </table> 
                            
                      
                                </apex:repeat>
                                 </div>  </div> 
                                  </apex:outputPanel>     
                           
                       <br/>     
                            
                             <div style="float:right;padding-right:35px;font-size:1.10em;font-style:normal;font-family: 'Calibri';font-weight:bold">
                                 <apex:outputPanel rendered="{!vq.Size > 0}">
