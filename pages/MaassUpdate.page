<apex:page standardController="Job__c" extensions="MassUpdateController" recordSetVar="job" sidebar="false" tabStyle="Job__c">

<script src="{!URLFOR($Resource.jQueryScheduleUpadate,'/js/jquery-1.5.1.min.js')}" type="text/javascript" />
    <script src="{!URLFOR($Resource.jQueryScheduleUpadate,'/js/jquery-ui-1.8.13.custom.min.js')}" type="text/javascript" />
    <apex:stylesheet value="{!URLFOR($Resource.jQueryScheduleUpadate,'/css/ui-lightness/jquery-ui-1.8.13.custom.css')}" />
    <script>

   var PEboo;
    
    
    
      var j$ = jQuery.noConflict();
         
         
         j$(document).ready(function(){
         j$( "#dialog-confirm1").dialog({
        
            autoOpen: false,
            resizable: false,
            height:150,
            modal: true,
            buttons: {
                "Yes": function() {
                    
                     
                 var retVal =   document.getElementById('{!$Component.frm1.hidden}').value = 'true';
                 
                  myFunc(retVal);
                    
                    j$( this ).dialog( "close" );
                },
                "No": function() {
                 var retVal =   document.getElementById('{!$Component.frm1.hidden}').value = 'false';
                 
                  myFunc(retVal);
                    j$( this ).dialog( "close" );
                }
            }
        });
        
        
        
        });
            
        function confirmBox(peboo)
        {
           if(peboo==true)
           { 
                j$( "#dialog-confirm1" ).dialog( "open" ); 
           }
         
        }    
    
    
</script>
    <apex:form id="frm1">
        <apex:pageMessages id="ff"/>
<apex:actionFunction name="myFunc" action="{!Complete}" reRender="pb,tstpopup2" status="mark">
    <apex:param name="itemsConfirm" assignTo="{!completeItems}"   value="" />

</apex:actionFunction>
            <apex:pageBlock id="pb">
            
            <apex:pageBlockButtons >
                      <apex:commandButton value="Mark Complete" onclick="confirmBox({!ShowPELI});" reRender="none">
                      
                      </apex:commandButton>
                        <apex:actionStatus id="mark">
                             <apex:facet name="start">
                                <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
                             </apex:facet>
                         </apex:actionStatus> 
                      
                      <apex:commandButton value="Cancel" action="{!CancelBut}"/>
                      <apex:commandButton value="Reset" action="{!Reset}"/>
                      
                  </apex:pageBlockButtons>
                  
                  
            <apex:pageBlockSection columns="4">
            
            
                            <apex:pageBlockSectionItem >
                               <apex:outputText >Campaign</apex:outputText>
                                   <apex:selectList id="campg" value="{!strCampaignName}" multiselect="true" size="3" onchange="campp()">
                                       <apex:selectOptions value="{!Campaigns}"></apex:selectOptions>
                                       <apex:actionFunction name="campp" action="{!updatejob}"/>
                                   </apex:selectList>
                            </apex:pageBlockSectionItem>
            
                            <apex:pageBlockSectionItem >
                                  <apex:outputText >Media Type</apex:outputText>
                                   <apex:selectList id="media" value="{!strmediatype}"  multiselect="true" size="3" onchange="media()">
                                       <apex:selectOptions value="{!Mediatype}"></apex:selectOptions>
                                            <apex:actionFunction name="media" action="{!updatejob}"/>
                                   </apex:selectList>
                            </apex:pageBlockSectionItem>
                            
                             <apex:pageBlockSectionItem >
                                  <apex:outputText >Schedule Template</apex:outputText>
                                   <apex:selectList id="schd" value="{!strscheduletemp}"  multiselect="true" size="3" onchange="schd()">
                                       <apex:selectOptions value="{!scheduletemp}"></apex:selectOptions>
                                       <apex:actionFunction name="schd" action="{!updatejob}"/>
                                   </apex:selectList>
                            </apex:pageBlockSectionItem>
                             
                             
                            
                            <apex:pageBlockSectionItem >
                               <apex:outputText >Client</apex:outputText>
                                   <apex:selectList id="client" value="{!strClientName}" multiselect="true" size="3" onchange="clien()">
                                       <apex:selectOptions value="{!Clients}"></apex:selectOptions>
                                          <apex:actionFunction name="clien" action="{!updatejob}"/>
                                   </apex:selectList>
                            </apex:pageBlockSectionItem>
            
            </apex:pageBlockSection> <br/><br/>
            
           <!--    <b style="color:maroon; margin-left:90%; " > Total Jobs {!count}</b><br/><br/>-->
                  <apex:variable var="ind" value="{!-1}">
                     <apex:pageBlockTable value="{!jobsInnerObj}" var="inner">
                          <apex:column width="10%" headerValue="Action">
                              <apex:inputCheckbox value="{!inner.isSelected}"/>
                          </apex:column> 
                           <apex:column headerValue="Job#" width="20%">
                                <apex:outputField value="{!inner.jobs.Job_Auto_Number__c }"/> 
                           </apex:column>
                           <apex:column headerValue="Job Name" width="40%">
                               <apex:variable var="ind" value="{! ind +1}"/>
                               <apex:outputField value="{!inner.jobs.name}"/> 
                           </apex:column>
                          
                      </apex:pageBlockTable>
                  </apex:variable>
                  
                  <br/><br/>
                  
                  <apex:outputPanel >
                  
                  
                  <apex:actionStatus id="edstatus">
                             <apex:facet name="start">
                                <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
                             </apex:facet>
                         </apex:actionStatus> 
                      
                       
                      <apex:commandButton value="<<Previous" action="{!previous}" rendered="{!hasPrevious}" status="edstatus" rerender="pb"/>
                      <apex:commandButton value="Next >>" action="{!next}" rendered="{!hasNext}" status="edstatus1" rerender="pb"/>
                      
                       <apex:actionStatus id="edstatus1">
                             <apex:facet name="start">
                                  <img src="/img/loading.gif" />&nbsp;&nbsp; <b> Please Wait....... </b>
                             </apex:facet>
                         </apex:actionStatus> 
                         
                  </apex:outputPanel>
                  
                  
              
        </apex:pageBlock>
        
         <apex:outputPanel id="tstpopup2">
                <apex:outputPanel styleClass="popupBackground" layout="block" rendered="{!load}"/>
                <apex:outputPanel styleClass="custPopup" layout="block" rendered="{!load}" ><br/>
                    <center>
                        <b><Font style="color:orange;font-size:25px;">Sucessfully Updated {!size} Jobs</Font></b><br/><br/>
                       
                        <b> <apex:commandButton value="OK" action="{!CancelBut}" style="width:20%;height:40%;font-size:160%;"/> </b>
                    </center>
               </apex:outputPanel>
        </apex:outputPanel>
        
        
        <div id="dialog-confirm1" title="Status complete" style="display:{!if(ShowPELI==true,"block","none")}">
            <p>
                Do you want to Aprrove  all Production Estimate Line Items?
            </p>
        </div>
        
        <apex:inputhidden value="{!ApprovePe}" id="hidden" />
        
        
        
        
    </apex:form>
    
     <style type="text/css">
        .custPopup{
            background-color: white;
            border: 2px solid orange;
            border-radius: 20px;
            z-index: 9999;
            left: 50%;
            padding:10px;
            position: absolute;
            /* These are the 3 css properties you will need to change so the popup 
            displays in the center of the screen. First set the width. Then set 
            margin-left to negative half of what the width is. You can add 
            the height property for a fixed size pop up if you want.*/
            width: 500px;
            margin-left: -250px;
            top:50px;
        }
        .popupBackground{
            background-color:lightblue;
            opacity: 0.20;
            filter: alpha(opacity = 20);
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            z-index: 9998;
        }
        .a:focus {
            background-color:orange;
        }

    </style>

</apex:page>