<!-- This page is used to display Job Note. -->
<apex:page standardController="Note" extensions="JobViewNote">
 <apex:form >
     <apex:pageMessages />
          <apex:pageBlock tabStyle="Job__c">
               <apex:pageBlockButtons >
                    <apex:commandButton action="{!editNote}" value="Edit" />
                    <apex:commandButton action="{!deleteNote}" value="Delete" />
                    <apex:commandButton action="{!cancel}" value="Notes View"></apex:commandButton>
               </apex:pageBlockButtons>
             
               <apex:pageBlockSection title="Note Information" columns="1" collapsible="false" > 
                
                 <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Note.Fields.Title.Label}"/>
                         <apex:outputField value="{!n.Title}"/>
                  </apex:pageBlockSectionItem> 
                  
                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Note.Fields.IsPrivate.Label}"/>
                         <apex:outputField value="{!n.IsPrivate}"/>
                  </apex:pageBlockSectionItem> 
                  
                  <apex:pageBlockSectionItem >
                         <apex:outputLabel value="{!$ObjectType.Note.Fields.Body.Label}"/>
                         <apex:outputField value="{!n.Body}"/>
                  </apex:pageBlockSectionItem> 
                  
                  </apex:pageBlockSection>
        </apex:pageBlock>
    </apex:form>
</apex:page>
<!-- End of Page -->