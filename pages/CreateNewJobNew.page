                  </apex:selectList>  
               </apex:pageBlockSectionItem>
                
                
               
               
               <apex:pageBlockSectionItem id="pbsCC" rendered="{!displayclient_contact}">
                  <apex:outputLabel value="{!$ObjectType.Job__c.Fields.JS_Client_Contact__c.Label}"  for="CC"  rendered="{!($ObjectType.Job__c.fields.JS_Client_Contact__c.accessible)}">
