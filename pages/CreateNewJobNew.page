<!-- This page is used to create New Job (Overrides create button of Job Object) -->
<apex:page standardController="Job__c" tabStyle="Job__c" extensions="createNewJobExtensionNew">

<apex:sectionHeader title="Job Details" />
<apex:pagemessages id="pgMsg"/>

  


   <apex:form >
      <apex:pageBlock id="pb">
          
         <apex:pageBlockButtons >
            <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
            <apex:commandButton action="{!cancel}" value="Cancel" immediate="true"></apex:commandButton>
         </apex:pageBlockButtons>
             
         <apex:actionRegion >  
               <apex:pageBlockSection title="Job Information" columns="2" collapsible="true"> 
               
               <apex:pageBlockSectionItem rendered="{!AND(Not(ShowNotrequiredJob),$ObjectType.Job__c.Fields.Name.accessible)}">
               
                  <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Name.Label}" rendered="{!If(orgId='00DG0000000k48JMAQ' || orgId='00DJ000000371J9MAI',false,true)}" />
                  <apex:inputField value="{!Job__c.Name}"  rendered="{!If(orgId='00DG0000000k48JMAQ' || orgId='00DJ000000371J9MAI',false,true)}" required="true" />
                  
               </apex:pageBlockSectionItem>
               
               <apex:pageBlockSectionItem id="pgSectionItem15" rendered="{!AND(ShowNotrequiredJob,$ObjectType.Job__c.Fields.Name.accessible)}"> 
                         
                              <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Name.Label}"/>
                                  <apex:inputField value="{!Job__c.Name}" html-placeholder="Auto Populate After Saving"/>
                </apex:pageBlockSectionItem>
                         
               <apex:pageBlockSectionItem rendered="{!$ObjectType.Job__c.Fields.Campaign__c.accessible}">
               <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Campaign__c.Label}" for="Campaign"  ></apex:outputLabel>
                  <apex:selectList id="CampName" value="{!CampaignName}" size="1" >
                      <apex:selectOptions value="{!Campaigns}"></apex:selectOptions>
                  </apex:selectList>            
               </apex:pageBlockSectionItem>
               
               <apex:pageBlockSectionItem rendered="{!$ObjectType.Job__c.Fields.Status__c.accessible}">
                  <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Status__c.Label}"  /> 
                  <apex:inputField value="{!Job__c.Status__c}"  id="oppNameInput" />
                    
               </apex:pageBlockSectionItem>
             
       
               <apex:pageBlockSectionItem rendered="{!$ObjectType.Job__c.Fields.Schedule_Calc__c.accessible}">
                  <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Schedule_Calc__c.Label}" /> 
                  <apex:inputField value="{!Job__c.Schedule_Calc__c}"/>
                   <!--  <apex:selectList id="ScheduleCalc" value="{!ScheduleCalc}" size="1" >
                              <apex:selectOptions value="{!ScheduleCalcList}"/>
                     </apex:selectList> -->
               </apex:pageBlockSectionItem>
         
              
              <apex:pageBlockSectionItem rendered="{!$ObjectType.Job__c.fields.Media_Types__c.accessible}">                  
                  <apex:outputLabel value="{!$ObjectType.Job__c.Fields.Media_Types__c.Label}" for="MediaTypeName" >
                  </apex:outputLabel>
                  <apex:actionRegion >
                     <apex:outputPanel >
                        <!--span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">-->
                        <span  class="requiredInput"  Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                           <div class="requiredBlock"> </div>
                          <!-- <div> </div>-->
                           <apex:selectList id="MtName" value="{!MTName}" size="1" >
                              <apex:actionSupport event="onchange" rerender="ST"/>
                              <apex:selectOptions value="{!MediaTypes}">
                              </apex:selectOptions> 
                           </apex:selectList>
                        </span>
                     </apex:outputPanel>  
                  </apex:actionRegion>
               </apex:pageBlockSectionItem>
              
              
               
                            
               <apex:pageBlockSectionItem rendered="{!$ObjectType.Job__c.fields.Start_Date__c.accessible}">
                 <!-- <apex:outputLabel value="Start Date"/>   -->
