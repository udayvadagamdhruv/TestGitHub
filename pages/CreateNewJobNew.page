                     <apex:selectOptions value="{!ClientContacts}">
                     </apex:selectOptions>
                  </apex:selectList>
               </apex:pageBlockSectionItem> 

              
                <apex:pageBlockSectionItem rendered="{!$ObjectType.Job__c.fields.Budgeted_Cost__c.accessible}">
