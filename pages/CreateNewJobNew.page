                  <apex:actionRegion >
                     <apex:selectList id="ClientName" value="{!ClientName}" size="1" rendered="{!($ObjectType.Job__c.fields.JS_Client__c.accessible)}" >
                        <apex:actionSupport event="onchange" rerender="CC"/>
                        <apex:selectOptions value="{!Clients}"></apex:selectOptions>
                     </apex:selectList>
                  </apex:actionRegion>  
               </apex:pageBlockSectionItem>
                
                
                <apex:pageBlockSectionItem rendered="{!($ObjectType.Job__c.fields.Specification_Template__c.accessible)}">                  
