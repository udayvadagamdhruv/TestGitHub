     <apex:pageBlock id="pgblk2" title="Add Line Items">

        <apex:pageBlockTable value="{!roleWraps}" var="p" id="ProductsTable" rendered="{!roleWraps.size > 0}">
           <apex:column headerValue="Action">
              <apex:inputCheckbox value="{!p.checked}"/>
           </apex:column>
             
           <apex:column value="{!p.e.Estimate_Line_Item__c}" headerValue="Line Item"  rendered="{!(Not(ShowProductionEstimate))}"  />
           <apex:column value="{!p.e.Production_Estimate__c}" headerValue="Line Item"  rendered="{!(ShowProductionEstimate)}"/>
             
<!--           <apex:column value="{!p.e.Amount__c}" headerValue="Amount"/> -->
           
           <apex:column headerValue="Amount">
               <apex:OutputText id="txt1" value="{!p.Calc_amnt}" /> <!-- onchange="doSearch(this.value,{!p.Calc_amnt})"/ -->
           </apex:column>
           
           <apex:column value="{!p.e.Quantity__c}" headerValue="Quantity" rendered="{!(Not(ShowProductionEstimate))}"/>
           <apex:column value="{!p.e.Quantity_production__c}" headerValue="Quantity" rendered="{!(ShowProductionEstimate)}"/>
           
           
        </apex:pageBlockTable> 

        <apex:pageBlockSection rendered="{!roleWraps.size <= 0}">
           <apex:pageBlockSectionItem >
            <b>   No records to display </b>
           </apex:pageBlockSectionItem>              
        </apex:pageBlockSection> 
       
