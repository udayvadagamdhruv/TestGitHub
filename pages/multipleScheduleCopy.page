<apex:page controller="multipleScheduleCopyController" tabStyle="Job__c">
    <apex:form id="fm1">
        <apex:actionFunction action="{!saveRsc}" name="saveRsc" reRender="pgb">
        </apex:actionFunction>
        
        <script type="text/javascript">
            function checkWithUser(){
                if(confirm('This will replace all tasks on selected jobs with current job\'s task. Do you want to proceed ?')){
                  //alert("Proceed.");
                  saveRsc();
                }
            } 
        </script>
        <apex:pageBlock >
            <apex:pagemessages />
            <apex:pageBlockButtons >
               <apex:commandButton onclick="checkWithUser();" value="Save" reRender="fm1" rendered="{!jbWrap.size  > 0}"></apex:commandButton>
               <apex:commandButton action="{!cancel}" value="Cancel" immediate="true"></apex:commandButton>
            </apex:pageBlockButtons>
          
            <apex:pageBlockSection >
                <apex:pageBlockSectionItem rendered="{!jbWrap.size  > 0}">
                    <apex:outputLabel value="Jobs : "/>
                    <apex:PageblockTable value="{!jbWrap}" var="jbw" >
                        <apex:column headerValue="Action">
                           <apex:inputCheckbox value="{!jbw.varJbSelect}" onclick="deSelectOthers(this)"/>  
                        </apex:column>
                 
                        <apex:column headerValue="Job Name">
                            <apex:outputField value="{!jbw.varJb.Name}" />
                        </apex:column>
                        <apex:column headerValue="Job #">
                            <apex:outputField value="{!jbw.varJb.Job_Auto_Number__c}" />
                        </apex:column>
                    </apex:PageblockTable>
                </apex:pageBlockSectionItem>
                <apex:outputPanel rendered="{!jbWrap.size  <= 0}">
                    <apex:outputText value="No Active jobs for this Schedule Template"></apex:outputText>
                </apex:outputPanel>
            </apex:pageblocksection>
        </apex:pageblock>
    </apex:form>
</apex:page>