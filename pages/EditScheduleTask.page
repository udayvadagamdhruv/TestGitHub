<!-- This page is used to Edit new Schedule Task -->

<apex:page standardController="Schedule_Task__c" extensions="EditScheduleTaskExtension" tabStyle="MyAdmin__tab">
     <head>
     </head>
     <apex:form >
        <apex:pageBlock mode="edit">
        <apex:pageMessages />
                 <apex:pageBlockButtons >
                    <apex:commandButton action="{!saveme}" value=" Save "></apex:commandButton>
              <!--      <apex:commandButton action="{!SaveandNew}" value=" Save&New "></apex:commandButton> -->
                    <apex:commandButton action="{!cancel}" value="Cancel"></apex:commandButton>
                 </apex:pageBlockButtons>
              
              <apex:pageBlockSection title="Information" columns="2" collapsible="false"> 
              <apex:pageBlockSectionitem > 
                      <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Name.Label}"/> 
                      <apex:inputfield value="{!Schedule_Task__c.Name}" required="true"/>
                   </apex:pageBlockSectionitem>
              
                 <apex:pageBlockSectionitem > 
                   <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Schedule_Template__c.Label}"/> <apex:outputfield value="{!Schedule_Task__c.Schedule_Template__c}"/>
                 </apex:pageBlockSectionitem>
                 <!--   <apex:pageBlockSectionitem > 
                      <apex:outputLabel value="GL Code"/> <apex:inputField value="{!Schedule_Task__c.GL_Code__c}" required="true"/>
                   </apex:pageBlockSectionitem>  -->
                   
                    <apex:pageBlockSectionItem >                  
                  <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.GL_Code__c.Label}" for="GLCName" ></apex:outputLabel>
                  <apex:outputPanel >
                  <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                  <!-- <div class="requiredBlock"> </div> -->
                  <apex:selectList id="GLCName" value="{!GLCName}" size="1">
                 <!-- <apex:actionSupport event="onchange"/> -->
                  <apex:selectOptions value="{!GLCodes}"></apex:selectOptions> 
                  </apex:selectList>
                  </span>
                  </apex:outputPanel>  
                  </apex:pageBlockSectionItem>
                  
                   <apex:pageBlockSectionitem > 
                      <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Days__c.Label}"/> <apex:inputField value="{!Schedule_Task__c.Days__c}" required="true"/>
                   </apex:pageBlockSectionitem>
                   
                   <apex:pageBlockSectionitem > 
                      <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Report__c.Label}"/>
                      <apex:inputCheckbox value="{!Schedule_Task__c.Report__c}"/>
                   </apex:pageBlockSectionitem>
                   
                   <apex:pageBlockSectionitem > 
                           <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Hours__c.Label}"/>
                           <apex:inputfield value="{!Schedule_Task__c.Hours__c}"/>
                   </apex:pageBlockSectionitem>
                   
                   <apex:pageBlockSectionitem > 
                           <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Task_Order__c.Label}"/>
                           <apex:outputField value="{!Schedule_Task__c.Task_Order__c}"/>
                   </apex:pageBlockSectionitem>
                  
                  <apex:pageBlockSectionitem > 
                           <apex:outputLabel Value="{!$ObjectType.Schedule_Task__c.Fields.Locked__c.Label}"/>
                           <apex:inputCheckbox value="{!Schedule_Task__c.Locked__c}"/>
                   </apex:pageBlockSectionitem>
              </apex:pageblocksection>    
      </apex:pageblock>
   </apex:form>
</apex:page>
<!-- End of Page -->