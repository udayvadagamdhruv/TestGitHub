<apex:page controller="MultipleScheduleCopyNewController" tabStyle="Job__c"  sidebar="true" docType="html-5.0" standardStylesheets="true" showHeader="false" applyBodyTag="false" applyHtmlTag="false">
   
     <style>
     
            .bPageBlock 
            {
                 margin: 0px 0px 0px 0px !important; 
            }
            .pageHeader
            {
                color:white;
                background-color:#851225;
                height:70px;
                padding-top:23px; 
                position:fixed;
                z-index:999;
                width:100% !important;
                padding-left:22px;
            }
        
            .SectionHeader
            {
                background-color:Grey !important;
                color:white;
            }
            
            .bPageBlock 
            {
                 margin: 20px 20px 20px 20px !important;
            }
            
            
            body
            {
                    //background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, rgba(32, 92, 159, 0), rgb(32, 92, 159));
                    background-image: url(/_slds/images/themes/oneSalesforce/banner-brand-default.png?cache=210.2), linear-gradient(to top, #d4d7da, #666) !important;
                    //background-image:none !important;
                    //background-color:#D7D7D7 !important;
                    background-repeat: repeat-x;
                    background-position: left top;
                    background-attachment: fixed; 
                    margin:0px !important;
            }
         
          .customImage{ height: 10px; width: 10px; }
          #rcorners1 
          {
                 border-radius:0%;
                 border: 1px solid #cccccc;
                 padding: 0px; 
                 width: 100%;
                 height: 0%;
          }
          #pagemessage
          {
              color:blue;
          }
          
          .required:after { content:" *";  color: Red;font:bold;}
           
           .slds table
           {
                height: 50px;
           }
           body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons
           {
               margin-top: -19px; 
           }
           .detailPage .bPageBlock, .editPage .bPageBlock
           {
               border-top-width: 0px;
           }
          
           .slds .slds-text-heading--large
           {
                font-size: 27px;
           }
           
           .pbHeader
           {
               background: white !important;
           }
           
           body .bPageBlock, body .bPageBlock .pbBody, body .bPageBlock .pbBottomButtons 
           {
               background: white;
           }
          
           .slds .slds-list--vertical.slds-has-dividers > .slds-list__item
           {
               border:none;
           }
           
           body .bEditBlock .pbBottomButtons, body .apexp .bPageBlock.apexDefaultPageBlock .pbBottomButtons
           {
               border:none;
           }
                       
           .slds .slds-checkbox .slds-checkbox--faux 
           {
                width: 25px;
                height: 25px;
                display: inline-block;
                position: relative;
                vertical-align: middle;
                border-width: 2px;
                border-style: solid;
                border-color: lightgrey;
                border-image: initial;
                border-radius: 2px;
                background: white;
                transition: border 0.1s linear, background-color 0.1s linear;
           }
            
           .slds .slds-checkbox [type=checkbox]:checked > .slds-checkbox--faux:after, .slds .slds-checkbox [type=checkbox]:checked ~ .slds-checkbox--faux:after 
           {
                height: 6px;
                width: 11px;
           }
           
           .bPageBlock .requiredInput .requiredBlock 
           {
                background-color:white;
                position: absolute;
                left: -4px;
                width: 3px;
                top: 1px;
                bottom: 1px;
            }
           
            errorM6, .errorM4, .errorM3, .errorM2, .errorS1 
            {
                  border-color: #c00;
            }
            .message 
            {
                background-color: #c00;
                border-style: solid;
                border-width: 0px;
                color: #000;
                padding: 0px 0px 0px 0px;
                margin: 0px 0px;
            }
            .errorM3 .msgIcon, .errorMedium 
            {
                background-image: url(); 
                background-position: 0 0;
                width:0px;
                height: 0px;
                padding-left: 4px;
            }
            .pbBody td
            {
                color:white;
            }
            .message .messageText h4 
            {
                 font-weight: bold; 
                 display:block;
                 color:white;
            }
            
            .messageText br
            {
               display:none !important;
            }
            .messageTable tr
            {
               padding-top:10px !important;
               padding-bottom:10px !important;
            }
            .slds-notify, .slds-text-heading--small, .slds-theme--error, .message, .errorM3
            {
                border-radius: 15px !important;
            }
            .pbBody
            {
                padding:10px !important;
            }
            
            
            .slds td {
                padding: 0;
                padding-left: 5px;
            }
            
            
            .dateFormat
            {
                display: block !important;
            }
            
                
            <!----------------------------------- error Mesgg-------------------------------------->
       
       
       
       
    </style>  
        
        
        <script type="text/javascript">
            function checkWithUser(){
               /*<!--if(confirm('This will replace all tasks on selected jobs with current job\'s task. Do you want to proceed ?')){
                  //alert("Proceed.");
                  saveRsc();
              //  }-->*/
              saveRsc();
            } 
        </script>
        
        
   
        <html xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
        <apex:stylesheet value="{!URLFOR($Resource.SLDS0102, 'assets/styles/salesforce-lightning-design-system-vf.css')}" />
        <body>    
        <div class="slds">
    
          <apex:form id="fm1" html-novalidate="novalidate">
   
            <apex:actionFunction action="{!saveRsc}" name="saveRsc" reRender="pgb">
            </apex:actionFunction>
        
        
             <div class="slds-media__body pageHeader">
                           <span  class="slds-page-header__title slds-m-right--medium slds-align-middle slds-truncate" style="color:white;font-size:18px;"><b>Copy Schedule</b></span>
                           <span style="float:right;padding-right:20px;">     
                              <b>   <apex:commandButton onclick="checkWithUser();" value="Save" reRender="fm1" rendered="{!jbWrap.size  > 0}" styleClass="slds-button slds-button--neutral"></apex:commandButton>
                                    <apex:commandButton action="{!cancel}" value="Cancel" immediate="true" styleClass="slds-button slds-button--neutral"></apex:commandButton></b>
                           </span>
                           
                     </div> 
                     <br/><br/><br/><br/>
            
             <apex:pageBlock mode="edit"> 
            <div class="slds-notify slds-text-heading--small slds-theme--error" role="alert">
              <apex:pageMessages ></apex:pageMessages>
            </div> 
            <br/>
            
            <div id="headerid" style="background-color:SteelBlue;color:white;">
                 <h3 class="slds-section-title"><b>&nbsp;Jobs</b></h3>
            </div>
            
             <br/>
             <div class="slds-card">
                            
                      <div class="slds-card__body">

                        <apex:outputPanel layout="block" rendered="{!jbWrap.size  > 0}">

                            <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                <thead class="slds-truncate">

                                    <tr class="slds-text-title">
                                        <th class="slds-size--1-of-6" scope="col"> 
                                            Action
                                        </th>
                                        <th class="slds-size--1-of-6" scope="col">
                                            Job Name
                                        </th>
                                        <th class="slds-size--1-of-6" scope="col">
                                           Job #
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <apex:repeat value="{!jbWrap}" var="jbw" rendered="{!jbWrap.size  > 0}" >
                                        <tr class="slds-hint-parent">
                                            <td class="slds-size--1-of-6" data-label="Job Name">
                                                <div>
                                                   <label class="slds-checkbox"> 
                                                          <apex:inputCheckbox value="{!jbw.varJbSelect}" onclick="deSelectOthers(this)"/> 
                                                          <span class="slds-checkbox--faux"></span>
                                                   </label>
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-6" data-label="Job Name" style="color:black;">
                                                <div>
                                                   <apex:outputField value="{!jbw.varJb.Name}" />
                                                </div>
                                            </td>
                                            <td class="slds-size--1-of-6" data-label="Job Name" style="color:black;">
                                                <div>
                                                    <apex:outputField value="{!jbw.varJb.Job_Auto_Number__c}" style="color:black;"/>
                                                </div>
                                            </td>
                                        </tr>
                                    </apex:repeat>
                                </tbody>
                            </table>
                        </apex:outputpanel>
                    </div>
                    </div>
            
            
              
                <apex:outputPanel rendered="{!jbWrap.size  <= 0}">
                    <apex:outputText value="No Active jobs for this Schedule Template"></apex:outputText>
                </apex:outputPanel>
                </apex:pageBlock>
          </apex:form>
      </div>
      </body>
    </html>
</apex:page>