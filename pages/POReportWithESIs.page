<!-- This page is used to display Purcase Order Report with ESI's. -->
<apex:page standardController="Purchase_Order__c" showHeader="false" sidebar="false" standardStylesheets="false" extensions="POReportWithESIs" renderAs="PDF">
    <head>
    <style type="text/css">

        .rightalign
        {
            text-align:right;
        }

        .leftalign
        {
            text-align:left;
        }

        .centeralign
        {
            text-align:center;
        }

        div.tab
        {
            width:100%;
            border:solid black;
        }
        @page
        {
            /* Landscape orientation */
            size:potrait;

            /* Put page numbers in the bottom right corner of each
            page in the pdf document. */
        
            @bottom-right
            {
            content: "Page " counter(page);
            font-family: sans-serif;
            font-size:8pt;
            }
   
            @bottom-left 
            {
            content: "<apex:outputText value="{0,date,MMMM dd, yyyy}"><apex:param value="{!NOW()}" /></apex:outputText>"; 
            background-repeat: no-repeat;
            font-size:8pt;
            font-family: sans-serif;
            } 
        }

        body 
        {
        font-family: sans-serif;
        font-size:8pt;
        }
  
        th
        {
        font-size:10pt
        font-style:bold;
        font-family: sans-serif;
        }

        td
        {
        font-size:8pt;
        font-family: sans-serif;
        }
  
        div.footer
        {
        position : running(footer) ;
        }
    </style>
    </head>

