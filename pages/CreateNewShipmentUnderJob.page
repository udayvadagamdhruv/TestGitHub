<apex:page standardController="Shipment__c" tabstyle="Shipment__c" extensions="CreateNewShipmentUnderJobExt">

  <apex:sectionHeader title="Shipment Details"/>
  
     <apex:pagemessages id="pgMsg"/>
     
        <apex:form >
        
           <apex:pageBlock id="pb">
              
                 <apex:pageBlockButtons >
                    <apex:commandButton value="Save" action="{!saveme}"></apex:commandButton>
                    <apex:commandButton action="{!cancelme}" value="Cancel" ></apex:commandButton>
                 </apex:pageBlockButtons>
                 
                 <apex:pageBlockSection title="Information" columns="2" collapsible="true">
                         
                        
                       
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Name__c.Label}"  />
                              <apex:inputField value="{!Shipment__c.Shipment_Name__c}"  />
                          </apex:pageBlockSectionItem> 
                          
                           <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Job__c.Label}"  />
                              {!jobn}
                          </apex:pageBlockSectionItem> 
                          
                         <!-- <apex:pageBlockSectionItem id="pbs">
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Job__c.Label}"/>
                                  <apex:outputPanel >
                                     <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                                        <div class="requiredBlock"></div>
                                            <apex:selectList id="JobName" value="{!JobName}" size="1" required="true">
                                               <apex:selectOptions value="{!jobs}"></apex:selectOptions>
                                            </apex:selectList> 
                                     </span>
                                  </apex:outputPanel>  
                           </apex:pageBlockSectionItem>  -->
                          
                          
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Status__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipment_Status__c}" />
                          </apex:pageBlockSectionItem>
                          
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipping_Method__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipping_Method__c}" />
                          </apex:pageBlockSectionItem>
                          
                          
                           <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Date__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipment_Date__c}" />
                          </apex:pageBlockSectionItem>
                          
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Tracking_Number__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Tracking_Number__c}" />
                          </apex:pageBlockSectionItem>
                          
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Phone__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipment_Phone__c}" />
                          </apex:pageBlockSectionItem>
                          
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Email__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipment_Email__c}" />
                          </apex:pageBlockSectionItem>
                          
                          
                          
                   </apex:pageBlockSection> 
                          
                   
                   
                  <apex:pageBlockSection title="Shipping Address" columns="2" collapsible="true">
                           
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Street_Address__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipment_Street_Address__c}" />
                          </apex:pageBlockSectionItem>
                          
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Address_2__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Shipment_Address_2__c}" />
                          </apex:pageBlockSectionItem>
                     
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_City__c.Label}"  />
                              <apex:inputField value="{!Shipment__c.Shipment_City__c}"  />
                         </apex:pageBlockSectionItem>
                       
                        <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_State__c.Label}"  />
                              <apex:inputField value="{!Shipment__c.Shipment_State__c}"  />
                       </apex:pageBlockSectionItem>   
                       
                        <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Shipment_Zip_code__c.Label}"  />
                              <apex:inputField value="{!Shipment__c.Shipment_Zip_code__c}"  />
                       </apex:pageBlockSectionItem>  
                       
               </apex:pageBlockSection> 
               
               
                <apex:pageBlockSection title="Other" columns="2" collapsible="true">
                           
                          <apex:pageBlockSectionItem >
                              <apex:outputLabel value="{!$ObjectType.Shipment__c.Fields.Special_Instructions__c.Label}" /> 
                              <apex:inputField value="{!Shipment__c.Special_Instructions__c}" />
                          </apex:pageBlockSectionItem>
                </apex:pageBlockSection>            
               
               
        </apex:pageBlock>
        
    </apex:form>
   
</apex:page>