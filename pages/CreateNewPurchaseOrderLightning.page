                      <apex:outputPanel id="Litems">
                        <apex:outputPanel rendered="{!ShowLIitem}">  
                          
                          <div class="SectionHeader"  style="background-color:SteelBlue;color:white;">
                               <h3 class="slds-section-title"><b>&nbsp;Line Items</b></h3>
                          </div>
                          
                     
                           <apex:outputPanel rendered="{!roleWraps.Size > 0  && NOT(ShowProductionEstimate)}">
                        
                               <div class="slds-card" >
                                   <div class="slds-card__body">
                                           <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                             <thead class="slds-truncate">
                                                    <tr class="slds-text-title">
                                                        <th class="slds-size--1-of-6" scope="col"> Action</th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Estimate_Line_Items__c.Fields.Name.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Code__c.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Estimate_Line_Items__c.Fields.Unit_Type__c.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Estimate_Line_Items__c.Fields.Quantity__c.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Estimate_Line_Items__c.Fields.Total_Amount__c.Label}</th>
                                                    </tr>
                                               </thead>
                                               <tbody>
                            
                                                    <apex:repeat value="{!roleWraps}" var="p" >
                                                      <tr> 
                                                          <td class="slds-size--1-of-6" data-label="Action">
                                                               <div class="slds-form-element">
                                                                  <label class="slds-checkbox" >
                                                                     <apex:inputCheckbox value="{!p.checked}" />
                                                                     <span class="slds-checkbox--faux"></span>
                                                                     <span class="slds-form-element__label"></span>
                                                                  </label>
                                                               </div>
                                                           </td>
                                                           
                                                           <td class="slds-size--1-of-6" data-label="{!$ObjectType.Estimate_Line_Items__c.Fields.Name.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.e.Name}" />
                                                                </div> 
                                                            </td>
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Estimate_Line_Items__c.Fields.GL_Code__c.Label}">
                                                                <div>
                                                                    <apex:outputField value="{!p.e.GL_Code__c}" />
                                                                </div> 
                                                               
                                                            </td>
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Estimate_Line_Items__c.Fields.Unit_Type__c.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.e.Unit_Type__c}" />
                                                                </div> 
                                                            </td>
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Estimate_Line_Items__c.Fields.Quantity__c.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.e.Quantity__c}" />
                                                                </div>                                              
                                                            </td>
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Estimate_Line_Items__c.Fields.Total_Amount__c.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.e.Total_Amount__c}" />
                                                                </div>                                                
                                                            </td>
                                                        </tr>   
                                                    </apex:repeat>
                                                    
                                                    
                                               </tbody>
                                        </table>
                                   </div>
                              </div>  
                         </apex:outputPanel>
                         
                         
                        
                         <apex:outputPanel rendered="{!roleWraps.Size > 0 && ShowProductionEstimate}">
                        
                               <div class="slds-card" >
                                   <div class="slds-card__body">
                                           <table class="slds-table slds-table--bordered slds-max-medium-table--stacked-horizontal slds-no-row-hover">
                                             <thead class="slds-truncate">
                                                    <tr class="slds-text-title">
                                                        <th class="slds-size--1-of-6" scope="col"> Action</th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Production_Estimate__c.Fields.Name.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Production_Estimate__c.Fields.GL_Code__c.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Production_Estimate__c.Fields.Quantity__c.Label} </th>
                                                        <th class="slds-size--1-of-6" scope="col">{!$ObjectType.Production_Estimate__c.Fields.Total_Cost__c.Label}</th>
                                                    </tr>
                                               </thead>
                                               <tbody>
                            
                                                    <apex:repeat value="{!roleWraps}" var="p"  >
                                                      <tr> 
                                                          <td class="slds-size--1-of-6" data-label="Action">
                                                               <div class="slds-form-element">
                                                                  <label class="slds-checkbox" >
                                                                     <apex:inputCheckbox value="{!p.checked}" />
                                                                     <span class="slds-checkbox--faux"></span>
                                                                     <span class="slds-form-element__label"></span>
                                                                  </label>
                                                               </div>
                                                           </td>
                                                           
                                                           <td class="slds-size--1-of-6" data-label="{!$ObjectType.Production_Estimate__c.Fields.Name.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.pe.Name}" />
                                                                </div> 
                                                            </td>
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Production_Estimate__c.Fields.GL_Code__c.Label}">
                                                                <div>
                                                                    <apex:outputField value="{!p.pe.GL_Code__c}" />
                                                                </div> 
                                                               
                                                            </td>
                                                            
                                                            
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Production_Estimate__c.Fields.Quantity__c.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.pe.Quantity__c}" />
                                                                </div>                                              
                                                            </td>
                                                            
                                                            <td class="slds-size--1-of-6" data-label="{!$ObjectType.Production_Estimate__c.Fields.Total_Cost__c.Label}">
                                                                <div style="color:#333 !important;">
                                                                    <apex:outputField value="{!p.pe.Total_Cost__c}" />
                                                                </div>                                                
                                                            </td>
                                                        </tr>   
                                                    </apex:repeat>
                                                    
                                                    
                                               </tbody>
                                        </table>
                                   </div>
                              </div>  
                         </apex:outputPanel>
                         
                         
                         
                         
                         
  
                        <apex:outputPanel rendered="{!roleWraps.size <= 0}"> 
                          
                            <div class="slds-card">
                                <div class="slds-card__footer">
                                   <p>&nbsp;&nbsp;  All Approved estimate line items for this vendor have already been added to Purchase Orders.</p> 
                                </div>
                            </div>
                        </apex:outputPanel>
                          
          </apex:outputPanel>            
          </apex:outputPanel>
                  
             
          </apex:pageBlock>
       </apex:form>
   </div>
   
   </body>
