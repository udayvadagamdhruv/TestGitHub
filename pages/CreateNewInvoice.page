<!-- This Page is used to override the New (Create) button of Invoice Object -->
<apex:page standardController="Invoice__c" tabStyle="Job__c" extensions="CreateNewInvoice">
   <apex:form >
      <apex:sectionHeader title="Invoice Details"/>
      <apex:pageBlock >
         <apex:pagemessages />
         <apex:pageBlockButtons >
            <apex:commandButton action="{!saveme}" value="Save"></apex:commandButton>
            <apex:commandButton action="{!cancelme}" value="Cancel" immediate="true"></apex:commandButton>
         </apex:pageBlockButtons>
             
         <apex:pageBlockSection title="Information" columns="2" collapsible="true">
            
        <!--    <apex:pageBlockSectionItem >
               <apex:outputLabel value="Vendor"/>
               <apex:inputField value="{!Invoice__c.Vendor__c}" required="true"/>
            </apex:pageBlockSectionItem> -->
            
            <apex:pageBlockSectionItem >
                  <apex:outputLabel value="{!$ObjectType.Invoice__c.Fields.Name.Label}"/>
                  <apex:inputField value="{!Invoice__c.Name}" required="true"/>
            </apex:pageBlockSectionItem>
            
            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Invoice__c.Fields.Vendor__c.Label}" for="prol">  </apex:outputLabel>
               <apex:outputPanel >
                  <span class="requiredInput" Style="padding:3px 0px 3px 0px; text-align:left; valign:middle;">
                     <div class="requiredBlock"> </div>
                     <apex:selectList value="{!Vendor1}" multiselect="false" size="1" id="selectedvendorId" onselect="{!Invoice__c.Vendor__c}" >
                        <apex:selectOptions value="{!Vendor}"/>
                     </apex:selectList>
                  </span>
               </apex:outputPanel>  
            </apex:pageBlockSectionItem> 
             
            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Invoice__c.Fields.Date_Received__c.Label}"/>
               <apex:inputField value="{!Invoice__c.Date_Received__c}" required="true"/>
            </apex:pageBlockSectionItem>
            
            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Invoice__c.Fields.Job__c.Label}"/>
               <apex:outputField value="{!Invoice__c.Job__c}"/>
            </apex:pageBlockSectionItem>
            
            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Invoice__c.Fields.Invoice_Status__c.Label}"/>
               <apex:inputField value="{!Invoice__c.Invoice_Status__c}"/>
            </apex:pageBlockSectionItem>
            
            <apex:pageBlockSectionItem ></apex:pageBlockSectionItem>
            
            <apex:pageBlockSectionItem >
               <apex:outputLabel value="{!$ObjectType.Invoice__c.Fields.Notes__c.Label}"/>
               <apex:inputField value="{!Invoice__c.Notes__c}"/>
            </apex:pageBlockSectionItem>
            
            
